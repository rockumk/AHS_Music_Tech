-- Suppress only the Note-layout acknowledgment caused by our own
-- Programmer Mode request. Later genuine Notes-button reports still act as
-- escapes back to HOME.
DAW.programmer_mode_ack_ignore_until = 0

local DEVICES = {
  {key = "X", name = "Launchpad X",        id = 0x0C},
  {key = "M", name = "Launchpad Mini Mk3", id = 0x0D},
}

DAW.device_by_key = function(key)
  key = tostring(key or "")
  for _, device in ipairs(DEVICES) do
    if device.key == key then return device end
  end
  return nil
end

