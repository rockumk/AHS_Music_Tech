local current_page = 1
local last_action = "Waiting to initialize the hardware"
local last_midi = "None yet"
local last_midi_source = "None yet"
local initialized = false
local return_to_live_on_exit = true
local grid_visible = true
local library_visible = not (
  selected_input_index ~= nil
  and selected_output_index ~= nil
  and DAW.input_index ~= nil
  and DAW.output_index ~= nil
  and not tostring(selected_input_name or ""):find("saved port unavailable", 1, true)
  and not tostring(selected_output_name or ""):find("saved port unavailable", 1, true)
  and not tostring(DAW.input_name or ""):find("saved port unavailable", 1, true)
  and not tostring(DAW.output_name or ""):find("saved port unavailable", 1, true)
)
local grid_preview_until = 0
local grid_preview_held = false
local scan_direction = 0 -- -1 = backward, 0 = stopped, 1 = forward
local scan_next_repeat_time = 0
local surface_mode = "UNKNOWN" -- UNKNOWN, PROGRAMMER, PROGRAMMER_TRACK_MATRIX, TRACK_PICKER, TRACK_VIEWER_SESSION, REGIONS_MARKERS, USER_ACTIONS, USER_CUSTOMS, SLEEP, CUSTOM_EXTERNAL, CUSTOM_PENDING, CUSTOM_VOLUME_BANK, DAW_SESSION, DAW_VOLUME_FADERS, LIVE
local active_custom_slot = nil -- Launchpad X Custom 1..8; selects the eight-track MCP bank
local pending_custom_slot = nil
local pending_custom_switch_time = 0

DAW.set_primary_device_model = function(device)
  DAW.save_primary_device_model(device)
  initialized = false
  last_action = "Primary device model set to " .. tostring(selected_device.name)
end

DAW.set_secondary_device_model = function(device)
  DAW.save_secondary_device_model(device)
  initialized = false
  last_action = "Secondary device model set to " .. tostring(DAW.secondary_device.name)
end

DAW.grid_button_should_flash = function(label)
  return normalize_label(label) == "Show/Hide This Grid" and not grid_visible
end

-- Recording deserves a more urgent state cue than an ordinary pulse. Launchpad
-- palette flash lighting type 0x01 carries two colours: Colour B and Colour A.
-- Keep Record statically red while idle, then alternate red and LED-off black
-- only while REAPER is actively recording. These helpers are shared by every
-- Programmer-mode surface that inherits the HOME Record button.
DAW.RECORD_FLASH_RED_PALETTE = 0x05
DAW.RECORD_FLASH_BLACK_PALETTE = 0x00

DAW.record_should_red_black_flash = function(label)
  return normalize_label(label) == "Record" and is_label_active("Record")
end

DAW.resolve_palette_lighting = function(label, lighting_type, color, flash_base_color)
  if DAW.record_should_red_black_flash(label) then
    return 0x01, DAW.RECORD_FLASH_RED_PALETTE, DAW.RECORD_FLASH_BLACK_PALETTE
  end
  return lighting_type, color, flash_base_color
end

DAW.record_flash_gui_color = function(label)
  if not DAW.record_should_red_black_flash(label) then return nil end
  local show_red = (math.floor(r.time_precise() * 4) % 2) == 0
  local palette = show_red and DAW.RECORD_FLASH_RED_PALETTE or DAW.RECORD_FLASH_BLACK_PALETTE
  if palette == 0x00 then return DAW.HOME_LED_OFF_GUI_COLOR end
  return DAW.SAMPLED_PALETTE_GUI_COLORS[palette]
    or DAW_MATRIX_PALETTE_TO_GUI_COLOR[palette]
    or 0xFF6161FF
end

DAW.primary_configuration_ready = function()
  local function usable_name(name)
    name = tostring(name or "")
    return name ~= "" and not name:find("saved port unavailable", 1, true)
  end
  return selected_input_index ~= nil
    and selected_output_index ~= nil
    and DAW.input_index ~= nil
    and DAW.output_index ~= nil
    and usable_name(selected_input_name)
    and usable_name(selected_output_name)
    and usable_name(DAW.input_name)
    and usable_name(DAW.output_name)
end

-- Patch 32 launcher functions are deliberately declared after trim() and
-- the local runtime status variables. Keeping the module here ensures its
-- closures bind to the script-local helpers and GRID status line rather
-- than accidentally resolving undefined globals.

DAW.CONTROLLER_FOCUS = {
  -- Public ReaPack repository for this ecosystem. The warning dialog exposes
  -- this copyable URL if ControllerFocus is not registered in REAPER's Main
  -- Actions list.
  REAPACK_URL = "https://github.com/rockumk/AHS_Music_Tech/blob/master/index.xml",

  EXTSTATE_NAMED_COMMAND = "ControllerFocusNamedCommand",
  EXTSTATE_DISPLAY_NAME = "ControllerFocusDisplayName",
  EXTSTATE_NUMERIC_COMMAND = "ControllerFocusNumericCommand",

  -- Action-list matching is deliberately forgiving so a development build such
  -- as ControllerFocus_v1_1_4_Turquoise_Learn_Target_Highlight.lua can still be
  -- found before the public package settles on ControllerFocus.lua.
  SEARCH_TEXT = "controllerfocus",
}

DAW.CONTROLLER_FOCUS.main_section = function()
  if not r.SectionFromUniqueID then return nil end
  return r.SectionFromUniqueID(0)
end

DAW.CONTROLLER_FOCUS.normalized_action_name = function(name)
  return trim(tostring(name or ""):lower():gsub("%s+", " "))
end

DAW.CONTROLLER_FOCUS.named_command_for_id = function(command_id)
  if not r.ReverseNamedCommandLookup then return "" end
  local bare = r.ReverseNamedCommandLookup(tonumber(command_id) or 0)
  bare = tostring(bare or "")
  if bare == "" then return "" end
  return bare:sub(1, 1) == "_" and bare or ("_" .. bare)
end

DAW.CONTROLLER_FOCUS.match_score = function(action_name)
  local name = DAW.CONTROLLER_FOCUS.normalized_action_name(action_name)
  if name == "" or not name:find(DAW.CONTROLLER_FOCUS.SEARCH_TEXT, 1, true) then
    return nil
  end

  -- Prefer the final public filename, then the exact base phrase, then
  -- versioned development variants.
  if name:find("controllerfocus.lua", 1, true) then return 0 end
  if name:find("script: controllerfocus", 1, true) then return 1 end
  return 2
end

DAW.CONTROLLER_FOCUS.enumerate_matches = function()
  local section = DAW.CONTROLLER_FOCUS.main_section()
  local matches = {}
  if not section or not r.kbd_enumerateActions then return matches end

  local index = 0
  while index < 100000 do
    local command_id, action_name = r.kbd_enumerateActions(section, index)
    if not command_id or command_id == 0 then break end

    local score = DAW.CONTROLLER_FOCUS.match_score(action_name)
    if score ~= nil then
      matches[#matches + 1] = {
        command_id = command_id,
        action_name = tostring(action_name or ""),
        named_command = DAW.CONTROLLER_FOCUS.named_command_for_id(command_id),
        score = score,
      }
    end
    index = index + 1
  end

  table.sort(matches, function(a, b)
    if a.score ~= b.score then return a.score < b.score end
    return a.action_name:lower() < b.action_name:lower()
  end)

  return matches
end

DAW.CONTROLLER_FOCUS.remember_match = function(match)
  if not match then return end
  r.SetExtState(
    EXTSTATE_SECTION,
    DAW.CONTROLLER_FOCUS.EXTSTATE_NAMED_COMMAND,
    tostring(match.named_command or ""),
    true
  )
  r.SetExtState(
    EXTSTATE_SECTION,
    DAW.CONTROLLER_FOCUS.EXTSTATE_DISPLAY_NAME,
    tostring(match.action_name or ""),
    true
  )
  r.SetExtState(
    EXTSTATE_SECTION,
    DAW.CONTROLLER_FOCUS.EXTSTATE_NUMERIC_COMMAND,
    tostring(match.command_id or ""),
    true
  )
end

DAW.CONTROLLER_FOCUS.command_from_saved_state = function()
  local named = r.GetExtState(
    EXTSTATE_SECTION,
    DAW.CONTROLLER_FOCUS.EXTSTATE_NAMED_COMMAND
  )
  named = tostring(named or "")
  if named ~= "" and r.NamedCommandLookup then
    local command_id = tonumber(r.NamedCommandLookup(named)) or 0
    if command_id > 0 then return command_id, named end
  end

  -- Numeric fallback is useful while a script remains registered in the same
  -- REAPER installation. Named command resolution remains the preferred path.
  local numeric = tonumber(r.GetExtState(
    EXTSTATE_SECTION,
    DAW.CONTROLLER_FOCUS.EXTSTATE_NUMERIC_COMMAND
  )) or 0
  if numeric > 0 then
    local section = DAW.CONTROLLER_FOCUS.main_section()
    local action_name = section and r.kbd_getTextFromCmd
      and tostring(r.kbd_getTextFromCmd(numeric, section) or "")
      or ""
    if DAW.CONTROLLER_FOCUS.match_score(action_name) ~= nil then
      return numeric, action_name
    end
  end

  return nil, nil
end

DAW.CONTROLLER_FOCUS.run_command = function(command_id, description)
  command_id = tonumber(command_id) or 0
  if command_id <= 0 then return false end

  r.Main_OnCommand(command_id, 0)
  last_action = "Launched ControllerFocus"
    .. ((description and description ~= "") and (": " .. tostring(description)) or "")
  return true
end

DAW.CONTROLLER_FOCUS.show_missing_warning = function()
  local url = DAW.CONTROLLER_FOCUS.REAPACK_URL
  r.ShowMessageBox(
    "ControllerFocus.lua could not be found in REAPER's Main Actions list.\n\n"
      .. "FX assignment pages rely on ControllerFocus.lua to map ValueVault slots "
      .. "to parameters of the focused FX.\n\n"
      .. "Install the AHS Music Tech package through ReaPack, or register "
      .. "ControllerFocus.lua manually through the REAPER Actions list.\n\n"
      .. "After installation, press Patch 32 again.\n\n"
      .. "The next dialog contains a copyable ReaPack repository URL.",
    "ControllerFocus Not Found",
    0
  )
  if r.GetUserInputs then
    r.GetUserInputs(
      "Install AHS Music Tech through ReaPack",
      1,
      "Copy ReaPack repository URL (Ctrl+C):,extrawidth=500",
      url
    )
  end
  last_action = "ControllerFocus is not registered. ReaPack URL shown."
  return false
end

DAW.CONTROLLER_FOCUS.choose_match = function(matches)
  if #matches <= 0 then return nil end
  if #matches == 1 then return matches[1] end

  local lines = {
    "More than one registered ControllerFocus action was found.",
    "",
    "Enter the number of the copy to launch and remember:",
    "",
  }

  local maximum = math.min(#matches, 20)
  for index = 1, maximum do
    lines[#lines + 1] = tostring(index) .. ". " .. tostring(matches[index].action_name)
  end
  if #matches > maximum then
    lines[#lines + 1] = ""
    lines[#lines + 1] = "Only the first " .. tostring(maximum) .. " matches are shown."
  end

  r.ShowMessageBox(table.concat(lines, "\n"), "Choose ControllerFocus Action", 0)

  if not r.GetUserInputs then return matches[1] end
  local ok, answer = r.GetUserInputs(
    "Choose ControllerFocus Action",
    1,
    "Match number:,extrawidth=150",
    "1"
  )
  if not ok then return nil end

  local selection = math.floor(tonumber(answer) or 0)
  if selection < 1 or selection > maximum then
    r.ShowMessageBox(
      "No valid ControllerFocus match was selected.",
      "ControllerFocus Launch Cancelled",
      0
    )
    last_action = "ControllerFocus launch cancelled"
    return nil
  end

  return matches[selection]
end

DAW.CONTROLLER_FOCUS.launch = function()
  local saved_command, saved_description =
    DAW.CONTROLLER_FOCUS.command_from_saved_state()

  if saved_command then
    return DAW.CONTROLLER_FOCUS.run_command(saved_command, saved_description)
  end

  local matches = DAW.CONTROLLER_FOCUS.enumerate_matches()
  if #matches <= 0 then
    return DAW.CONTROLLER_FOCUS.show_missing_warning()
  end

  local selected = DAW.CONTROLLER_FOCUS.choose_match(matches)
  if not selected then return false end

  DAW.CONTROLLER_FOCUS.remember_match(selected)
  return DAW.CONTROLLER_FOCUS.run_command(
    selected.command_id,
    selected.action_name
  )
end


------------------------------------------------------------
-- PATCH 34: MIDI NOTE NAMER LAUNCHER
------------------------------------------------------------
DAW.MIDI_NOTE_NAMER = {
  EXTSTATE_NAMED_COMMAND = "MidiNoteNamerNamedCommand",
  EXTSTATE_DISPLAY_NAME = "MidiNoteNamerDisplayName",
  EXTSTATE_NUMERIC_COMMAND = "MidiNoteNamerNumericCommand",
}

DAW.MIDI_NOTE_NAMER.main_section = function()
  if not r.SectionFromUniqueID then return nil end
  return r.SectionFromUniqueID(0)
end

DAW.MIDI_NOTE_NAMER.normalize = function(name)
  return trim(
    tostring(name or "")
      :lower()
      :gsub("[_%-%./\\%(%)%[%]:]", " ")
      :gsub("%s+", " ")
  )
end

DAW.MIDI_NOTE_NAMER.is_match = function(action_name)
  local name = DAW.MIDI_NOTE_NAMER.normalize(action_name)
  return name == "midi note namer"
      or name:find("script midi note namer lua", 1, true) ~= nil
      or name:find("midi note namer", 1, true) ~= nil
end

DAW.MIDI_NOTE_NAMER.named_command_for_id = function(command_id)
  if not r.ReverseNamedCommandLookup then return "" end
  local bare = r.ReverseNamedCommandLookup(tonumber(command_id) or 0)
  bare = tostring(bare or "")
  if bare == "" then return "" end
  return bare:sub(1, 1) == "_" and bare or ("_" .. bare)
end

DAW.MIDI_NOTE_NAMER.find_action = function()
  local section = DAW.MIDI_NOTE_NAMER.main_section()
  if not section or not r.kbd_enumerateActions then return nil end

  local best = nil
  local index = 0

  while index < 100000 do
    local command_id, action_name = r.kbd_enumerateActions(section, index)
    if not command_id or command_id == 0 then break end

    if DAW.MIDI_NOTE_NAMER.is_match(action_name) then
      best = {
        command_id = command_id,
        action_name = tostring(action_name or ""),
        named_command = DAW.MIDI_NOTE_NAMER.named_command_for_id(command_id),
      }
      break
    end

    index = index + 1
  end

  return best
end

DAW.MIDI_NOTE_NAMER.remember_action = function(match)
  if not match then return end

  r.SetExtState(
    EXTSTATE_SECTION,
    DAW.MIDI_NOTE_NAMER.EXTSTATE_NAMED_COMMAND,
    tostring(match.named_command or ""),
    true
  )

  r.SetExtState(
    EXTSTATE_SECTION,
    DAW.MIDI_NOTE_NAMER.EXTSTATE_DISPLAY_NAME,
    tostring(match.action_name or ""),
    true
  )

  r.SetExtState(
    EXTSTATE_SECTION,
    DAW.MIDI_NOTE_NAMER.EXTSTATE_NUMERIC_COMMAND,
    tostring(match.command_id or ""),
    true
  )
end

DAW.MIDI_NOTE_NAMER.saved_command = function()
  local named = tostring(r.GetExtState(
    EXTSTATE_SECTION,
    DAW.MIDI_NOTE_NAMER.EXTSTATE_NAMED_COMMAND
  ) or "")

  if named ~= "" and r.NamedCommandLookup then
    local command_id = tonumber(r.NamedCommandLookup(named)) or 0
    if command_id > 0 then return command_id, named end
  end

  local numeric = tonumber(r.GetExtState(
    EXTSTATE_SECTION,
    DAW.MIDI_NOTE_NAMER.EXTSTATE_NUMERIC_COMMAND
  )) or 0

  if numeric > 0 then
    return numeric, tostring(r.GetExtState(
      EXTSTATE_SECTION,
      DAW.MIDI_NOTE_NAMER.EXTSTATE_DISPLAY_NAME
    ) or "")
  end

  return nil, nil
end

DAW.MIDI_NOTE_NAMER.run = function(command_id, label)
  command_id = tonumber(command_id) or 0
  if command_id <= 0 then return false end

  r.Main_OnCommand(command_id, 0)
  last_action = "Launched MIDI Note Namer"
    .. ((label and label ~= "") and (": " .. tostring(label)) or "")
  return true
end

DAW.MIDI_NOTE_NAMER.launch = function()
  local command_id, label = DAW.MIDI_NOTE_NAMER.saved_command()
  if command_id then
    return DAW.MIDI_NOTE_NAMER.run(command_id, label)
  end

  local match = DAW.MIDI_NOTE_NAMER.find_action()
  if not match then
    r.ShowMessageBox(
      "MIDI Note Namer was not found in REAPER's Main Actions list.\n\n"
        .. "Make sure MIDI_Note_Namer.lua is registered in the Actions list.",
      "MIDI Note Namer Not Found",
      0
    )
    last_action = "MIDI Note Namer not found in Actions list"
    return false
  end

  DAW.MIDI_NOTE_NAMER.remember_action(match)
  return DAW.MIDI_NOTE_NAMER.run(match.command_id, match.action_name)
end



-- Custom faders target only tracks that are visible in the Mixer Control Panel.
-- Cache the MCP-visible track list briefly so a dense stream of fader messages
-- does not rescan the project track list for every single MIDI value.
local mcp_visible_tracks = {}
DAW.tcp_visible_tracks = {}
local last_mcp_track_cache_refresh = -1000000
local pending_custom_fader_values = {}
local mcp_ui_dirty = false
local next_mcp_ui_refresh_time = 0

-- Two-way Custom fader feedback state. The Launchpad's native Custom Mode
-- faders respond to incoming CC messages using the same channel and CC numbers
-- that they transmit. Track-originated changes are sent only when their
-- quantized CC value changes. Hardware-originated changes update the remembered
-- value immediately so the script does not echo them straight back.
local last_custom_fader_feedback_poll_time = -1000000
local pending_full_custom_fader_feedback_time = nil
local last_feedback_custom_slot = nil
local last_sent_custom_fader_values = {}
local recent_outbound_custom_fader_feedback = {}
local custom_fader_hardware_holdoff_until = {}
local mcp_visible_track_signature = ""
DAW.tcp_visible_track_signature = ""
local mcp_structure_change_pending = false

-- MCP-tab layouts are deliberately outside the live fader synchronization path.
-- Apply them only when a different Custom Mode becomes active, and restore the
-- tracks' previous layouts only when leaving Custom Mode or changing banks.
local mcp_tab_state = {
  managed_layouts = {},
  active_slot = nil,
  status = "Not applied yet",
}

-- GUI-only drag state. This is intentionally separate from the established
-- DAW <-> Novation synchronization path. A GRID drag simply reuses the same
-- working setter as a GRID click and emits only when its MIDI value changes.
local custom_grid_drag = {
  active_fader = nil,
  last_value = nil,
  bounds = {},
  started_in_gap = false,
  start_x = 0,
  start_y = 0,
}

local schedule_full_active_custom_fader_feedback
local process_active_custom_fader_feedback
local apply_custom_fader_mcp_layout_tabs
local clear_custom_fader_mcp_layout_tabs
local refresh_mcp_track_cache

local function reset_custom_fader_feedback_state()
  last_custom_fader_feedback_poll_time = -1000000
  pending_full_custom_fader_feedback_time = nil
  last_feedback_custom_slot = nil
  last_sent_custom_fader_values = {}
  recent_outbound_custom_fader_feedback = {}
  custom_fader_hardware_holdoff_until = {}
  custom_grid_drag.active_fader = nil
  custom_grid_drag.last_value = nil
  custom_grid_drag.bounds = {}
  custom_grid_drag.started_in_gap = false
  custom_grid_drag.start_x = 0
  custom_grid_drag.start_y = 0
end

DAW.bytes_for_device = function(bytes, device)
  local translated = {}
  for index = 1, #(bytes or {}) do translated[index] = bytes[index] end

  -- Novation SysEx byte 6 identifies the hardware family. Ordinary note and CC
  -- messages are identical across the supported Launchpads, but SysEx must be
  -- translated per physical endpoint when Primary and Secondary use different
  -- models.
  if #translated >= 6
      and translated[1] == 0xF0
      and translated[2] == 0x00
      and translated[3] == 0x20
      and translated[4] == 0x29
      and translated[5] == 0x02 then
    translated[6] = (device or selected_device).id
  end

  return translated
end

DAW.send_to_unique_outputs = function(endpoints, bytes)
  local sent, seen, packed_by_model = false, {}, {}
  for _, endpoint in ipairs(endpoints or {}) do
    local index = type(endpoint) == "table" and tonumber(endpoint.index) or tonumber(endpoint)
    local device = (type(endpoint) == "table" and endpoint.device) or selected_device
    if index ~= nil and not seen[index] then
      local model_key = tostring((device or selected_device).key or "X")
      local packed = packed_by_model[model_key]
      if not packed then
        packed = bytes_to_string(DAW.bytes_for_device(bytes, device))
        packed_by_model[model_key] = packed
      end
      r.SendMIDIMessageToHardware(index, packed)
      seen[index] = true
      sent = true
    end
  end
  return sent
end

local function send_bytes(bytes)
  if not DAW.send_to_unique_outputs({
      {index = selected_output_index, device = selected_device},
      {index = DAW.ordinary_output_index_2, device = DAW.secondary_device},
    }, bytes) then
    last_action = "Cannot send: choose at least one MIDI hardware output first"
    return false
  end
  return true
end

DAW.send_bytes_primary = function(bytes)
  if selected_output_index == nil then
    last_action = "Cannot send: choose a primary MIDI hardware output first"
    return false
  end
  r.SendMIDIMessageToHardware(
    selected_output_index,
    bytes_to_string(DAW.bytes_for_device(bytes, selected_device))
  )
  return true
end

DAW.ordinary_input_matches = function(device_index)
  device_index = tonumber(device_index)
  return selected_input_index == -1
    or device_index == selected_input_index
    or (DAW.ordinary_input_index_2 ~= nil and device_index == DAW.ordinary_input_index_2)
end

DAW.input_matches = function(device_index)
  device_index = tonumber(device_index)
  return (DAW.input_index ~= nil and device_index == DAW.input_index)
    or (DAW.input_index_2 ~= nil and device_index == DAW.input_index_2)
end

DAW.configured_device_id_matches = function(device_id)
  device_id = tonumber(device_id)
  return device_id == tonumber(selected_device.id)
    or device_id == tonumber((DAW.secondary_device or selected_device).id)
end

DAW.send_bytes = function(bytes)
  if not DAW.send_to_unique_outputs({
      {index = DAW.output_index, device = selected_device},
      {index = DAW.output_index_2, device = DAW.secondary_device},
    }, bytes) then
    last_action = "Cannot send DAW command: choose at least one DAW MIDI output first"
    return false
  end
  return true
end

DAW.send_mode = function(enabled)
  return DAW.send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x10,
    enabled and 0x01 or 0x00,
    0xF7
  })
end

DAW.send_layout = function(layout)
  return DAW.send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x00, layout, 0xF7
  })
end

DAW.current_preset_definition = function()
  return DAW.PRESETS[tonumber(DAW.active_preset) or 1] or DAW.PRESETS[1]
end

DAW.active_target = function()
  local preset = DAW.current_preset_definition()
  return preset.target or "volume"
end

DAW.active_scope = function()
  local preset = DAW.current_preset_definition()
  return preset.scope == "tcp" and "tcp" or "mcp"
end

DAW.scope_label = function(scope)
  return (scope == "tcp") and "TCP" or "MCP"
end

DAW.active_scope_label = function()
  return DAW.scope_label(DAW.active_scope())
end

DAW.visible_tracks_for_scope = function(scope)
  return (scope == "tcp") and DAW.tcp_visible_tracks or mcp_visible_tracks
end

DAW.active_visible_tracks = function()
  return DAW.visible_tracks_for_scope(DAW.active_scope())
end

DAW.active_layout_property = function()
  return (DAW.active_scope() == "tcp") and "P_TCP_LAYOUT" or "P_MCP_LAYOUT"
end

DAW.active_send_index = function()
  local preset = DAW.current_preset_definition()
  return tonumber(preset.send_index)
end

DAW.target_is_available = function(track)
  if not track then return false end
  if DAW.active_target() == "send" then
    local send_index = DAW.active_send_index()
    return send_index ~= nil and r.GetTrackNumSends(track, 0) > send_index
  end
  return true
end

DAW.active_parameter_label = function()
  local target = DAW.active_target()
  if target == "pan" then return "Pan" end
  if target == "send" then return "Send " .. tostring((DAW.active_send_index() or 0) + 1) end
  return "Volume"
end

DAW.home_preset_lines = function(preset_number)
  preset_number = tonumber(preset_number) or -1

  -- Purposeful compact wraps for the two combined FX pages.
  if preset_number == 24 then return {"FX", "Pots &", "buttons"} end
  if preset_number == 25 then return {"FX", "Faders &", "buttons"} end

  local preset = DAW.PRESETS[preset_number]
  if not preset then return nil end
  
  if preset.home_lines then
    return preset.home_lines
  end
  
  local lines = {}
  for word in tostring(preset.name or ""):gmatch("%S+") do lines[#lines + 1] = word end
  return (#lines > 0) and lines or nil
end

-- Return the real REAPER project-track number for an active-scope-visible track.
-- MCP/TCP positions remain the internal controller indices, but user-facing GRID
-- labels should identify the actual project tracks when tracks are hidden from
-- the selected panel.
DAW.project_track_number = function(track, fallback)
  if not track then return tonumber(fallback) or 0 end
  local number = r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER")
  number = tonumber(number) or tonumber(fallback) or 0
  return math.floor(number + 0.5)
end

-- Compact user-facing name for GRID labels.  Keep this deliberately cheap:
-- it runs only while drawing the helper GRID and does not participate in the
-- hardware feedback path.
DAW.short_track_name = function(track, max_chars)
  if not track then return "" end
  local ok, name = r.GetTrackName(track)
  name = ok and trim(name or "") or ""
  name = name:gsub("[%s_]+", " ")
  max_chars = math.max(4, tonumber(max_chars) or 11)
  if name == "" then return "" end
  if #name <= max_chars then return name end
  return name:sub(1, math.max(1, max_chars - 3)) .. "..."
end

DAW.track_grid_lines = function(track, fallback, parameter_label, compact)
  local number = DAW.project_track_number(track, fallback)
  local name = DAW.short_track_name(track, compact and 10 or 12)
  if compact then
    return name ~= "" and {"T" .. tostring(number), name} or {"T" .. tostring(number)}
  end
  local lines = {"Track " .. tostring(number)}
  if name ~= "" then lines[#lines + 1] = name end
  if parameter_label and parameter_label ~= "" then lines[#lines + 1] = parameter_label end
  return lines
end

DAW.build_volume_fader_setup = function(start_track)
  start_track = math.max(1, tonumber(start_track) or DAW.active_start_track or 1)
  refresh_mcp_track_cache(false)

  local preset = DAW.current_preset_definition()
  local visible_tracks = DAW.active_visible_tracks()
  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x01, 0x00,
    preset.orientation or 0x00,
  }
  for fader_number = 1, 8 do
    local visible_track_index = start_track + fader_number - 1
    local track = visible_tracks[visible_track_index]

    bytes[#bytes + 1] = fader_number - 1
    bytes[#bytes + 1] = preset.fader_type or 0x00
    bytes[#bytes + 1] = DAW.CC_FIRST + fader_number - 1
    -- Firmware DAW faders accept colour 0 as disabled. Rebuild the compact
    -- bank definition on each page turn so a short final MCP bank can expose
    -- only the tracks that actually exist.
    bytes[#bytes + 1] = DAW.target_is_available(track) and DAW.COLORS[fader_number] or 0x00
  end
  bytes[#bytes + 1] = 0xF7
  return bytes
end

-- The firmware DAW Fader layout leaves the right-hand Session CC column
-- available. Use it as an eight-bank selector and hardware page indicator.
-- Channel 1 (B0) sets static colours; Channel 3 (B2) sets pulsing colours.
DAW.send_bank_indicators = function(bank)
  bank = math.max(1, math.min(8, tonumber(bank) or DAW.active_bank or 1))
  if DAW.output_index == nil and DAW.output_index_2 == nil then return false end

  for slot = 1, 8 do
    local cc = DAW.BANK_CC_BY_SLOT[slot]
    -- Always clear a previously pulsing state first, then leave inactive rows
    -- dim and make only the active row pulse.
    DAW.send_bytes({0xB2, cc, 0x00})
    DAW.send_bytes({0xB0, cc, DAW.BANK_INACTIVE_COLOR})
  end

  local start_track = math.max(1, tonumber(DAW.active_start_track) or (((bank - 1) * 8) + 1))
  -- Pulse a right-column page indicator only when the movable window is aligned
  -- to one of the fixed eight-track pages. A one-track offset intentionally has
  -- no pulsing page marker rather than displaying a misleading page.
  if ((start_track - 1) % 8) == 0 then
    local aligned_bank = math.floor((start_track - 1) / 8) + 1
    local physical_slot = 9 - aligned_bank
    local active_cc = DAW.BANK_CC_BY_SLOT[physical_slot]
    if active_cc then DAW.send_bytes({0xB2, active_cc, DAW.BANK_ACTIVE_COLOR}) end
  end
  return true
end

DAW.clear_bank_indicators = function()
  if DAW.output_index == nil and DAW.output_index_2 == nil then return false end
  for slot = 1, 8 do
    local cc = DAW.BANK_CC_BY_SLOT[slot]
    DAW.send_bytes({0xB2, cc, 0x00})
    DAW.send_bytes({0xB0, cc, 0x00})
  end
  return true
end

-- Session has a dedicated colour command because the physical Session button
-- is firmware-owned while DAW mode is active. Request white in both states.
DAW.send_session_button_colors = function(active_color, inactive_color)
  if DAW.output_index == nil and DAW.output_index_2 == nil then return false end
  return DAW.send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x14,
    active_color == nil and DAW.SESSION_BUTTON_ACTIVE_COLOR or active_color,
    inactive_color == nil and DAW.SESSION_BUTTON_INACTIVE_COLOR or inactive_color,
    0xF7
  })
end

DAW.preset_name = function(preset_number)
  local preset = DAW.PRESETS[tonumber(preset_number) or -1]
  return preset and preset.name or nil
end

DAW.bank_available = function(bank)
  bank = tonumber(bank) or -1
  if bank < 1 or bank > 8 then return false end
  return DAW.active_visible_tracks()[((bank - 1) * 8) + 1] ~= nil
end

DAW.current_start_track = function()
  return math.max(1, tonumber(DAW.active_start_track) or (((DAW.active_bank or 1) - 1) * 8 + 1))
end

DAW.window_available = function(start_track)
  start_track = tonumber(start_track) or -1
  return start_track >= 1 and DAW.active_visible_tracks()[start_track] ~= nil
end

DAW.top_row_slot_available = function(slot)
  if surface_mode == "PROGRAMMER_TRACK_MATRIX" then return DAW.MATRIX.matrix_top_row_available(slot) end
  if DAW.FX and DAW.FX.surface_is_active and DAW.FX.surface_is_active() then
    if DAW.FX.surface_is_combo and DAW.FX.surface_is_combo() then
      return DAW.FX.combo_top_row_available(slot)
    end
    if slot == 1 then return DAW.FX.surface_is_faders() and DAW.FX.page_available((DAW.FX.active_page or 1) - 1) end
    if slot == 2 then return DAW.FX.surface_is_faders() and DAW.FX.page_available((DAW.FX.active_page or 1) + 1) end
    if slot == 3 or slot == 4 then return DAW.FX.top_row_target_preset(slot) ~= nil end
    if slot == 5 then return true end
    return false
  end
  local start_track = DAW.current_start_track()
  if slot == 1 then return DAW.window_available(start_track + 8) end -- BANK UP
  if slot == 2 then return DAW.window_available(start_track - 8) end -- BANK DOWN
  if slot == 3 then return DAW.window_available(start_track - 1) end -- TRACK DOWN
  if slot == 4 then return DAW.window_available(start_track + 1) end -- TRACK UP
  if slot == 5 then return true end -- SESSION button becomes GO BACK through layout report
  return false
end

DAW.top_row_slot_lines = function(slot)
  if surface_mode == "PROGRAMMER_TRACK_MATRIX" then
    return DAW.MATRIX.matrix_top_row_lines(slot)
  end
  if DAW.FX and DAW.FX.surface_is_active and DAW.FX.surface_is_active() then
    if DAW.FX.surface_is_combo and DAW.FX.surface_is_combo() then
      return DAW.FX.combo_top_row_lines(slot)
    end
    if DAW.FX.surface_is_faders() then
      if slot == 1 then return {"GROUP", "UP"} end
      if slot == 2 then return {"GROUP", "DOWN"} end
    end
    if slot == 3 or slot == 4 then
      return DAW.FX.top_row_target_lines(slot) or {"N.A."}
    end
    if slot == 5 then return {"GO", "HOME"} end
    return {"N.A."}
  end
  if slot == 1 then
    return {"BANK", "UP"}
  elseif slot == 2 then
    return {"BANK", "DOWN"}
  elseif slot == 3 then
    return {"TRACK", "DOWN"}
  elseif slot == 4 then
    return {"TRACK", "UP"}
  elseif slot == 5 then
    return {"GO", "HOME"}
  elseif slot == 6 or slot == 7 or slot == 8 then
    return {"N.A."}
  end
  return {" "}
end

DAW.top_row_slot_color = function(slot)
  if DAW.FX and DAW.FX.surface_is_combo and DAW.FX.surface_is_combo() then
    return DAW.FX.combo_top_row_color(slot)
  end
  return DAW.top_row_slot_available(slot)
    and DAW.TOP_ROW_BRIGHT_COLORS[slot]
    or DAW.TOP_ROW_DIM_COLORS[slot]
end

DAW.send_top_row_indicators = function()
  if DAW.output_index == nil and DAW.output_index_2 == nil then return false end
  for slot = 1, 8 do
    local cc = DAW.TOP_ROW_CC_BY_SLOT[slot]
    DAW.send_bytes({0xB2, cc, 0x00})
    -- Try to paint the entire row. Reserved firmware controls may ignore these
    -- writes, but the GUI still mirrors the intended gray/white state.
    DAW.send_bytes({0xB0, cc, DAW.top_row_slot_color(slot)})
  end
  DAW.send_session_button_colors()
  return true
end

DAW.clear_top_row_indicators = function()
  if DAW.output_index == nil and DAW.output_index_2 == nil then return false end
  for slot = 1, 8 do
    local cc = DAW.TOP_ROW_CC_BY_SLOT[slot]
    DAW.send_bytes({0xB2, cc, 0x00})
    DAW.send_bytes({0xB0, cc, 0x00})
  end
  -- Zero active colour restores the firmware default Session colouring.
  DAW.send_session_button_colors(0x00, 0x00)
  return true
end

-- Keep the established call sites intact: they now update the complete top row.
DAW.send_go_back_indicator = function()
  return DAW.send_top_row_indicators()
end

DAW.clear_go_back_indicator = function()
  return DAW.clear_top_row_indicators()
end

DAW.clear_surface_indicators = function()
  DAW.clear_bank_indicators()
  DAW.clear_top_row_indicators()
  return true
end

local function send_programmer_mode()
  if clear_custom_fader_mcp_layout_tabs then
    clear_custom_fader_mcp_layout_tabs()
  end

  local sent = send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x0E, 0x01, 0xF7
  })
  if sent then
    DAW.programmer_mode_ack_ignore_until =
      r.time_precise() + (CFG.PROGRAMMER_MODE_ACK_IGNORE_SECONDS or 0.75)
    initialized = true
    surface_mode = "PROGRAMMER"
    active_custom_slot = nil
    reset_custom_fader_feedback_state()
    last_action = selected_device.name .. " switched to Programmer Mode"
  end
  return sent
end

local function send_live_mode()
  if clear_custom_fader_mcp_layout_tabs then
    clear_custom_fader_mcp_layout_tabs()
  end

  local sent = send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x0E, 0x00, 0xF7
  })
  if sent then
    initialized = false
    surface_mode = "LIVE"
    active_custom_slot = nil
    pending_custom_slot = nil
    pending_custom_switch_time = 0
    reset_custom_fader_feedback_state()
    last_action = selected_device.name .. " returned to Live Mode"
  end
  return sent
end

local function label_for_page_index(page, index)
  local row = math.floor((index - 1) / 9) + 1
  local col = ((index - 1) % 9) + 1
  return labels[page][row][col]
end

local function build_page_lighting_message(page, first_index, last_index)
  first_index = math.max(1, math.min(81, math.floor(tonumber(first_index) or 1)))
  last_index = math.max(first_index, math.min(81, math.floor(tonumber(last_index) or 81)))
  if (page == 2 or page == 3) and DAW.USER_PAGES then
    return DAW.USER_PAGES.build_lighting_message(page, first_index, last_index)
  end
  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03
  }

  local active_index = ACTIVE_PAGE_ARRAY_INDEX[page]
  local page_colors = hardware_colors[page]

  for i = first_index, last_index do
    local pad_type = hex_string_to_byte(Lpxlib.pad_types[i])
    local label = normalize_label(label_for_page_index(page, i))

    local is_page_button =
      i == ACTIVE_PAGE_ARRAY_INDEX[1] or
      i == ACTIVE_PAGE_ARRAY_INDEX[2] or
      i == ACTIVE_PAGE_ARRAY_INDEX[3]

    local should_pulse = (is_page_button and i == active_index) or is_label_active(label)
    local should_flash = DAW.grid_button_should_flash(label)
    if should_flash then
      pad_type = 0x01
    elseif is_page_button or should_pulse then
      pad_type = should_pulse and 0x02 or 0x00
    end

    local record_color = hex_string_to_byte(page_colors[i])
    local record_flash_base = 0x00
    pad_type, record_color, record_flash_base = DAW.resolve_palette_lighting(
      label, pad_type, record_color, record_flash_base
    )
    DAW.append_palette_colourspec(
      bytes,
      pad_type,
      hex_string_to_byte(Lpxlib.pad_addresses[i]),
      record_color,
      record_flash_base
    )
  end

  bytes[#bytes + 1] = 0xF7
  return bytes
end

-- Clear every address on the 9x9 surface. This mirrors the full-surface clear
-- pattern from the earlier Launchpad librarian: mode 0, address, color 0.
local function build_clear_lighting_message()
  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03
  }

  for i = 1, 81 do
    bytes[#bytes + 1] = 0x00
    bytes[#bytes + 1] = hex_string_to_byte(Lpxlib.pad_addresses[i])
    bytes[#bytes + 1] = 0x00
  end

  bytes[#bytes + 1] = 0xF7
  return bytes
end

local last_hardware_state_signature = nil

local function make_hardware_state_signature()
  if (current_page == 2 or current_page == 3) and DAW.USER_PAGES then
    return DAW.USER_PAGES.signature(current_page)
  end
  local parts = { tostring(current_page), grid_visible and "grid:1" or "grid:0" }
  for row = 1, 9 do
    for col = 1, 9 do
      local label = normalize_label(labels[current_page][row][col])
      if ACTIVE_STATE_CHECKS[label] then
        parts[#parts + 1] = label .. ":" .. (is_label_active(label) and "1" or "0")
      end
    end
  end
  return table.concat(parts, "|")
end

local function send_page_lighting(page, silent)
  if not send_bytes(build_page_lighting_message(page,1,81)) then
    return false
  end
  last_hardware_state_signature = make_hardware_state_signature()
  if not silent then
    last_action = string.format("Sent Page %d lighting configuration directly to %s", page, selected_device.name)
  end
  return true
end

local function send_page_lighting_range(page, first_index, last_index)
  return send_bytes(build_page_lighting_message(page, first_index, last_index))
end

local function send_clear_lighting(silent)
  if not send_bytes(build_clear_lighting_message()) then
    return false
  end
  last_hardware_state_signature = nil
  if not silent then
    last_action = "Cleared the Launchpad surface"
  end
  return true
end

local function refresh_hardware_state(force)
  if not initialized or (surface_mode ~= "PROGRAMMER" and surface_mode ~= "USER_ACTIONS" and surface_mode ~= "USER_CUSTOMS") then return end

  -- A Notes escape from resident Custom Mode intentionally separates the
  -- Programmer Mode request from the Page 3 repaint. Do not let the ordinary
  -- periodic refresher collapse that settling interval by sending early.
  if DAW and DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.pending_home_resend_time then
    return
  end

  local signature = make_hardware_state_signature()
  if force or signature ~= last_hardware_state_signature then
    send_page_lighting(current_page, true)
  end
end

local function initialize_hardware()
  if not send_programmer_mode() then return end
  send_page_lighting(current_page)
end

local function build_custom_mode_upload_message(dump_hex, custom_slot)
  local bytes = hex_text_to_bytes(dump_hex)
  if #bytes < 12 or bytes[1] ~= 0xF0 or bytes[#bytes] ~= 0xF7 then
    return nil, "Custom Mode SysEx dump could not be interpreted"
  end

  -- Match the proven upload conversion used in the earlier Launchpad librarian.
  -- Byte 6 selects X vs Mini. Byte 9 changes dump/response 0x10 to upload 0x45.
  -- Byte 11 selects the resident Custom Mode slot (slot 1 = 0x04).
  bytes[6] = selected_device.id
  bytes[9] = 0x45
  bytes[11] = 0x03 + custom_slot
  return bytes
end

local function send_switch_to_custom_slot(custom_slot, return_page, return_message)
  custom_slot = math.max(1, math.min(8, math.floor(tonumber(custom_slot) or 1)))

  local sent = send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id,
    0x00, 0x03 + custom_slot, 0xF7
  })

  if sent then
    if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end

    active_custom_slot = nil
    pending_custom_slot = nil
    pending_custom_switch_time = 0
    reset_custom_fader_feedback_state()

    if DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.clear_selection then
      DAW.CUSTOM_LIBRARY.clear_selection()
    end

    surface_mode = "CUSTOM_EXTERNAL"
    initialized = true

    DAW.custom_external_return_page =
      math.max(1, math.min(3, math.floor(tonumber(return_page) or 3)))

    DAW.custom_external_return_message = return_message

    if DAW.CUSTOM_LIBRARY then
      DAW.CUSTOM_LIBRARY.external_layout = 0x03 + custom_slot
      DAW.CUSTOM_LIBRARY.external_layout_ack_until = r.time_precise() + 1.0
      DAW.CUSTOM_LIBRARY.next_external_layout_poll_time = r.time_precise() + 0.05
    end

    last_action = "Entered passive external Custom Mode " .. tostring(custom_slot)
      .. "; script standing aside until NOTE returns to HOME Page "
      .. tostring(DAW.custom_external_return_page)
  end

  return sent
end

refresh_mcp_track_cache = function(force)
  local now = r.time_precise()
  if not force and (now - last_mcp_track_cache_refresh) < CFG.MCP_TRACK_CACHE_REFRESH_INTERVAL then
    return
  end

  mcp_visible_tracks = {}
  DAW.tcp_visible_tracks = {}
  local mcp_signature_parts = {}
  local tcp_signature_parts = {}
  for i = 0, r.CountTracks(0) - 1 do
    local track = r.GetTrack(0, i)
    if track and r.GetMediaTrackInfo_Value(track, "B_SHOWINMIXER") > 0.5 then
      mcp_visible_tracks[#mcp_visible_tracks + 1] = track
      mcp_signature_parts[#mcp_signature_parts + 1] = tostring(track)
    end
    if track and r.GetMediaTrackInfo_Value(track, "B_SHOWINTCP") > 0.5 then
      DAW.tcp_visible_tracks[#DAW.tcp_visible_tracks + 1] = track
      tcp_signature_parts[#tcp_signature_parts + 1] = tostring(track)
    end
  end

  local new_mcp_signature = table.concat(mcp_signature_parts, "|")
  local new_tcp_signature = table.concat(tcp_signature_parts, "|")
  if new_mcp_signature ~= mcp_visible_track_signature or new_tcp_signature ~= DAW.tcp_visible_track_signature then
    mcp_visible_track_signature = new_mcp_signature
    DAW.tcp_visible_track_signature = new_tcp_signature
    -- A changed visible-track list may redirect one or more physical faders.
    -- Force the next feedback scan to repaint the currently active bank.
    last_feedback_custom_slot = nil
    last_sent_custom_fader_values = {}
    mcp_structure_change_pending = true
  end

  last_mcp_track_cache_refresh = now
end

-- Restore only the track layouts temporarily replaced by this script. This is
-- called only when leaving Custom Mode or immediately before coloring a new bank.
clear_custom_fader_mcp_layout_tabs = function()
  local changed = 0
  local confirmed = 0

  for key, info in pairs(mcp_tab_state.managed_layouts) do
    local track = info.track
    if track and r.ValidatePtr(track, "MediaTrack*") then
      local restore_layout = info.layout or ""
      local property = info.property or "P_MCP_LAYOUT"
      local _, current_layout = r.GetSetMediaTrackInfo_String(track, property, "", false)
      if current_layout ~= restore_layout then
        r.GetSetMediaTrackInfo_String(track, property, restore_layout, true)
        changed = changed + 1
      end
      local _, assigned_layout = r.GetSetMediaTrackInfo_String(track, property, "", false)
      if assigned_layout == restore_layout then confirmed = confirmed + 1 end
    end
    mcp_tab_state.managed_layouts[key] = nil
  end

  mcp_tab_state.active_slot = nil
  if changed > 0 and r.UpdateArrange then r.UpdateArrange() end
  mcp_tab_state.status = string.format(
    "Restored previous temporary track-panel layouts: %d confirmed (%d changed)",
    confirmed,
    changed
  )
  return changed
end

-- Apply colored tabs once when a different Custom Mode becomes active. Do not
-- call this from a deferred feedback poll or from MCP-cache refreshes.
apply_custom_fader_mcp_layout_tabs = function(custom_slot, start_override, force)
  custom_slot = tonumber(custom_slot)
  if not custom_slot then return 0 end
  local bank_start = math.max(1, tonumber(start_override) or (((custom_slot - 1) * 8) + 1))
  local scope = (surface_mode == "DAW_VOLUME_FADERS") and DAW.active_scope() or "mcp"
  local visible_tracks = DAW.visible_tracks_for_scope(scope)
  local property = (scope == "tcp") and "P_TCP_LAYOUT" or "P_MCP_LAYOUT"
  local identity = scope .. ":" .. tostring(custom_slot) .. ":" .. tostring(bank_start)
  if not force and mcp_tab_state.active_slot == identity then return 0 end

  refresh_mcp_track_cache(true)
  visible_tracks = DAW.visible_tracks_for_scope(scope)
  clear_custom_fader_mcp_layout_tabs()

  local changed = 0
  local confirmed = 0
  local failed = {}

  for bank_offset = 1, 8 do
    local visible_index = bank_start + bank_offset - 1
    local track = visible_tracks[visible_index]
    local desired_layout = CUSTOM_FADER_MCP_LAYOUTS[bank_offset]

    if track and desired_layout then
      local key = tostring(track)
      local _, current_layout = r.GetSetMediaTrackInfo_String(track, property, "", false)
      mcp_tab_state.managed_layouts[key] = {track = track, layout = current_layout, property = property}

      if current_layout ~= desired_layout then
        r.GetSetMediaTrackInfo_String(track, property, desired_layout, true)
        changed = changed + 1
      end

      local _, assigned_layout = r.GetSetMediaTrackInfo_String(track, property, "", false)
      if assigned_layout == desired_layout then
        confirmed = confirmed + 1
      else
        failed[#failed + 1] = string.format("%d:%s", visible_index, desired_layout)
      end
    end
  end

  mcp_tab_state.active_slot = identity
  if changed > 0 and r.UpdateArrange then r.UpdateArrange() end

  if #failed == 0 then
    mcp_tab_state.status = string.format(
      "Applied %s tabs at visible track %d: %d confirmed (%d changed)",
      DAW.scope_label(scope),
      bank_start,
      confirmed,
      changed
    )
  else
    mcp_tab_state.status = string.format(
      "%s tab warning: %d assignments did not read back (%s)",
      DAW.scope_label(scope),
      #failed,
      table.concat(failed, ", ")
    )
  end

  return changed
end

local function mcp_track_description(track)
  if not track then return "missing MCP track" end
  local project_track_number = math.floor(r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER") or 0)
  local _, name = r.GetTrackName(track)
  name = trim(name)
  if name == "" then
    return "Project Track " .. tostring(project_track_number)
  end
  return "Project Track " .. tostring(project_track_number) .. " (" .. name .. ")"
end

local function enter_volume_custom_mode_1()
  -- Keep the first experiment deliberately narrow. The uploaded layout was
  -- captured from Launchpad X. Mini support can be added after this path works.
  if selected_device.key ~= "X" then
    last_action = "Rainbow volume Custom Mode test is currently enabled for Launchpad X only"
    return
  end

  refresh_mcp_track_cache(true)

  local bytes, err = build_custom_mode_upload_message(RAINBOW_FADERS_CUSTOM_MODE_DUMP_HEX, VOLUME_CUSTOM_SLOT)
  if not bytes then
    last_action = tostring(err)
    return
  end

  if send_bytes(bytes) then
    pending_custom_slot = VOLUME_CUSTOM_SLOT
    pending_custom_switch_time = r.time_precise() + CFG.CUSTOM_MODE_SWITCH_DELAY
    surface_mode = "CUSTOM_PENDING"
    initialized = true
    last_action = "Uploaded Rainbow Fades to Custom Mode 1; entering it shortly"
  end
end

local function return_to_home_page_1(reason, clear_first, requested_page, delay_lighting_until_settled)
  local target_page = math.max(1, math.min(3, math.floor(tonumber(requested_page) or 1)))

  -- Cancel a stale delayed HOME paint whenever a new explicit navigation
  -- request supersedes it. The Notes escape path below schedules a fresh one.
  if DAW and DAW.CUSTOM_LIBRARY then
    DAW.CUSTOM_LIBRARY.pending_home_resend_time = nil
    DAW.CUSTOM_LIBRARY.pending_home_resend_count = 0
    DAW.CUSTOM_LIBRARY.pending_home_resend_page = nil
    DAW.CUSTOM_LIBRARY.pending_home_resend_reason = nil
    DAW.CUSTOM_LIBRARY.pending_home_resend_stage = nil
    DAW.CUSTOM_LIBRARY.pending_home_resend_row = nil
    DAW.CUSTOM_LIBRARY.pending_post_upload_home_time = nil
    DAW.CUSTOM_LIBRARY.pending_post_upload_home_page = nil
    DAW.CUSTOM_LIBRARY.pending_post_upload_home_reason = nil
  end
  active_custom_slot = nil
  DAW.active_preset = nil
  pending_custom_slot = nil
  pending_custom_switch_time = 0
  if DAW and DAW.TRACK_VIEWER then
    DAW.TRACK_VIEWER.layout_identity = nil
    DAW.TRACK_VIEWER.surface_identity = nil
    DAW.TRACK_VIEWER.fade_states = {}
    DAW.TRACK_VIEWER.pending_fx_click = nil
    DAW.TRACK_VIEWER.pending_fx_center = nil
    DAW.TRACK_VIEWER.last_selection_signature = nil
    DAW.TRACK_VIEWER.last_touched_selected_track = nil
    DAW.TRACK_VIEWER.locked_to_track = false
    DAW.TRACK_VIEWER.select_hold = {
      active = false,
      source = nil,
      start_time = 0,
      lock_triggered = false,
    }
    DAW.TRACK_VIEWER.grid_drag.active_fader = nil
    DAW.TRACK_VIEWER.grid_drag.started_in_gap = false
    DAW.TRACK_VIEWER.grid_drag.last_value = nil
  end
  current_page = target_page
  if DAW and DAW.MATRIX then DAW.MATRIX.last_surface_signature = nil end

  -- If we are leaving the firmware DAW Fader layout, clear its dedicated DAW
  -- port indicators before restoring the scripted Programmer Mode home page.
  if DAW and DAW.clear_surface_indicators then
    DAW.clear_surface_indicators()
  end

  -- Session mode can briefly expose Novation's native pattern. Blank the
  -- surface first, then immediately restore Programmer Mode and our home page.
  if clear_first then
    send_clear_lighting(true)
  end

  if send_programmer_mode() then
    surface_mode = (target_page == 2) and "USER_ACTIONS"
      or ((target_page == 3) and "USER_CUSTOMS" or "PROGRAMMER")

    if delay_lighting_until_settled and DAW and DAW.CUSTOM_LIBRARY then
      DAW.CUSTOM_LIBRARY.schedule_home_lighting_after_programmer(
        target_page,
        reason or ("Returned to HOME Page " .. tostring(target_page))
      )
      last_action = "Requested Programmer Mode; rebuilding HOME Page "
        .. tostring(target_page) .. " in staged passes"
    else
      send_page_lighting(target_page, true)
      last_action = reason or ("Returned to HOME Page " .. tostring(target_page))
    end
  end
end

local function process_pending_custom_mode_switch(now)
  if pending_custom_slot and now >= pending_custom_switch_time then
    local slot = pending_custom_slot
    pending_custom_slot = nil
    pending_custom_switch_time = 0
    send_switch_to_custom_slot(slot)
  end
end

local function helper_window_should_be_visible()
  return grid_visible or grid_preview_held or r.time_precise() < grid_preview_until
end

local function hold_grid_preview_open()
  grid_preview_held = true
  grid_preview_until = 0
end

local function release_grid_preview()
  if grid_preview_held then
    grid_preview_held = false
    grid_preview_until = r.time_precise() + CFG.TEMP_GRID_PREVIEW_SECONDS
    last_action = "Keeping Page " .. tostring(current_page) .. " helper grid visible for " .. tostring(CFG.TEMP_GRID_PREVIEW_SECONDS) .. " seconds after release"
  end
end

local function set_page(page, reason)
  if page < 1 or page > 3 then return end

  local pressed_current_page = (page == current_page)
  current_page = page
  if initialized and (surface_mode == "PROGRAMMER" or surface_mode == "USER_ACTIONS" or surface_mode == "USER_CUSTOMS") then
    surface_mode = (page == 2) and "USER_ACTIONS" or ((page == 3) and "USER_CUSTOMS" or "PROGRAMMER")
  end

  -- When the helper is intentionally hidden, holding the already-active page
  -- button temporarily reveals it. The release event starts a three-second tail.
  if not grid_visible and pressed_current_page then
    hold_grid_preview_open()
  end

  if initialized and (surface_mode == "PROGRAMMER" or surface_mode == "USER_ACTIONS" or surface_mode == "USER_CUSTOMS") then
    if DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.pending_home_resend_time
        and DAW.CUSTOM_LIBRARY.schedule_home_lighting_after_programmer then
      DAW.CUSTOM_LIBRARY.schedule_home_lighting_after_programmer(
        current_page,
        reason or ("Rebuilding HOME Page " .. tostring(current_page)),
        CFG.HOME_REPAINT_PAGE_CHANGE_DELAY_SECONDS or 0.03
      )
    else
      -- Ordinary HOME page presses use one immediate paint. The slow staged
      -- rebuild is reserved for genuine recovery transitions such as Notes-mode
      -- escape and Sleep wakeup; it is unnecessary when HOME is already healthy.
      send_page_lighting(current_page, true)
    end
  end

  if not grid_visible and pressed_current_page then
    last_action = "Showing Page " .. tostring(page) .. " helper grid while the page button is held"
  elseif reason then
    last_action = reason
  elseif not initialized then
    last_action = "Changed GUI to Page " .. tostring(page) .. "; initialize hardware to send it"
  end
end

------------------------------------------------------------
-- REAPER ACTIONS
------------------------------------------------------------
local function describe_command(command_id)
  if r.kbd_getTextFromCmd then
    local text = r.kbd_getTextFromCmd(command_id, 0)
    if text and text ~= "" then return text end
  end
  return "Action " .. tostring(command_id)
end

local function run_main_action(command_id, friendly_name)
  r.Main_OnCommand(command_id, 0)
  last_action = (friendly_name or "Ran action") .. " | " .. describe_command(command_id)
end

local function go_to_marker_or_region(direction)
  local _, marker_count, region_count = r.CountProjectMarkers(0)
  local total = (marker_count or 0) + (region_count or 0)
  local cursor = r.GetCursorPosition()
  local first_target, last_target, target = nil, nil, nil
  local eps = 0.000001

  local function make_target(pos, is_region, name)
    return {
      pos = pos,
      kind = is_region and "region" or "marker",
      name = name or ""
    }
  end

  for i = 0, total - 1 do
    local retval, is_region, pos, _, name = r.EnumProjectMarkers3(0, i)
    if retval then
      local candidate = make_target(pos, is_region, name)

      if not first_target or pos < first_target.pos then first_target = candidate end
      if not last_target or pos > last_target.pos then last_target = candidate end

      if direction < 0 and pos < cursor - eps then
        if not target or pos > target.pos then target = candidate end
      elseif direction > 0 and pos > cursor + eps then
        if not target or pos < target.pos then target = candidate end
      end
    end
  end

  -- Wrap at either end so the hardware button remains useful.
  if not target then
    target = (direction < 0) and last_target or first_target
  end

  if target then
    r.SetEditCurPos(target.pos, true, false)
    local description = target.kind
    if target.name ~= "" then
      description = description .. ' "' .. target.name .. '"'
    end
    last_action = ((direction < 0) and "Moved to previous " or "Moved to next ") .. description
  else
    last_action = "No project markers or regions exist"
  end
end

local function toggle_track_fx_chain(track, label)
  if not track then
    last_action = "Cannot open " .. label .. ": no target track"
    return
  end

  local visible_fx = r.TrackFX_GetChainVisible(track)
  if visible_fx == -1 then
    -- TrackFX_Show(..., 0, 1) opens the FX-chain window even when the chain is
    -- currently empty. That is important for Track Viewer: the button should
    -- open the chain so the user can add the first FX.
    r.TrackFX_Show(track, 0, 1)
    last_action = "Opened " .. label
  else
    r.TrackFX_Show(track, math.max(visible_fx, 0), 0)
    last_action = "Closed " .. label
  end
end

local function toggle_selected_track_fx()
  toggle_track_fx_chain(r.GetSelectedTrack(0, 0), "selected-track FX chain")
end

local function toggle_master_fx()
  toggle_track_fx_chain(r.GetMasterTrack(0), "master FX chain")
end

local function command_is_on(command_id)
  if r.GetToggleCommandStateEx then
    return r.GetToggleCommandStateEx(0, command_id) == 1
  end
  return r.GetToggleCommandState(command_id) == 1
end

local function ripple_is_on()
  return command_is_on(CMD.RIPPLE_PER_TRACK) or command_is_on(CMD.RIPPLE_ALL)
end

local function selected_track_fx_is_visible()
  local track = r.GetSelectedTrack(0, 0)
  return track and r.TrackFX_GetChainVisible(track) ~= -1
end

local function master_fx_is_visible()
  local track = r.GetMasterTrack(0)
  return track and r.TrackFX_GetChainVisible(track) ~= -1
end

ACTIVE_STATE_CHECKS["Auto Crossfade"] = function() return command_is_on(CMD.AUTO_CROSSFADE) end
ACTIVE_STATE_CHECKS["Item Grouping"] = function() return command_is_on(CMD.ITEM_GROUPING) end
ACTIVE_STATE_CHECKS["Ripple"] = ripple_is_on
ACTIVE_STATE_CHECKS["Grid"] = function() return command_is_on(CMD.GRID) end
ACTIVE_STATE_CHECKS["Snap"] = function() return command_is_on(CMD.SNAP) end
ACTIVE_STATE_CHECKS["Locking"] = function() return command_is_on(CMD.LOCKING) end
ACTIVE_STATE_CHECKS["Metronome"] = function() return command_is_on(CMD.METRONOME) end
ACTIVE_STATE_CHECKS["Loop"] = function() return r.GetSetRepeat(-1) == 1 end
ACTIVE_STATE_CHECKS["Show/Hide Master FX"] = master_fx_is_visible
ACTIVE_STATE_CHECKS["Go to Master FX"] = master_fx_is_visible -- legacy alias for older saved layouts
ACTIVE_STATE_CHECKS["Show/Hide FX"] = selected_track_fx_is_visible
ACTIVE_STATE_CHECKS["Show/Hide Docker"] = function() return command_is_on(CMD.DOCKER) end
ACTIVE_STATE_CHECKS["Show/Hide FX Browser"] = function() return command_is_on(CMD.FX_BROWSER) end
ACTIVE_STATE_CHECKS["Show/Hide Media"] = function() return command_is_on(CMD.MEDIA_EXPLORER) end
ACTIVE_STATE_CHECKS["Show/Hide Mixer"] = function() return command_is_on(CMD.MIXER) end
ACTIVE_STATE_CHECKS["Show/Hide This Grid"] = function() return grid_visible end
ACTIVE_STATE_CHECKS["Show/Hide Library & Settings"] = function() return library_visible end
ACTIVE_STATE_CHECKS["Play"] = function() return (r.GetPlayState() & 1) == 1 end
ACTIVE_STATE_CHECKS["Stop"] = function() return r.GetPlayState() == 0 end
ACTIVE_STATE_CHECKS["Pause"] = function() return (r.GetPlayState() & 2) == 2 end
ACTIVE_STATE_CHECKS["Record"] = function() return (r.GetPlayState() & 4) == 4 end
ACTIVE_STATE_CHECKS["Scan Forward"] = function() return scan_direction > 0 end
ACTIVE_STATE_CHECKS["Scan Backward"] = function() return scan_direction < 0 end

local ACTIONS = {}
local HOLD_ACTIONS = {}

local function bind(label, fn)
  ACTIONS[label] = fn
end

local function bind_hold(label, on_press, on_release)
  HOLD_ACTIONS[label] = { press = on_press, release = on_release }
end

DAW.TRACK_PICKER.track_color_for_inner_row = function(inner_row, gui)
  inner_row = math.max(1, math.min(8, tonumber(inner_row) or 1))
  local colored_band = inner_row <= 2 or (inner_row >= 5 and inner_row <= 6)
  if gui then
    return colored_band
      and (DAW.TRACK_PICKER.PAGE_GUI_COLORS[DAW.TRACK_PICKER.page] or 0x8161DDFF)
      or DAW.TRACK_PICKER.NEUTRAL_GUI_COLOR
  end
  return colored_band
    and (DAW.TRACK_PICKER.PAGE_HARDWARE_COLORS[DAW.TRACK_PICKER.page] or 0x74)
    or DAW.TRACK_PICKER.NEUTRAL_HARDWARE_COLOR
end

DAW.TRACK_PICKER.track_number_at_cell = function(row, col)
  row = tonumber(row)
  col = tonumber(col)
  if not row or not col or row < 2 or row > 9 or col < 1 or col > 5 then return nil end
  return ((DAW.TRACK_PICKER.page - 1) * 40) + ((row - 2) * 5) + col
end

DAW.TRACK_PICKER.make_hardware_state_signature = function()
  local parts = {"picker:" .. tostring(DAW.TRACK_PICKER.page)}
  local page = DAW.TRACK_PICKER.page
  for row = 1, 9 do
    for col = 6, 9 do
      local label = normalize_label(labels[page][row][col])
      if ACTIVE_STATE_CHECKS[label] then
        parts[#parts + 1] = label .. ":" .. (is_label_active(label) and "1" or "0")
      end
    end
  end
  return table.concat(parts, "|")
end

DAW.TRACK_PICKER.build_lighting_message = function(page)
  page = math.max(1, math.min(3, tonumber(page) or DAW.TRACK_PICKER.page or 1))
  DAW.TRACK_PICKER.page = page

  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03
  }
  local active_index = ACTIVE_PAGE_ARRAY_INDEX[page]
  local page_colors = hardware_colors[page]

  for i = 1, 81 do
    local row = math.floor((i - 1) / 9) + 1
    local col = ((i - 1) % 9) + 1
    local pad_type = hex_string_to_byte(Lpxlib.pad_types[i])
    local color = hex_string_to_byte(page_colors[i])
    local label = normalize_label(label_for_page_index(page, i))

    if row >= 2 and col <= 5 then
      color = DAW.TRACK_PICKER.track_color_for_inner_row(row - 1, false)
      pad_type = 0x00
    else
      local is_page_button =
        i == ACTIVE_PAGE_ARRAY_INDEX[1] or
        i == ACTIVE_PAGE_ARRAY_INDEX[2] or
        i == ACTIVE_PAGE_ARRAY_INDEX[3]
      local should_pulse = (is_page_button and i == active_index) or is_label_active(label)
      local should_flash = DAW.grid_button_should_flash(label)
      if should_flash then
        pad_type = 0x01
      elseif is_page_button or should_pulse then
        pad_type = should_pulse and 0x02 or 0x00
      end
    end

    local flash_base_color = 0x00
    pad_type, color, flash_base_color = DAW.resolve_palette_lighting(
      label, pad_type, color, flash_base_color
    )
    DAW.append_palette_colourspec(
      bytes,
      pad_type,
      hex_string_to_byte(Lpxlib.pad_addresses[i]),
      color,
      flash_base_color
    )
  end

  bytes[#bytes + 1] = 0xF7
  return bytes
end

DAW.TRACK_PICKER.send_lighting = function(page, silent)
  if not send_bytes(DAW.TRACK_PICKER.build_lighting_message(page)) then return false end
  DAW.TRACK_PICKER.last_hardware_state_signature =
    DAW.TRACK_PICKER.make_hardware_state_signature()
  if not silent then
    last_action = "Sent Track Picker Page " .. tostring(DAW.TRACK_PICKER.page) .. " lighting"
  end
  return true
end

DAW.TRACK_PICKER.refresh_hardware_state = function(force)
  if not initialized or surface_mode ~= "TRACK_PICKER" then return false end
  local signature = DAW.TRACK_PICKER.make_hardware_state_signature()
  if force or signature ~= DAW.TRACK_PICKER.last_hardware_state_signature then
    return DAW.TRACK_PICKER.send_lighting(DAW.TRACK_PICKER.page, true)
  end
  return false
end

DAW.TRACK_PICKER.preset_for_page = function(page)
  page = math.max(1, math.min(3, tonumber(page) or 1))
  return 25 + page
end

DAW.TRACK_PICKER.range_label = function(page)
  page = math.max(1, math.min(3, tonumber(page) or DAW.TRACK_PICKER.page or 1))
  local first_track = ((page - 1) * 40) + 1
  return tostring(first_track) .. "-" .. tostring(first_track + 39)
end

DAW.TRACK_PICKER.screen_title = function()
  local page = math.max(1, math.min(3, tonumber(DAW.TRACK_PICKER.page) or 1))
  return string.format(
    "Preset %d: Track Picker %s",
    DAW.TRACK_PICKER.preset_for_page(page),
    DAW.TRACK_PICKER.range_label(page)
  )
end

DAW.TRACK_PICKER.set_page = function(page, reason)
  page = tonumber(page)
  if not page or page < 1 or page > 3 then return false end
  DAW.TRACK_PICKER.page = page
  if initialized and surface_mode == "TRACK_PICKER" then
    DAW.active_preset = DAW.TRACK_PICKER.preset_for_page(page)
    DAW.TRACK_PICKER.send_lighting(page, true)
  end
  last_action = reason or ("Changed Track Picker to " .. DAW.TRACK_PICKER.range_label(page))
  return true
end

DAW.TRACK_PICKER.enter = function(page)
  if not send_programmer_mode() then return false end
  page = math.max(1, math.min(3, tonumber(page) or 1))
  DAW.TRACK_PICKER.page = page
  DAW.active_preset = DAW.TRACK_PICKER.preset_for_page(page)
  DAW.TRACK_PICKER.last_hardware_state_signature = nil
  surface_mode = "TRACK_PICKER"
  initialized = true
  DAW.TRACK_PICKER.send_lighting(page, true)
  last_action = DAW.TRACK_PICKER.screen_title()
  return true
end

-- The complete Track Viewer entry function is installed later, after the
-- shared fader conversion helpers have been declared.
DAW.TRACK_VIEWER.enter = function(track_number)
  DAW.TRACK_VIEWER.selected_track_number = tonumber(track_number)
    or DAW.TRACK_PICKER.selected_track_number
  last_action = "Track Viewer is still initializing"
  return false
end

DAW.TRACK_PICKER.select_track = function(track_number)
  track_number = tonumber(track_number)
  if not track_number then return false end
  local track = r.GetTrack(0, track_number - 1)
  if not track then
    last_action = "Track Picker: project track " .. tostring(track_number) .. " is unavailable"
    return false
  end

  DAW.TRACK_PICKER.selected_track_number = track_number
  if r.SetOnlyTrackSelected then
    r.SetOnlyTrackSelected(track)
  else
    for i = 0, r.CountTracks(0) - 1 do
      local candidate = r.GetTrack(0, i)
      if candidate then r.SetTrackSelected(candidate, candidate == track) end
    end
  end
  if r.SetMixerScroll then r.SetMixerScroll(track) end
  if r.UpdateArrange then r.UpdateArrange() end
  return DAW.TRACK_VIEWER.enter(track_number)
end

DAW.TRACK_PICKER.dispatch_index = function(index, source)
  if not index or index < 1 or index > 81 then return false end
  local row = math.floor((index - 1) / 9) + 1
  local col = ((index - 1) % 9) + 1

  if row >= 2 and col <= 5 then
    return DAW.TRACK_PICKER.select_track(DAW.TRACK_PICKER.track_number_at_cell(row, col))
  end

  local raw_label = labels[DAW.TRACK_PICKER.page][row][col]
  local label = normalize_label(raw_label)
  if label == "Page Status" then
    last_action = (source or "Track Picker") .. ": Track Picker page status has no action"
    return true
  elseif label == "Save Project" then
    return_to_home_page_1("Track Picker: returned to HOME Page 1", false)
    return true
  elseif label == "Page 1" then
    return DAW.TRACK_PICKER.set_page(1, "Changed Track Picker to Page 1")
  elseif label == "Page 2" then
    return DAW.TRACK_PICKER.set_page(2, "Changed Track Picker to Page 2")
  elseif label == "Page 3" then
    return DAW.TRACK_PICKER.set_page(3, "Changed Track Picker to Page 3")
  end

  local action = ACTIONS[label]
  local hold_action = HOLD_ACTIONS[label]
  if action then
    action()
    DAW.TRACK_PICKER.send_lighting(DAW.TRACK_PICKER.page, true)
    return true
  elseif hold_action then
    hold_action.press()
    hold_action.release()
    DAW.TRACK_PICKER.send_lighting(DAW.TRACK_PICKER.page, true)
    return true
  end

  last_action = (source or "Track Picker") .. ": " .. label .. " is not wired yet"
  return true
end

local function send_scan_step(direction)
  if direction == 0 then return end

  -- These control-surface calls act like repeated presses rather than a
  -- self-sustaining key-down state. The deferred loop repeats them while the
  -- Launchpad button remains held.
  if r.CSurf_OnRewFwd then
    r.CSurf_OnRewFwd(1, direction)
  elseif direction > 0 and r.CSurf_OnFwd then
    r.CSurf_OnFwd(1)
  elseif direction < 0 and r.CSurf_OnRew then
    r.CSurf_OnRew(1)
  end
end

local function release_scan_transport(direction)
  if r.CSurf_OnRewFwd then
    r.CSurf_OnRewFwd(0, direction)
  elseif direction > 0 and r.CSurf_OnFwd then
    r.CSurf_OnFwd(0)
  elseif direction < 0 and r.CSurf_OnRew then
    r.CSurf_OnRew(0)
  end
end

local function set_scan_transport(direction, held)
  if held then
    -- Release an opposite-direction scan first in case the user changes
    -- direction without a clean intervening release event.
    if scan_direction ~= 0 and scan_direction ~= direction then
      release_scan_transport(scan_direction)
    end

    scan_direction = direction
    send_scan_step(direction)
    scan_next_repeat_time = r.time_precise() + CFG.SCAN_REPEAT_INTERVAL
    last_action = (direction > 0) and "Scanning forward while held" or "Scanning backward while held"
  else
    release_scan_transport(direction)
    if scan_direction == direction then
      scan_direction = 0
      scan_next_repeat_time = 0
    end
    last_action = (direction > 0) and "Stopped scanning forward" or "Stopped scanning backward"
  end
end

local function repeat_scan_if_held(now)
  if scan_direction == 0 or now < scan_next_repeat_time then return end
  send_scan_step(scan_direction)
  scan_next_repeat_time = now + CFG.SCAN_REPEAT_INTERVAL
end

bind_hold("Scan Forward",  function() set_scan_transport( 1, true) end, function() set_scan_transport( 1, false) end)
bind_hold("Scan Backward", function() set_scan_transport(-1, true) end, function() set_scan_transport(-1, false) end)

local function midi_cc_to_track_volume(value)
  value = math.max(0, math.min(127, value or 0))
  if value == 0 then return 0 end

  if r.SLIDER2DB then
    local db = r.SLIDER2DB((value / 127) * 1000)
    return 10 ^ (db / 20)
  end

  -- Conservative fallback if a future REAPER build lacks SLIDER2DB().
  return value / 127
end

local function track_volume_to_midi_cc(volume)
  volume = tonumber(volume) or 0
  if volume <= 0 then return 0 end

  if r.DB2SLIDER then
    local db = 20 * (math.log(volume) / math.log(10))
    local slider = r.DB2SLIDER(db) or 0
    slider = math.max(0, math.min(1000, slider))
    return math.floor((slider / 1000) * 127 + 0.5)
  end

  return math.floor(math.max(0, math.min(1, volume)) * 127 + 0.5)
end

local function midi_cc_to_track_pan(value)
  value = math.max(0, math.min(127, math.floor((tonumber(value) or 64) + 0.5)))
  if value <= 64 then
    return (value - 64) / 64
  end
  return (value - 64) / 63
end

local function track_pan_to_midi_cc(pan)
  pan = math.max(-1, math.min(1, tonumber(pan) or 0))
  if pan <= 0 then
    return math.floor(64 + (pan * 64) + 0.5)
  end
  return math.floor(64 + (pan * 63) + 0.5)
end

local function daw_pan_surface_is_active()
  return surface_mode == "DAW_VOLUME_FADERS" and DAW.active_target() == "pan"
end

DAW.daw_send_surface_is_active = function()
  return surface_mode == "DAW_VOLUME_FADERS" and DAW.active_target() == "send"
end

DAW.active_fader_track_list = function()
  return (surface_mode == "DAW_VOLUME_FADERS") and DAW.active_visible_tracks() or mcp_visible_tracks
end

local function track_target_to_midi_cc(track)
  if not DAW.target_is_available(track) then return 0 end
  if daw_pan_surface_is_active() then
    return track_pan_to_midi_cc(r.GetMediaTrackInfo_Value(track, "D_PAN"))
  elseif DAW.daw_send_surface_is_active() then
    return track_volume_to_midi_cc(r.GetTrackSendInfo_Value(track, 0, DAW.active_send_index(), "D_VOL"))
  end
  return track_volume_to_midi_cc(r.GetMediaTrackInfo_Value(track, "D_VOL"))
end

local function apply_midi_cc_to_track_target(track, value)
  -- Controller and GRID gestures should affect only the addressed panel-visible
  -- track. REAPER's CSurf_OnVolumeChange / CSurf_OnPanChange paths can apply
  -- selected-track grouping, which is desirable for a native DAW mouse drag
  -- but surprising when moving one physical controller fader. Write the track
  -- property directly here so Novation and GRID control remain single-track.
  if not DAW.target_is_available(track) then return nil end
  if daw_pan_surface_is_active() then
    local pan = midi_cc_to_track_pan(value)
    r.SetMediaTrackInfo_Value(track, "D_PAN", pan)
    return pan
  elseif DAW.daw_send_surface_is_active() then
    local volume = midi_cc_to_track_volume(value)
    r.SetTrackSendInfo_Value(track, 0, DAW.active_send_index(), "D_VOL", volume)
    return volume
  end

  local volume = midi_cc_to_track_volume(value)
  r.SetMediaTrackInfo_Value(track, "D_VOL", volume)
  return volume
end

local function is_recent_outbound_custom_fader_echo(cc_number, value, now)
  local recent = recent_outbound_custom_fader_feedback[cc_number]
  if not recent then return false end
  if (now - recent.time) > CFG.CUSTOM_FADER_FEEDBACK_ECHO_SUPPRESSION_SECONDS then
    recent_outbound_custom_fader_feedback[cc_number] = nil
    return false
  end
  return recent.value == value
end

local function volume_fader_surface_is_active()
  return active_custom_slot ~= nil and
    (surface_mode == "CUSTOM_VOLUME_BANK" or surface_mode == "DAW_VOLUME_FADERS")
end

local function send_custom_fader_feedback(fader_number, value)
  if not volume_fader_surface_is_active() then return false end

  local cc_number = VOLUME_CC_FIRST + fader_number - 1
  value = math.max(0, math.min(127, math.floor((tonumber(value) or 0) + 0.5)))

  local sent
  if surface_mode == "DAW_VOLUME_FADERS" then
    sent = DAW.send_bytes({
      0xB0 | DAW.FADER_CHANNEL,
      cc_number,
      value,
    })
  else
    sent = send_bytes({
      0xB0 | VOLUME_MIDI_CHANNEL,
      cc_number,
      value,
    })
  end

  if sent then
    last_sent_custom_fader_values[fader_number] = value
    recent_outbound_custom_fader_feedback[cc_number] = {
      value = value,
      time = r.time_precise(),
    }
  end

  return sent
end

local function active_fader_start_index()
  if surface_mode == "DAW_VOLUME_FADERS" then
    return DAW.current_start_track()
  end
  return ((active_custom_slot or 1) - 1) * 8 + 1
end

local function active_fader_identity()
  if surface_mode == "DAW_VOLUME_FADERS" then
    return "DAW:" .. tostring(active_fader_start_index())
  end
  return "CUSTOM:" .. tostring(active_custom_slot or 1)
end

local function sync_active_custom_fader_feedback(force)
  if not volume_fader_surface_is_active() then return 0 end

  refresh_mcp_track_cache(false)

  local feedback_identity = active_fader_identity()
  if last_feedback_custom_slot ~= feedback_identity then
    force = true
    last_feedback_custom_slot = feedback_identity
    last_sent_custom_fader_values = {}
  end

  local now = r.time_precise()
  local bank_start = active_fader_start_index()
  local visible_tracks = DAW.active_fader_track_list()
  local sent_count = 0

  for fader_number = 1, 8 do
    local holdoff_until = custom_fader_hardware_holdoff_until[fader_number] or 0

    -- A soft press on a native Novation fader produces a gradual stream of CC
    -- values. Do not fight that gesture by sending the DAW's intermediate
    -- values back to the same fader until its incoming traffic has gone quiet.
    -- Even a forced bank refresh must respect this per-fader quiet period.
    if now >= holdoff_until then
      local track = visible_tracks[bank_start + fader_number - 1]
      local midi_value = 0
      if DAW.target_is_available(track) then
        midi_value = track_target_to_midi_cc(track)
      end

      if force or last_sent_custom_fader_values[fader_number] ~= midi_value then
        if send_custom_fader_feedback(fader_number, midi_value) then
          sent_count = sent_count + 1
        end
      end
    end
  end

  return sent_count
end

schedule_full_active_custom_fader_feedback = function(delay_seconds)
  last_feedback_custom_slot = nil
  last_sent_custom_fader_values = {}
  pending_full_custom_fader_feedback_time = r.time_precise() + (delay_seconds or 0)
end

process_active_custom_fader_feedback = function(now)
  if not volume_fader_surface_is_active() then return end

  if pending_full_custom_fader_feedback_time and now >= pending_full_custom_fader_feedback_time then
    pending_full_custom_fader_feedback_time = nil
    local sent_count = sync_active_custom_fader_feedback(true)
    last_custom_fader_feedback_poll_time = now
    if sent_count > 0 then
      last_action = string.format(
        "Synced %d Novation %s faders from %s-visible tracks %d-%d",
        sent_count,
        DAW.active_parameter_label(),
        DAW.active_scope_label(),
        active_fader_start_index(),
        active_fader_start_index() + 7
      )
    end
    return
  end

  if (now - last_custom_fader_feedback_poll_time) >= CFG.CUSTOM_FADER_FEEDBACK_POLL_INTERVAL then
    sync_active_custom_fader_feedback(false)
    last_custom_fader_feedback_poll_time = now
  end
end

local function begin_custom_fader_hardware_holdoff(cc_number, now)
  -- Start the physical-fader protection window at the earliest possible point:
  -- as soon as any incoming Novation fader CC is observed, before echo filtering
  -- or deferred application to REAPER. This prevents a short pad tap from being
  -- overwritten by stale DAW feedback before its new value has settled.
  local fader_number = (cc_number - VOLUME_CC_FIRST) + 1
  custom_fader_hardware_holdoff_until[fader_number] =
    (now or r.time_precise()) + CFG.CUSTOM_FADER_HARDWARE_TOUCH_HOLDOFF_SECONDS
end

local function queue_track_volume_from_custom_fader(cc_number, value, now)
  -- Retain only the newest value for each physical fader during this defer cycle.
  -- A fast fader sweep can generate many intermediate CC messages; applying every
  -- stale intermediate value is unnecessary and makes the surface feel sluggish.
  -- Capture the Custom slot with the event so a bank change cannot redirect a
  -- value that was already received from the previous Custom Mode.
  begin_custom_fader_hardware_holdoff(cc_number, now)

  pending_custom_fader_values[cc_number] = {
    value = value,
    custom_slot = active_custom_slot or 1,
    start_index = active_fader_start_index(),
  }
end

local function flush_custom_fader_values()
  if not next(pending_custom_fader_values) then return end

  refresh_mcp_track_cache(false)

  local applied = 0
  local last_description = nil
  local first_missing_fader = nil
  local visible_tracks = DAW.active_fader_track_list()

  for cc_number = VOLUME_CC_FIRST, VOLUME_CC_LAST do
    local event = pending_custom_fader_values[cc_number]
    if event ~= nil then
      local value = event.value
      local custom_slot = event.custom_slot or 1
      local fader_number = (cc_number - VOLUME_CC_FIRST) + 1
      local start_index = event.start_index or (((custom_slot - 1) * 8) + 1)
      local visible_track_index = start_index + fader_number - 1
      local track = visible_tracks[visible_track_index]

      if DAW.target_is_available(track) then
        -- Keep REAPER's control-surface path for proper mixer behavior, but do
        -- not force an expensive complete MCP/TCP window layout refresh for
        -- every individual MIDI value.
        apply_midi_cc_to_track_target(track, value)

        -- The hardware fader already displays the value it just transmitted.
        -- Remember the quantized value locally so the track-feedback poll does
        -- not immediately echo that same movement back to the Launchpad.
        if start_index == active_fader_start_index() then
          last_feedback_custom_slot = active_fader_identity()
          -- The physical fader is already showing the exact CC value it sent.
          -- Keep that exact value during the hardware-touch holdoff rather than
          -- immediately correcting it from a round-trip volume conversion.
          last_sent_custom_fader_values[fader_number] = value
        end

        applied = applied + 1
        last_description = string.format(
          "%s fader %d -> %s-visible track %d: %s, value %d",
          DAW.active_parameter_label(),
          fader_number,
          DAW.active_scope_label(),
          visible_track_index,
          mcp_track_description(track),
          value
        )
      elseif not first_missing_fader then
        first_missing_fader = visible_track_index
      end
    end
  end

  pending_custom_fader_values = {}

  if applied > 0 then
    mcp_ui_dirty = true
    last_action = last_description or ("Updated " .. DAW.active_scope_label() .. "-visible track " .. DAW.active_parameter_label())
  elseif first_missing_fader then
    last_action = DAW.active_scope_label() .. "-visible track " .. tostring(first_missing_fader) .. " or its target is unavailable"
  end
end

local function refresh_mcp_ui_if_needed(now)
  if not mcp_ui_dirty or now < next_mcp_ui_refresh_time then return end
  -- A throttled arrange repaint is enough. Avoid TrackList_AdjustWindows() here:
  -- forcing a complete track-panel layout refresh for every fader movement was
  -- the main source of unnecessary work in the first direct-MIDI experiment.
  if r.UpdateArrange then r.UpdateArrange() end
  mcp_ui_dirty = false
  next_mcp_ui_refresh_time = now + CFG.MCP_UI_REFRESH_INTERVAL
end

DAW.SCROLL_TRACK_CLICK = { direction = 0, time = -1000000 }

local function scroll_tracks(direction)
  direction = direction > 0 and 1 or -1
  local now = r.time_precise()
  local click = DAW.SCROLL_TRACK_CLICK
  local is_double_click = click.direction == direction
    and (now - click.time) <= (CFG.SCROLL_DOUBLE_CLICK_SECONDS or 0.32)
  local count = CFG.SCROLL_SINGLE_TRACKS or 1

  if is_double_click then
    -- The first click already moved one track. Add four more so the complete
    -- double-click gesture moves five tracks rather than six.
    local total = CFG.SCROLL_DOUBLE_TRACKS or 5
    count = math.max(0, total - count)
    click.direction = 0
    click.time = -1000000
    last_action = (direction > 0)
      and ("Double-click: scrolled down " .. tostring(total) .. " tracks")
      or  ("Double-click: scrolled up " .. tostring(total) .. " tracks")
  else
    click.direction = direction
    click.time = now
    last_action = (direction > 0)
      and ("Scrolled down " .. tostring(count) .. " track")
      or  ("Scrolled up " .. tostring(count) .. " track")
  end

  for _ = 1, count do
    r.CSurf_OnScroll(0, direction)
  end
end

