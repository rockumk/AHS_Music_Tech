-- HOME page buttons keep their original physical positions but use clearer
-- user-facing names. Page 2 and Page 3 become data-driven launcher pages below.
DAW.PAGE_LABELS = {
  [1] = "Page 1 Basics",
  [2] = "Page 2 Actions",
  [3] = "Page 3 Customs",
}

DAW.page_number_from_label = function(label)
  label = normalize_label(label)
  for page = 1, 3 do
    if label == DAW.PAGE_LABELS[page] or label == ("Page " .. tostring(page)) then
      return page
    end
  end
  return nil
end

DAW.apply_home_page_labels = function()
  for page = 1, 3 do
    for button_page = 1, 3 do
      local index = ACTIVE_PAGE_ARRAY_INDEX[button_page]
      local row = math.floor((index - 1) / 9) + 1
      local col = ((index - 1) % 9) + 1
      labels[page][row][col] = DAW.PAGE_LABELS[button_page]
    end
  end
end
DAW.apply_home_page_labels()

