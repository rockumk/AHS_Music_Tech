------------------------------------------------------------
-- PATCH 33: SLEEP / WAKE
------------------------------------------------------------
DAW.SLEEP = {
  active = false,
}

DAW.SLEEP.should_wake = function(buf)
  if not buf or #buf < 3 then return false end
  local status, _, value = buf:byte(1, 3)
  if not status or not value then return false end
  local message_type = status & 0xF0
  return value > 0 and (message_type == 0x90 or message_type == 0xB0)
end

DAW.SLEEP.enter = function()
  send_programmer_mode()
  send_clear_lighting(true)
  DAW.send_bytes({
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id,
    0x12, 0x01, 0x00, 0x01, 0xF7
  })
  DAW.SLEEP.active = true
  surface_mode = "SLEEP"
  initialized = true
  last_action = "Sleep: Launchpad LEDs off; press any button to wake"
  return true
end

DAW.SLEEP.wake = function()
  DAW.SLEEP.active = false
  return_to_home_page_1("Woke Launchpad: rebuilt HOME Page 1 Basics", false, 1, true)
  return true
end

DAW.SLEEP.consume_event = function(buf, dev_idx)
  if not DAW.SLEEP.active then return false end
  local device_index = (dev_idx or 0) & 0xFFFF
  if DAW.ordinary_input_matches(device_index) or DAW.input_matches(device_index) then
    if DAW.SLEEP.should_wake(buf) then DAW.SLEEP.wake() end
  end
  return true
end

------------------------------------------------------------
-- READABLE USER LIBRARIES FOR HOME PAGE 2 AND PAGE 3
------------------------------------------------------------
DAW.USER_DATA = {
  command_path = script_path .. "LaunchpadCommandLibrary.lua",
  custom_path = script_path .. "LaunchpadCustomLibrary.lua",
}

DAW.USER_DATA.quote = function(value)
  return string.format("%q", tostring(value or ""))
end

DAW.USER_DATA.write_file = function(path, content)
  local file, err = io.open(path, "w")
  if not file then
    last_action = "Could not save " .. tostring(path) .. ": " .. tostring(err)
    return false
  end
  file:write(content)
  file:close()
  return true
end

DAW.USER_DATA.load_table = function(path, default_value)
  local ok_load, value = pcall(dofile, path)
  if ok_load and type(value) == "table" then return value end
  return default_value
end

-- Import files are generated by Launchpad Xtra itself, but load them in an
-- empty environment anyway. This keeps a chosen exchange file from executing
-- arbitrary REAPER or operating-system code merely because it returns a table.
DAW.USER_DATA.load_exchange_table = function(path)
  local file, open_err = io.open(tostring(path or ""), "rb")
  if not file then return nil, tostring(open_err or "Could not open file") end
  local text = file:read("*a") or ""
  file:close()
  local chunk, load_err = load(text, "@" .. tostring(path or "LaunchpadXtraLibrary.lua"), "t", {})
  if not chunk then return nil, tostring(load_err or "Could not parse library file") end
  local ok, value = pcall(chunk)
  if not ok then return nil, tostring(value or "Could not read library file") end
  if type(value) ~= "table" or type(value.entries) ~= "table" then
    return nil, "The selected file is not a Launchpad Xtra library export"
  end
  return value
end

DAW.USER_DATA.append_extension = function(path, extension)
  path = tostring(path or "")
  extension = tostring(extension or "")
  if extension ~= "" and path ~= "" and not path:lower():match("%.[%w_%-]+$") then
    path = path .. extension
  end
  return path
end

DAW.USER_DATA.prompt_import_mode = function(library_name)
  local result = r.ShowMessageBox(
    "How should the imported " .. tostring(library_name or "library") .. " rows be added?\n\n"
      .. "YES — Replace the current rows\n"
      .. "NO — Append after the current rows\n"
      .. "CANCEL — Leave the current library unchanged",
    "Launchpad Xtra " .. tostring(library_name or "Library") .. " Import",
    3
  )
  if result == 6 then return "replace" end
  if result == 7 then return "append" end
  return nil
end

DAW.USER_DATA.serialize_command_data = function(data)
  local lines = {
    "-- User-editable Command Library for Launchpad Xtra HOME Page 2",
    "-- Each entry occupies one numbered Launchpad action slot.",
    "return {",
    "  entries = {",
  }
  for index, entry in ipairs(data.entries or {}) do
    lines[#lines + 1] = string.format(
      "    [%d] = {name=%s, label=%s, command=%s, color=%d, source_action_name=%s, source_named_command=%s, import_unresolved=%s},",
      index,
      DAW.USER_DATA.quote(entry.name),
      DAW.USER_DATA.quote(entry.label),
      DAW.USER_DATA.quote(entry.command),
      math.max(0, math.min(127, tonumber(entry.color) or 0x01)),
      DAW.USER_DATA.quote(entry.source_action_name),
      DAW.USER_DATA.quote(entry.source_named_command),
      tostring(entry.import_unresolved and true or false)
    )
  end
  lines[#lines + 1] = "  },"
  lines[#lines + 1] = "}"
  return table.concat(lines, "\n") .. "\n"
end

DAW.USER_DATA.serialize_custom_data = function(data)
  local settings = type(data.settings) == "table" and data.settings or {}
  local lines = {
    "-- User-editable SysEx & Customs Library for Launchpad Xtra HOME Page 3",
    "-- Each entry uses either ordinary SysEx or Custom-slot uploads, then may switch layout.",
    "return {",
    "  settings = {",
    "    scroll_text=" .. DAW.USER_DATA.quote(settings.scroll_text or "") .. ",",
    "    scroll_loop=" .. tostring(settings.scroll_loop and true or false) .. ",",
    "    scroll_interval=" .. tostring(math.max(0.25, tonumber(settings.scroll_interval) or 5.0)) .. ",",
    "    scroll_palette=" .. tostring(math.max(0, math.min(127, tonumber(settings.scroll_palette) or 0x25))) .. ",",
    "    resident_source_entry_by_slot={",
    "      [1]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[1]) or 0))) .. ",",
    "      [2]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[2]) or 0))) .. ",",
    "      [3]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[3]) or 0))) .. ",",
    "      [4]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[4]) or 0))) .. ",",
    "      [5]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[5]) or 0))) .. ",",
    "      [6]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[6]) or 0))) .. ",",
    "      [7]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[7]) or 0))) .. ",",
    "      [8]=" .. tostring(math.max(0, math.floor(tonumber(settings.resident_source_entry_by_slot and settings.resident_source_entry_by_slot[8]) or 0))) .. ",",
    "    },",
    "    resident_source_payload_by_slot={",
    "      [1]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[1]) or 0)))) .. ",",
    "      [2]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[2]) or 0)))) .. ",",
    "      [3]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[3]) or 0)))) .. ",",
    "      [4]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[4]) or 0)))) .. ",",
    "      [5]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[5]) or 0)))) .. ",",
    "      [6]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[6]) or 0)))) .. ",",
    "      [7]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[7]) or 0)))) .. ",",
    "      [8]=" .. tostring(math.max(0, math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot and settings.resident_source_payload_by_slot[8]) or 0)))) .. ",",
    "    },",
    "  },",
    "  entries = {",
  }
  for index, entry in ipairs(data.entries or {}) do
    lines[#lines + 1] = string.format("    [%d] = {", index)
    lines[#lines + 1] = "      name=" .. DAW.USER_DATA.quote(entry.name) .. ","
    lines[#lines + 1] = "      label=" .. DAW.USER_DATA.quote(entry.label) .. ","
    lines[#lines + 1] = "      non_custom=" .. DAW.USER_DATA.quote(entry.non_custom) .. ","
    lines[#lines + 1] = "      non_custom_labels=" .. DAW.USER_DATA.quote(entry.non_custom_labels) .. ","
    lines[#lines + 1] = "      payload_mode=" .. DAW.USER_DATA.quote(entry.payload_mode == "non_custom" and "non_custom" or "custom") .. ","
    lines[#lines + 1] = "      color=" .. tostring(math.max(0, math.min(127, tonumber(entry.color) or 0x01))) .. ","
    lines[#lines + 1] = "      switch_to_slot=" .. tostring(math.max(0, math.min(8, tonumber(entry.switch_to_slot) or 0))) .. ","
    lines[#lines + 1] = "      customs={"
    for slot = 1, 8 do
      lines[#lines + 1] = "        [" .. tostring(slot) .. "]=" .. DAW.USER_DATA.quote(entry.customs and entry.customs[slot] or "") .. ","
    end
    lines[#lines + 1] = "      },"
    lines[#lines + 1] = "      custom_labels={"
    for slot = 1, 8 do
      lines[#lines + 1] = "        [" .. tostring(slot) .. "]=" .. DAW.USER_DATA.quote(entry.custom_labels and entry.custom_labels[slot] or "") .. ","
    end
    lines[#lines + 1] = "      },"
    lines[#lines + 1] = "    },"
  end
  lines[#lines + 1] = "  },"
  lines[#lines + 1] = "}"
  return table.concat(lines, "\n") .. "\n"
end

DAW.COMMAND_LIBRARY = {
  visible = false,
  data = DAW.USER_DATA.load_table(DAW.USER_DATA.command_path, {entries={}}),
  editor_index = 1,
  search_text = "",
  search_results = {},
  page_start = 1,
  palette_picker_visible = false,
  pending_palette_color = 0x25,
  drag_index = nil,
  drag_target = nil,
  hovered_swap_index = nil,
  last_valid_drop_index = nil,

  -- When Page 2 opens an unconfigured action slot, scroll the table to that
  -- row and keep it visually highlighted.
  scroll_to_editor_index = nil,

  -- Runtime measurements displayed in the Settings status area.
  window_width = CFG.COMMAND_LIBRARY_DEFAULT_WIDTH,
  window_height = CFG.COMMAND_LIBRARY_DEFAULT_HEIGHT,
  table_column_widths = {},

  -- Runtime-only starting point for whole-library Import / Export dialogs.
  last_library_file_path = "",
}

DAW.CUSTOM_LIBRARY = {
  visible = false,
  data = DAW.USER_DATA.load_table(DAW.USER_DATA.custom_path, {settings={}, entries={}}),
  editor_index = 1,
  page_start = 1,
  scroll_to_editor_index = nil,

  scroll_text = "",
  scroll_loop = false,
  scroll_interval = 5.0,
  scroll_next_time = nil,
  scroll_palette = 0x25,

  palette_picker_visible = false,
  palette_picker_target = "entry",
  pending_palette_color = 0x25,

  -- Runtime-only starting points for the native Load/Save file choosers.
  last_sysex_file_path = "",
  last_button_labels_file_path = "",
  last_library_file_path = "",

  -- Cached parsed label grids and Custom-payload colors for the resident-Custom
  -- helper GRID. The serialized settings below remember which library record
  -- last populated each of the Launchpad's resident Custom slots.
  payload_visual_cache = {},

  drag_index = nil,
  drag_target = nil,
  hovered_swap_index = nil,
  last_valid_drop_index = nil,

  -- Field expansion is deliberately runtime-only. Reloading the script resets
  -- every SysEx field to a compact single-line height.
  field_heights = {},
  field_resize_start = {},
  field_resize_active_key = nil,
  field_resize_start_mouse_y = 0,
  field_resize_start_height = 0,

  pending_readback = nil,
  external_layout_ack_until = 0,
  external_layout = nil,
  next_external_layout_poll_time = nil,

  -- Delayed HOME lighting is used after the controller has first been asked
  -- to re-enter Programmer Mode. Store the intended page explicitly so a later
  -- user navigation can cancel the stale repaint instead of being overwritten.
  pending_home_resend_time = nil,
  pending_home_resend_count = 0,
  pending_home_resend_page = nil,
  pending_home_resend_reason = nil,
  pending_home_resend_stage = nil,
  pending_home_resend_row = nil,

  -- Custom uploads can momentarily blank the currently active Programmer-mode
  -- surface even when the user deliberately chose Switch To = 0.  Wait for the
  -- Launchpad to finish storing all resident payloads, then explicitly restore
  -- Programmer Mode and run the proven staged HOME repaint.
  pending_post_upload_home_time = nil,
  pending_post_upload_home_page = nil,
  pending_post_upload_home_reason = nil,

  -- Keep the editor contents visible after an entry is sent, but drop its
  -- selected-row highlight and HOME-button flashing while resident Custom Mode
  -- owns the hardware.
  selection_active = true,

  -- Drag state for the eight Custom 1..8 payload rows inside the selected entry.
  destination_drag_index = nil,
  destination_drag_target = nil,
  destination_hovered_index = nil,
  destination_last_valid_drop_index = nil,
}

DAW.CUSTOM_LIBRARY.apply_loaded_settings = function()
  local settings = type(DAW.CUSTOM_LIBRARY.data.settings) == "table"
    and DAW.CUSTOM_LIBRARY.data.settings
    or {}
  DAW.CUSTOM_LIBRARY.data.settings = settings
  DAW.CUSTOM_LIBRARY.scroll_text = tostring(settings.scroll_text or "")
  DAW.CUSTOM_LIBRARY.scroll_loop = settings.scroll_loop and true or false
  DAW.CUSTOM_LIBRARY.scroll_interval = math.max(0.25, tonumber(settings.scroll_interval) or 5.0)
  DAW.CUSTOM_LIBRARY.scroll_palette = math.max(0, math.min(127, tonumber(settings.scroll_palette) or 0x25))
  settings.resident_source_entry_by_slot = type(settings.resident_source_entry_by_slot) == "table"
    and settings.resident_source_entry_by_slot or {}
  settings.resident_source_payload_by_slot = type(settings.resident_source_payload_by_slot) == "table"
    and settings.resident_source_payload_by_slot or {}
  for slot = 1, 8 do
    settings.resident_source_entry_by_slot[slot] = math.max(
      0,
      math.floor(tonumber(settings.resident_source_entry_by_slot[slot]) or 0)
    )
    settings.resident_source_payload_by_slot[slot] = math.max(
      0,
      math.min(8, math.floor(tonumber(settings.resident_source_payload_by_slot[slot]) or 0))
    )
  end
end

DAW.CUSTOM_LIBRARY.sync_persistent_settings = function()
  local settings = type(DAW.CUSTOM_LIBRARY.data.settings) == "table"
    and DAW.CUSTOM_LIBRARY.data.settings
    or {}
  DAW.CUSTOM_LIBRARY.data.settings = settings
  settings.scroll_text = tostring(DAW.CUSTOM_LIBRARY.scroll_text or "")
  settings.scroll_loop = DAW.CUSTOM_LIBRARY.scroll_loop and true or false
  settings.scroll_interval = math.max(0.25, tonumber(DAW.CUSTOM_LIBRARY.scroll_interval) or 5.0)
  settings.scroll_palette = math.max(0, math.min(127, tonumber(DAW.CUSTOM_LIBRARY.scroll_palette) or 0x25))
  settings.resident_source_entry_by_slot = type(settings.resident_source_entry_by_slot) == "table"
    and settings.resident_source_entry_by_slot or {}
  settings.resident_source_payload_by_slot = type(settings.resident_source_payload_by_slot) == "table"
    and settings.resident_source_payload_by_slot or {}
end

DAW.CUSTOM_LIBRARY.apply_loaded_settings()

DAW.USER_DATA.ensure_command_entry = function(index)
  index = math.max(1, math.floor(tonumber(index) or 1))
  local entries = DAW.COMMAND_LIBRARY.data.entries
  while #entries < index do
    entries[#entries + 1] = {
      name="", label="", command="", color=0x01,
      source_action_name="", source_named_command="", import_unresolved=false
    }
  end
  entries[index].name = tostring(entries[index].name or "")
  entries[index].label = tostring(entries[index].label or "")
  entries[index].command = tostring(entries[index].command or "")
  entries[index].source_action_name = tostring(entries[index].source_action_name or "")
  entries[index].source_named_command = tostring(entries[index].source_named_command or "")
  entries[index].import_unresolved = entries[index].import_unresolved and true or false
  entries[index].color = math.max(0, math.min(127, tonumber(entries[index].color) or 0x01))
  return entries[index]
end

DAW.USER_DATA.ensure_custom_entry = function(index)
  index = math.max(1, math.floor(tonumber(index) or 1))
  local entries = DAW.CUSTOM_LIBRARY.data.entries
  while #entries < index do
    entries[#entries + 1] = {
      name="", label="", non_custom="", non_custom_labels="",
      customs={}, custom_labels={}, payload_mode="custom",
      color=0x01, switch_to_slot=0
    }
  end
  local entry = entries[index]
  entry.name = tostring(entry.name or "")
  entry.label = tostring(entry.label or "")
  entry.non_custom = tostring(entry.non_custom or "")
  entry.non_custom_labels = tostring(entry.non_custom_labels or "")
  entry.customs = type(entry.customs) == "table" and entry.customs or {}
  entry.custom_labels = type(entry.custom_labels) == "table" and entry.custom_labels or {}
  local has_custom_payload = false
  for slot = 1, 8 do
    entry.customs[slot] = tostring(entry.customs[slot] or "")
    entry.custom_labels[slot] = tostring(entry.custom_labels[slot] or "")
    if trim(entry.customs[slot]) ~= "" then has_custom_payload = true end
  end
  -- Migration for libraries saved before payload_mode existed: preserve an
  -- old Non-Custom-only row as Non-Custom. New and ambiguous rows default to
  -- Custom, matching the editor's primary workflow.
  if entry.payload_mode ~= "custom" and entry.payload_mode ~= "non_custom" then
    entry.payload_mode = (trim(entry.non_custom) ~= "" and not has_custom_payload)
      and "non_custom"
      or "custom"
  end
  entry.color = math.max(0, math.min(127, tonumber(entry.color) or 0x01))
  entry.switch_to_slot = math.max(0, math.min(8, tonumber(entry.switch_to_slot) or 0))
  return entry
end

DAW.COMMAND_LIBRARY.select_editor_index = function(index, request_scroll)
  index = math.max(1, math.floor(tonumber(index) or 1))
  DAW.USER_DATA.ensure_command_entry(index)
  DAW.COMMAND_LIBRARY.editor_index = index
  if request_scroll then
    DAW.COMMAND_LIBRARY.scroll_to_editor_index = index
  end
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return index
end

DAW.COMMAND_LIBRARY.open_for_index = function(index, request_scroll)
  DAW.COMMAND_LIBRARY.select_editor_index(index or DAW.COMMAND_LIBRARY.editor_index, request_scroll)
  DAW.COMMAND_LIBRARY.visible = true
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return true
end

DAW.COMMAND_LIBRARY.save = function()
  return DAW.USER_DATA.write_file(
    DAW.USER_DATA.command_path,
    DAW.USER_DATA.serialize_command_data(DAW.COMMAND_LIBRARY.data)
  )
end

DAW.CUSTOM_LIBRARY.save = function()
  DAW.CUSTOM_LIBRARY.sync_persistent_settings()
  -- Normalize every materialized row before serialization. This preserves the
  -- intended migration of older Non-Custom-only rows even when a Settings edit
  -- triggers a save before that row has been opened in the editor.
  for index = 1, #(DAW.CUSTOM_LIBRARY.data.entries or {}) do
    DAW.USER_DATA.ensure_custom_entry(index)
  end
  return DAW.USER_DATA.write_file(
    DAW.USER_DATA.custom_path,
    DAW.USER_DATA.serialize_custom_data(DAW.CUSTOM_LIBRARY.data)
  )
end

-- Materialized rows are not necessarily usable patches. Selecting a distant
-- index may create intermediate rows for storage, but a Page 2 slot remains
-- dormant until it contains a command. Preserve any stored color for later
-- editing while presenting the dormant HOME slot as neutral gray.
DAW.COMMAND_LIBRARY.entry_is_defined = function(entry)
  return entry and trim(entry.command or "") ~= "" or false
end

DAW.COMMAND_LIBRARY.display_color = function(entry)
  if not DAW.COMMAND_LIBRARY.entry_is_defined(entry) then return 0x01 end
  return math.max(0, math.min(127, tonumber(entry.color) or 0x01))
end

DAW.COMMAND_LIBRARY.resolve_command = function(raw)
  raw = trim(tostring(raw or ""))
  if raw == "" then return nil end
  local numeric = tonumber(raw)
  if numeric and numeric > 0 then return math.floor(numeric) end
  if r.NamedCommandLookup then
    local result = tonumber(r.NamedCommandLookup(raw)) or 0
    if result > 0 then return result end
  end
  return nil
end

DAW.COMMAND_LIBRARY.run_entry = function(index)
  local entry = DAW.COMMAND_LIBRARY.data.entries[index]
  local command_id = entry and DAW.COMMAND_LIBRARY.resolve_command(entry.command)
  if not command_id then
    DAW.COMMAND_LIBRARY.open_for_index(index, true)
    last_action = "Action slot " .. tostring(index) .. " needs a command"
    return false
  end
  r.Main_OnCommand(command_id, 0)
  last_action = "Ran action slot " .. tostring(index) .. ": " .. tostring(entry.name ~= "" and entry.name or entry.label)
  return true
end

DAW.COMMAND_LIBRARY.refresh_search = function()
  local wanted = trim(DAW.COMMAND_LIBRARY.search_text):lower()
  local results = {}
  if wanted ~= "" and r.SectionFromUniqueID and r.kbd_enumerateActions then
    local section = r.SectionFromUniqueID(0)
    local index = 0
    while index < 100000 and #results < 250 do
      local command_id, name = r.kbd_enumerateActions(section, index)
      if not command_id or command_id == 0 then break end
      name = tostring(name or "")
      if name:lower():find(wanted, 1, true) then
        local named = r.ReverseNamedCommandLookup and tostring(r.ReverseNamedCommandLookup(command_id) or "") or ""
        if named ~= "" and named:sub(1,1) ~= "_" then named = "_" .. named end
        results[#results + 1] = {id=command_id, name=name, named=named, command=named ~= "" and named or tostring(command_id)}
      end
      index = index + 1
    end
  end
  DAW.COMMAND_LIBRARY.search_results = results
end


DAW.COMMAND_LIBRARY.normalized_named_command = function(named)
  named = trim(tostring(named or ""))
  if named ~= "" and named:sub(1,1) ~= "_" then named = "_" .. named end
  return named
end

DAW.COMMAND_LIBRARY.enumerate_action_index = function()
  local result = {by_id={}, by_exact_name={}, by_lower_name={}}
  if not (r.SectionFromUniqueID and r.kbd_enumerateActions) then return result end
  local section = r.SectionFromUniqueID(0)
  local index = 0
  while index < 100000 do
    local command_id, name = r.kbd_enumerateActions(section,index)
    if not command_id or command_id == 0 then break end
    name = tostring(name or "")
    local record = {id=math.floor(tonumber(command_id) or 0), name=name}
    result.by_id[record.id] = record
    result.by_exact_name[name] = result.by_exact_name[name] or {}
    result.by_exact_name[name][#result.by_exact_name[name]+1] = record
    local lower = name:lower()
    result.by_lower_name[lower] = result.by_lower_name[lower] or {}
    result.by_lower_name[lower][#result.by_lower_name[lower]+1] = record
    index = index + 1
  end
  return result
end

DAW.COMMAND_LIBRARY.capture_entry_identity = function(entry,action_index)
  if not entry then return end
  local command_id = DAW.COMMAND_LIBRARY.resolve_command(entry.command)
  if not command_id then return end
  local named = r.ReverseNamedCommandLookup
    and DAW.COMMAND_LIBRARY.normalized_named_command(r.ReverseNamedCommandLookup(command_id))
    or ""
  if named ~= "" then entry.source_named_command = named end
  action_index = action_index or DAW.COMMAND_LIBRARY.enumerate_action_index()
  local record = action_index.by_id and action_index.by_id[command_id]
  if record and trim(record.name) ~= "" then entry.source_action_name = record.name end
  entry.import_unresolved = false
end

DAW.COMMAND_LIBRARY.capture_all_entry_identities = function()
  local action_index = DAW.COMMAND_LIBRARY.enumerate_action_index()
  for index = 1,#(DAW.COMMAND_LIBRARY.data.entries or {}) do
    local entry = DAW.USER_DATA.ensure_command_entry(index)
    if trim(entry.command) ~= "" then
      DAW.COMMAND_LIBRARY.capture_entry_identity(entry,action_index)
    end
  end
end

DAW.COMMAND_LIBRARY.copy_import_entry = function(raw,action_index)
  raw = type(raw) == "table" and raw or {}
  local entry = {
    name=tostring(raw.name or ""),
    label=tostring(raw.label or ""),
    command=tostring(raw.command or ""),
    color=math.max(0,math.min(127,tonumber(raw.color) or 0x01)),
    source_action_name=tostring(raw.source_action_name or ""),
    source_named_command=DAW.COMMAND_LIBRARY.normalized_named_command(raw.source_named_command),
    import_unresolved=false,
  }

  local named = entry.source_named_command
  if named == "" and entry.command:sub(1,1) == "_" then named = entry.command end
  if named ~= "" and r.NamedCommandLookup then
    local resolved = tonumber(r.NamedCommandLookup(named)) or 0
    if resolved > 0 then
      entry.command=tostring(math.floor(resolved))
      entry.source_named_command=named
      DAW.COMMAND_LIBRARY.capture_entry_identity(entry,action_index)
      return entry,"direct"
    end
  end

  local numeric = tonumber(entry.command)
  local source_name = trim(entry.source_action_name)
  if numeric and numeric > 0 and named == "" then
    local numeric_id=math.floor(numeric)
    local current_record=action_index.by_id and action_index.by_id[numeric_id]
    local likely_native=numeric_id < 65536
    if likely_native or source_name == "" or (current_record and current_record.name == source_name) then
      entry.command=tostring(numeric_id)
      DAW.COMMAND_LIBRARY.capture_entry_identity(entry,action_index)
      return entry,"direct"
    end
  end

  if source_name ~= "" then
    local matches = action_index.by_exact_name[source_name]
      or action_index.by_lower_name[source_name:lower()]
      or {}
    if #matches == 1 then
      entry.command=tostring(matches[1].id)
      DAW.COMMAND_LIBRARY.capture_entry_identity(entry,action_index)
      return entry,"name"
    end
  end

  entry.command=""
  entry.import_unresolved=true
  return entry,"unresolved"
end

DAW.COMMAND_LIBRARY.export_library = function()
  DAW.COMMAND_LIBRARY.capture_all_entry_identities()
  local path = DAW.USER_DATA.choose_library_file(
    DAW.COMMAND_LIBRARY,0,"Export Launchpad Xtra Command Library","LaunchpadXtra_Command_Library.lua"
  )
  if not path then return false end
  local ok = DAW.USER_DATA.write_file(path,DAW.USER_DATA.serialize_command_data(DAW.COMMAND_LIBRARY.data))
  if ok then last_action="Exported Command Library: " .. tostring(path) end
  return ok
end

DAW.COMMAND_LIBRARY.import_library = function()
  local path = DAW.USER_DATA.choose_library_file(
    DAW.COMMAND_LIBRARY,1,"Import Launchpad Xtra Command Library","LaunchpadXtra_Command_Library.lua"
  )
  if not path then return false end
  local imported,err = DAW.USER_DATA.load_exchange_table(path)
  if not imported then
    r.ShowMessageBox("Could not import Command Library:\n\n"..tostring(err),"Launchpad Xtra Command Import",0)
    return false
  end
  local mode = DAW.USER_DATA.prompt_import_mode("Command Library")
  if not mode then return false end
  local target = mode == "replace" and {} or DAW.COMMAND_LIBRARY.data.entries
  local action_index = DAW.COMMAND_LIBRARY.enumerate_action_index()
  local counts={direct=0,name=0,unresolved=0}
  local unresolved={}
  for _,raw in ipairs(imported.entries or {}) do
    local entry,status = DAW.COMMAND_LIBRARY.copy_import_entry(raw,action_index)
    target[#target+1]=entry
    counts[status]=counts[status]+1
    if status == "unresolved" then
      unresolved[#unresolved+1]=trim(entry.source_action_name) ~= "" and entry.source_action_name
        or trim(raw.name or "") ~= "" and tostring(raw.name)
        or "Unnamed command row"
    end
  end
  DAW.COMMAND_LIBRARY.data.entries=target
  DAW.COMMAND_LIBRARY.editor_index=math.max(1,math.min(#target,DAW.COMMAND_LIBRARY.editor_index or 1))
  DAW.COMMAND_LIBRARY.save()
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  local lines={
    "Command Library import complete.","",
    "Matched directly: "..tostring(counts.direct),
    "Matched by original action name: "..tostring(counts.name),
    "Unresolved: "..tostring(counts.unresolved),
  }
  if #unresolved>0 then
    lines[#lines+1]=""
    lines[#lines+1]="Could not match:"
    for _,name in ipairs(unresolved) do lines[#lines+1]="- "..tostring(name) end
  end
  r.ShowMessageBox(table.concat(lines,"\n"),"Launchpad Xtra Command Import",0)
  last_action="Imported Command Library: " .. tostring(path)
  return true
end

DAW.CUSTOM_LIBRARY.select_editor_index = function(index, request_scroll)
  index = math.max(1, math.floor(tonumber(index) or 1))
  DAW.USER_DATA.ensure_custom_entry(index)
  DAW.CUSTOM_LIBRARY.editor_index = index
  DAW.CUSTOM_LIBRARY.selection_active = true
  if request_scroll then DAW.CUSTOM_LIBRARY.scroll_to_editor_index = index end
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return index
end

DAW.CUSTOM_LIBRARY.clear_selection = function()
  DAW.CUSTOM_LIBRARY.selection_active = false
  DAW.CUSTOM_LIBRARY.drag_index = nil
  DAW.CUSTOM_LIBRARY.drag_target = nil
  DAW.CUSTOM_LIBRARY.hovered_swap_index = nil
  DAW.CUSTOM_LIBRARY.last_valid_drop_index = nil
  DAW.CUSTOM_LIBRARY.destination_drag_index = nil
  DAW.CUSTOM_LIBRARY.destination_drag_target = nil
  DAW.CUSTOM_LIBRARY.destination_hovered_index = nil
  DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index = nil
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return true
end

DAW.CUSTOM_LIBRARY.open_for_index = function(index, request_scroll)
  DAW.CUSTOM_LIBRARY.select_editor_index(index or DAW.CUSTOM_LIBRARY.editor_index, request_scroll)
  DAW.CUSTOM_LIBRARY.visible = true
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return true
end

DAW.CUSTOM_LIBRARY.send_hex = function(hex)
  local bytes = hex_text_to_bytes(hex)
  if #bytes <= 0 then return false end
  return send_bytes(bytes)
end

DAW.CUSTOM_LIBRARY.entry_uses_custom = function(entry)
  return not entry or entry.payload_mode ~= "non_custom"
end

DAW.CUSTOM_LIBRARY.entry_has_data = function(entry)
  if not entry then return false end
  if not DAW.CUSTOM_LIBRARY.entry_uses_custom(entry) then
    return trim(entry.non_custom or "") ~= ""
  end
  for slot = 1, 8 do
    if trim(entry.customs and entry.customs[slot] or "") ~= "" then return true end
  end
  return false
end

DAW.CUSTOM_LIBRARY.display_color = function(entry)
  if not DAW.CUSTOM_LIBRARY.entry_has_data(entry) then return 0x01 end
  return math.max(0, math.min(127, tonumber(entry.color) or 0x01))
end

DAW.CUSTOM_LIBRARY.remember_resident_source = function(resident_slot, entry_index, payload_slot)
  resident_slot = math.max(1, math.min(8, math.floor(tonumber(resident_slot) or 1)))
  entry_index = math.max(0, math.floor(tonumber(entry_index) or 0))
  payload_slot = math.max(0, math.min(8, math.floor(tonumber(payload_slot) or 0)))
  local settings = DAW.CUSTOM_LIBRARY.data.settings
  settings.resident_source_entry_by_slot = type(settings.resident_source_entry_by_slot) == "table"
    and settings.resident_source_entry_by_slot or {}
  settings.resident_source_payload_by_slot = type(settings.resident_source_payload_by_slot) == "table"
    and settings.resident_source_payload_by_slot or {}
  settings.resident_source_entry_by_slot[resident_slot] = entry_index
  settings.resident_source_payload_by_slot[resident_slot] = payload_slot
end

DAW.CUSTOM_LIBRARY.resident_source = function(resident_slot)
  resident_slot = math.max(1, math.min(8, math.floor(tonumber(resident_slot) or 1)))
  local settings = DAW.CUSTOM_LIBRARY.data.settings or {}
  local entry_index = math.floor(tonumber(settings.resident_source_entry_by_slot
    and settings.resident_source_entry_by_slot[resident_slot]) or 0)
  local payload_slot = math.floor(tonumber(settings.resident_source_payload_by_slot
    and settings.resident_source_payload_by_slot[resident_slot]) or 0)
  if entry_index >= 1 and payload_slot >= 1 and payload_slot <= 8 then
    local entry = DAW.CUSTOM_LIBRARY.data.entries[entry_index]
    if entry then
      entry = DAW.USER_DATA.ensure_custom_entry(entry_index)
      return entry, payload_slot, entry_index
    end
  end

  -- Older libraries predate persistent resident-source tracking. When exactly
  -- one saved Custom entry explicitly switches to this resident slot and also
  -- carries labels for that slot, use it as a safe unambiguous fallback.
  local candidate_entry,candidate_index = nil,nil
  for index, entry in ipairs(DAW.CUSTOM_LIBRARY.data.entries or {}) do
    entry = DAW.USER_DATA.ensure_custom_entry(index)
    if DAW.CUSTOM_LIBRARY.entry_uses_custom(entry)
        and tonumber(entry.switch_to_slot) == resident_slot
        and trim(entry.custom_labels[resident_slot] or "") ~= "" then
      if candidate_entry then return nil end
      candidate_entry,candidate_index = entry,index
    end
  end
  if candidate_entry then return candidate_entry,resident_slot,candidate_index end
  return nil
end

DAW.CUSTOM_LIBRARY.remap_resident_source_entries_after_swap = function(a,b)
  a,b = tonumber(a),tonumber(b)
  if not a or not b or a == b then return end
  local settings = DAW.CUSTOM_LIBRARY.data.settings or {}
  local sources = settings.resident_source_entry_by_slot or {}
  for slot = 1, 8 do
    if tonumber(sources[slot]) == a then sources[slot] = b
    elseif tonumber(sources[slot]) == b then sources[slot] = a end
  end
end

DAW.CUSTOM_LIBRARY.remap_resident_source_entries_after_delete = function(index)
  index = tonumber(index)
  if not index then return end
  local settings = DAW.CUSTOM_LIBRARY.data.settings or {}
  local sources = settings.resident_source_entry_by_slot or {}
  local payloads = settings.resident_source_payload_by_slot or {}
  for slot = 1, 8 do
    local source = tonumber(sources[slot]) or 0
    if source == index then
      sources[slot],payloads[slot] = 0,0
    elseif source > index then
      sources[slot] = source - 1
    end
  end
end

DAW.CUSTOM_LIBRARY.remap_resident_source_payloads_after_swap = function(entry_index,a,b)
  entry_index,a,b = tonumber(entry_index),tonumber(a),tonumber(b)
  if not entry_index or not a or not b or a == b then return end
  local settings = DAW.CUSTOM_LIBRARY.data.settings or {}
  local sources = settings.resident_source_entry_by_slot or {}
  local payloads = settings.resident_source_payload_by_slot or {}
  for resident_slot = 1, 8 do
    if tonumber(sources[resident_slot]) == entry_index then
      if tonumber(payloads[resident_slot]) == a then payloads[resident_slot] = b
      elseif tonumber(payloads[resident_slot]) == b then payloads[resident_slot] = a end
    end
  end
end

DAW.CUSTOM_LIBRARY.mark_external_custom_mode = function(slot, reason)
  slot = math.max(1, math.min(8, math.floor(tonumber(slot) or 1)))
  local now = r.time_precise()
  local layout = 0x03 + slot
  local previous_layout = DAW.CUSTOM_LIBRARY.external_layout
  local next_poll = tonumber(DAW.CUSTOM_LIBRARY.next_external_layout_poll_time)
  if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end
  active_custom_slot = nil
  pending_custom_slot = nil
  pending_custom_switch_time = 0
  reset_custom_fader_feedback_state()
  if DAW.CUSTOM_LIBRARY.clear_selection then DAW.CUSTOM_LIBRARY.clear_selection() end
  surface_mode = "CUSTOM_EXTERNAL"
  initialized = true
  DAW.CUSTOM_LIBRARY.external_layout = layout
  DAW.CUSTOM_LIBRARY.external_layout_ack_until = now + 1.0
  -- The manual guarantees a command-00 readback response, while a spontaneous
  -- report from a physical layout-button press can vary by port or firmware.
  -- Begin a harmless periodic query so Notes always hands control back promptly.
  -- Preserve an already-scheduled poll when this is merely the answer to our
  -- last query, so acknowledgments cannot collapse the interval to 50 ms.
  if previous_layout ~= layout or not next_poll or next_poll <= now then
    DAW.CUSTOM_LIBRARY.next_external_layout_poll_time = now + 0.05
  end
  last_action = reason or ("Entered passive external Custom Mode " .. tostring(slot))
  return true
end

DAW.CUSTOM_LIBRARY.switch_to_slot = function(slot)
  if DAW.CUSTOM_LIBRARY.cancel_pending_post_upload_home_recovery then
    DAW.CUSTOM_LIBRARY.cancel_pending_post_upload_home_recovery()
  end
  slot = math.max(1, math.min(8, math.floor(tonumber(slot) or 1)))
  local sent = send_bytes({
    0xF0,0x00,0x20,0x29,0x02,selected_device.id,
    0x00,0x03 + slot,0xF7
  })
  if sent then
    DAW.CUSTOM_LIBRARY.mark_external_custom_mode(slot)
  end
  return sent
end

DAW.CUSTOM_LIBRARY.send_custom_slot = function(entry, destination, entry_index, defer_source_save)
  destination = math.max(1, math.min(8, math.floor(tonumber(destination) or 1)))
  local dump = trim(entry and entry.customs and entry.customs[destination] or "")
  if dump == "" then
    last_action = "Custom " .. tostring(destination) .. " has no SysEx payload"
    return false
  end
  local bytes, err = build_custom_mode_upload_message(dump, destination)
  if not bytes then
    last_action = "Custom upload error: " .. tostring(err)
    return false
  end
  local sent = send_bytes(bytes)
  if not sent then return false end
  if tonumber(entry_index) and tonumber(entry_index) >= 1 then
    DAW.CUSTOM_LIBRARY.remember_resident_source(destination,entry_index,destination)
    if not defer_source_save then DAW.CUSTOM_LIBRARY.save() end
  end
  if not defer_source_save and DAW.CUSTOM_LIBRARY.schedule_home_recovery_after_custom_upload then
    DAW.CUSTOM_LIBRARY.schedule_home_recovery_after_custom_upload(
      current_page,
      "SysEx & Customs Library: restored HOME Page " .. tostring(current_page)
        .. " after uploading Custom " .. tostring(destination),
      CFG.CUSTOM_UPLOAD_HOME_RECOVERY_DELAY_SECONDS or 1.00
    )
  else
    last_action = "Uploaded library Custom " .. tostring(destination)
  end
  return true
end

DAW.CUSTOM_LIBRARY.execute_entry = function(index)
  local entry = DAW.CUSTOM_LIBRARY.data.entries[index]
  if not DAW.CUSTOM_LIBRARY.entry_has_data(entry) then
    DAW.CUSTOM_LIBRARY.open_for_index(index, true)
    last_action = "Custom slot " .. tostring(index) .. " needs a SysEx setup"
    return false
  end

  DAW.CUSTOM_LIBRARY.clear_selection()
  if not DAW.CUSTOM_LIBRARY.entry_uses_custom(entry) then
    DAW.CUSTOM_LIBRARY.send_hex(entry.non_custom)
    last_action = "Sent Non-Custom SysEx library entry " .. tostring(index)
    return true
  end

  for slot = 1, 8 do
    local dump = trim(entry.customs and entry.customs[slot] or "")
    if dump ~= "" then DAW.CUSTOM_LIBRARY.send_custom_slot(entry, slot, index, true) end
  end
  DAW.CUSTOM_LIBRARY.save()

  local switch_slot = tonumber(entry.switch_to_slot) or 0
  if switch_slot >= 1 and switch_slot <= 8 then
    DAW.CUSTOM_LIBRARY.switch_to_slot(switch_slot)
  else
    DAW.CUSTOM_LIBRARY.schedule_home_recovery_after_custom_upload(
      current_page,
      "SysEx & Customs Library: restored HOME Page " .. tostring(current_page)
        .. " after sending Custom entry " .. tostring(index),
      CFG.CUSTOM_UPLOAD_HOME_RECOVERY_DELAY_SECONDS or 1.00
    )
  end
  return true
end

DAW.CUSTOM_LIBRARY.send_layout = function(layout)
  layout = math.max(0, math.min(127, math.floor(tonumber(layout) or 0)))
  if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end
  local sent = send_bytes({0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x00,layout,0xF7})
  if sent then
    active_custom_slot = nil
    surface_mode = "CUSTOM_EXTERNAL"
    initialized = true
    DAW.CUSTOM_LIBRARY.external_layout = layout
    DAW.CUSTOM_LIBRARY.external_layout_ack_until = r.time_precise() + 1.0
    last_action = "Selected external Launchpad layout " .. tostring(layout)
  end
  return sent
end

DAW.CUSTOM_LIBRARY.send_scroll = function()
  local text = tostring(DAW.CUSTOM_LIBRARY.scroll_text or "")
  if text == "" then return false end
  local bytes = {0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x07,0x00,0x08,0x00,DAW.CUSTOM_LIBRARY.scroll_palette}
  for index = 1, #text do bytes[#bytes + 1] = text:byte(index) & 0x7F end
  bytes[#bytes + 1] = 0xF7
  send_bytes(bytes)
  if DAW.CUSTOM_LIBRARY.scroll_loop then
    DAW.CUSTOM_LIBRARY.scroll_next_time = r.time_precise() + math.max(0.25, tonumber(DAW.CUSTOM_LIBRARY.scroll_interval) or 5)
  else
    DAW.CUSTOM_LIBRARY.scroll_next_time = nil
  end
  last_action = "Scrolled Launchpad text"
  return true
end

DAW.CUSTOM_LIBRARY.stop_scroll = function()
  DAW.CUSTOM_LIBRARY.scroll_next_time = nil
  return send_bytes({0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x07,0xF7})
end

DAW.CUSTOM_LIBRARY.process_scroll_loop = function(now)
  if DAW.CUSTOM_LIBRARY.scroll_loop and DAW.CUSTOM_LIBRARY.scroll_next_time and now >= DAW.CUSTOM_LIBRARY.scroll_next_time then
    DAW.CUSTOM_LIBRARY.send_scroll()
  end
end

DAW.CUSTOM_LIBRARY.request_custom = function(destination_entry, destination_slot, hardware_slot)
  destination_entry = math.max(1, math.floor(tonumber(destination_entry) or 1))
  destination_slot = math.max(1, math.min(8, math.floor(tonumber(destination_slot) or 1)))
  hardware_slot = math.max(1, math.min(8, math.floor(tonumber(hardware_slot) or 1)))
  if selected_output_index == nil then
    last_action = "Choose a primary ordinary MIDI output before reading a Custom slot"
    return false
  end
  DAW.CUSTOM_LIBRARY.pending_readback = {
    destination_entry=destination_entry,
    destination_slot=destination_slot,
    hardware_slot=hardware_slot,
    deadline=r.time_precise()+3.0,
    buffer={},
    capturing=false,
  }
  DAW.send_bytes_primary({0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x20,0x00,0x40,0x40,0x03+hardware_slot,0xF7})
  last_action = "Requested hardware Custom " .. tostring(hardware_slot)
  return true
end

DAW.CUSTOM_LIBRARY.bytes_to_hex = function(bytes)
  local result = {}
  for _, byte in ipairs(bytes or {}) do result[#result + 1] = string.format("%02X", byte) end
  return table.concat(result, " ")
end

DAW.CUSTOM_LIBRARY.file_filters = "SysEx files|*.syx|Text files|*.txt|All files|*.*"
DAW.CUSTOM_LIBRARY.button_labels_file_filters = "Button Label files|*.csv;*.txt|CSV files|*.csv|Text files|*.txt|All files|*.*"

DAW.CUSTOM_LIBRARY.read_file_binary = function(path)
  local file = io.open(tostring(path or ""), "rb")
  if not file then return nil, "Could not open file for reading" end
  local data = file:read("*a")
  file:close()
  return data or ""
end

DAW.CUSTOM_LIBRARY.write_file_binary = function(path, data)
  local file = io.open(tostring(path or ""), "wb")
  if not file then return false, "Could not open file for writing" end
  file:write(data or "")
  file:close()
  return true
end

DAW.CUSTOM_LIBRARY.file_content_to_hex = function(data)
  data = tostring(data or "")
  if data == "" then return "" end

  -- Binary .syx files normally begin with F0 and may contain non-printing
  -- bytes. Text exports are also accepted when they contain hexadecimal byte
  -- pairs separated by spaces, line breaks, commas, or descriptive text.
  local binary = data:byte(1) == 0xF0 or data:find("[%z\1-\8\11\12\14-\31\128-\255]") ~= nil
  if binary then
    return DAW.CUSTOM_LIBRARY.bytes_to_hex({data:byte(1,#data)})
  end

  local bytes = hex_text_to_bytes(data)
  if #bytes <= 0 then return nil, "The selected file does not contain recognizable SysEx bytes" end
  return DAW.CUSTOM_LIBRARY.bytes_to_hex(bytes)
end

DAW.CUSTOM_LIBRARY.path_parts = function(path)
  path = tostring(path or "")
  local folder, filename = path:match("^(.*[/\\])([^/\\]*)$")
  return folder or "", filename or path
end

DAW.CUSTOM_LIBRARY.file_dialog_selected = function(ok, path)
  -- Some extension dialogs return integer 0/1 rather than Lua booleans.
  -- In Lua, numeric 0 is truthy, so test it explicitly.
  return ok ~= false and ok ~= 0 and trim(path or "") ~= ""
end

DAW.CUSTOM_LIBRARY.choose_file = function(mode, caption, suggested_name, options)
  options = options or {}
  mode = tonumber(mode) or 1
  caption = tostring(caption or ((mode == 0) and "Save file" or "Load file"))
  suggested_name = tostring(suggested_name or options.suggested_name or "File.dat")
  local path_key = tostring(options.path_key or "last_sysex_file_path")
  local filters = tostring(options.filters or DAW.CUSTOM_LIBRARY.file_filters)
  local js_filters = tostring(options.js_filters or "All files (*.*)\0*.*\0")
  local legacy_extension = tostring(options.legacy_extension or "")

  local previous = tostring(DAW.CUSTOM_LIBRARY[path_key] or "")
  local initial = previous
  if mode == 0 and trim(initial) == "" then initial = suggested_name end

  if r.GetUserFileName then
    local call_ok, ok, path = pcall(r.GetUserFileName,mode,caption,initial,filters)
    if call_ok then
      if not DAW.CUSTOM_LIBRARY.file_dialog_selected(ok, path) then return nil end
      DAW.CUSTOM_LIBRARY[path_key] = tostring(path)
      return tostring(path)
    end
  end

  local folder, prior_name = DAW.CUSTOM_LIBRARY.path_parts(previous)
  if mode == 1 and r.GetUserFileNameForRead then
    local seed = previous ~= "" and previous or folder
    local call_ok, ok, path = pcall(r.GetUserFileNameForRead,seed,caption,legacy_extension)
    if call_ok then
      if not DAW.CUSTOM_LIBRARY.file_dialog_selected(ok, path) then return nil end
      DAW.CUSTOM_LIBRARY[path_key] = tostring(path)
      return tostring(path)
    end
  end

  if mode == 1 and r.JS_Dialog_BrowseForOpenFiles then
    local call_ok, ok, path = pcall(r.JS_Dialog_BrowseForOpenFiles,caption,folder,prior_name,js_filters,false)
    if call_ok then
      if not DAW.CUSTOM_LIBRARY.file_dialog_selected(ok, path) then return nil end
      DAW.CUSTOM_LIBRARY[path_key] = tostring(path)
      return tostring(path)
    end
  elseif mode == 0 and r.JS_Dialog_BrowseForSaveFile then
    local call_ok, ok, path = pcall(r.JS_Dialog_BrowseForSaveFile,caption,folder,suggested_name,js_filters)
    if call_ok then
      if not DAW.CUSTOM_LIBRARY.file_dialog_selected(ok, path) then return nil end
      DAW.CUSTOM_LIBRARY[path_key] = tostring(path)
      return tostring(path)
    end
  end

  if mode == 0 and r.GetUserInputs then
    local default_path = folder .. suggested_name
    local ok, path = r.GetUserInputs(caption,1,"Full file path,extrawidth=500",default_path)
    if not DAW.CUSTOM_LIBRARY.file_dialog_selected(ok, path) then return nil end
    DAW.CUSTOM_LIBRARY[path_key] = tostring(path)
    return tostring(path)
  end

  last_action = (mode == 0)
    and "This REAPER build does not provide an available Save-file dialog"
    or "This REAPER build does not provide an available Load-file dialog"
  return nil
end

DAW.CUSTOM_LIBRARY.choose_sysex_file = function(mode, caption, suggested_name)
  return DAW.CUSTOM_LIBRARY.choose_file(mode,caption,suggested_name or "SysEx.syx",{
    path_key="last_sysex_file_path",
    filters=DAW.CUSTOM_LIBRARY.file_filters,
    legacy_extension="syx",
    js_filters="SysEx files (*.syx)\0*.syx\0Text files (*.txt)\0*.txt\0All files (*.*)\0*.*\0",
  })
end

DAW.CUSTOM_LIBRARY.choose_button_labels_file = function(mode, caption, suggested_name)
  return DAW.CUSTOM_LIBRARY.choose_file(mode,caption,suggested_name or "Button_Labels.csv",{
    path_key="last_button_labels_file_path",
    filters=DAW.CUSTOM_LIBRARY.button_labels_file_filters,
    legacy_extension="csv",
    js_filters="Button Label files (*.csv;*.txt)\0*.csv;*.txt\0CSV files (*.csv)\0*.csv\0Text files (*.txt)\0*.txt\0All files (*.*)\0*.*\0",
  })
end


DAW.USER_DATA.library_file_filters = "Launchpad Xtra library files|*.lua|All files|*.*"
DAW.USER_DATA.choose_library_file = function(owner, mode, caption, suggested_name)
  owner = owner or DAW.CUSTOM_LIBRARY
  local owner_key = owner == DAW.COMMAND_LIBRARY and "command" or "custom"
  local path_key = owner_key .. "_library_exchange_path"
  DAW.CUSTOM_LIBRARY[path_key] = tostring(owner.last_library_file_path or DAW.CUSTOM_LIBRARY[path_key] or "")
  local path = DAW.CUSTOM_LIBRARY.choose_file(mode,caption,suggested_name or "LaunchpadXtraLibrary.lua",{
    path_key=path_key,
    filters=DAW.USER_DATA.library_file_filters,
    legacy_extension="lua",
    js_filters="Launchpad Xtra library files (*.lua)\0*.lua\0All files (*.*)\0*.*\0",
  })
  if path then
    path = DAW.USER_DATA.append_extension(path,".lua")
    owner.last_library_file_path = path
    DAW.CUSTOM_LIBRARY[path_key] = path
  end
  return path
end

DAW.CUSTOM_LIBRARY.normalize_button_labels_text = function(text)
  text = tostring(text or "")
  if text:sub(1,3) == "\239\187\191" then text = text:sub(4) end
  text = text:gsub("\r\n","\n"):gsub("\r","\n")
  text = text:gsub("\t"," "):gsub("\194\160"," "):gsub("%z","")
  return text
end

DAW.CUSTOM_LIBRARY.parse_button_labels_text = function(text)
  text = DAW.CUSTOM_LIBRARY.normalize_button_labels_text(text)
  local rows = {}
  for line in (text .. "\n"):gmatch("(.-)\n") do
    if #rows < 8 or line ~= "" then
      local cells = {}
      for cell in (line .. ","):gmatch("(.-),") do
        cells[#cells + 1] = trim(cell):gsub("|","\n")
      end
      rows[#rows + 1] = cells
    end
  end
  while #rows > 0 and #rows[#rows] == 1 and rows[#rows][1] == "" do table.remove(rows) end
  if #rows ~= 8 then
    return nil, "Button Labels files must contain exactly 8 lines; this file contains " .. tostring(#rows)
  end
  for row = 1, 8 do
    if #rows[row] ~= 8 then
      return nil, "Button Labels line " .. tostring(row) .. " must contain exactly 8 comma-separated labels; it contains " .. tostring(#rows[row])
    end
  end
  return rows
end

DAW.CUSTOM_LIBRARY.load_hex_from_file = function(caption)
  local path = DAW.CUSTOM_LIBRARY.choose_sysex_file(1, caption or "Load SysEx file")
  if not path then return nil end
  local data, err = DAW.CUSTOM_LIBRARY.read_file_binary(path)
  if not data then last_action = tostring(err) .. ": " .. tostring(path); return nil end
  local hex, parse_err = DAW.CUSTOM_LIBRARY.file_content_to_hex(data)
  if hex == nil then last_action = tostring(parse_err) .. ": " .. tostring(path); return nil end
  last_action = "Loaded SysEx file: " .. tostring(path)
  return hex
end

DAW.CUSTOM_LIBRARY.load_button_labels_from_file = function(caption)
  local path = DAW.CUSTOM_LIBRARY.choose_button_labels_file(1, caption or "Load Button Labels file")
  if not path then return nil end
  local data, err = DAW.CUSTOM_LIBRARY.read_file_binary(path)
  if not data then last_action = tostring(err) .. ": " .. tostring(path); return nil end
  data = DAW.CUSTOM_LIBRARY.normalize_button_labels_text(data)
  local _, parse_err = DAW.CUSTOM_LIBRARY.parse_button_labels_text(data)
  if parse_err then last_action = tostring(parse_err) .. ": " .. tostring(path); return nil end
  last_action = "Loaded Button Labels file: " .. tostring(path)
  return data
end

DAW.CUSTOM_LIBRARY.save_hex_to_file = function(hex, suggested_name, caption)
  local bytes = hex_text_to_bytes(hex)
  if #bytes <= 0 then last_action = "There is no SysEx payload to save"; return false end
  local path = DAW.CUSTOM_LIBRARY.choose_sysex_file(0, caption or "Save SysEx file", suggested_name or "SysEx.syx")
  if not path then return false end
  if not path:match("%.[^/\\]+$") then path = path .. ".syx" end
  local ok, err = DAW.CUSTOM_LIBRARY.write_file_binary(path, bytes_to_string(bytes))
  if not ok then last_action = tostring(err) .. ": " .. tostring(path); return false end
  DAW.CUSTOM_LIBRARY.last_sysex_file_path = path
  last_action = "Saved SysEx file: " .. tostring(path)
  return true
end

DAW.CUSTOM_LIBRARY.save_button_labels_to_file = function(text, suggested_name, caption)
  text = DAW.CUSTOM_LIBRARY.normalize_button_labels_text(text)
  if trim(text) == "" then last_action = "There are no Button Labels to save"; return false end
  local _, parse_err = DAW.CUSTOM_LIBRARY.parse_button_labels_text(text)
  if parse_err then last_action = tostring(parse_err); return false end
  local path = DAW.CUSTOM_LIBRARY.choose_button_labels_file(0,caption or "Save Button Labels file",suggested_name or "Button_Labels.csv")
  if not path then return false end
  if not path:match("%.[^/\\]+$") then path = path .. ".csv" end
  local ok, err = DAW.CUSTOM_LIBRARY.write_file_binary(path,text)
  if not ok then last_action = tostring(err) .. ": " .. tostring(path); return false end
  DAW.CUSTOM_LIBRARY.last_button_labels_file_path = path
  last_action = "Saved Button Labels file: " .. tostring(path)
  return true
end

DAW.CUSTOM_LIBRARY.prompt_load_asset_kind = function()
  local text = table.concat({
    "Which would you like to load?",
    "",
    "YES — SysEx file",
    "Launchpad SysEx layouts can be created and exported at:",
    "https://components.novationmusic.com/",
    "They work well for drum layouts and controller-specific surfaces, and can also be designed to work with automation software such as ReaLearn.",
    "",
    "NO — Button Labels file",
    "A Button Labels file is an 8x8 CSV-style text file: 8 lines with 8 comma-separated labels on each line.",
    "Example:",
    "Bass, Snare, Hi Hat|Open, Hi-Hat|Closed, Shaker, Tom 1, Tom 2, Tom 3",
    "Use the pipe character | inside a label to split it across lines.",
    "",
    "CANCEL — Return without loading.",
  },"\n")
  local answer = r.ShowMessageBox(text,"Load SysEx or Button Labels",3)
  if answer == 6 then return "sysex" end
  if answer == 7 then return "labels" end
  return nil
end

DAW.CUSTOM_LIBRARY.load_payload_asset = function(hex, labels, caption_prefix)
  local kind = DAW.CUSTOM_LIBRARY.prompt_load_asset_kind()
  if kind == "sysex" then
    local loaded = DAW.CUSTOM_LIBRARY.load_hex_from_file("Load " .. tostring(caption_prefix or "") .. " SysEx file")
    if loaded ~= nil then return loaded,tostring(labels or ""),true end
  elseif kind == "labels" then
    local loaded = DAW.CUSTOM_LIBRARY.load_button_labels_from_file("Load " .. tostring(caption_prefix or "") .. " Button Labels file")
    if loaded ~= nil then return tostring(hex or ""),loaded,true end
  end
  return tostring(hex or ""),tostring(labels or ""),false
end

DAW.CUSTOM_LIBRARY.save_payload_files = function(hex, labels, suggested_sysex_name, caption_prefix)
  local prefix = tostring(caption_prefix or "Payload")
  if not DAW.CUSTOM_LIBRARY.save_hex_to_file(hex,suggested_sysex_name,"Save " .. prefix .. " SysEx file") then return false end
  labels = tostring(labels or "")
  if trim(labels) ~= "" then
    local answer = r.ShowMessageBox(
      "This SysEx payload also contains an 8x8 Button Labels file.\n\nSave a copy of the Button Labels file now?",
      "Save Button Labels",
      4
    )
    if answer == 6 then
      local suggested_labels = tostring(suggested_sysex_name or "Payload.syx")
        :gsub("%.syx$","") .. "_Button_Labels.csv"
      DAW.CUSTOM_LIBRARY.save_button_labels_to_file(labels,suggested_labels,"Save " .. prefix .. " Button Labels file")
    end
  end
  return true
end


DAW.CUSTOM_LIBRARY.copy_import_entry = function(raw)
  raw = type(raw) == "table" and raw or {}
  local entry = {
    name=tostring(raw.name or ""), label=tostring(raw.label or ""),
    non_custom=tostring(raw.non_custom or ""), non_custom_labels=tostring(raw.non_custom_labels or ""),
    payload_mode=(raw.payload_mode == "non_custom") and "non_custom" or "custom",
    color=math.max(0,math.min(127,tonumber(raw.color) or 0x01)),
    switch_to_slot=math.max(0,math.min(8,tonumber(raw.switch_to_slot) or 0)),
    customs={}, custom_labels={},
  }
  for slot=1,8 do
    entry.customs[slot]=tostring(type(raw.customs)=="table" and raw.customs[slot] or "")
    entry.custom_labels[slot]=tostring(type(raw.custom_labels)=="table" and raw.custom_labels[slot] or "")
  end
  return entry
end

DAW.CUSTOM_LIBRARY.clear_resident_source_map = function()
  local settings=type(DAW.CUSTOM_LIBRARY.data.settings)=="table" and DAW.CUSTOM_LIBRARY.data.settings or {}
  DAW.CUSTOM_LIBRARY.data.settings=settings
  settings.resident_source_entry_by_slot={}
  settings.resident_source_payload_by_slot={}
  for slot=1,8 do
    settings.resident_source_entry_by_slot[slot]=0
    settings.resident_source_payload_by_slot[slot]=0
  end
  DAW.CUSTOM_LIBRARY.payload_visual_cache={}
end

DAW.CUSTOM_LIBRARY.export_library = function()
  DAW.CUSTOM_LIBRARY.sync_persistent_settings()
  local path=DAW.USER_DATA.choose_library_file(
    DAW.CUSTOM_LIBRARY,0,"Export Launchpad Xtra SysEx & Customs Library","LaunchpadXtra_SysEx_Customs_Library.lua"
  )
  if not path then return false end
  local ok=DAW.USER_DATA.write_file(path,DAW.USER_DATA.serialize_custom_data(DAW.CUSTOM_LIBRARY.data))
  if ok then last_action="Exported SysEx & Customs Library: " .. tostring(path) end
  return ok
end

DAW.CUSTOM_LIBRARY.import_library = function()
  local path=DAW.USER_DATA.choose_library_file(
    DAW.CUSTOM_LIBRARY,1,"Import Launchpad Xtra SysEx & Customs Library","LaunchpadXtra_SysEx_Customs_Library.lua"
  )
  if not path then return false end
  local imported,err=DAW.USER_DATA.load_exchange_table(path)
  if not imported then
    r.ShowMessageBox("Could not import SysEx & Customs Library:\n\n"..tostring(err),"Launchpad Xtra SysEx Import",0)
    return false
  end
  local mode=DAW.USER_DATA.prompt_import_mode("SysEx & Customs Library")
  if not mode then return false end
  local target
  if mode=="replace" then
    DAW.CUSTOM_LIBRARY.data.settings=type(imported.settings)=="table" and imported.settings or {}
    target={}
  else
    target=DAW.CUSTOM_LIBRARY.data.entries
  end
  for _,raw in ipairs(imported.entries or {}) do target[#target+1]=DAW.CUSTOM_LIBRARY.copy_import_entry(raw) end
  DAW.CUSTOM_LIBRARY.data.entries=target
  DAW.CUSTOM_LIBRARY.apply_loaded_settings()
  DAW.CUSTOM_LIBRARY.clear_resident_source_map()
  for index=1,#target do DAW.USER_DATA.ensure_custom_entry(index) end
  DAW.CUSTOM_LIBRARY.editor_index=math.max(1,math.min(#target,DAW.CUSTOM_LIBRARY.editor_index or 1))
  DAW.CUSTOM_LIBRARY.save()
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  r.ShowMessageBox(
    "SysEx & Customs Library import complete.\n\nImported rows: "..tostring(#(imported.entries or {}))
      .."\nMode: "..(mode=="replace" and "Replaced current rows" or "Appended after current rows"),
    "Launchpad Xtra SysEx Import",0
  )
  last_action="Imported SysEx & Customs Library: " .. tostring(path)
  return true
end

DAW.CUSTOM_LIBRARY.capture_readback = function(buf, dev_idx)
  local pending = DAW.CUSTOM_LIBRARY.pending_readback
  if not pending or not buf then return false end
  local device_index = (dev_idx or 0) & 0xFFFF
  if not DAW.ordinary_input_matches(device_index) then return false end
  local bytes = {buf:byte(1, #buf)}
  if #bytes <= 0 then return false end
  if bytes[1] == 0xF0 then
    pending.buffer = {}
    pending.capturing = true
  end
  if not pending.capturing then return false end
  for _, byte in ipairs(bytes) do pending.buffer[#pending.buffer + 1] = byte end
  if pending.buffer[#pending.buffer] == 0xF7 then
    local b = pending.buffer
    if #b >= 12 and b[1]==0xF0 and b[2]==0x00 and b[3]==0x20 and b[4]==0x29 and b[5]==0x02 and b[6]==selected_device.id and b[7]==0x20 and b[8]==0x00 and b[9]==0x10 then
      local entry = DAW.USER_DATA.ensure_custom_entry(pending.destination_entry)
      entry.customs[pending.destination_slot] = DAW.CUSTOM_LIBRARY.bytes_to_hex(b)
      DAW.CUSTOM_LIBRARY.save()
      last_action = "Captured hardware Custom " .. tostring(pending.hardware_slot) .. " into library entry " .. tostring(pending.destination_entry) .. ", Custom " .. tostring(pending.destination_slot)
    else
      last_action = "Received SysEx while waiting for Custom readback, but format was not a Custom dump"
    end
    DAW.CUSTOM_LIBRARY.pending_readback = nil
  end
  return true
end

DAW.CUSTOM_LIBRARY.process_readback_timeout = function(now)
  local pending = DAW.CUSTOM_LIBRARY.pending_readback
  if pending and now >= pending.deadline then
    DAW.CUSTOM_LIBRARY.pending_readback = nil
    last_action = "Timed out waiting for Custom slot readback"
  end
end


-- A physical layout-button press is not guaranteed to emit an unsolicited
-- message on every firmware/port combination. The documented readback variant
-- is reliable: ask command 00 for the current layout while standing aside.
DAW.CUSTOM_LIBRARY.request_layout_readback = function()
  local bytes = {0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x00,0xF7}
  local sent = DAW.send_to_unique_outputs({
    {index = selected_output_index, device = selected_device},
    {index = DAW.ordinary_output_index_2, device = DAW.secondary_device},
    {index = DAW.output_index, device = selected_device},
    {index = DAW.output_index_2, device = DAW.secondary_device},
  }, bytes)
  return sent and true or false
end

DAW.CUSTOM_LIBRARY.process_external_layout_poll = function(now)
  if surface_mode ~= "CUSTOM_EXTERNAL" then
    DAW.CUSTOM_LIBRARY.next_external_layout_poll_time = nil
    return false
  end

  now = tonumber(now) or r.time_precise()
  if now < (tonumber(DAW.CUSTOM_LIBRARY.next_external_layout_poll_time) or 0) then
    return false
  end

  DAW.CUSTOM_LIBRARY.request_layout_readback()
  DAW.CUSTOM_LIBRARY.next_external_layout_poll_time =
    now + (CFG.CUSTOM_EXTERNAL_LAYOUT_POLL_INTERVAL or 0.20)
  return true
end

------------------------------------------------------------
-- HOME PAGE 2 ACTIONS / PAGE 3 CUSTOMS
------------------------------------------------------------
DAW.USER_PAGES = {
  starts = {[2]=1, [3]=1},
  SLOT_COLUMNS = 5,
  SLOT_ROWS = 8,
  BANK_SIZE = 40,
  STEP_SIZE = 10,
}

DAW.USER_PAGES.palette_gui = function(palette)
  palette = math.max(0, math.min(127, tonumber(palette) or 0))
  return DAW.SAMPLED_PALETTE_GUI_COLORS[palette]
    or DAW_MATRIX_PALETTE_TO_GUI_COLOR[palette]
    or 0x555555FF
end

DAW.USER_PAGES.entries = function(page)
  return page == 2 and DAW.COMMAND_LIBRARY.data.entries or DAW.CUSTOM_LIBRARY.data.entries
end

DAW.USER_PAGES.library = function(page)
  return page == 2 and DAW.COMMAND_LIBRARY or DAW.CUSTOM_LIBRARY
end

DAW.USER_PAGES.entry_is_defined = function(page, entry)
  if page == 2 then return DAW.COMMAND_LIBRARY.entry_is_defined(entry) end
  return DAW.CUSTOM_LIBRARY.entry_has_data(entry)
end

DAW.USER_PAGES.entry_display_color = function(page, entry)
  if page == 2 then return DAW.COMMAND_LIBRARY.display_color(entry) end
  return DAW.CUSTOM_LIBRARY.display_color(entry)
end

DAW.USER_PAGES.slot_index = function(page,row,col)
  if row < 2 or row > 9 or col < 1 or col > 5 then return nil end
  return DAW.USER_PAGES.starts[page] + ((row - 2) * 5) + col - 1
end

DAW.USER_PAGES.set_start = function(page,start,reason)
  start = math.max(1, math.floor(tonumber(start) or 1))
  DAW.USER_PAGES.starts[page] = start
  last_hardware_state_signature = nil
  send_page_lighting(page, true)
  last_action = reason or ((page == 2 and "Actions" or "Customs") .. " slots " .. tostring(start) .. "-" .. tostring(start + 39))
end

DAW.USER_PAGES.navigate = function(page,delta)
  DAW.USER_PAGES.set_start(page, DAW.USER_PAGES.starts[page] + delta)
end

DAW.USER_PAGES.cell_index = function(row,col)
  return ((row - 1) * 9) + col
end

DAW.USER_PAGES.home_duplicate_info = function(row,col)
  local index = DAW.USER_PAGES.cell_index(row,col)
  local label = normalize_label(labels[1][row][col])
  return {
    label = label,
    kind = "home",
    home_label = label,
    color = hex_string_to_byte(hardware_colors[1][index]),
    gui = gui_colors[1][index],
  }
end

DAW.USER_PAGES.status_color = function(page)
  local index = ACTIVE_PAGE_ARRAY_INDEX[page] or ACTIVE_PAGE_ARRAY_INDEX[1]
  return hex_string_to_byte(hardware_colors[1][index])
end

DAW.USER_PAGES.status_gui_color = function(page)
  local index = ACTIVE_PAGE_ARRAY_INDEX[page] or ACTIVE_PAGE_ARRAY_INDEX[1]
  return gui_colors[1][index]
end

DAW.USER_PAGES.info_is_active = function(page,info)
  if not info or info.kind ~= "home" then return false end
  local page_number = DAW.page_number_from_label(info.home_label)
  return page_number == page or is_label_active(info.home_label)
end

DAW.USER_PAGES.fixed_cell = function(page,row,col)
  if row == 1 then
    local top = {
      [1]={label="Bank -40", kind="navigate", value=-40, color=0x25},
      [2]={label="Bank +40", kind="navigate", value=40, color=0x25},
      [3]={label="Step -10", kind="navigate", value=-10, color=0x21},
      [4]={label="Step +10", kind="navigate", value=10, color=0x21},
    }
    if top[col] then return top[col] end

    -- HOME Pages 2 and 3 are already HOME. Keep the Page 1 Save Project
    -- control in its original top-row physical position.
    if col == 5 then return DAW.USER_PAGES.home_duplicate_info(row,col) end
    if col >= 6 and col <= 8 then return DAW.USER_PAGES.home_duplicate_info(row,col) end
    if col == 9 then
      return {
        label = (page == 2 and "Actions" or "Customs")
          .. "\n" .. tostring(DAW.USER_PAGES.starts[page])
          .. " - " .. tostring(DAW.USER_PAGES.starts[page] + 39),
        kind = "status",
        color = DAW.USER_PAGES.status_color(page),
        gui = DAW.USER_PAGES.status_gui_color(page),
      }
    end
  end

  -- Columns 6-8 and the entire right edge intentionally mirror HOME Page 1
  -- exactly. The only exception is the page-specific top-right status light.
  if (col >= 6 and col <= 8) or col == 9 then
    return DAW.USER_PAGES.home_duplicate_info(row,col)
  end

  return {label=" ",kind="empty",color=0x00}
end

DAW.USER_PAGES.cell_info = function(page,row,col)
  local slot = DAW.USER_PAGES.slot_index(page,row,col)
  if slot then
    local entry = DAW.USER_PAGES.entries(page)[slot]
    local defined = DAW.USER_PAGES.entry_is_defined(page, entry)
    local label = defined and trim(entry.label ~= "" and entry.label or entry.name) or ""
    return {
      kind="slot",
      slot=slot,
      entry=entry,
      defined=defined,
      label=label ~= "" and label or tostring(slot),
      color=DAW.USER_PAGES.entry_display_color(page, entry),
    }
  end
  return DAW.USER_PAGES.fixed_cell(page,row,col)
end

DAW.USER_PAGES.run_cell = function(page,row,col,pressed,source)
  local info = DAW.USER_PAGES.cell_info(page,row,col)
  if not info then return false end
  pressed = pressed ~= false

  if info.kind == "slot" then
    if not pressed then return true end
    if page == 2 then return DAW.COMMAND_LIBRARY.run_entry(info.slot) end
    return DAW.CUSTOM_LIBRARY.execute_entry(info.slot)
  elseif info.kind == "navigate" then
    if pressed then DAW.USER_PAGES.navigate(page,info.value) end
  elseif info.kind == "page" then
    if pressed then set_page(info.value) end
  elseif info.kind == "library" then
    if pressed then
      if page == 2 then DAW.COMMAND_LIBRARY.visible = true else DAW.CUSTOM_LIBRARY.visible = true end
    end
  elseif info.kind == "action" and ACTIONS[info.value] then
    if pressed then ACTIONS[info.value]() end
  elseif info.kind == "preset" then
    if pressed then DAW.activate_preset(info.value) end
  elseif info.kind == "home" then
    local action = ACTIONS[info.home_label]
    local hold_action = HOLD_ACTIONS[info.home_label]
    if hold_action then
      if pressed then hold_action.press() else hold_action.release() end
    elseif pressed and action then
      action()
    elseif pressed then
      last_action = (source or "HOME duplicate") .. ": " .. tostring(info.home_label) .. " is not wired yet"
    end
  end
  last_hardware_state_signature = nil
  refresh_hardware_state(true)
  return true
end

DAW.USER_PAGES.editing_slot_for_page = function(page)
  if current_page ~= page then return nil end
  local library = DAW.USER_PAGES.library(page)
  if not library or not library.visible then return nil end
  if page == 3 and not library.selection_active then return nil end

  local slot = math.floor(tonumber(library.editor_index) or 0)
  local first = tonumber(DAW.USER_PAGES.starts[page]) or 1
  if slot < first or slot > (first + 39) then return nil end
  return slot
end

DAW.USER_PAGES.build_lighting_message = function(page, first_index, last_index)
  first_index = math.max(1, math.min(81, math.floor(tonumber(first_index) or 1)))
  last_index = math.max(first_index, math.min(81, math.floor(tonumber(last_index) or 81)))
  local bytes = {0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x03}
  local editing_slot = DAW.USER_PAGES.editing_slot_for_page(page)
  for index = first_index,last_index do
    local row = math.floor((index-1)/9)+1
    local col = ((index-1)%9)+1
    local info = DAW.USER_PAGES.cell_info(page,row,col)
    local pulse = (info and info.kind == "page" and info.value == page)
      or DAW.USER_PAGES.info_is_active(page,info)
    local editor_flash = info and info.kind == "slot"
      and tonumber(editing_slot) == tonumber(info.slot)
    local grid_flash = info and info.kind == "home"
      and info.home_label == "Show/Hide This Grid"
      and not grid_visible
    local lighting_type = (editor_flash or grid_flash) and 0x01 or (pulse and 0x02 or 0x00)
    local color = info and info.color or 0x00
    local flash_base_color = 0x00
    local label = info and (info.home_label or info.label) or ""
    lighting_type, color, flash_base_color = DAW.resolve_palette_lighting(
      label, lighting_type, color, flash_base_color
    )
    DAW.append_palette_colourspec(
      bytes,
      lighting_type,
      hex_string_to_byte(Lpxlib.pad_addresses[index]),
      color,
      flash_base_color
    )
  end
  bytes[#bytes+1]=0xF7
  return bytes
end

DAW.USER_PAGES.signature = function(page)
  local parts={
    "user-page:"..tostring(page)..":"..tostring(DAW.USER_PAGES.starts[page]),
    grid_visible and "grid:1" or "grid:0",
    "editing:"..tostring(DAW.USER_PAGES.editing_slot_for_page(page) or 0),
  }
  local entries=DAW.USER_PAGES.entries(page)
  for i=DAW.USER_PAGES.starts[page],DAW.USER_PAGES.starts[page]+39 do
    local e=entries[i]
    parts[#parts+1]=tostring(i)..":"
      ..(DAW.USER_PAGES.entry_is_defined(page,e) and "1" or "0")..":"
      ..tostring(e and e.name or "")..":"..tostring(e and e.label or "")..":"
      ..tostring(DAW.USER_PAGES.entry_display_color(page,e))
  end

  for row=1,9 do
    for col=1,9 do
      local info=DAW.USER_PAGES.fixed_cell(page,row,col)
      if info and info.kind=="home" then
        parts[#parts+1]="home:"..tostring(row)..":"..tostring(col)..":"
          ..tostring(info.home_label)..":"
          ..(DAW.USER_PAGES.info_is_active(page,info) and "1" or "0")
      end
    end
  end

  return table.concat(parts,"|")
end

------------------------------------------------------------
-- GRID DISPATCH
------------------------------------------------------------
local PAD_INDEX_BY_ADDRESS = {}
for i = 1, #Lpxlib.pad_addresses do
  PAD_INDEX_BY_ADDRESS[hex_string_to_byte(Lpxlib.pad_addresses[i])] = i
end

local function label_for_index(index)
  local row = math.floor((index - 1) / 9) + 1
  local col = ((index - 1) % 9) + 1
  return labels[current_page][row][col]
end

local function dispatch_index(index, source)
  if not index or index < 1 or index > 81 then return end

  -- On-screen GRID clicks remain useful while the hardware is asleep: wake the
  -- LEDs and continue with the requested action. The Sleep cell itself is the
  -- exception; when already sleeping it acts only as Wake and must not toggle
  -- straight back into Sleep again.
  local woke_from_sleep = DAW.SLEEP and DAW.SLEEP.active
  if woke_from_sleep then DAW.SLEEP.wake() end

  if (current_page == 2 or current_page == 3) and DAW.USER_PAGES then
    local row = math.floor((index - 1) / 9) + 1
    local col = ((index - 1) % 9) + 1
    DAW.USER_PAGES.run_cell(current_page,row,col,true,source)
    return
  end

  local label = normalize_label(label_for_index(index))
  if label == "Page Status" then
    last_action = (source or "Grid") .. ": Page status indicator has no action"
    return
  end

  if woke_from_sleep and label == "33" then return end

  local action = ACTIONS[label]
  local hold_action = HOLD_ACTIONS[label]
  if action then
    action()
    refresh_hardware_state(true)
  elseif hold_action then
    -- On-screen clicks act as a brief tap. Physical buttons use true press/release handling.
    hold_action.press()
    hold_action.release()
    refresh_hardware_state(true)
  else
    last_action = (source or "Grid") .. ": " .. label .. " is not wired yet"
  end
end

------------------------------------------------------------
-- PROGRAMMER-MODE REGIONS / MARKERS SONG MAP (PRESET 31)
------------------------------------------------------------
DAW.REGIONS_MARKERS.cell_index = function(row, col)
  return ((row - 1) * 9) + col
end

DAW.REGIONS_MARKERS.home_hardware_color = function(row, col)
  local index = DAW.REGIONS_MARKERS.cell_index(row, col)
  return hex_string_to_byte(hardware_colors[1][index])
end

DAW.REGIONS_MARKERS.home_gui_color = function(row, col)
  local index = DAW.REGIONS_MARKERS.cell_index(row, col)
  return gui_colors[1][index] or 0x333333FF
end

DAW.REGIONS_MARKERS.home_color_by_label = function(label, gui, fallback)
  local wanted = normalize_label(label)
  for row = 1, 9 do
    for col = 1, 9 do
      if normalize_label(labels[1][row][col]) == wanted then
        return gui
          and DAW.REGIONS_MARKERS.home_gui_color(row, col)
          or DAW.REGIONS_MARKERS.home_hardware_color(row, col)
      end
    end
  end
  return fallback
end

DAW.REGIONS_MARKERS.palette_gui_color = function(color)
  return DAW_MATRIX_PALETTE_TO_GUI_COLOR[tonumber(color) or 0x00]
    or CUSTOM_FADER_GUI_COLORS[1]
    or 0x333333FF
end

DAW.REGIONS_MARKERS.normalize_search_text = function(text)
  text = tostring(text or ""):lower()
  text = text:gsub("[^%w]+", " ")
  text = text:gsub("%s+", " ")
  return trim(text)
end

DAW.REGIONS_MARKERS.name_matches_expression = function(name, expression, reject_following_number)
  local normalized_name = DAW.REGIONS_MARKERS.normalize_search_text(name)
  local normalized_expression = DAW.REGIONS_MARKERS.normalize_search_text(expression)
  if normalized_expression == "" then return false end

  local padded_name = " " .. normalized_name .. " "
  local needle = " " .. normalized_expression .. " "
  local start_pos, end_pos = padded_name:find(needle, 1, true)
  if not start_pos then return false end

  if reject_following_number then
    local suffix = padded_name:sub(end_pos + 1)
    if suffix:match("^%s*%d+") then return false end
  end

  return true
end

DAW.REGIONS_MARKERS.parse_location_label = function(label)
  label = trim(tostring(label or ""))
  local base_label, bars = label:match("^(.-)%s+[Bb][Aa][Rr]%s+(%d+)%s*$")
  if base_label and bars then
    return trim(base_label), math.max(0, tonumber(bars) or 0)
  end
  return label, 0
end

DAW.REGIONS_MARKERS.search_expressions_for_base = function(base_label)
  base_label = trim(tostring(base_label or ""))
  local expressions = {
    {text = base_label, reject_following_number = false},
  }

  -- "Chorus", "Verse", "Pre", etc. are accepted as the unnumbered first
  -- occurrence when the surface asks for Chorus 1, Verse 1, or Pre 1.
  -- Reject a following number during the fallback so "Chorus" cannot
  -- accidentally bind to "Chorus 2".
  local unnumbered = base_label:match("^(.-)%s+1%s*$")
  if unnumbered and trim(unnumbered) ~= "" then
    expressions[#expressions + 1] = {
      text = trim(unnumbered),
      reject_following_number = true,
    }
  end

  return expressions
end

DAW.REGIONS_MARKERS.shift_position_by_bars = function(position, bars, preserve_beat_in_measure)
  position = tonumber(position) or 0
  bars = math.floor(tonumber(bars) or 0)
  if bars == 0 then return position end

  if r.TimeMap2_timeToBeats and r.TimeMap2_beatsToTime then
    local beats_in_measure, measure_index = r.TimeMap2_timeToBeats(0, position)
    if measure_index ~= nil then
      local beat = preserve_beat_in_measure and (tonumber(beats_in_measure) or 0) or 0
      return r.TimeMap2_beatsToTime(0, beat, math.max(0, measure_index + bars))
    end
  end

  return position
end

DAW.REGIONS_MARKERS.resolve_location_target = function(targets, label)
  local base_label, bar_offset = DAW.REGIONS_MARKERS.parse_location_label(label)
  local base_target = nil
  local matched_expression = nil

  for _, expression in ipairs(DAW.REGIONS_MARKERS.search_expressions_for_base(base_label)) do
    base_target = DAW.REGIONS_MARKERS.find_best_target_in(
      targets,
      expression.text,
      expression.reject_following_number
    )
    if base_target then
      matched_expression = expression.text
      break
    end
  end

  if not base_target then return nil end
  if bar_offset <= 0 then return base_target end

  local shifted_position = DAW.REGIONS_MARKERS.shift_position_by_bars(
    base_target.pos,
    bar_offset,
    true
  )

  -- Derived Bar 4 / 8 / 12 locations are point destinations calculated from
  -- the matched base section. They are not separately searched markers.
  return {
    is_region = false,
    derived = true,
    derived_from_region = base_target.is_region and true or false,
    base_target = base_target,
    base_label = base_label,
    matched_expression = matched_expression,
    bar_offset = bar_offset,
    pos = shifted_position,
    region_end = shifted_position,
    name = base_target.name,
    marker_region_index = base_target.marker_region_index,
  }
end

DAW.REGIONS_MARKERS.enumerate_targets = function()
  local targets = {}
  local _, marker_count, region_count = r.CountProjectMarkers(0)
  local total = (marker_count or 0) + (region_count or 0)

  for index = 0, total - 1 do
    local retval, is_region, pos, region_end, name, marker_region_index = r.EnumProjectMarkers3(0, index)
    if retval then
      targets[#targets + 1] = {
        is_region = is_region and true or false,
        pos = tonumber(pos) or 0,
        region_end = tonumber(region_end) or tonumber(pos) or 0,
        name = tostring(name or ""),
        marker_region_index = marker_region_index,
      }
    end
  end

  return targets
end

DAW.REGIONS_MARKERS.target_cache_state_signature = function()
  local _, marker_count, region_count = r.CountProjectMarkers(0)
  local project_state = r.GetProjectStateChangeCount and r.GetProjectStateChangeCount(0) or 0
  return table.concat({
    tostring(project_state),
    tostring(marker_count or 0),
    tostring(region_count or 0),
  }, ":")
end

DAW.REGIONS_MARKERS.find_best_target_in = function(targets, expression, reject_following_number)
  local normalized_expression = DAW.REGIONS_MARKERS.normalize_search_text(expression)
  local best = nil

  for _, target in ipairs(targets or {}) do
    local normalized_name = DAW.REGIONS_MARKERS.normalize_search_text(target.name)
    if DAW.REGIONS_MARKERS.name_matches_expression(
        normalized_name,
        normalized_expression,
        reject_following_number
      ) then
      local candidate = {
        target = target,
        region_rank = target.is_region and 0 or 1,
        exact_rank = (normalized_name == normalized_expression) and 0 or 1,
        extra_length = math.max(0, #normalized_name - #normalized_expression),
      }

      if not best
          or candidate.region_rank < best.region_rank
          or (candidate.region_rank == best.region_rank and candidate.exact_rank < best.exact_rank)
          or (candidate.region_rank == best.region_rank and candidate.exact_rank == best.exact_rank
              and candidate.extra_length < best.extra_length)
          or (candidate.region_rank == best.region_rank and candidate.exact_rank == best.exact_rank
              and candidate.extra_length == best.extra_length and target.pos < best.target.pos) then
        best = candidate
      end
    end
  end

  return best and best.target or nil
end

DAW.REGIONS_MARKERS.all_location_labels = function()
  local result = {}
  for row = 2, 9 do
    for col = 1, 8 do
      local label = DAW.REGIONS_MARKERS.LOCATION_LABELS[row]
        and DAW.REGIONS_MARKERS.LOCATION_LABELS[row][col]
      if label then result[#result + 1] = label end
    end
  end
  return result
end

DAW.REGIONS_MARKERS.refresh_targets = function(force)
  local now = r.time_precise()
  if not force
      and (now - (DAW.REGIONS_MARKERS.last_target_cache_refresh_time or -1000000))
        < DAW.REGIONS_MARKERS.TARGET_CACHE_REFRESH_SECONDS then
    return false
  end

  DAW.REGIONS_MARKERS.last_target_cache_refresh_time = now
  local signature = DAW.REGIONS_MARKERS.target_cache_state_signature()
  if not force and signature == DAW.REGIONS_MARKERS.target_cache_signature then
    return false
  end

  local targets = DAW.REGIONS_MARKERS.enumerate_targets()
  local cache = {}
  for _, label in ipairs(DAW.REGIONS_MARKERS.all_location_labels()) do
    cache[label] = DAW.REGIONS_MARKERS.resolve_location_target(targets, label)
  end

  DAW.REGIONS_MARKERS.target_cache = cache
  DAW.REGIONS_MARKERS.target_cache_signature = signature
  DAW.REGIONS_MARKERS.active_location_cache_key = nil
  DAW.REGIONS_MARKERS.active_location_cache_label = nil
  DAW.REGIONS_MARKERS.last_hardware_state_signature = nil
  return true
end

DAW.REGIONS_MARKERS.target_for_label = function(label)
  DAW.REGIONS_MARKERS.refresh_targets(false)
  return DAW.REGIONS_MARKERS.target_cache[label]
end

DAW.REGIONS_MARKERS.reference_position = function()
  local playing = ((r.GetPlayState() or 0) & 1) == 1
  return playing and r.GetPlayPosition() or r.GetCursorPosition()
end

DAW.REGIONS_MARKERS.base_section_definitions = function()
  local definitions = {}
  local by_base_label = {}

  for row = 2, 9 do
    for col = 1, 8 do
      local label = DAW.REGIONS_MARKERS.LOCATION_LABELS[row]
        and DAW.REGIONS_MARKERS.LOCATION_LABELS[row][col]
      if label and label ~= "Start" and label ~= "End" then
        local base_label, bar_offset = DAW.REGIONS_MARKERS.parse_location_label(label)
        local definition = by_base_label[base_label]
        if not definition then
          definition = {
            base_label = base_label,
            labels_by_offset = {},
          }
          by_base_label[base_label] = definition
          definitions[#definitions + 1] = definition
        end
        definition.labels_by_offset[bar_offset] = label
      end
    end
  end

  return definitions
end

DAW.REGIONS_MARKERS.section_instances = function()
  DAW.REGIONS_MARKERS.refresh_targets(false)

  local sections = {}
  for _, definition in ipairs(DAW.REGIONS_MARKERS.base_section_definitions()) do
    local target = DAW.REGIONS_MARKERS.target_cache[definition.base_label]
    if target then
      sections[#sections + 1] = {
        base_label = definition.base_label,
        labels_by_offset = definition.labels_by_offset,
        target = target,
        start_pos = tonumber(target.pos) or 0,
        region_end = target.is_region and (tonumber(target.region_end) or 0) or nil,
      }
    end
  end

  table.sort(sections, function(a, b)
    if a.start_pos ~= b.start_pos then return a.start_pos < b.start_pos end
    if a.target.is_region ~= b.target.is_region then return a.target.is_region end
    return tostring(a.base_label) < tostring(b.base_label)
  end)

  local project_end = r.GetProjectLength and (tonumber(r.GetProjectLength(0)) or 0) or 0
  for index, section in ipairs(sections) do
    local next_section = sections[index + 1]
    local next_start = next_section and next_section.start_pos or nil

    -- A named section continues until the next named song section begins.
    -- For the final section, use its region end when available, otherwise the
    -- end of the project. This keeps the fourth pad active for bars 13 onward.
    if next_start and next_start > section.start_pos then
      section.end_pos = next_start
    elseif section.region_end and section.region_end > section.start_pos then
      section.end_pos = section.region_end
    else
      section.end_pos = math.max(section.start_pos, project_end)
    end
  end

  return sections
end

DAW.REGIONS_MARKERS.measure_index_at = function(position)
  if not r.TimeMap2_timeToBeats then return nil end
  local _, measure_index = r.TimeMap2_timeToBeats(0, tonumber(position) or 0)
  return measure_index
end

DAW.REGIONS_MARKERS.segment_offset_for_position = function(section, position)
  local start_measure = DAW.REGIONS_MARKERS.measure_index_at(section.start_pos)
  local current_measure = DAW.REGIONS_MARKERS.measure_index_at(position)

  local bars_elapsed
  if start_measure ~= nil and current_measure ~= nil then
    bars_elapsed = math.max(0, current_measure - start_measure)
  else
    bars_elapsed = 0
  end

  if bars_elapsed >= 12 then return 12 end
  if bars_elapsed >= 8 then return 8 end
  if bars_elapsed >= 4 then return 4 end
  return 0
end

DAW.REGIONS_MARKERS.segment_label_for_section = function(section, position)
  local wanted_offset = DAW.REGIONS_MARKERS.segment_offset_for_position(section, position)

  -- Use the requested four-bar segment when the layout has it. For short
  -- one-pad sections such as Solo, retain the base section pad.
  for _, offset in ipairs({wanted_offset, 12, 8, 4, 0}) do
    if offset <= wanted_offset and section.labels_by_offset[offset] then
      return section.labels_by_offset[offset]
    end
  end
  return section.labels_by_offset[0]
end

DAW.REGIONS_MARKERS.active_location_label = function()
  DAW.REGIONS_MARKERS.refresh_targets(false)

  local pos = DAW.REGIONS_MARKERS.reference_position()
  local cache_key = string.format(
    "%.3f|%s",
    tonumber(pos) or 0,
    tostring(DAW.REGIONS_MARKERS.target_cache_signature or "")
  )
  if cache_key == DAW.REGIONS_MARKERS.active_location_cache_key then
    return DAW.REGIONS_MARKERS.active_location_cache_label
  end

  local active_section = nil
  local epsilon = DAW.REGIONS_MARKERS.ACTIVE_BOUNDARY_EPSILON_SECONDS or 0.020

  -- Choose the most recently entered section. At a boundary this means the
  -- newly starting Chorus wins over the Verse that has just ended.
  for _, section in ipairs(DAW.REGIONS_MARKERS.section_instances()) do
    if pos + epsilon >= section.start_pos
        and pos < (section.end_pos or section.start_pos) then
      if not active_section or section.start_pos >= active_section.start_pos then
        active_section = section
      end
    end
  end

  local active_label = active_section
    and DAW.REGIONS_MARKERS.segment_label_for_section(active_section, pos)
    or nil

  DAW.REGIONS_MARKERS.active_location_cache_key = cache_key
  DAW.REGIONS_MARKERS.active_location_cache_label = active_label
  return active_label
end

DAW.REGIONS_MARKERS.offset_position = function(target_pos)
  target_pos = tonumber(target_pos) or 0
  local bars = math.max(0, math.floor(tonumber(DAW.REGIONS_MARKERS.start_offset_bars) or 0))
  if bars <= 0 then return target_pos end

  return DAW.REGIONS_MARKERS.shift_position_by_bars(target_pos, -bars, false)
end

DAW.REGIONS_MARKERS.jump_to_target = function(target, label)
  if not target then
    last_action = 'Regions & Markers: no matching marker or region for "' .. tostring(label or "") .. '"'
    return false
  end

  local target_pos = DAW.REGIONS_MARKERS.offset_position(target.pos)
  local playing = ((r.GetPlayState() or 0) & 1) == 1
  r.SetEditCurPos(target_pos, true, playing)

  if not playing and DAW.REGIONS_MARKERS.playback_on_click then
    r.CSurf_OnPlay()
  end

  local target_kind
  if target.derived then
    target_kind = "calculated +" .. tostring(target.bar_offset or 0) .. " bar location from"
  else
    target_kind = target.is_region and "region" or "marker"
  end

  last_action = string.format(
    'Regions & Markers: %s "%s" -> %.3f%s',
    target_kind,
    target.name ~= "" and target.name or tostring(label or ""),
    target_pos,
    DAW.REGIONS_MARKERS.playback_on_click and " | playback on click" or ""
  )
  return true
end

DAW.REGIONS_MARKERS.find_region_containing = function(pos)
  pos = tonumber(pos) or DAW.REGIONS_MARKERS.reference_position()
  local best = nil

  for _, target in ipairs(DAW.REGIONS_MARKERS.enumerate_targets()) do
    if target.is_region and pos >= target.pos and pos < target.region_end then
      if not best or (target.region_end - target.pos) < (best.region_end - best.pos) then
        best = target
      end
    end
  end

  return best
end

DAW.REGIONS_MARKERS.toggle_loop_section = function()
  local region = DAW.REGIONS_MARKERS.find_region_containing(DAW.REGIONS_MARKERS.reference_position())
  if not region then
    last_action = "Regions & Markers: no containing region is available to loop"
    return false
  end

  local repeat_enabled = r.GetSetRepeat(-1) == 1
  local loop_start, loop_end = 0, 0
  if r.GetSet_LoopTimeRange2 then
    loop_start, loop_end = r.GetSet_LoopTimeRange2(0, false, true, 0, 0, false)
  end

  local already_this_region =
    math.abs((tonumber(loop_start) or 0) - region.pos) < 0.0001
    and math.abs((tonumber(loop_end) or 0) - region.region_end) < 0.0001

  if repeat_enabled and already_this_region then
    r.GetSetRepeat(0)
    last_action = 'Regions & Markers: disabled loop for "' .. region.name .. '"'
  else
    if r.GetSet_LoopTimeRange2 then
      r.GetSet_LoopTimeRange2(0, true, true, region.pos, region.region_end, false)
    end
    r.GetSetRepeat(1)
    last_action = 'Regions & Markers: looped region "' .. region.name .. '"'
  end
  return true
end

DAW.REGIONS_MARKERS.adjacent_targets = function()
  local by_position = {}
  for _, target in ipairs(DAW.REGIONS_MARKERS.enumerate_targets()) do
    local key = string.format("%.9f", target.pos)
    local existing = by_position[key]
    if not existing or (target.is_region and not existing.is_region) then
      by_position[key] = target
    end
  end

  local result = {}
  for _, target in pairs(by_position) do result[#result + 1] = target end
  table.sort(result, function(a, b) return a.pos < b.pos end)
  return result
end

DAW.REGIONS_MARKERS.jump_adjacent = function(direction)
  direction = (tonumber(direction) or 1) >= 0 and 1 or -1
  local current = DAW.REGIONS_MARKERS.reference_position()
  local targets = DAW.REGIONS_MARKERS.adjacent_targets()
  local selected = nil
  local eps = 0.000001

  for _, target in ipairs(targets) do
    if direction > 0 and target.pos > current + eps then
      selected = target
      break
    elseif direction < 0 and target.pos < current - eps then
      selected = target
    end
  end

  if not selected and #targets > 0 then
    selected = (direction > 0) and targets[1] or targets[#targets]
  end

  if not selected then
    last_action = "Regions & Markers: no project markers or regions exist"
    return false
  end

  return DAW.REGIONS_MARKERS.jump_to_target(
    selected,
    direction > 0 and "Next Section" or "Previous Section"
  )
end

DAW.REGIONS_MARKERS.track_picker_page_for_selection = function()
  local track = r.GetSelectedTrack(0, 0)
  if not track then return 1 end
  local number = math.floor((r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER") or 1) + 0.5)
  if number <= 40 then return 1 end
  if number <= 80 then return 2 end
  return 3
end

DAW.REGIONS_MARKERS.home_duplicate_info = function(row, col)
  local raw_label = labels[1][row][col]
  local normalized = normalize_label(raw_label)
  local info = {
    label = normalized,
    kind = "home",
    home_label = normalized,
    hardware = DAW.REGIONS_MARKERS.home_hardware_color(row, col),
    gui = DAW.REGIONS_MARKERS.home_gui_color(row, col),
  }

  if DAW.page_number_from_label(normalized) == 1 then
    info.label = "Previous Section"
    info.kind = "previous_section"
  elseif DAW.page_number_from_label(normalized) == 2 then
    info.label = "Next Section"
    info.kind = "next_section"
  elseif DAW.page_number_from_label(normalized) == 3 then
    info.label = "Loop Section"
    info.kind = "loop_section"
  elseif normalized == "Page Status" then
    info.kind = "status"
  end

  return info
end

DAW.REGIONS_MARKERS.location_color = function(row, col, gui)
  local fallback_hardware = 0x01
  local fallback_gui = 0x333333FF

  if row == 2 and col <= 4 then
    return DAW.REGIONS_MARKERS.home_color_by_label("Scroll Down", gui, gui and fallback_gui or fallback_hardware)
  elseif row >= 3 and row <= 5 then
    return DAW.REGIONS_MARKERS.home_color_by_label(
      col <= 4 and "Save Take" or "Restart Take",
      gui,
      gui and fallback_gui or fallback_hardware
    )
  elseif row == 6 then
    return gui
      and DAW.REGIONS_MARKERS.home_gui_color(col <= 4 and 2 or 6, 1)
      or DAW.REGIONS_MARKERS.home_hardware_color(col <= 4 and 2 or 6, 1)
  elseif row == 7 then
    if col <= 4 then
      return gui and DAW.REGIONS_MARKERS.home_gui_color(2, 1) or DAW.REGIONS_MARKERS.home_hardware_color(2, 1)
    end
    return gui and DAW.REGIONS_MARKERS.palette_gui_color(0x0B) or 0x0B
  elseif row == 8 then
    if col <= 4 then
      return gui and DAW.REGIONS_MARKERS.home_gui_color(2, 1) or DAW.REGIONS_MARKERS.home_hardware_color(2, 1)
    end
    return gui and DAW.REGIONS_MARKERS.palette_gui_color(0x02) or 0x02
  elseif row == 9 then
    if col <= 4 then
      -- Outro uses the exact dimmer green from the HOME-page bottom-left pad.
      return gui
        and DAW.REGIONS_MARKERS.home_gui_color(9, 1)
        or DAW.REGIONS_MARKERS.home_hardware_color(9, 1)
    end
    return gui and DAW.REGIONS_MARKERS.palette_gui_color(0x02) or 0x02
  end

  return gui and fallback_gui or fallback_hardware
end

DAW.REGIONS_MARKERS.project_boundary_target = function(which)
  if which == "start" then
    return {pos = 0, name = "Start", boundary = "start"}
  end

  local project_end = r.GetProjectLength and (tonumber(r.GetProjectLength(0)) or 0) or 0
  return {pos = project_end, name = "End", boundary = "end"}
end

DAW.REGIONS_MARKERS.jump_to_project_boundary = function(which)
  local target = DAW.REGIONS_MARKERS.project_boundary_target(which)
  local target_pos = tonumber(target.pos) or 0
  local playing = ((r.GetPlayState() or 0) & 1) == 1

  -- Start and End are absolute project boundaries. Do not apply the optional
  -- one- or two-bar pre-roll to these gray utility buttons.
  r.SetEditCurPos(target_pos, true, playing)

  -- Playback on Click is useful for Start. Starting playback from End while
  -- stopped is not useful, so End only relocates the cursor or running playhead.
  if which == "start" and not playing and DAW.REGIONS_MARKERS.playback_on_click then
    r.CSurf_OnPlay()
  end

  last_action = which == "start"
    and "Regions & Markers: moved to project start"
    or "Regions & Markers: moved to project end"
  return true
end

DAW.REGIONS_MARKERS.cell_info = function(row, col)
  row, col = tonumber(row), tonumber(col)
  if not row or not col or row < 1 or row > 9 or col < 1 or col > 9 then return nil end

  if row == 1 and col <= 8 then
    return DAW.REGIONS_MARKERS.HEADER[col]
  elseif col == 9 then
    return DAW.REGIONS_MARKERS.home_duplicate_info(row, col)
  elseif row >= 7 and row <= 9 and col >= 6 and col <= 8 then
    return DAW.REGIONS_MARKERS.home_duplicate_info(row, col)
  elseif row == 2 and col == 5 then
    return {
      label = "Playback on Click",
      kind = "playback_on_click",
      hardware = DAW.REGIONS_MARKERS.ROW_1_CONTROL_HARDWARE[col],
      gui = DAW.REGIONS_MARKERS.ROW_1_CONTROL_GUI[col],
    }
  elseif row == 2 and col >= 6 and col <= 8 then
    local bars = 8 - col
    return {
      label = bars == 0 and "Start Immediate" or ("Start - " .. tostring(bars) .. " Bars"),
      kind = "start_offset",
      value = bars,
      hardware = DAW.REGIONS_MARKERS.ROW_1_CONTROL_HARDWARE[col],
      gui = DAW.REGIONS_MARKERS.ROW_1_CONTROL_GUI[col],
    }
  end

  local label = DAW.REGIONS_MARKERS.LOCATION_LABELS[row]
    and DAW.REGIONS_MARKERS.LOCATION_LABELS[row][col]
  if label == "Start" or label == "End" then
    local which = label:lower()
    return {
      label = label,
      kind = "project_boundary",
      value = which,
      target = DAW.REGIONS_MARKERS.project_boundary_target(which),
      hardware = DAW.REGIONS_MARKERS.location_color(row, col, false),
      gui = DAW.REGIONS_MARKERS.location_color(row, col, true),
    }
  elseif label then
    return {
      label = label,
      kind = "location",
      target = DAW.REGIONS_MARKERS.target_for_label(label),
      hardware = DAW.REGIONS_MARKERS.location_color(row, col, false),
      gui = DAW.REGIONS_MARKERS.location_color(row, col, true),
    }
  end

  return {label = " ", kind = "empty", hardware = 0x00, gui = CUSTOM_FADER_OFF_COLOR}
end

DAW.REGIONS_MARKERS.cell_available = function(info)
  if not info or info.kind == "empty" then return false end
  if info.kind == "location" then
    -- Song-map buttons remain visibly present even before the corresponding
    -- marker or region has been created. An unresolved press reports the
    -- missing location rather than hiding or dimming the section.
    return true
  end
  if info.kind == "home" then
    return ACTIONS[info.home_label] ~= nil or HOLD_ACTIONS[info.home_label] ~= nil
  end
  return true
end

DAW.REGIONS_MARKERS.cell_pulses = function(info)
  if not info then return false end
  if info.kind == "location" then
    return info.label == DAW.REGIONS_MARKERS.active_location_label()
  elseif info.kind == "playback_on_click" then
    return DAW.REGIONS_MARKERS.playback_on_click
  elseif info.kind == "start_offset" then
    return DAW.REGIONS_MARKERS.start_offset_bars == info.value
  elseif info.kind == "loop_section" then
    return r.GetSetRepeat(-1) == 1
  elseif info.kind == "home" then
    return is_label_active(info.home_label)
  end
  return false
end

DAW.REGIONS_MARKERS.cell_hardware_color = function(info)
  return info and info.hardware or 0x00
end

DAW.REGIONS_MARKERS.cell_gui_color = function(info)
  return info and info.gui or CUSTOM_FADER_OFF_COLOR
end

DAW.REGIONS_MARKERS.make_hardware_state_signature = function()
  DAW.REGIONS_MARKERS.refresh_targets(false)
  local parts = {
    "regions-markers",
    tostring(DAW.REGIONS_MARKERS.target_cache_signature or ""),
    DAW.REGIONS_MARKERS.playback_on_click and "play:1" or "play:0",
    "offset:" .. tostring(DAW.REGIONS_MARKERS.start_offset_bars or 0),
    "repeat:" .. tostring(r.GetSetRepeat(-1)),
    grid_visible and "grid:1" or "grid:0",
  }

  for row = 1, 9 do
    for col = 1, 9 do
      local info = DAW.REGIONS_MARKERS.cell_info(row, col)
      parts[#parts + 1] = table.concat({
        tostring(row),
        tostring(col),
        DAW.REGIONS_MARKERS.cell_available(info) and "1" or "0",
        DAW.REGIONS_MARKERS.cell_pulses(info) and "1" or "0",
      }, ":")
    end
  end

  return table.concat(parts, "|")
end

DAW.REGIONS_MARKERS.build_lighting_message = function()
  DAW.REGIONS_MARKERS.refresh_targets(false)
  local bytes = {0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03}

  for index = 1, 81 do
    local row = math.floor((index - 1) / 9) + 1
    local col = ((index - 1) % 9) + 1
    local info = DAW.REGIONS_MARKERS.cell_info(row, col)
    local flash = info
      and info.kind == "home"
      and info.home_label == "Show/Hide This Grid"
      and not grid_visible
    local lighting_type = flash and 0x01 or (DAW.REGIONS_MARKERS.cell_pulses(info) and 0x02 or 0x00)
    local color = DAW.REGIONS_MARKERS.cell_hardware_color(info)
    local flash_base_color = 0x00
    local label = info and (info.home_label or info.label) or ""
    lighting_type, color, flash_base_color = DAW.resolve_palette_lighting(
      label, lighting_type, color, flash_base_color
    )
    DAW.append_palette_colourspec(
      bytes,
      lighting_type,
      hex_string_to_byte(Lpxlib.pad_addresses[index]),
      color,
      flash_base_color
    )
  end

  bytes[#bytes + 1] = 0xF7
  return bytes
end

DAW.REGIONS_MARKERS.send_lighting = function(silent)
  if not send_bytes(DAW.REGIONS_MARKERS.build_lighting_message()) then return false end
  DAW.REGIONS_MARKERS.last_hardware_state_signature =
    DAW.REGIONS_MARKERS.make_hardware_state_signature()
  if not silent then last_action = "Sent Regions & Markers surface lighting" end
  return true
end

DAW.REGIONS_MARKERS.refresh_hardware_state = function(force)
  if not initialized or surface_mode ~= "REGIONS_MARKERS" then return false end
  local signature = DAW.REGIONS_MARKERS.make_hardware_state_signature()
  if force or signature ~= DAW.REGIONS_MARKERS.last_hardware_state_signature then
    return DAW.REGIONS_MARKERS.send_lighting(true)
  end
  return false
end

DAW.REGIONS_MARKERS.enter = function()
  if not send_programmer_mode() then return false end
  DAW.active_preset = 31
  DAW.REGIONS_MARKERS.last_hardware_state_signature = nil
  DAW.REGIONS_MARKERS.refresh_targets(true)
  surface_mode = "REGIONS_MARKERS"
  initialized = true
  DAW.REGIONS_MARKERS.send_lighting(true)
  last_action = "Preset 31: Regions & Markers"
  return true
end

DAW.REGIONS_MARKERS.run_home_duplicate = function(info, pressed)
  local label = info and info.home_label
  if not label then return false end
  local action = ACTIONS[label]
  local hold_action = HOLD_ACTIONS[label]

  if hold_action then
    if pressed then hold_action.press() else hold_action.release() end
    return true
  elseif pressed and action then
    action()
    return true
  end
  return false
end

DAW.REGIONS_MARKERS.dispatch_cell = function(row, col, pressed, source)
  local info = DAW.REGIONS_MARKERS.cell_info(row, col)
  if not info then return false end
  pressed = pressed and true or false

  if info.kind == "location" then
    if pressed then DAW.REGIONS_MARKERS.jump_to_target(info.target, info.label) end
  elseif info.kind == "project_boundary" then
    if pressed then DAW.REGIONS_MARKERS.jump_to_project_boundary(info.value) end
  elseif info.kind == "playback_on_click" then
    if pressed then
      DAW.REGIONS_MARKERS.playback_on_click = not DAW.REGIONS_MARKERS.playback_on_click
      last_action = DAW.REGIONS_MARKERS.playback_on_click
        and "Regions & Markers: playback on click enabled"
        or "Regions & Markers: playback on click disabled"
    end
  elseif info.kind == "start_offset" then
    if pressed then
      DAW.REGIONS_MARKERS.start_offset_bars = info.value
      last_action = info.value == 0
        and "Regions & Markers: start immediately"
        or ("Regions & Markers: start " .. tostring(info.value) .. " bar(s) early")
    end
  elseif info.kind == "previous_section" then
    if pressed then DAW.REGIONS_MARKERS.jump_adjacent(-1) end
  elseif info.kind == "next_section" then
    if pressed then DAW.REGIONS_MARKERS.jump_adjacent(1) end
  elseif info.kind == "loop_section" then
    if pressed then DAW.REGIONS_MARKERS.toggle_loop_section() end
  elseif info.kind == "preset" then
    if pressed then DAW.activate_preset(info.value) end
  elseif info.kind == "track_picker" then
    if pressed then DAW.TRACK_PICKER.enter(DAW.REGIONS_MARKERS.track_picker_page_for_selection()) end
  elseif info.kind == "track_viewer" then
    if pressed then DAW.TRACK_VIEWER.enter(nil) end
  elseif info.kind == "go_home" then
    if pressed then return_to_home_page_1("Regions & Markers: returned to HOME Page 1", false) end
  elseif info.kind == "action" then
    if pressed and ACTIONS[info.value] then ACTIONS[info.value]() end
  elseif info.kind == "home" then
    DAW.REGIONS_MARKERS.run_home_duplicate(info, pressed)
  elseif info.kind == "status" then
    if pressed then last_action = (source or "Regions & Markers") .. ": HOME Page 1 status" end
  end

  DAW.REGIONS_MARKERS.last_hardware_state_signature = nil
  DAW.REGIONS_MARKERS.refresh_hardware_state(true)
  return true
end

DAW.REGIONS_MARKERS.dispatch_index = function(index, pressed, source)
  if not index or index < 1 or index > 81 then return false end
  local row = math.floor((index - 1) / 9) + 1
  local col = ((index - 1) % 9) + 1
  return DAW.REGIONS_MARKERS.dispatch_cell(row, col, pressed, source)
end

------------------------------------------------------------
-- DAW SESSION MCP BUTTON MATRIX (MATRIX PRESETS)
------------------------------------------------------------
DAW.MATRIX.matrix_inner_note = function(row, col)
  return ((9 - row) * 10) + col -- top row 81..88; bottom row 11..18
end

DAW.MATRIX.matrix_right_cc = function(row)
  return ((9 - row) * 10) + 9 -- top 89; bottom 19
end

DAW.MATRIX.matrix_track_is_active = function(track, mode)
  if not track then return false end
  if mode == "select" or mode == "multiselect" then
    return r.IsTrackSelected(track)
  elseif mode == "mute" then
    return r.GetMediaTrackInfo_Value(track, "B_MUTE") > 0.5
  elseif mode == "solo" then
    return r.GetMediaTrackInfo_Value(track, "I_SOLO") > 0
  elseif mode == "arm" then
    return r.GetMediaTrackInfo_Value(track, "I_RECARM") > 0.5
  end
  return false
end

DAW.MATRIX.matrix_track_style = function(mcp_index, active)
  local row_style = DAW.MATRIX.ROW_STYLES[math.floor((mcp_index - 1) / 5) + 1]
  if not row_style then return 0x00 end
  return active and row_style.active or row_style.normal
end

DAW.MATRIX.matrix_tab_layout_for_mcp_index = function(mcp_index)
  return DAW.MATRIX.TAB_LAYOUTS[math.floor((mcp_index - 1) / 5) + 1]
end

DAW.MATRIX.matrix_preset_for_mode = function(mode)
  local scope = DAW.active_scope()
  local map = DAW.MATRIX.MODE_PRESET_BY_SCOPE[scope] or DAW.MATRIX.MODE_PRESET_BY_SCOPE.mcp
  return map[mode] or map.select
end

-- Colour every active-scope-visible track represented by the matrix system, not merely
-- the current forty-track viewport. Apply this only on matrix entry or when the
-- active visible-track structure changes; never from the live LED refresh loop.
DAW.MATRIX.apply_mcp_layout_tabs = function(force)
  refresh_mcp_track_cache(true)
  local scope = DAW.active_scope()
  local property = (scope == "tcp") and "P_TCP_LAYOUT" or "P_MCP_LAYOUT"
  local visible_tracks = DAW.active_visible_tracks()
  local identity = "matrix:" .. scope .. ":" .. tostring((scope == "tcp") and DAW.tcp_visible_track_signature or mcp_visible_track_signature)
  if not force and mcp_tab_state.active_slot == identity then return 0 end

  clear_custom_fader_mcp_layout_tabs()

  local changed = 0
  local confirmed = 0
  local failed = {}
  local limit = math.min(#visible_tracks, DAW.MATRIX.maximum_track_count)

  for mcp_index = 1, limit do
    local track = visible_tracks[mcp_index]
    local desired_layout = DAW.MATRIX.matrix_tab_layout_for_mcp_index(mcp_index)
    if track and desired_layout then
      local key = tostring(track)
      local _, current_layout = r.GetSetMediaTrackInfo_String(track, property, "", false)
      mcp_tab_state.managed_layouts[key] = {track = track, layout = current_layout, property = property}

      if current_layout ~= desired_layout then
        r.GetSetMediaTrackInfo_String(track, property, desired_layout, true)
        changed = changed + 1
      end

      local _, assigned_layout = r.GetSetMediaTrackInfo_String(track, property, "", false)
      if assigned_layout == desired_layout then
        confirmed = confirmed + 1
      else
        failed[#failed + 1] = string.format("%d:%s", mcp_index, desired_layout)
      end
    end
  end

  mcp_tab_state.active_slot = identity
  if changed > 0 and r.UpdateArrange then r.UpdateArrange() end

  if #failed == 0 then
    mcp_tab_state.status = string.format(
      "Applied matrix %s tabs: %d confirmed (%d changed)",
      DAW.scope_label(scope),
      confirmed,
      changed
    )
  else
    mcp_tab_state.status = string.format(
      "Matrix %s tab warning: %d assignments did not read back (%s)",
      DAW.scope_label(scope),
      #failed,
      table.concat(failed, ", ")
    )
  end

  return changed
end

DAW.MATRIX.matrix_track_label = function(mcp_index)
  local track = DAW.active_visible_tracks()[mcp_index]
  return "Track " .. tostring(DAW.project_track_number(track, mcp_index))
end

DAW.MATRIX.matrix_track_at_cell = function(row, col)
  if col < 1 or col > 5 or row < 1 or row > 8 then return nil, nil end
  local mcp_index = (DAW.MATRIX.start_track or 1) + ((row - 1) * 5) + col - 1
  if mcp_index > DAW.MATRIX.maximum_track_count then return nil, mcp_index end
  return DAW.active_visible_tracks()[mcp_index], mcp_index
end

DAW.MATRIX.matrix_clear_selections = function()
  for index = 0, r.CountTracks(0) - 1 do
    local track = r.GetTrack(0, index)
    if track then r.SetTrackSelected(track, false) end
  end
  if r.TrackList_AdjustWindows then r.TrackList_AdjustWindows(false) end
  if r.UpdateArrange then r.UpdateArrange() end
  DAW.MATRIX.last_surface_signature = nil
  last_action = "Matrix: cleared all track selections"
  return true
end

DAW.MATRIX.matrix_select_all = function()
  for index = 1, math.min(#DAW.active_visible_tracks(), DAW.MATRIX.maximum_track_count) do
    local track = DAW.active_visible_tracks()[index]
    if track then r.SetTrackSelected(track, true) end
  end
  if r.TrackList_AdjustWindows then r.TrackList_AdjustWindows(false) end
  if r.UpdateArrange then r.UpdateArrange() end
  DAW.MATRIX.last_surface_signature = nil
  last_action = "Matrix: selected all " .. DAW.active_scope_label() .. "-visible tracks"
  return true
end

DAW.MATRIX.matrix_page_for_start_track = function(start_track)
  start_track = tonumber(start_track) or DAW.MATRIX.start_track or 1
  if start_track <= 40 then return 1 end
  if start_track <= 80 then return 2 end
  return 3
end

DAW.MATRIX.matrix_selected_project_track_number = function()
  local track = r.GetSelectedTrack(0, 0)
  if not track then return nil end
  return math.floor((r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER") or 0) + 0.5)
end

DAW.MATRIX.matrix_utility_is_wired = function(label)
  return label == "Clear Selections"
    or label == "Select All"
    or label == "Track View of Selected"
    or label == "Track Picker"
    or label == "Tracks 1-40"
    or label == "Tracks 41-80"
    or label == "Tracks 81-120"
    or ACTIONS[label] ~= nil
    or HOLD_ACTIONS[label] ~= nil
end

DAW.MATRIX.matrix_dispatch_named_action = function(label, pressed, source)
  if pressed and label == "Clear Selections" then return DAW.MATRIX.matrix_clear_selections() end
  if pressed and label == "Select All" then return DAW.MATRIX.matrix_select_all() end
  if pressed and label == "Track View of Selected" then
    local track_number = DAW.MATRIX.matrix_selected_project_track_number()
    if not track_number or track_number < 1 then
      last_action = "Track View of Selected: no project track is selected"
      return false
    end
    DAW.TRACK_PICKER.selected_track_number = track_number
    return DAW.TRACK_VIEWER.enter(track_number)
  end
  if pressed and label == "Track Picker" then
    return DAW.TRACK_PICKER.enter(DAW.MATRIX.matrix_page_for_start_track())
  end
  if pressed and label == "Tracks 1-40" then
    return DAW.MATRIX.matrix_select_window(1, "Matrix range: tracks 1-40")
  end
  if pressed and label == "Tracks 41-80" then
    return DAW.MATRIX.matrix_select_window(41, "Matrix range: tracks 41-80")
  end
  if pressed and label == "Tracks 81-120" then
    return DAW.MATRIX.matrix_select_window(81, "Matrix range: tracks 81-120")
  end
  local action = ACTIONS[label]
  local hold_action = HOLD_ACTIONS[label]
  if hold_action then
    if pressed then hold_action.press() else hold_action.release() end
    return true
  elseif pressed and action then
    action()
    return true
  end
  if pressed then last_action = (source or "Matrix") .. ": " .. tostring(label) .. " is not wired yet" end
  return false
end

DAW.MATRIX.matrix_apply_track_press = function(track, mcp_index)
  if not track then
    last_action = "" .. DAW.active_scope_label() .. "-visible track " .. tostring(mcp_index) .. " is unavailable"
    return false
  end

  local mode = DAW.MATRIX.active_mode
  if mode == "multiselect" then
    r.SetTrackSelected(track, not r.IsTrackSelected(track))
  elseif mode == "select" then
    r.SetOnlyTrackSelected(track)
  elseif mode == "mute" then
    local value = r.GetMediaTrackInfo_Value(track, "B_MUTE") > 0.5 and 0 or 1
    r.SetMediaTrackInfo_Value(track, "B_MUTE", value)
  elseif mode == "solo" then
    local value = r.GetMediaTrackInfo_Value(track, "I_SOLO") > 0 and 0 or 1
    r.SetMediaTrackInfo_Value(track, "I_SOLO", value)
  elseif mode == "arm" then
    local value = r.GetMediaTrackInfo_Value(track, "I_RECARM") > 0.5 and 0 or 1
    r.SetMediaTrackInfo_Value(track, "I_RECARM", value)
  end

  if r.TrackList_AdjustWindows then r.TrackList_AdjustWindows(false) end
  if r.UpdateArrange then r.UpdateArrange() end
  DAW.MATRIX.last_surface_signature = nil
  last_action = string.format("Matrix %s: " .. DAW.active_scope_label() .. "-visible track %d", DAW.MATRIX.MODE_LABELS[mode] or mode, mcp_index)
  return true
end

DAW.MATRIX.matrix_max_start_track = function()
  local last_possible = math.max(1, math.min(
    DAW.MATRIX.maximum_track_count - DAW.MATRIX.visible_track_count + 1,
    #DAW.active_visible_tracks()
  ))
  return last_possible
end

DAW.MATRIX.matrix_window_available = function(start_track)
  start_track = tonumber(start_track) or -1
  return start_track >= 1
    and start_track <= DAW.MATRIX.matrix_max_start_track()
    and start_track <= DAW.MATRIX.maximum_track_count
    and DAW.active_visible_tracks()[start_track] ~= nil
end

DAW.MATRIX.matrix_top_row_available = function(slot)
  local start_track = DAW.MATRIX.start_track or 1
  if slot == 1 then return DAW.MATRIX.matrix_window_available(start_track + DAW.MATRIX.bank_step) end
  if slot == 2 then return DAW.MATRIX.matrix_window_available(start_track - DAW.MATRIX.bank_step) end
  if slot == 3 then return DAW.MATRIX.matrix_window_available(start_track - DAW.MATRIX.track_step) end
  if slot == 4 then return DAW.MATRIX.matrix_window_available(start_track + DAW.MATRIX.track_step) end
  if slot == 5 or slot == 6 or slot == 7 or slot == 8 then return true end
  return false
end

DAW.MATRIX.matrix_top_row_lines = function(slot)
  if slot == 1 then return {"BANK", "-40"} end
  if slot == 2 then return {"BANK", "+40"} end
  if slot == 3 then return {"STEP", "-10"} end
  if slot == 4 then return {"STEP", "+10"} end
  if slot == 5 then return {"GO", "HOME"} end
  if slot == 6 then return {"UNDO"} end
  if slot == 7 then return {"REDO"} end
  if slot == 8 then return {"PANIC!"} end
  return {" "}
end

DAW.MATRIX.matrix_top_row_color = function(slot)
  if slot == 1 or slot == 2 then return 0x25 end -- section / Bank family
  if slot == 3 or slot == 4 then return 0x21 end -- bar / Step family
  if slot == 5 then return 0x03 end -- GO HOME
  if slot == 6 then return 0x25 end -- UNDO blue
  if slot == 7 then return 0x15 end -- REDO green
  if slot == 8 then return 0x05 end -- PANIC red
  return DAW.MATRIX.matrix_top_row_available(slot) and 0x03 or 0x01
end

DAW.MATRIX.matrix_page_status_lines = function()
  return {DAW.active_scope_label(), "Matrix"}
end

DAW.MATRIX.matrix_page_status_color = function()
  return (DAW.active_scope() == "tcp") and 0x21 or 0x25
end

DAW.MATRIX.matrix_set_mode = function(mode)
  if not DAW.MATRIX.MODE_LABELS[mode] then return false end
  DAW.MATRIX.active_mode = mode
  DAW.active_preset = DAW.MATRIX.matrix_preset_for_mode(mode)
  DAW.MATRIX.last_surface_signature = nil
  last_action = "Matrix mode: " .. DAW.MATRIX.MODE_LABELS[mode]
  return true
end

DAW.MATRIX.matrix_surface_signature = function()
  local parts = {
    tostring(DAW.MATRIX.start_track or 1),
    tostring(DAW.MATRIX.active_mode or "select"),
    tostring(DAW.active_scope()),
    tostring((DAW.active_scope() == "tcp") and DAW.tcp_visible_track_signature or mcp_visible_track_signature),
    grid_visible and "grid:1" or "grid:0",
  }
  for row = 1, 8 do
    for col = 1, 5 do
      local track, mcp_index = DAW.MATRIX.matrix_track_at_cell(row, col)
      parts[#parts + 1] = tostring(mcp_index) .. ":" .. (DAW.MATRIX.matrix_track_is_active(track, DAW.MATRIX.active_mode) and "1" or "0")
    end
  end
  for row = 1, 8 do
    local info = DAW.MATRIX.RIGHT_UTILITY[row]
    if info and ACTIVE_STATE_CHECKS[info.label] then
      parts[#parts + 1] = info.label .. ":" .. (is_label_active(info.label) and "1" or "0")
    end
  end
  return table.concat(parts, "|")
end

DAW.MATRIX.matrix_send_note = function(note, color, pulse)
  DAW.send_bytes({pulse and 0x92 or 0x90, note, color or 0x00})
end

DAW.MATRIX.matrix_send_cc = function(cc, color, pulse)
  DAW.send_bytes({pulse and 0xB2 or 0xB0, cc, color or 0x00})
end

DAW.MATRIX.matrix_led_state_key = function(color, pulse)
  return string.format("%02X:%s", color or 0x00, pulse and "P" or "S")
end

DAW.MATRIX.matrix_reset_led_cache = function()
  DAW.MATRIX.led_cache = {notes = {}, ccs = {}}
end

DAW.MATRIX.matrix_send_note_if_changed = function(note, color, pulse, force)
  local cache = DAW.MATRIX.led_cache.notes
  local desired = DAW.MATRIX.matrix_led_state_key(color, pulse)
  if not force and cache[note] == desired then return false end
  DAW.MATRIX.matrix_send_note(note, color, pulse)
  cache[note] = desired
  return true
end

DAW.MATRIX.matrix_send_cc_if_changed = function(cc, color, pulse, force)
  local cache = DAW.MATRIX.led_cache.ccs
  local desired = DAW.MATRIX.matrix_led_state_key(color, pulse)
  if not force and cache[cc] == desired then return false end
  DAW.MATRIX.matrix_send_cc(cc, color, pulse)
  cache[cc] = desired
  return true
end

DAW.MATRIX.matrix_programmer_cell_state = function(row, col)
  local color = 0x00
  local pulse = false

  if row == 1 then
    if col <= 8 then
      color = DAW.MATRIX.matrix_top_row_color(col)
    else
      color = 0x25
    end
    return color, false
  end

  local matrix_row = row - 1
  if col <= 5 then
    local track, mcp_index = DAW.MATRIX.matrix_track_at_cell(matrix_row, col)
    if track then
      local track_active = DAW.MATRIX.matrix_track_is_active(track, DAW.MATRIX.active_mode)
      color = DAW.MATRIX.matrix_track_style(mcp_index, track_active)
      pulse = track_active
    end
  elseif col == 7 and matrix_row <= 5 then
    local mode = DAW.MATRIX.MODE_ORDER[matrix_row]
    color = DAW.MATRIX.MODE_COLORS[mode] or 0x00
    pulse = mode == DAW.MATRIX.active_mode
  elseif col <= 8 then
    local utility = DAW.MATRIX.MAIN_UTILITY[matrix_row] and DAW.MATRIX.MAIN_UTILITY[matrix_row][col]
    if utility then
      color = utility.color or 0x00
      pulse = ACTIVE_STATE_CHECKS[utility.label] and is_label_active(utility.label) or false
    end
  else
    local utility = DAW.MATRIX.RIGHT_UTILITY[matrix_row]
    if utility then
      color = utility.color or 0x00
      if utility.label == "Tracks 1-40" then
        pulse = DAW.MATRIX.matrix_page_for_start_track() == 1
      elseif utility.label == "Tracks 41-80" then
        pulse = DAW.MATRIX.matrix_page_for_start_track() == 2
      elseif utility.label == "Tracks 81-120" then
        pulse = DAW.MATRIX.matrix_page_for_start_track() == 3
      else
        pulse = ACTIVE_STATE_CHECKS[utility.label] and is_label_active(utility.label) or false
      end
    end
  end

  return color, pulse
end

DAW.MATRIX.build_programmer_lighting_message = function()
  local bytes = {0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03}

  for index = 1, 81 do
    local row = math.floor((index - 1) / 9) + 1
    local col = ((index - 1) % 9) + 1
    local color, pulse = DAW.MATRIX.matrix_programmer_cell_state(row, col)
    local utility = (row >= 2 and col <= 8)
      and DAW.MATRIX.MAIN_UTILITY[row - 1]
      and DAW.MATRIX.MAIN_UTILITY[row - 1][col]
      or nil
    local flash = utility
      and utility.label == "Show/Hide This Grid"
      and not grid_visible
    local lighting_type = flash and 0x01 or (pulse and 0x02 or 0x00)
    local flash_base_color = 0x00
    lighting_type, color, flash_base_color = DAW.resolve_palette_lighting(
      utility and utility.label or "", lighting_type, color or 0x00, flash_base_color
    )
    DAW.append_palette_colourspec(
      bytes,
      lighting_type,
      hex_string_to_byte(Lpxlib.pad_addresses[index]),
      color or 0x00,
      flash_base_color
    )
  end

  bytes[#bytes + 1] = 0xF7
  return bytes
end

DAW.MATRIX.send_programmer_lighting = function()
  return send_bytes(DAW.MATRIX.build_programmer_lighting_message())
end

DAW.refresh_matrix_surface = function(force_full)
  if surface_mode ~= "PROGRAMMER_TRACK_MATRIX" then return false end
  refresh_mcp_track_cache(false)
  local signature = DAW.MATRIX.matrix_surface_signature()
  if not force_full and signature == DAW.MATRIX.last_surface_signature then return false end
  DAW.MATRIX.last_surface_signature = signature
  return DAW.MATRIX.send_programmer_lighting()
end

DAW.MATRIX.matrix_select_window = function(start_track, reason)
  refresh_mcp_track_cache(true)
  start_track = math.max(1, math.floor(tonumber(start_track) or 1))
  if not DAW.MATRIX.matrix_window_available(start_track) then
    last_action = "Matrix window starting at " .. DAW.active_scope_label() .. "-visible track " .. tostring(start_track) .. " is unavailable"
    DAW.refresh_matrix_surface(true)
    return false
  end
  DAW.MATRIX.start_track = start_track
  DAW.MATRIX.last_surface_signature = nil
  DAW.refresh_matrix_surface(true)
  last_action = reason or string.format("Matrix window: " .. DAW.active_scope_label() .. "-visible tracks %d-%d", start_track, math.min(start_track + 39, #DAW.active_visible_tracks(), DAW.MATRIX.maximum_track_count))
  return true
end

DAW.MATRIX.matrix_handle_top_row_press = function(slot, source)
  local start_track = DAW.MATRIX.start_track or 1
  if slot == 1 then
    if DAW.MATRIX.matrix_top_row_available(slot) then return DAW.MATRIX.matrix_select_window(start_track + 40, "Matrix bank up") end
  elseif slot == 2 then
    if DAW.MATRIX.matrix_top_row_available(slot) then return DAW.MATRIX.matrix_select_window(start_track - 40, "Matrix bank down") end
  elseif slot == 3 then
    if DAW.MATRIX.matrix_top_row_available(slot) then return DAW.MATRIX.matrix_select_window(start_track - 10, "Matrix track window down") end
  elseif slot == 4 then
    if DAW.MATRIX.matrix_top_row_available(slot) then return DAW.MATRIX.matrix_select_window(start_track + 10, "Matrix track window up") end
  elseif slot == 5 then
    return_to_home_page_1((source or "Matrix") .. ": returned to HOME Page 1", false)
    return true
  elseif slot == 6 then
    ACTIONS["UNDO"]()
    return true
  elseif slot == 7 then
    ACTIONS["REDO"]()
    return true
  elseif slot == 8 then
    ACTIONS["PANIC!"]()
    return true
  end
  last_action = "Matrix top-row control unavailable"
  DAW.refresh_matrix_surface(true)
  return true
end

DAW.MATRIX.matrix_enter_preset = function(preset_number)
  local preset = DAW.PRESETS[preset_number]
  if not preset or preset.target ~= "matrix" then return false end
  if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end
  if not send_programmer_mode() then return false end
  active_custom_slot = nil
  DAW.active_preset = preset_number
  DAW.MATRIX.active_mode = preset.matrix_mode or "select"
  DAW.MATRIX.start_track = math.max(1, math.min(DAW.MATRIX.start_track or 1, DAW.MATRIX.matrix_max_start_track()))
  DAW.MATRIX.last_surface_signature = nil
  surface_mode = "PROGRAMMER_TRACK_MATRIX"
  initialized = true
  reset_custom_fader_feedback_state()
  DAW.MATRIX.apply_mcp_layout_tabs(true)
  DAW.refresh_matrix_surface(true)
  last_action = string.format(
    "Preset %d: %s | %s-visible tracks %d-%d",
    preset_number,
    preset.name,
    DAW.active_scope_label(),
    DAW.MATRIX.start_track,
    math.min(DAW.MATRIX.start_track + 39, #DAW.active_visible_tracks(), DAW.MATRIX.maximum_track_count)
  )
  return true
end

DAW.MATRIX.matrix_handle_inner_pad = function(row, col, pressed)
  if col <= 5 then
    if pressed then
      local track, mcp_index = DAW.MATRIX.matrix_track_at_cell(row, col)
      DAW.MATRIX.matrix_apply_track_press(track, mcp_index)
      DAW.refresh_matrix_surface(false)
    end
    return true
  end
  if col == 7 and row <= 5 then
    if pressed then
      DAW.MATRIX.matrix_set_mode(DAW.MATRIX.MODE_ORDER[row])
      DAW.refresh_matrix_surface(false)
    end
    return true
  end
  local utility = DAW.MATRIX.MAIN_UTILITY[row] and DAW.MATRIX.MAIN_UTILITY[row][col]
  if utility then
    DAW.MATRIX.matrix_dispatch_named_action(utility.label, pressed, "Matrix")
    DAW.MATRIX.last_surface_signature = nil
    DAW.refresh_matrix_surface(false)
    return true
  end
  return false
end

DAW.MATRIX.matrix_handle_right_row = function(row, pressed)
  local utility = DAW.MATRIX.RIGHT_UTILITY[row]
  if not utility then return false end
  DAW.MATRIX.matrix_dispatch_named_action(utility.label, pressed, "Matrix right column")
  DAW.MATRIX.last_surface_signature = nil
  DAW.refresh_matrix_surface(false)
  return true
end

DAW.MATRIX.matrix_handle_right_cc = function(cc, pressed)
  local row = math.floor((89 - cc) / 10) + 1
  return DAW.MATRIX.matrix_handle_right_row(row, pressed)
end

DAW.MATRIX.matrix_handle_programmer_index = function(index, pressed)
  if not index or index < 1 or index > 81 then return false end
  local row = math.floor((index - 1) / 9) + 1
  local col = ((index - 1) % 9) + 1

  if row == 1 then
    if pressed and col <= 8 then
      return DAW.MATRIX.matrix_handle_top_row_press(col, "Matrix Programmer top row")
    end
    return true
  end

  local matrix_row = row - 1
  if col <= 8 then
    return DAW.MATRIX.matrix_handle_inner_pad(matrix_row, col, pressed)
  elseif col == 9 then
    return DAW.MATRIX.matrix_handle_right_row(matrix_row, pressed)
  end
  return false
end

DAW.MATRIX.matrix_note_to_cell = function(note)
  local row_from_bottom = math.floor(note / 10)
  local col = note % 10
  if row_from_bottom < 1 or row_from_bottom > 8 or col < 1 or col > 8 then return nil, nil end
  return 9 - row_from_bottom, col
end


------------------------------------------------------------
-- VALUEVAULT FX CONTROL SURFACES (Presets 21-23)
------------------------------------------------------------
-- These functions intentionally live beside the existing MCP/TCP engines rather
-- than inside them. Presets 1-20 continue to use track lists; presets 21-23 use
-- the first Monitoring FX whose displayed name contains "ValueVault".
DAW.FX = DAW.FX or {
  active_page = 1,
  last_surface_signature = nil,
  last_feedback_poll_time = -1000000,
  pending_feedback_time = nil,
  last_sent_fader_values = {},
  pending_fader_values = {},
  hardware_holdoff_until = {},
  led_cache = {notes = {}, ccs = {}},
  label_cache = {},
  assignment_cache = {},
  label_cache_time = -1000000,
  active_button_page = 1,
  last_combo_button_signature = nil,

  -- ControllerFocus can republish its ValueVault assignment map while an FX
  -- surface is already visible. The GRID notices through refresh_labels();
  -- firmware fader columns also need a one-time setup rebuild.
  assignment_surface_dirty = false,
}

DAW.FX.PARAM_STATUS      = 490
DAW.FX.PARAM_TRACK_ID    = 491
DAW.FX.PARAM_FX_SIGN     = 492
DAW.FX.PARAM_FX_DIGIT_1  = 493
DAW.FX.PARAM_FX_DIGIT_2  = 494
DAW.FX.PARAM_FX_DIGIT_3  = 495
DAW.FX.PARAM_FX_DIGIT_4  = 496
DAW.FX.PARAM_SLOT_START  = 499 -- slot 1 lives at ValueVault parameter 500
DAW.FX.LABEL_REFRESH_INTERVAL = 0.50

DAW.FX.ROW_COLORS = {0x05, 0x54, 0x0C, 0x15, 0x28, 0x30, 0x34, 0x03}
DAW.FX.GRAY_NORMAL = 0x02 -- slightly lighter gray for alternating FX-button rows
DAW.FX.GRAY_ACTIVE = 0x03
DAW.FX.GROUP_NAMES = {"Red", "Orange", "Yellow", "Green", "Blue", "Purple", "Magenta", "Neutral"}
-- The physical right column is top-to-bottom. FX groups deliberately follow
-- ControllerFocus's top-to-bottom red-through-neutral order rather than the
-- older mixer-bank bottom-up page order.
DAW.FX.GROUP_SLOT_BY_CC = {
  [0x59] = 1, [0x4F] = 2, [0x45] = 3, [0x3B] = 4,
  [0x31] = 5, [0x27] = 6, [0x1D] = 7, [0x13] = 8,
}

DAW.FX.preset_is_combo = function()
  local preset = DAW.PRESETS[tonumber(DAW.active_preset) or -1]
  return preset and preset.target == "fx_combo" or false
end

DAW.FX.surface_is_combo = function()
  return surface_mode == "DAW_FX_FADERS" and DAW.FX.preset_is_combo()
end

DAW.FX.combo_button_param = function(row, page)
  row = math.max(1, math.min(8, tonumber(row) or 1))
  page = math.max(1, math.min(8, tonumber(page) or DAW.FX.active_button_page or 1))
  return 64 + ((page - 1) * 8) + row - 1
end

DAW.FX.combo_button_range_text = function(page)
  page = math.max(1, math.min(8, tonumber(page) or DAW.FX.active_button_page or 1))
  local first = DAW.FX.param_human_number(DAW.FX.combo_button_param(1, page))
  return tostring(first) .. "-" .. tostring(first + 7)
end

DAW.FX.combo_button_signature = function()
  local parts = {"buttons", tostring(DAW.FX.active_button_page or 1)}
  for row = 1, 8 do
    local param_index = DAW.FX.combo_button_param(row)
    parts[#parts + 1] = tostring(param_index) .. ":"
      .. (((DAW.FX.get_normalized(param_index) or 0) > 0.5) and "1" or "0")
  end
  return table.concat(parts, "|")
end

DAW.FX.send_combo_button_indicators = function(force)
  if not DAW.FX.surface_is_combo() or (DAW.output_index == nil and DAW.output_index_2 == nil) then return false end
  local signature = DAW.FX.combo_button_signature()
  if not force and signature == DAW.FX.last_combo_button_signature then return false end
  DAW.FX.last_combo_button_signature = signature

  for row = 1, 8 do
    local cc = DAW.BANK_CC_BY_SLOT[row]
    local color = DAW.FX.ROW_COLORS[row] or 0x01
    local active = (DAW.FX.get_normalized(DAW.FX.combo_button_param(row)) or 0) > 0.5
    DAW.send_bytes({0xB2, cc, 0x00})
    DAW.send_bytes({active and 0xB2 or 0xB0, cc, color})
  end
  return true
end

DAW.FX.send_right_column_indicators = function(force)
  if DAW.FX.surface_is_combo() then
    return DAW.FX.send_combo_button_indicators(force)
  end
  return DAW.FX.send_group_indicators(DAW.FX.active_page)
end

DAW.FX.select_button_page = function(page, reason)
  page = math.max(1, math.min(8, tonumber(page) or DAW.FX.active_button_page or 1))
  DAW.FX.active_button_page = page
  DAW.FX.last_combo_button_signature = nil
  DAW.FX.send_combo_button_indicators(true)
  DAW.send_top_row_indicators()
  last_action = reason or ("ValueVault FX button page " .. DAW.FX.combo_button_range_text(page))
  return true
end

DAW.FX.toggle_combo_button = function(row)
  local param_index = DAW.FX.combo_button_param(row)
  local old_value = DAW.FX.get_normalized(param_index) or 0
  local new_value = (old_value > 0.5) and 0.0 or 1.0
  if DAW.FX.set_normalized(param_index, new_value) then
    DAW.FX.last_combo_button_signature = nil
    DAW.FX.send_combo_button_indicators(true)
    last_action = string.format(
      "Toggled ValueVault parameter %d %s",
      DAW.FX.param_human_number(param_index),
      new_value > 0.5 and "ON" or "OFF"
    )
    return true
  end
  return false
end

DAW.FX.combo_top_row_available = function(slot)
  if slot == 1 then return DAW.FX.page_available((DAW.FX.active_page or 1) - 1) end
  if slot == 2 then return DAW.FX.page_available((DAW.FX.active_page or 1) + 1) end
  if slot == 3 then return DAW.FX.page_available((DAW.FX.active_button_page or 1) + 1) end
  if slot == 4 then return DAW.FX.page_available((DAW.FX.active_button_page or 1) - 1) end
  return slot >= 5 and slot <= 8
end

DAW.FX.combo_top_row_lines = function(slot)
  if slot == 1 then return {"BANK", "UP"} end
  if slot == 2 then return {"BANK", "DOWN"} end
  if slot == 3 then return {"NEXT", "BUTTONS"} end
  if slot == 4 then return {"PREVIOUS", "BUTTONS"} end
  if slot == 5 then return {"GO", "HOME"} end
  if slot == 6 then return {"UNDO"} end
  if slot == 7 then return {"REDO"} end
  if slot == 8 then return {"PANIC!"} end
  return {" "}
end

DAW.FX.combo_top_row_color = function(slot)
  if slot == 6 then return 0x25 end
  if slot == 7 then return 0x15 end
  if slot == 8 then return 0x05 end
  return DAW.FX.combo_top_row_available(slot) and 0x03 or 0x01
end

DAW.FX.surface_is_faders = function()
  return surface_mode == "DAW_FX_FADERS"
end

DAW.FX.surface_is_matrix = function()
  return surface_mode == "DAW_FX_MATRIX"
end

DAW.FX.surface_is_active = function()
  return DAW.FX.surface_is_faders() or DAW.FX.surface_is_matrix()
end

DAW.FX.top_row_target_preset = function(slot)
  slot = tonumber(slot)
  local preset = tonumber(DAW.active_preset)
  if slot == 3 then
    if preset == 21 then return 22 end -- Pots/Sliders -> FX Buttons
    if preset == 22 then return 21 end -- FX Buttons -> Pots/Sliders
    if preset == 23 then return 21 end -- FX Faders -> Pots/Sliders
  elseif slot == 4 then
    if preset == 21 then return 23 end -- Pots/Sliders -> FX Faders
    if preset == 22 then return 23 end -- FX Buttons -> FX Faders
    if preset == 23 then return 22 end -- FX Faders -> FX Buttons
  end
  return nil
end

DAW.FX.top_row_target_lines = function(slot)
  local target = DAW.FX.top_row_target_preset(slot)
  if target == 21 then return {"FX", "POTS/", "SLIDERS"} end
  if target == 22 then return {"FX", "BUTTONS"} end
  if target == 23 then return {"FX", "FADERS"} end
  return nil
end

DAW.FX.find_valuevault = function()
  local master = r.GetMasterTrack(0)
  if not master then return nil, nil end
  local fx_count = r.TrackFX_GetRecCount(master)
  for i = 0, fx_count - 1 do
    local ok, fx_name = r.TrackFX_GetFXName(master, 0x1000000 + i, "")
    if ok and tostring(fx_name or ""):lower():find("valuevault", 1, true) then
      return master, 0x1000000 + i
    end
  end
  return nil, nil
end

DAW.FX.valuevault_available = function()
  local master, fx = DAW.FX.find_valuevault()
  return master ~= nil and fx ~= nil
end

DAW.FX.active_preset = function()
  return DAW.PRESETS[tonumber(DAW.active_preset) or -1]
end

DAW.FX.param_start = function()
  local preset = DAW.FX.active_preset()
  return tonumber(preset and preset.fx_param_start) or 0
end

DAW.FX.page_start_param = function(page)
  page = math.max(1, math.min(8, tonumber(page) or DAW.FX.active_page or 1))
  return DAW.FX.param_start() + ((page - 1) * 8)
end

DAW.FX.param_for_fader = function(fader_number, page)
  return DAW.FX.page_start_param(page) + (tonumber(fader_number) or 1) - 1
end

DAW.FX.param_for_matrix_cell = function(row, col)
  return DAW.FX.param_start() + ((tonumber(row) or 1) - 1) * 8 + ((tonumber(col) or 1) - 1)
end

DAW.FX.param_human_number = function(param_index)
  return (tonumber(param_index) or 0) + 1
end

DAW.FX.set_normalized = function(param_index, value)
  local master, fx = DAW.FX.find_valuevault()
  if not master then
    last_action = "ValueVault not found in Monitoring FX"
    return false
  end
  value = math.max(0, math.min(1, tonumber(value) or 0))
  r.TrackFX_SetParamNormalized(master, fx, param_index, value)
  return true
end

DAW.FX.get_normalized = function(param_index)
  local master, fx = DAW.FX.find_valuevault()
  if not master then return nil end
  return r.TrackFX_GetParamNormalized(master, fx, param_index)
end

DAW.FX.midi_to_normalized = function(value)
  return math.max(0, math.min(127, tonumber(value) or 0)) / 127
end

DAW.FX.normalized_to_midi = function(value)
  return math.floor(math.max(0, math.min(1, tonumber(value) or 0)) * 127 + 0.5)
end

DAW.FX.decode_fx_index = function(sign, d1, d2, d3, d4)
  local p1 = math.floor((tonumber(d1) or 0) * 1000 + 0.5)
  local p2 = math.floor((tonumber(d2) or 0) * 1000 + 0.5)
  local p3 = math.floor((tonumber(d3) or 0) * 1000 + 0.5)
  local p4 = math.floor((tonumber(d4) or 0) * 1000 + 0.5)
  local total = (p1 * 1000000000) + (p2 * 1000000) + (p3 * 1000) + p4
  if (tonumber(sign) or 1) < 0.5 then total = -total end
  return total
end

DAW.FX.read_published_target = function(master, vault_fx)
  master = master or select(1, DAW.FX.find_valuevault())
  if not master then return nil, nil end
  vault_fx = vault_fx or select(2, DAW.FX.find_valuevault())
  if not vault_fx then return nil, nil end

  local track_id = math.floor((r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_TRACK_ID) or 0) * 1000 + 0.5)
  local target_track = (track_id == 0) and r.GetMasterTrack(0) or r.GetTrack(0, track_id - 1)
  if not target_track then return nil, nil end

  local fx_index = DAW.FX.decode_fx_index(
    r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_FX_SIGN),
    r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_FX_DIGIT_1),
    r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_FX_DIGIT_2),
    r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_FX_DIGIT_3),
    r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_FX_DIGIT_4)
  )

  if fx_index < 0 or fx_index >= r.TrackFX_GetCount(target_track) then return nil, nil end
  return target_track, fx_index
end

DAW.FX.refresh_labels = function(force)
  local now = r.time_precise()
  local previous_signature = DAW.FX.label_signature or ""
  if not force and (now - (DAW.FX.label_cache_time or -1000000)) < DAW.FX.LABEL_REFRESH_INTERVAL then
    return DAW.FX.label_cache
  end

  DAW.FX.label_cache_time = now
  local master, vault_fx = DAW.FX.find_valuevault()
  if not master then
    DAW.FX.label_cache = {}
    DAW.FX.assignment_cache = {}
    DAW.FX.label_signature = ""
    if previous_signature ~= "" then
      DAW.FX.assignment_surface_dirty = true
      DAW.FX.last_combo_button_signature = nil
      DAW.FX.last_surface_signature = nil
    end
    return DAW.FX.label_cache
  end

  -- ControllerFocus uses parameter 490 as the authoritative active-target flag.
  -- Do not display names reconstructed from stale metadata when it is inactive.
  local status = r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_STATUS) or 0
  if status < 0.5 then
    DAW.FX.label_cache = {}
    DAW.FX.assignment_cache = {}
    DAW.FX.label_signature = ""
    if previous_signature ~= "" then
      DAW.FX.assignment_surface_dirty = true
      DAW.FX.last_combo_button_signature = nil
      DAW.FX.last_surface_signature = nil
    end
    return DAW.FX.label_cache
  end

  local target_track, target_fx = DAW.FX.read_published_target(master, vault_fx)
  if not target_track then
    DAW.FX.label_cache = {}
    DAW.FX.assignment_cache = {}
    DAW.FX.label_signature = ""
    if previous_signature ~= "" then
      DAW.FX.assignment_surface_dirty = true
      DAW.FX.last_combo_button_signature = nil
      DAW.FX.last_surface_signature = nil
    end
    return DAW.FX.label_cache
  end

  -- Build the assignment map exactly as ControllerDisplay does: ValueVault
  -- stores (zero-based target parameter index + 1) * 0.001.  Zero is empty.
  local parameter_count = r.TrackFX_GetNumParams(target_track, target_fx)
  local assignment_indices = {}
  local signature_parts = {tostring(target_track), tostring(target_fx)}
  for slot = 1, 192 do
    local raw = r.TrackFX_GetParam(master, vault_fx, DAW.FX.PARAM_SLOT_START + slot) or 0
    local one_based_parameter_number = math.floor((raw * 1000) + 0.5)
    local assigned_param = one_based_parameter_number > 0 and (one_based_parameter_number - 1) or nil
    if assigned_param and assigned_param < parameter_count then
      assignment_indices[slot] = assigned_param
    end
    signature_parts[#signature_parts + 1] = tostring(one_based_parameter_number)
  end

  DAW.FX.assignment_cache = assignment_indices

  local signature = table.concat(signature_parts, "|")
  local signature_changed = signature ~= previous_signature
  if not force and not signature_changed then
    return DAW.FX.label_cache
  end

  DAW.FX.label_signature = signature
  if signature_changed then
    DAW.FX.assignment_surface_dirty = true
    DAW.FX.last_combo_button_signature = nil
    DAW.FX.last_surface_signature = nil
  end
  DAW.FX.label_cache = {}
  for slot = 1, 192 do
    local assigned_param = assignment_indices[slot]
    if assigned_param ~= nil then
      local ok, name = r.TrackFX_GetParamName(target_track, target_fx, assigned_param, "")
      if ok and name and name ~= "" then
        DAW.FX.label_cache[slot] = name
      end
    end
  end

  return DAW.FX.label_cache
end

DAW.FX.short_label = function(param_index)
  local slot = (tonumber(param_index) or 0) + 1
  local labels = DAW.FX.refresh_labels(false)
  local name = labels[slot]
  if name and name ~= "" then
    name = name:gsub("[%s_]+", " ")
    if #name > 16 then name = name:sub(1, 13) .. "..." end
    return name
  end
  return "VV " .. tostring(slot)
end

DAW.FX.has_assignment = function(param_index)
  DAW.FX.refresh_labels(false)
  local slot = (tonumber(param_index) or 0) + 1
  return DAW.FX.assignment_cache[slot] ~= nil
end

DAW.FX.group_selector_lines = function(page)
  page = math.max(1, math.min(8, tonumber(page) or 1))
  local name = DAW.FX.GROUP_NAMES[page] or ("Group " .. tostring(page))
  return {name, "Group"}
end

DAW.FX.send_group_indicators = function(page)
  if DAW.output_index == nil and DAW.output_index_2 == nil then return false end
  page = math.max(1, math.min(8, tonumber(page) or DAW.FX.active_page or 1))
  for slot = 1, 8 do
    local cc = DAW.BANK_CC_BY_SLOT[slot]
    local color = DAW.FX.ROW_COLORS[slot] or 0x01
    DAW.send_bytes({0xB2, cc, 0x00})
    DAW.send_bytes({0xB0, cc, color})
  end
  local active_cc = DAW.BANK_CC_BY_SLOT[page]
  local active_color = DAW.FX.ROW_COLORS[page] or 0x03
  if active_cc then DAW.send_bytes({0xB2, active_cc, active_color}) end
  return true
end

DAW.FX.build_fader_setup = function(page)
  local preset = DAW.FX.active_preset() or {}
  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x01, 0x00,
    preset.orientation or 0x00,
  }
  DAW.FX.refresh_labels(false)
  for fader_number = 1, 8 do
    local param_index = DAW.FX.param_for_fader(fader_number, page)
    local enabled = DAW.FX.valuevault_available() and DAW.FX.has_assignment(param_index)
    bytes[#bytes + 1] = fader_number - 1
    bytes[#bytes + 1] = preset.fader_type or 0x00
    bytes[#bytes + 1] = DAW.CC_FIRST + fader_number - 1
    bytes[#bytes + 1] = enabled and DAW.COLORS[fader_number] or 0x00
  end
  bytes[#bytes + 1] = 0xF7
  return bytes
end

DAW.FX.reset_fader_feedback = function()
  DAW.FX.last_feedback_poll_time = -1000000
  DAW.FX.pending_feedback_time = nil
  DAW.FX.last_sent_fader_values = {}
  DAW.FX.pending_fader_values = {}
  DAW.FX.hardware_holdoff_until = {}
  DAW.FX.last_surface_signature = nil
  DAW.FX.last_combo_button_signature = nil
end

DAW.FX.send_fader_feedback = function(fader_number, value)
  if not DAW.FX.surface_is_faders() then return false end
  local cc_number = DAW.CC_FIRST + fader_number - 1
  value = math.max(0, math.min(127, math.floor((tonumber(value) or 0) + 0.5)))
  local sent = DAW.send_bytes({0xB0 | DAW.FADER_CHANNEL, cc_number, value})
  if sent then
    DAW.FX.last_sent_fader_values[fader_number] = value
    recent_outbound_custom_fader_feedback[cc_number] = {value = value, time = r.time_precise()}
  end
  return sent
end

DAW.FX.sync_fader_feedback = function(force)
  if not DAW.FX.surface_is_faders() then return 0 end
  local now = r.time_precise()
  local sent_count = 0
  for fader_number = 1, 8 do
    local holdoff_until = DAW.FX.hardware_holdoff_until[fader_number] or 0
    if now >= holdoff_until then
      local param_index = DAW.FX.param_for_fader(fader_number)
      if DAW.FX.has_assignment(param_index) then
        local midi_value = DAW.FX.normalized_to_midi(DAW.FX.get_normalized(param_index) or 0)
        if force or DAW.FX.last_sent_fader_values[fader_number] ~= midi_value then
          if DAW.FX.send_fader_feedback(fader_number, midi_value) then
            sent_count = sent_count + 1
          end
        end
      end
    end
  end
  return sent_count
end

DAW.FX.refresh_active_assignment_surface_if_needed = function()
  if not DAW.FX.assignment_surface_dirty then return false end
  DAW.FX.assignment_surface_dirty = false

  if DAW.FX.surface_is_faders() then
    -- Rebuild only the currently visible fader bank. Newly assigned columns
    -- appear immediately; newly cleared columns disappear immediately.
    if not DAW.send_bytes(DAW.FX.build_fader_setup(DAW.FX.active_page)) then
      return false
    end
    DAW.FX.reset_fader_feedback()
    DAW.FX.pending_feedback_time = r.time_precise()
    DAW.FX.send_right_column_indicators(true)
    DAW.send_top_row_indicators()
    last_action = "ControllerFocus assignment map changed: refreshed active FX hardware surface"
    return true
  elseif DAW.FX.surface_is_matrix() then
    DAW.FX.last_surface_signature = nil
    DAW.FX.refresh_matrix_surface(true)
    last_action = "ControllerFocus assignment map changed: refreshed FX button surface"
    return true
  end

  return false
end

DAW.FX.process_fader_feedback = function(now)
  if not DAW.FX.surface_is_faders() then return end

  -- refresh_labels() is throttled internally. This adds only a low-frequency
  -- assignment-map check, not a continuous hardware re-upload.
  DAW.FX.refresh_labels(false)
  DAW.FX.refresh_active_assignment_surface_if_needed()

  if DAW.FX.pending_feedback_time and now >= DAW.FX.pending_feedback_time then
    DAW.FX.pending_feedback_time = nil
    DAW.FX.sync_fader_feedback(true)
    DAW.FX.last_feedback_poll_time = now
    return
  end
  if (now - (DAW.FX.last_feedback_poll_time or -1000000)) >= CFG.CUSTOM_FADER_FEEDBACK_POLL_INTERVAL then
    DAW.FX.sync_fader_feedback(false)
    DAW.FX.send_combo_button_indicators(false)
    DAW.FX.last_feedback_poll_time = now
  end
end

DAW.FX.begin_fader_holdoff = function(cc_number, now)
  local fader_number = (cc_number - DAW.CC_FIRST) + 1
  DAW.FX.hardware_holdoff_until[fader_number] =
    (now or r.time_precise()) + CFG.CUSTOM_FADER_HARDWARE_TOUCH_HOLDOFF_SECONDS
end

DAW.FX.queue_fader_value = function(cc_number, value, now)
  DAW.FX.begin_fader_holdoff(cc_number, now)
  DAW.FX.pending_fader_values[cc_number] = {
    value = value,
    page = DAW.FX.active_page or 1,
  }
end

DAW.FX.flush_fader_values = function()
  if not next(DAW.FX.pending_fader_values) then return end
  local applied = 0
  local last_param = nil
  for cc_number = DAW.CC_FIRST, DAW.CC_LAST do
    local event = DAW.FX.pending_fader_values[cc_number]
    if event then
      local fader_number = (cc_number - DAW.CC_FIRST) + 1
      local param_index = DAW.FX.param_for_fader(fader_number, event.page)
      if DAW.FX.set_normalized(param_index, DAW.FX.midi_to_normalized(event.value)) then
        DAW.FX.last_sent_fader_values[fader_number] = event.value
        applied = applied + 1
        last_param = param_index
      end
    end
  end
  DAW.FX.pending_fader_values = {}
  if applied > 0 then
    last_action = string.format("Updated %d ValueVault FX fader(s); last was parameter %d", applied, DAW.FX.param_human_number(last_param or 0))
  end
end

DAW.FX.page_available = function(page)
  page = tonumber(page) or -1
  return page >= 1 and page <= 8
end

DAW.FX.select_page = function(page, reason)
  page = math.max(1, math.min(8, tonumber(page) or DAW.FX.active_page or 1))
  DAW.FX.active_page = page
  DAW.active_bank = page
  DAW.active_start_track = ((page - 1) * 8) + 1
  active_custom_slot = page

  if DAW.FX.surface_is_faders() then
    DAW.send_bytes(DAW.FX.build_fader_setup(page))
    DAW.FX.reset_fader_feedback()
    DAW.FX.pending_feedback_time = r.time_precise()
    DAW.FX.send_right_column_indicators(true)
    DAW.send_top_row_indicators()
    DAW.FX.assignment_surface_dirty = false
    last_action = reason or string.format(
      "ValueVault FX group %d active: parameters %d-%d",
      page,
      DAW.FX.param_human_number(DAW.FX.page_start_param(page)),
      DAW.FX.param_human_number(DAW.FX.page_start_param(page) + 7)
    )
    return true
  end
  return false
end

DAW.FX.enter_faders = function(preset_number)
  DAW.active_preset = preset_number or DAW.active_preset
  -- FX surfaces always open on the top red group so the helper GRID, hardware
  -- right column and ControllerFocus color order all start from the same place.
  DAW.FX.active_page = 1
  if DAW.FX.preset_is_combo() then DAW.FX.active_button_page = 1 end
  DAW.FX.refresh_labels(true)
  if not DAW.send_mode(true) then return false end
  DAW.send_session_button_colors()
  if not DAW.send_bytes(DAW.FX.build_fader_setup(DAW.FX.active_page)) then return false end
  surface_mode = "DAW_FX_FADERS"
  initialized = true
  active_custom_slot = DAW.FX.active_page
  DAW.active_bank = DAW.FX.active_page
  DAW.active_start_track = ((DAW.FX.active_page - 1) * 8) + 1
  DAW.FX.reset_fader_feedback()
  DAW.FX.refresh_labels(true)
  DAW.FX.sync_fader_feedback(true)
  DAW.FX.send_right_column_indicators(true)
  DAW.send_top_row_indicators()
  if not DAW.send_layout(0x0D) then return false end
  DAW.FX.send_right_column_indicators(true)
  DAW.send_top_row_indicators()
  DAW.FX.assignment_surface_dirty = false
  last_action = string.format("Preset %d: %s | ValueVault parameters %d-%d",
    DAW.active_preset or 0,
    DAW.preset_name(DAW.active_preset) or "FX Faders",
    DAW.FX.param_human_number(DAW.FX.page_start_param(DAW.FX.active_page)),
    DAW.FX.param_human_number(DAW.FX.page_start_param(DAW.FX.active_page) + 7)
  )
  return true
end

DAW.FX.matrix_cell_color = function(row, col, active)
  if (row % 2) == 0 then
    return active and DAW.FX.GRAY_ACTIVE or DAW.FX.GRAY_NORMAL
  end
  return DAW.FX.ROW_COLORS[col] or 0x01
end

DAW.FX.matrix_signature = function()
  local parts = {"fx_matrix", tostring(DAW.FX.param_start()), grid_visible and "grid:1" or "grid:0"}
  for row = 1, 8 do
    for col = 1, 8 do
      local value = DAW.FX.get_normalized(DAW.FX.param_for_matrix_cell(row, col)) or 0
      parts[#parts + 1] = tostring(row) .. ":" .. tostring(col) .. ":" .. ((value > 0.5) and "1" or "0")
    end
  end
  return table.concat(parts, "|")
end

DAW.FX.refresh_matrix_surface = function(force_full)
  if not DAW.FX.surface_is_matrix() or (DAW.output_index == nil and DAW.output_index_2 == nil) then return false end
  local signature = DAW.FX.matrix_signature()
  if not force_full and signature == DAW.FX.last_surface_signature then return false end
  DAW.FX.last_surface_signature = signature
  if force_full then DAW.MATRIX.matrix_reset_led_cache() end

  for slot = 1, 8 do
    DAW.MATRIX.matrix_send_cc_if_changed(
      DAW.TOP_ROW_CC_BY_SLOT[slot],
      DAW.top_row_slot_color(slot),
      false,
      force_full
    )
  end
  if force_full then DAW.send_session_button_colors(0x03, 0x03) end

  for row = 1, 8 do
    for col = 1, 8 do
      local param_index = DAW.FX.param_for_matrix_cell(row, col)
      local active = (DAW.FX.get_normalized(param_index) or 0) > 0.5
      DAW.MATRIX.matrix_send_note_if_changed(
        DAW.MATRIX.matrix_inner_note(row, col),
        DAW.FX.matrix_cell_color(row, col, active),
        active,
        force_full
      )
    end
    -- Right-column orientation key: top-to-bottom red-through-neutral groups.
    DAW.MATRIX.matrix_send_cc_if_changed(
      DAW.MATRIX.matrix_right_cc(row),
      DAW.FX.ROW_COLORS[row] or 0x01,
      false,
      force_full
    )
  end
  return true
end

DAW.FX.enter_matrix = function(preset_number)
  DAW.active_preset = preset_number or DAW.active_preset
  if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end
  DAW.clear_surface_indicators()
  if not DAW.send_mode(true) then return false end
  DAW.send_session_button_colors()
  if not DAW.send_layout(0x00) then return false end
  surface_mode = "DAW_FX_MATRIX"
  initialized = true
  active_custom_slot = nil
  DAW.FX.refresh_labels(true)
  DAW.FX.last_surface_signature = nil
  DAW.FX.refresh_matrix_surface(true)
  DAW.FX.assignment_surface_dirty = false
  last_action = "Preset 22: FX Buttons | ValueVault parameters 65-128"
  return true
end

DAW.FX.handle_top_row_press = function(slot, source)
  slot = tonumber(slot)
  if not slot then return false end

  if DAW.FX.surface_is_combo() then
    if slot == 1 and DAW.FX.combo_top_row_available(slot) then
      return DAW.FX.select_page((DAW.FX.active_page or 1) - 1, "ValueVault FX bank up")
    elseif slot == 2 and DAW.FX.combo_top_row_available(slot) then
      return DAW.FX.select_page((DAW.FX.active_page or 1) + 1, "ValueVault FX bank down")
    elseif slot == 3 and DAW.FX.combo_top_row_available(slot) then
      return DAW.FX.select_button_page((DAW.FX.active_button_page or 1) + 1, "ValueVault next FX buttons")
    elseif slot == 4 and DAW.FX.combo_top_row_available(slot) then
      return DAW.FX.select_button_page((DAW.FX.active_button_page or 1) - 1, "ValueVault previous FX buttons")
    elseif slot == 5 then
      return_to_home_page_1("FX combined surface GO HOME: returned to HOME Page 1", false)
      return true
    elseif slot == 6 then
      ACTIONS["UNDO"]()
      return true
    elseif slot == 7 then
      ACTIONS["REDO"]()
      return true
    elseif slot == 8 then
      ACTIONS["PANIC!"]()
      return true
    end
    last_action = "FX combined top-row control unavailable"
    DAW.send_top_row_indicators()
    return true
  end

  if slot == 1 and DAW.FX.surface_is_faders() then
    return DAW.FX.select_page((DAW.FX.active_page or 1) - 1, "ValueVault FX group up")
  elseif slot == 2 and DAW.FX.surface_is_faders() then
    return DAW.FX.select_page((DAW.FX.active_page or 1) + 1, "ValueVault FX group down")
  elseif slot == 3 or slot == 4 then
    local target_preset = DAW.FX.top_row_target_preset(slot)
    if target_preset then
      return DAW.activate_preset(target_preset)
    end
  elseif slot == 5 then
    return_to_home_page_1("FX surface GO HOME: returned to HOME Page 1", false)
    return true
  end
  last_action = "FX top-row slot " .. tostring(slot) .. " is unavailable"
  DAW.send_top_row_indicators()
  return true
end

DAW.FX.handle_matrix_pad = function(row, col, pressed)
  if not pressed then return true end
  local param_index = DAW.FX.param_for_matrix_cell(row, col)
  local old_value = DAW.FX.get_normalized(param_index) or 0
  local new_value = (old_value > 0.5) and 0.0 or 1.0
  if DAW.FX.set_normalized(param_index, new_value) then
    DAW.FX.last_surface_signature = nil
    DAW.FX.refresh_matrix_surface(false)
    last_action = string.format("Toggled ValueVault parameter %d %s", DAW.FX.param_human_number(param_index), new_value > 0.5 and "ON" or "OFF")
  end
  return true
end

DAW.FX.process_midi_event = function(buf, dev_idx)
  if not buf or (DAW.input_index == nil and DAW.input_index_2 == nil) or not DAW.FX.surface_is_active() then return false end
  local device_index = (dev_idx or 0) & 0xFFFF
  if not DAW.input_matches(device_index) then return false end

  local reported_layout = DAW.layout_from_report(buf)
  if DAW.layout_is_escape(reported_layout) then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi_buffer(buf)
    return_to_home_page_1(string.format("Novation layout %02X detected: returned to HOME Page 1", reported_layout), false)
    return true
  end

  if #buf < 3 then return false end
  local status, data1, data2 = buf:byte(1, 3)
  if not status or not data1 or not data2 then return false end
  local message_type = status & 0xF0
  local channel = status & 0x0F

  if channel == 0 and message_type == 0xB0 and data2 > 0 and DAW.TOP_ROW_SLOT_BY_CC[data1] then
    local slot = DAW.TOP_ROW_SLOT_BY_CC[data1]
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)
    DAW.FX.handle_top_row_press(slot, "Hardware")
    return true
  end

  if DAW.FX.surface_is_faders() and channel == 0 and message_type == 0xB0 and data2 > 0 and DAW.FX.GROUP_SLOT_BY_CC[data1] then
    local row = DAW.FX.GROUP_SLOT_BY_CC[data1]
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)
    if DAW.FX.surface_is_combo() then
      DAW.FX.toggle_combo_button(row)
    else
      DAW.FX.select_page(row, "ValueVault FX group " .. tostring(row))
      DAW.FX.sync_fader_feedback(true)
    end
    return true
  end

  if DAW.FX.surface_is_faders() and channel == DAW.FADER_CHANNEL and message_type == 0xB0
      and data1 >= DAW.CC_FIRST and data1 <= DAW.CC_LAST then
    local now = r.time_precise()
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)
    DAW.FX.begin_fader_holdoff(data1, now)
    if not is_recent_outbound_custom_fader_echo(data1, data2, now) then
      DAW.FX.queue_fader_value(data1, data2, now)
    end
    return true
  end

  if DAW.FX.surface_is_matrix() and channel == 0 then
    if message_type == 0x90 or message_type == 0x80 then
      local row, col = DAW.MATRIX.matrix_note_to_cell(data1)
      if row and col then
        local ok_name, source_name = r.GetMIDIInputName(device_index, "")
        last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
        last_midi = format_midi(status, data1, data2)
        return DAW.FX.handle_matrix_pad(row, col, message_type == 0x90 and data2 > 0)
      end
    end
  end

  return false
end

------------------------------------------------------------
-- EXPERIMENTAL DAW SESSION / FIRMWARE FADER PATH
------------------------------------------------------------
DAW.select_volume_window = function(start_track, reason)
  refresh_mcp_track_cache(true)
  start_track = math.max(1, tonumber(start_track) or 1)
  if not DAW.window_available(start_track) then
    last_action = string.format(DAW.active_scope_label() .. " fader window starting at track %d is unavailable", start_track)
    DAW.send_top_row_indicators()
    return false
  end

  DAW.active_start_track = start_track
  DAW.active_bank = math.floor((start_track - 1) / 8) + 1
  active_custom_slot = DAW.active_bank -- compatibility for the shared fader renderer
  DAW.active_preset = DAW.active_preset or 1
  surface_mode = "DAW_VOLUME_FADERS"

  apply_custom_fader_mcp_layout_tabs(DAW.active_bank, start_track, true)
  DAW.send_bytes(DAW.build_volume_fader_setup(start_track))
  reset_custom_fader_feedback_state()
  schedule_full_active_custom_fader_feedback(0)
  DAW.send_bank_indicators(DAW.active_bank)
  DAW.send_top_row_indicators()
  last_action = reason or string.format(
    "DAW %s %s fader window active: %s-visible tracks %d-%d",
    DAW.active_scope_label(), DAW.active_parameter_label(), DAW.active_scope_label(), start_track, start_track + 7
  )
  return true
end

DAW.select_volume_bank = function(bank)
  bank = math.max(1, math.min(8, tonumber(bank) or 1))
  return DAW.select_volume_window(((bank - 1) * 8) + 1)
end

DAW.enter_volume_faders = function(bank)
  bank = math.max(1, math.min(8, tonumber(bank) or DAW.active_bank or 1))
  local start_track = tonumber(DAW.active_start_track) or (((bank - 1) * 8) + 1)
  refresh_mcp_track_cache(true)
  if not DAW.window_available(start_track) then start_track = 1 end
  if not DAW.send_mode(true) then return false end
  DAW.send_session_button_colors()
  if not DAW.send_bytes(DAW.build_volume_fader_setup(start_track)) then return false end

  DAW.active_start_track = start_track
  DAW.active_bank = math.floor((start_track - 1) / 8) + 1
  active_custom_slot = DAW.active_bank
  DAW.active_preset = DAW.active_preset or 1
  surface_mode = "DAW_VOLUME_FADERS"
  initialized = true
  apply_custom_fader_mcp_layout_tabs(DAW.active_bank, start_track, true)
  reset_custom_fader_feedback_state()

  sync_active_custom_fader_feedback(true)
  DAW.send_bank_indicators(DAW.active_bank)
  DAW.send_top_row_indicators()
  if not DAW.send_layout(0x0D) then return false end
  DAW.send_bank_indicators(DAW.active_bank)
  DAW.send_top_row_indicators()

  last_action = string.format(
    "Enabled DAW mode and entered firmware %s %s faders: %s-visible tracks %d-%d",
    DAW.active_scope_label(), DAW.active_parameter_label(), DAW.active_scope_label(), start_track, start_track + 7
  )
  return true
end

DAW.enter_session = function()
  if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end
  DAW.clear_surface_indicators()
  if not DAW.send_mode(true) then return false end
  DAW.send_session_button_colors()
  if not DAW.send_layout(0x00) then return false end
  active_custom_slot = nil
  surface_mode = "DAW_SESSION"
  initialized = true
  reset_custom_fader_feedback_state()
  last_action = "Enabled DAW mode and selected Session layout"
  return true
end

DAW.activate_preset = function(preset_number)
  preset_number = tonumber(preset_number) or 1
  local preset = DAW.PRESETS[preset_number]
  if not preset then
    last_action = string.format("Preset %d is unavailable", preset_number)
    DAW.send_top_row_indicators()
    return false
  end
  DAW.active_preset = preset_number
  if preset.target == "volume" or preset.target == "pan" or preset.target == "send" then
    return DAW.enter_volume_faders(DAW.active_bank or 1)
  elseif preset.target == "matrix" then
    return DAW.MATRIX.matrix_enter_preset(preset_number)
  elseif preset.target == "fx_fader" then
    return DAW.FX.enter_faders(preset_number)
  elseif preset.target == "fx_matrix" then
    return DAW.FX.enter_matrix(preset_number)
  elseif preset.target == "fx_combo" then
    return DAW.FX.enter_faders(preset_number)
  elseif preset.target == "track_picker" then
    return DAW.TRACK_PICKER.enter(preset.track_picker_page)
  elseif preset.target == "track_viewer" then
    return DAW.TRACK_VIEWER.enter(DAW.TRACK_PICKER.selected_track_number)
  elseif preset.target == "master_track_view" then
    return DAW.TRACK_VIEWER.enter(0, {lock_to_track = true})
  elseif preset.target == "regions_markers" then
    return DAW.REGIONS_MARKERS.enter()
  elseif preset.target == "controller_focus_launcher" then
    return DAW.CONTROLLER_FOCUS.launch()
  elseif preset.target == "midi_note_namer_launcher" then
    return DAW.MIDI_NOTE_NAMER.launch()
  elseif preset.target == "midi_layout_builder" then
    return DAW.MIDI_LAYOUT_BUILDER.launch()
  elseif preset.target == "sleep" then
    if DAW.SLEEP.active then return DAW.SLEEP.wake() end
    return DAW.SLEEP.enter()
  end
  last_action = string.format("Preset %d (%s) is defined but has no handler yet", preset_number, preset.name)
  DAW.send_top_row_indicators()
  return false
end

DAW.handle_top_row_press = function(slot, source)
  slot = tonumber(slot)
  if not slot then return false end
  if surface_mode == "PROGRAMMER_TRACK_MATRIX" then
    return DAW.MATRIX.matrix_handle_top_row_press(slot, source)
  end
  if DAW.FX and DAW.FX.surface_is_active and DAW.FX.surface_is_active() then
    return DAW.FX.handle_top_row_press(slot, source)
  end
  local start_track = DAW.current_start_track()

  if slot == 1 then
    if not DAW.top_row_slot_available(slot) then
      last_action = "Bank Up unavailable"
      DAW.send_top_row_indicators()
      return true
    end
    return DAW.select_volume_window(start_track + 8)
  elseif slot == 2 then
    if not DAW.top_row_slot_available(slot) then
      last_action = "Bank Down unavailable"
      DAW.send_top_row_indicators()
      return true
    end
    return DAW.select_volume_window(start_track - 8)
  elseif slot == 3 then
    if not DAW.top_row_slot_available(slot) then
      last_action = "Track Down unavailable"
      DAW.send_top_row_indicators()
      return true
    end
    return DAW.select_volume_window(start_track - 1)
  elseif slot == 4 then
    if not DAW.top_row_slot_available(slot) then
      last_action = "Track Up unavailable"
      DAW.send_top_row_indicators()
      return true
    end
    return DAW.select_volume_window(start_track + 1)
  elseif slot == 5 then
    return_to_home_page_1("Session / GO HOME: returned to HOME Page 1", false)
    return true
  end

  last_action = "Top-row slot " .. tostring(slot) .. " is unavailable"
  DAW.send_top_row_indicators()
  return true
end

DAW.disable = function()
  if clear_custom_fader_mcp_layout_tabs then clear_custom_fader_mcp_layout_tabs() end
  DAW.clear_surface_indicators()
  local sent = DAW.send_mode(false)
  if sent then
    active_custom_slot = nil
    DAW.active_preset = nil
    surface_mode = "LIVE"
    reset_custom_fader_feedback_state()
    last_action = "Disabled Launchpad DAW mode"
  end
  return sent
end

-- Rebuild the firmware surface and MCP/TCP tabs only when the active visible-track
-- structure changes. This catches add/remove/reorder/show-hide changes
-- without putting layout work in the live fader-feedback loop.
DAW.reconcile_mcp_structure = function()
  if not mcp_structure_change_pending then return false end
  mcp_structure_change_pending = false

  if surface_mode == "PROGRAMMER_TRACK_MATRIX" then
    DAW.MATRIX.start_track = math.max(1, math.min(DAW.MATRIX.start_track or 1, DAW.MATRIX.matrix_max_start_track()))
    DAW.MATRIX.last_surface_signature = nil
    DAW.MATRIX.apply_mcp_layout_tabs(true)
    DAW.refresh_matrix_surface(true)
    last_action = string.format(
      DAW.active_scope_label() .. "-visible tracks changed: rebuilt matrix window %d-%d",
      DAW.MATRIX.start_track,
      math.min(DAW.MATRIX.start_track + 39, #DAW.active_visible_tracks(), DAW.MATRIX.maximum_track_count)
    )
    return true
  end

  if surface_mode ~= "DAW_VOLUME_FADERS" then return false end

  local max_start = math.max(1, #DAW.active_visible_tracks())
  DAW.active_start_track = math.max(1, math.min(DAW.current_start_track(), max_start))
  DAW.active_bank = math.floor((DAW.active_start_track - 1) / 8) + 1
  active_custom_slot = DAW.active_bank

  apply_custom_fader_mcp_layout_tabs(DAW.active_bank, DAW.active_start_track, true)
  DAW.send_bytes(DAW.build_volume_fader_setup(DAW.active_start_track))
  reset_custom_fader_feedback_state()
  schedule_full_active_custom_fader_feedback(0)
  DAW.send_bank_indicators(DAW.active_bank)
  DAW.send_top_row_indicators()
  last_action = string.format(
    DAW.active_scope_label() .. "-visible tracks changed: rebuilt fader window %d-%d",
    DAW.active_start_track, DAW.active_start_track + 7
  )
  return true
end

-- Layout selection reports use the same compact SysEx form as the requests:
--   F0 00 20 29 02 <device> 00 <layout> F7
-- Treat Note and Custom selections as escape routes when they happen while our
-- firmware DAW Fader surface is active. Session is also kept as an escape route
-- for consistency with the earlier Custom-Mode workflow.
DAW.layout_from_report = function(buf)
  if not buf or #buf ~= 9 then return nil end
  local b = {buf:byte(1, 9)}
  if b[1] ~= 0xF0 or b[2] ~= 0x00 or b[3] ~= 0x20 or b[4] ~= 0x29
      or b[5] ~= 0x02 or not DAW.configured_device_id_matches(b[6]) or b[7] ~= 0x00
      or b[9] ~= 0xF7 then
    return nil
  end
  return b[8]
end

DAW.layout_is_escape = function(layout)
  return layout == 0x00 or layout == 0x01 or (layout and layout >= 0x04 and layout <= 0x0B)
end

DAW.handle_layout_report_from_either_port = function(buf, dev_idx)
  local device_index = (dev_idx or 0) & 0xFFFF
  local selected_regular = DAW.ordinary_input_matches(device_index)
  local selected_daw = DAW.input_matches(device_index)
  if not selected_regular and not selected_daw then return false end

  local reported_layout = DAW.layout_from_report(buf)
  if reported_layout == nil then return false end






  -- Resident Custom Modes are deliberately passive. Listen only for a layout
  -- report so the user can press Session or Notes to hand the controller back
  -- to the script. Either hardware layout button restores the reliable staged
  -- Programmer/Home Page 3 recovery path used by Notes.
  
  
  -- Paired MIDI Layout custom mode is also passive, but it should return
  -- to HOME Page 1 when the user presses NOTE, not Page 3.
  if surface_mode == "MIDI_LAYOUT_ACTIVE" then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("Input " .. tostring(device_index))
    last_midi = format_midi_buffer(buf)
  
    -- 0x01 = Note layout button
    if reported_layout == 0x01 then
      if DAW.MIDI_LAYOUT_BUILDER then
        DAW.MIDI_LAYOUT_BUILDER.waiting_for_note_return = false
        DAW.MIDI_LAYOUT_BUILDER.active_custom_slot = nil
      end
  
      return_to_home_page_1(
        "NOTE mode detected: returned from paired MIDI layout to HOME Page 1",
        false
      )
  
      return true
    end
  
    -- If the user manually switches to another Custom mode while in paired
    -- layout mode, keep standing aside and update the tracked custom slot.
    if reported_layout >= 0x04 and reported_layout <= 0x0B then
      if DAW.MIDI_LAYOUT_BUILDER then
        DAW.MIDI_LAYOUT_BUILDER.active_custom_slot = reported_layout - 0x03
      end
  
      last_action = "Paired MIDI layout custom mode changed to Custom "
        .. tostring(reported_layout - 0x03)
  
      return true
    end
  
    return true
  end
  
  
  
  if surface_mode == "CUSTOM_EXTERNAL" then
      local ok_name, source_name = r.GetMIDIInputName(device_index, "")
      last_midi_source = ok_name and source_name or ("Input " .. tostring(device_index))
      last_midi = format_midi_buffer(buf)
  
      if reported_layout == 0x00 or reported_layout == 0x01 then
        local layout_name = (reported_layout == 0x00) and "Session" or "Note"
      
        local return_page =
          math.max(1, math.min(3, math.floor(tonumber(DAW.custom_external_return_page) or 3)))
      
        local msg =
          DAW.custom_external_return_message
          or (
            "Novation " .. layout_name
            .. " mode detected: returned to HOME Page "
            .. tostring(return_page)
          )
      
        if return_page == 3 then
          return_to_home_page_1(msg, false, 3, true)
        else
          return_to_home_page_1(msg, false, return_page, false)
        end
  
      elseif reported_layout >= 0x04 and reported_layout <= 0x0B then
        DAW.CUSTOM_LIBRARY.mark_external_custom_mode(
          reported_layout - 0x03,
          "Passive external Custom Mode " .. tostring(reported_layout - 0x03) .. " selected"
        )
      end
  
      return true
    end

  if surface_mode ~= "DAW_VOLUME_FADERS"
      and surface_mode ~= "DAW_FX_FADERS"
      and surface_mode ~= "DAW_FX_MATRIX"
      and surface_mode ~= "TRACK_VIEWER_SESSION" then
    return false
  end

  if reported_layout == 0x00 then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("Input " .. tostring(device_index))
    last_midi = format_midi_buffer(buf)
    if surface_mode == "TRACK_VIEWER_SESSION" then
      if r.time_precise() <= (DAW.TRACK_VIEWER.session_entry_ack_ignore_until or 0) then
        DAW.TRACK_VIEWER.rebuild_surface(true)
        last_action = "Track Viewer Session layout acknowledged"
      else
        return_to_home_page_1("Track Viewer GO HOME: returned to HOME Page 1", false)
      end
    elseif surface_mode == "LEGACY_DAW_TRACK_MATRIX" then
      DAW.MATRIX.last_surface_signature = nil
      DAW.refresh_matrix_surface(true)
      last_action = "Session pressed: repainted current MCP matrix surface"
    elseif surface_mode == "DAW_FX_MATRIX" then
      DAW.FX.last_surface_signature = nil
      DAW.FX.refresh_matrix_surface(true)
      last_action = "Session pressed: repainted current FX Buttons surface"
    elseif surface_mode == "DAW_FX_FADERS" then
      DAW.send_bytes(DAW.FX.build_fader_setup(DAW.FX.active_page))
      DAW.FX.sync_fader_feedback(true)
      DAW.FX.send_right_column_indicators(true)
      DAW.send_top_row_indicators()
      DAW.send_layout(0x0D)
      last_action = "Session pressed: rebuilt current FX fader surface"
    else
      DAW.send_bytes(DAW.build_volume_fader_setup(DAW.current_start_track()))
      sync_active_custom_fader_feedback(true)
      DAW.send_bank_indicators(DAW.active_bank)
      DAW.send_top_row_indicators()
      DAW.send_layout(0x0D)
      last_action = "Session pressed: rebuilt current DAW fader surface"
    end
    return true
  elseif reported_layout == 0x01 then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("Input " .. tostring(device_index))
    last_midi = format_midi_buffer(buf)
    return_to_home_page_1(
      string.format("Novation layout %02X detected: returned to HOME Page 1", reported_layout),
      false
    )
    return true
  elseif reported_layout >= 0x04 and reported_layout <= 0x0B then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("Input " .. tostring(device_index))
    last_midi = format_midi_buffer(buf)
    DAW.CUSTOM_LIBRARY.mark_external_custom_mode(
      reported_layout - 0x03,
      "Novation Custom mode detected: script standing aside until Notes returns to HOME Page 3"
    )
    return true
  end
  return false
end

DAW.process_midi_event = function(buf, dev_idx)
  if not buf or (DAW.input_index == nil and DAW.input_index_2 == nil) then return false end
  local device_index = (dev_idx or 0) & 0xFFFF
  if not DAW.input_matches(device_index) then return false end

  if DAW.TRACK_VIEWER and DAW.TRACK_VIEWER.process_daw_midi_event
      and DAW.TRACK_VIEWER.process_daw_midi_event(buf, dev_idx) then
    return true
  end

  if DAW.FX and DAW.FX.process_midi_event and DAW.FX.process_midi_event(buf, dev_idx) then
    return true
  end

  local reported_layout = DAW.layout_from_report(buf)
  if surface_mode == "DAW_VOLUME_FADERS" and DAW.layout_is_escape(reported_layout) then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi_buffer(buf)
    return_to_home_page_1(
      string.format("Novation layout %02X detected: returned to HOME Page 1", reported_layout),
      false
    )
    return true
  end

  if #buf < 3 then return false end
  local status, data1, data2 = buf:byte(1, 3)
  if not status or not data1 or not data2 then return false end
  local message_type = status & 0xF0
  local channel = status & 0x0F

  -- The Session top-row button is the HOME escape from firmware faders.
  if surface_mode == "DAW_VOLUME_FADERS" and channel == 0 and message_type == 0xB0
      and data2 > 0 and data1 == DAW.GO_BACK_CC then
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)
    return_to_home_page_1("DAW Faders GO HOME: returned to HOME Page 1", false)
    return true
  end

  -- The remaining DAW-fader top row provides preset and bank navigation.
  -- Slots 5..7 are firmware-owned Session / Note / Custom buttons; their
  -- subsequent layout SysEx reports are handled above as escape requests.
  if surface_mode == "DAW_VOLUME_FADERS" and channel == 0 and message_type == 0xB0
      and data2 > 0 and DAW.TOP_ROW_SLOT_BY_CC[data1] then
    local slot = DAW.TOP_ROW_SLOT_BY_CC[data1]
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)
    DAW.handle_top_row_press(slot, "Hardware")
    return true
  end

  -- Session MCP matrix: inner 8x8 note pads and far-right CC column.
  if surface_mode == "LEGACY_DAW_TRACK_MATRIX" and channel == 0 then
    if (message_type == 0x90 or message_type == 0x80) then
      local row, col = DAW.MATRIX.matrix_note_to_cell(data1)
      if row and col then
        local pressed = message_type == 0x90 and data2 > 0
        local ok_name, source_name = r.GetMIDIInputName(device_index, "")
        last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
        last_midi = format_midi(status, data1, data2)
        DAW.MATRIX.matrix_handle_inner_pad(row, col, pressed)
        return true
      end
    elseif message_type == 0xB0 and data1 >= 0x13 and data1 <= 0x59 and ((data1 - 9) % 10) == 0 then
      local ok_name, source_name = r.GetMIDIInputName(device_index, "")
      last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
      last_midi = format_midi(status, data1, data2)
      DAW.MATRIX.matrix_handle_right_cc(data1, data2 > 0)
      return true
    end
  end

  -- The far-right column remains available in the DAW Fader layout as the
  -- Session-layout CC column. Treat a press as a logical MCP fader-bank change.
  -- Top-to-bottom hardware rows map to banks 8..1: CC 89,79,...,19.
  if surface_mode == "DAW_VOLUME_FADERS" and channel == 0 and message_type == 0xB0
      and data2 > 0 and DAW.BANK_SLOT_BY_CC[data1] then
    local bank = DAW.BANK_SLOT_BY_CC[data1]
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)
    DAW.select_volume_bank(bank)
    -- Select_volume_bank schedules the normal settled feedback pass. Send one
    -- immediate level sync as well so the visible faders redraw promptly.
    sync_active_custom_fader_feedback(true)
    return true
  end

  if surface_mode == "DAW_VOLUME_FADERS" and channel == DAW.FADER_CHANNEL
      and message_type == 0xB0 and data1 >= DAW.CC_FIRST and data1 <= DAW.CC_LAST then
    local now = r.time_precise()
    local ok_name, source_name = r.GetMIDIInputName(device_index, "")
    last_midi_source = ok_name and source_name or ("DAW Input " .. tostring(device_index))
    last_midi = format_midi(status, data1, data2)

    -- Reuse the proven early-lock logic from the Custom Mode path. The configured
    -- DAW faders intentionally use the same CC numbers, so the established queue
    -- and MCP-volume handling remain unchanged.
    begin_custom_fader_hardware_holdoff(data1, now)
    if not is_recent_outbound_custom_fader_echo(data1, data2, now) then
      queue_track_volume_from_custom_fader(data1, data2, now)
    end
    return true
  end

  return false
end

------------------------------------------------------------
-- DIRECT MIDI POLLING
------------------------------------------------------------
-- Latch the latest pre-existing event so the script does not replay old presses at startup.
local last_seen_sequence = select(1, r.MIDI_GetRecentInputEvent(0)) or 0

-- Novation layout reports use:
--   F0 00 20 29 02 <device> 00 <layout> F7
-- Accept reports from either configured model. Launchpad X uses device 0x0C;
-- Launchpad Mini Mk3 uses 0x0D.
DAW.ordinary_layout_from_report = function(buf)
  if not buf or #buf ~= 9 then return nil end
  local b = {buf:byte(1, 9)}
  if b[1] ~= 0xF0 or b[2] ~= 0x00 or b[3] ~= 0x20 or b[4] ~= 0x29
      or b[5] ~= 0x02 or not DAW.configured_device_id_matches(b[6])
      or b[7] ~= 0x00 or b[9] ~= 0xF7 then
    return nil
  end
  return b[8], b[6]
end

-- Launchpad X reports layout selections as:
--   F0 00 20 29 02 0C 00 <layout> F7
-- Layout 04..0B corresponds to Custom 1..8. Keep this separate from the
-- uploaded layout data: the report tells us which resident Custom slot the
-- user selected on the hardware, and therefore which eight-track MCP bank the
-- faders should control.
local function launchpad_x_custom_slot_from_report(buf)
  if not buf or #buf ~= 9 then return nil end
  local b = {buf:byte(1, 9)}
  if b[1] ~= 0xF0 or b[2] ~= 0x00 or b[3] ~= 0x20 or b[4] ~= 0x29
      or b[5] ~= 0x02 or b[6] ~= 0x0C or b[7] ~= 0x00 or b[9] ~= 0xF7 then
    return nil
  end
  if b[8] >= 0x04 and b[8] <= 0x0B then
    return b[8] - 0x03
  end
  return nil
end

DAW.programmer_surface_is_active = function()
  return surface_mode == "PROGRAMMER"
    or surface_mode == "PROGRAMMER_TRACK_MATRIX"
    or surface_mode == "TRACK_PICKER"
    or surface_mode == "REGIONS_MARKERS"
    or surface_mode == "USER_ACTIONS"
    or surface_mode == "USER_CUSTOMS"
end

DAW.ignore_guarded_programmer_layout_report = function(description)
  local now = r.time_precise()
  if not DAW.programmer_surface_is_active()
      or now > (tonumber(DAW.programmer_mode_ack_ignore_until) or 0) then
    return false
  end

  DAW.programmer_mode_ack_ignore_until = math.max(
    tonumber(DAW.programmer_mode_ack_ignore_until) or 0,
    now + (CFG.PROGRAMMER_MODE_ACK_BURST_EXTEND_SECONDS or 0.50)
  )
  last_action = "Ignored delayed Novation " .. tostring(description)
    .. " report after Programmer Mode request"
  return true
end

local function process_midi_event(buf, dev_idx)
  if not buf or #buf < 3 then return end

  local device_index = (dev_idx or 0) & 0xFFFF
  if not DAW.ordinary_input_matches(device_index) then
    return
  end

  local ok_name, source_name = r.GetMIDIInputName(device_index, "")
  last_midi_source = ok_name and source_name or ("Input " .. tostring(device_index))

  -- Experimental fallback: the DAW guide says the final top-row Capture button
  -- should remain available, but some firmware/port combinations may report it
  -- on the ordinary MIDI interface. Accept that route as HOME as well.
  if (surface_mode == "DAW_VOLUME_FADERS" or surface_mode == "DAW_FX_FADERS" or surface_mode == "DAW_FX_MATRIX" or surface_mode == "TRACK_VIEWER_SESSION") and #buf >= 3 then
    local status, data1, data2 = buf:byte(1, 3)
    if status and data1 and data2 and (status & 0xF0) == 0xB0
        and (status & 0x0F) == 0 and data1 == DAW.GO_BACK_CC and data2 > 0 then
      last_midi = format_midi(status, data1, data2)
      return_to_home_page_1("DAW Faders GO HOME (ordinary MIDI port): returned to HOME Page 1", false)
      return
    end
  end

  -- Session and Notes are both escape paths from a loaded Custom Mode. The
  -- device reports the selected Novation layout as SysEx. Session is also the
  -- firmware-owned GO BACK control for the DAW-fader surface.
  if DAW.ordinary_layout_from_report(buf) == 0x00 then
    last_midi = format_midi_buffer(buf)
    if surface_mode == "CUSTOM_EXTERNAL"
        and r.time_precise() <= (DAW.CUSTOM_LIBRARY.external_layout_ack_until or 0) then
      last_action = "External Session layout acknowledged"
      return
    elseif DAW.ignore_guarded_programmer_layout_report("Session-layout") then
      return
    elseif surface_mode == "TRACK_VIEWER_SESSION" then
      if r.time_precise() <= (DAW.TRACK_VIEWER.session_entry_ack_ignore_until or 0) then
        DAW.TRACK_VIEWER.rebuild_surface(true)
        last_action = "Track Viewer Session layout acknowledged"
      else
        return_to_home_page_1("Track Viewer GO HOME: returned to HOME Page 1", false)
      end
    elseif surface_mode == "LEGACY_DAW_TRACK_MATRIX" then
      DAW.MATRIX.last_surface_signature = nil
      DAW.refresh_matrix_surface(true)
      last_action = "Novation Session detected: repainted current MCP matrix surface"
    elseif surface_mode == "DAW_FX_MATRIX" then
      DAW.FX.last_surface_signature = nil
      DAW.FX.refresh_matrix_surface(true)
      last_action = "Novation Session detected: repainted current FX Buttons surface"
    elseif surface_mode == "DAW_FX_FADERS" then
      DAW.send_bytes(DAW.FX.build_fader_setup(DAW.FX.active_page))
      DAW.FX.sync_fader_feedback(true)
      DAW.FX.send_right_column_indicators(true)
      DAW.send_top_row_indicators()
      DAW.send_layout(0x0D)
      last_action = "Novation Session detected: rebuilt current FX fader surface"
    elseif surface_mode == "DAW_VOLUME_FADERS" then
      DAW.send_bytes(DAW.build_volume_fader_setup(DAW.current_start_track()))
      sync_active_custom_fader_feedback(true)
      DAW.send_bank_indicators(DAW.active_bank)
      DAW.send_top_row_indicators()
      DAW.send_layout(0x0D)
      last_action = "Novation Session detected: rebuilt current DAW fader surface"
    else
      return_to_home_page_1("Novation Session detected: returned to HOME Page 1", true)
    end
    return
  end

  if DAW.ordinary_layout_from_report(buf) == 0x01 then
    last_midi = format_midi_buffer(buf)
  
    if surface_mode == "CUSTOM_EXTERNAL" then
      local return_page =
        math.max(1, math.min(3, math.floor(tonumber(DAW.custom_external_return_page) or 3)))
  
      local msg =
        DAW.custom_external_return_message
        or (
          "Novation Note mode detected: returned to HOME Page "
          .. tostring(return_page)
        )
  
      if return_page == 3 then
        return_to_home_page_1(msg, false, 3, true)
      else
        return_to_home_page_1(msg, false, return_page, false)
      end
  
      return
    end

    -- send_programmer_mode() can provoke this exact Note-layout report as an
    -- acknowledgment. Do not feed that acknowledgment back into
    -- return_to_home_page_1(), which would request Programmer Mode again and
    -- create a self-sustaining HOME Page 1 loop.
    if DAW.ignore_guarded_programmer_layout_report("Note-layout") then
      return
    end

    return_to_home_page_1(
      "Novation Note mode detected: returned to HOME Page 1",
      false
    )
    return
  end

  local reported_custom_slot = launchpad_x_custom_slot_from_report(buf)
  if reported_custom_slot then
    if DAW.ignore_guarded_programmer_layout_report("Custom-layout") then
      return
    end
    last_midi = format_midi_buffer(buf)
    DAW.CUSTOM_LIBRARY.mark_external_custom_mode(
      reported_custom_slot,
      "Launchpad X Custom " .. tostring(reported_custom_slot)
        .. " selected: script standing aside until Notes returns to HOME Page 3"
    )
    return
  end

  -- Custom Mode belongs to the Launchpad firmware. Ignore its ordinary note and
  -- CC traffic completely; only the layout reports above are meaningful here.
  if surface_mode == "CUSTOM_EXTERNAL" or surface_mode == "CUSTOM_PENDING" then
    return
  end

  -- During a staged HOME recovery, ignore ordinary pad/CC traffic left over
  -- from the layout-button gesture. Layout reports above remain visible, but a
  -- stale release or spillover press cannot accidentally select Page 2 or fire
  -- an action before the surface has finished rebuilding.
  if DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.pending_home_resend_time then
    return
  end

  local status, data1, data2 = buf:byte(1, 3)
  if not status or not data1 or not data2 then return end

  last_midi = format_midi(status, data1, data2)

  local message_type = status & 0xF0
  local channel = status & 0x0F

  -- Legacy compatibility only: older sessions could have entered a scripted
  -- Custom volume-bank state. New Custom selections remain passive above and
  -- never reach this branch.
  if channel == VOLUME_MIDI_CHANNEL and message_type == 0xB0 and active_custom_slot ~= nil
      and surface_mode == "CUSTOM_VOLUME_BANK"
      and data1 >= VOLUME_CC_FIRST and data1 <= VOLUME_CC_LAST then
    local now = r.time_precise()

    -- Arm the Novation-side holdoff before echo classification. A very quick tap
    -- can otherwise lose the race to the periodic DAW-feedback pass and visibly
    -- snap back to the previous LED level.
    begin_custom_fader_hardware_holdoff(data1, now)

    if is_recent_outbound_custom_fader_echo(data1, data2, now) then
      return
    end
    queue_track_volume_from_custom_fader(data1, data2, now)
    return
  end

  -- Programmer Mode uses notes for the 8x8 area and CC messages for outer buttons.
  -- Most controls act on press. Held scan controls and temporary page previews also
  -- consume release events.
  if channel == 0 and (message_type == 0x90 or message_type == 0xB0) then
    local index = PAD_INDEX_BY_ADDRESS[data1]
    if not index then return end
    
    if surface_mode == "SYSEX_LAYOUT_EDITOR" then
          if data2 > 0
              and DAW.MIDI_LAYOUT_BUILDER
              and DAW.MIDI_LAYOUT_BUILDER.handle_editor_confirm_hardware_index then
            DAW.MIDI_LAYOUT_BUILDER.handle_editor_confirm_hardware_index(index)
          end
          return
        end
  
    if surface_mode == "MIDI_LAYOUT_SETUP" and DAW.MIDI_LAYOUT_BUILDER then
      if data2 > 0 then
        DAW.MIDI_LAYOUT_BUILDER.dispatch_index(index, "Hardware")
      end
      return
    end
  
    if (current_page == 2 or current_page == 3) and DAW.USER_PAGES
        and surface_mode == "PROGRAMMER" then
      local row = math.floor((index - 1) / 9) + 1
      local col = ((index - 1) % 9) + 1
      DAW.USER_PAGES.run_cell(current_page,row,col,data2 > 0,"Hardware")
      return
    elseif surface_mode == "REGIONS_MARKERS" then
      DAW.REGIONS_MARKERS.dispatch_index(index, data2 > 0, "Hardware")
      return
    elseif surface_mode == "TRACK_PICKER" then
      if data2 > 0 then
        DAW.TRACK_PICKER.dispatch_index(index, "Hardware")
      end
      return
    elseif surface_mode == "PROGRAMMER_TRACK_MATRIX" then
      DAW.MATRIX.matrix_handle_programmer_index(index, data2 > 0)
      return
    end

    local label = normalize_label(label_for_index(index))
    local hold_action = HOLD_ACTIONS[label]

    if data2 > 0 then
      if hold_action then
        hold_action.press()
        refresh_hardware_state(true)
      else
        dispatch_index(index, "Hardware")
      end
    else
      if hold_action then
        hold_action.release()
        refresh_hardware_state(true)
      end

      local released_page = DAW.page_number_from_label(label) == current_page
      if released_page then
        release_grid_preview()
      end
    end
  end
end

local function poll_recent_midi()
  local pending = {}

  for idx = 0, CFG.MAX_RECENT_EVENTS - 1 do
    local seq, buf, _, dev_idx = r.MIDI_GetRecentInputEvent(idx)
    if not seq or seq == 0 or seq == last_seen_sequence then
      break
    end
    pending[#pending + 1] = {seq = seq, buf = buf, dev_idx = dev_idx}
  end

  -- Events are returned newest-first. Process oldest-first.
  for i = #pending, 1, -1 do
    local event = pending[i]
    if DAW.SLEEP and DAW.SLEEP.consume_event(event.buf, event.dev_idx) then
      -- Sleep consumes every MIDI event; the first button press wakes without
      -- also triggering the button's ordinary action.
    elseif DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.capture_readback(event.buf, event.dev_idx) then
      -- Custom readback SysEx belongs to the librarian, not surface dispatch.
    else
    local handled_layout = DAW.handle_layout_report_from_either_port(event.buf, event.dev_idx)
    local handled_by_daw = handled_layout or DAW.process_midi_event(event.buf, event.dev_idx)
    if not handled_by_daw then
      process_midi_event(event.buf, event.dev_idx)
    end
    end
  end

  if pending[1] then
    last_seen_sequence = pending[1].seq
  end

  flush_custom_fader_values()
  if DAW.FX and DAW.FX.flush_fader_values then DAW.FX.flush_fader_values() end
end

------------------------------------------------------------
-- GUI
------------------------------------------------------------
local ctx = nil
local custom_footer_font = nil
local open = true

local function attach_context_fonts()
  custom_footer_font = nil
  DAW.GUI.screen_title_font = nil
  DAW.GUI.track_number_font = nil
  if r.ImGui_CreateFont and r.ImGui_Attach then
    custom_footer_font = r.ImGui_CreateFont("sans-serif", 9)
    DAW.GUI.screen_title_font = r.ImGui_CreateFont("sans-serif", 19)
    DAW.GUI.track_number_font = r.ImGui_CreateFont("sans-serif", 16)
    if custom_footer_font then r.ImGui_Attach(ctx, custom_footer_font) end
    if DAW.GUI.screen_title_font then r.ImGui_Attach(ctx, DAW.GUI.screen_title_font) end
    if DAW.GUI.track_number_font then r.ImGui_Attach(ctx, DAW.GUI.track_number_font) end
  end
end

local function context_is_valid()
  if not ctx then return false end
  if r.ImGui_ValidatePtr then
    return r.ImGui_ValidatePtr(ctx, "ImGui_Context*")
  end
  return true
end

local function ensure_context()
  if not context_is_valid() then
    ctx = r.ImGui_CreateContext(CFG.WINDOW_TITLE)
    attach_context_fonts()
  end
  return ctx
end

local function window_flag(name)
  local fn = r["ImGui_WindowFlags_" .. name]
  return fn and fn() or 0
end

local HIDDEN_KEEPALIVE_FLAGS =
    window_flag("NoTitleBar")
  | window_flag("NoResize")
  | window_flag("NoMove")
  | window_flag("NoScrollbar")
  | window_flag("NoSavedSettings")
  | window_flag("NoInputs")

local function keep_context_alive_while_hidden()
  ensure_context()
  r.ImGui_SetNextWindowPos(ctx, -10000, -10000, r.ImGui_Cond_Always())
  r.ImGui_SetNextWindowSize(ctx, 1, 1, r.ImGui_Cond_Always())
  local visible = r.ImGui_Begin(ctx, "##Launchpad_Xtra_Hidden_Keepalive", true, HIDDEN_KEEPALIVE_FLAGS)
  if visible ~= nil then
    r.ImGui_End(ctx)
  end
end

ensure_context()

local function draw_device_setup()
  local label_x, input_x, output_x, model_x = 12, 145, 472, 799
  local combo_width, model_width = 300, 190

  local function set_x(x)
    if r.ImGui_SetCursorPosX then r.ImGui_SetCursorPosX(ctx, x) end
  end

  local function begin_combo(id, shown, width)
    r.ImGui_SetNextItemWidth(ctx, width or combo_width)
    return r.ImGui_BeginCombo(ctx, "##" .. tostring(id), tostring(shown or ""))
  end

  local function ordinary_input_combo(id, secondary)
    local shown = secondary and DAW.ordinary_input_name_2 or selected_input_name
    if begin_combo(id, shown) then
      if secondary and r.ImGui_Selectable(ctx, DAW.NO_SECONDARY_ORDINARY_INPUT_NAME, DAW.ordinary_input_index_2 == nil) then
        DAW.ordinary_input_index_2, DAW.ordinary_input_name_2 = nil, DAW.NO_SECONDARY_ORDINARY_INPUT_NAME
        DAW.save_selected_input_2(DAW.ordinary_input_name_2)
        initialized = false
      end
      for _, input in ipairs(midi_inputs) do
        if not secondary or input.index ~= -1 then
          local selected = secondary
            and input.index == DAW.ordinary_input_index_2
            or ((not secondary) and input.index == selected_input_index)
          if r.ImGui_Selectable(ctx, input.name, selected) then
            if secondary then
              DAW.ordinary_input_index_2, DAW.ordinary_input_name_2 = input.index, input.name
              DAW.save_selected_input_2(input.name)
            else
              selected_input_index, selected_input_name = input.index, input.name
              save_selected_input(input.name)
            end
            initialized = false
            last_action = "Listening to " .. input.name .. "; press Initialize hardware"
          end
        end
      end
      r.ImGui_EndCombo(ctx)
    end
  end

  local function ordinary_output_combo(id, secondary)
    local shown = secondary and DAW.ordinary_output_name_2 or selected_output_name
    if begin_combo(id, shown) then
      if secondary and r.ImGui_Selectable(ctx, DAW.NO_SECONDARY_ORDINARY_OUTPUT_NAME, DAW.ordinary_output_index_2 == nil) then
        DAW.ordinary_output_index_2, DAW.ordinary_output_name_2 = nil, DAW.NO_SECONDARY_ORDINARY_OUTPUT_NAME
        DAW.save_selected_output_2(DAW.ordinary_output_name_2)
        initialized = false
      end
      for _, output in ipairs(midi_outputs) do
        local selected = secondary
          and output.index == DAW.ordinary_output_index_2
          or ((not secondary) and output.index == selected_output_index)
        if r.ImGui_Selectable(ctx, output.name, selected) then
          if secondary then
            DAW.ordinary_output_index_2, DAW.ordinary_output_name_2 = output.index, output.name
            DAW.save_selected_output_2(output.name)
          else
            selected_output_index, selected_output_name = output.index, output.name
            save_selected_output(output.name)
          end
          initialized = false
          last_action = "Selected output " .. output.name .. "; press Initialize hardware"
        end
      end
      r.ImGui_EndCombo(ctx)
    end
  end

  local function daw_input_combo(id, secondary)
    local shown = secondary and DAW.input_name_2 or DAW.input_name
    local none_name = secondary and DAW.NO_INPUT_NAME_2 or DAW.NO_INPUT_NAME
    local selected_index = secondary and DAW.input_index_2 or DAW.input_index
    if begin_combo(id, shown) then
      if r.ImGui_Selectable(ctx, none_name, selected_index == nil) then
        if secondary then
          DAW.input_index_2, DAW.input_name_2 = nil, none_name
          DAW.save_input_2(none_name)
        else
          DAW.input_index, DAW.input_name = nil, none_name
          DAW.save_input(none_name)
        end
        initialized = false
      end
      for _, input in ipairs(midi_inputs) do
        if input.index ~= -1 then
          local selected = input.index == selected_index
          if r.ImGui_Selectable(ctx, input.name, selected) then
            if secondary then
              DAW.input_index_2, DAW.input_name_2 = input.index, input.name
              DAW.save_input_2(input.name)
            else
              DAW.input_index, DAW.input_name = input.index, input.name
              DAW.save_input(input.name)
            end
            initialized = false
            last_action = "Selected " .. input.name .. "; press Initialize hardware"
          end
        end
      end
      r.ImGui_EndCombo(ctx)
    end
  end

  local function daw_output_combo(id, secondary)
    local shown = secondary and DAW.output_name_2 or DAW.output_name
    local none_name = secondary and DAW.NO_OUTPUT_NAME_2 or DAW.NO_OUTPUT_NAME
    local selected_index = secondary and DAW.output_index_2 or DAW.output_index
    if begin_combo(id, shown) then
      if r.ImGui_Selectable(ctx, none_name, selected_index == nil) then
        if secondary then
          DAW.output_index_2, DAW.output_name_2 = nil, none_name
          DAW.save_output_2(none_name)
        else
          DAW.output_index, DAW.output_name = nil, none_name
          DAW.save_output(none_name)
        end
        initialized = false
      end
      for _, output in ipairs(midi_outputs) do
        local selected = output.index == selected_index
        if r.ImGui_Selectable(ctx, output.name, selected) then
          if secondary then
            DAW.output_index_2, DAW.output_name_2 = output.index, output.name
            DAW.save_output_2(output.name)
          else
            DAW.output_index, DAW.output_name = output.index, output.name
            DAW.save_output(output.name)
          end
          initialized = false
          last_action = "Selected " .. output.name .. "; press Initialize hardware"
        end
      end
      r.ImGui_EndCombo(ctx)
    end
  end

  local function device_model_combo(id, secondary)
    local chosen = secondary and DAW.secondary_device or selected_device
    if begin_combo(id, chosen.name, model_width) then
      for _, device in ipairs(DEVICES) do
        if r.ImGui_Selectable(ctx, device.name, device.key == chosen.key) then
          if secondary then
            DAW.set_secondary_device_model(device)
          else
            DAW.set_primary_device_model(device)
          end
        end
      end
      r.ImGui_EndCombo(ctx)
    end
  end

  local function draw_headers()
    set_x(input_x); r.ImGui_Text(ctx, "Input")
    r.ImGui_SameLine(ctx); set_x(output_x); r.ImGui_Text(ctx, "Output")
    r.ImGui_SameLine(ctx); set_x(model_x); r.ImGui_Text(ctx, "Device Type")
  end

  local function draw_row(label, input_draw, output_draw, model_draw)
    set_x(label_x); r.ImGui_Text(ctx, label)
    r.ImGui_SameLine(ctx); set_x(input_x); input_draw()
    r.ImGui_SameLine(ctx); set_x(output_x); output_draw()
    if model_draw then
      r.ImGui_SameLine(ctx); set_x(model_x); model_draw()
    end
  end

  draw_headers()
  draw_row(
    "Primary MIDI",
    function() ordinary_input_combo("primary_midi_input", false) end,
    function() ordinary_output_combo("primary_midi_output", false) end,
    function() device_model_combo("primary_device_type", false) end
  )
  draw_row(
    "Primary DAW",
    function() daw_input_combo("primary_daw_input", false) end,
    function() daw_output_combo("primary_daw_output", false) end
  )

  r.ImGui_Separator(ctx)

  draw_row(
    "Secondary MIDI",
    function() ordinary_input_combo("secondary_midi_input", true) end,
    function() ordinary_output_combo("secondary_midi_output", true) end,
    function() device_model_combo("secondary_device_type", true) end
  )
  draw_row(
    "Secondary DAW",
    function() daw_input_combo("secondary_daw_input", true) end,
    function() daw_output_combo("secondary_daw_output", true) end
  )

  if r.ImGui_Button(ctx, "Refresh MIDI Ports") then
    refresh_midi_inputs()
    refresh_midi_outputs()
    DAW.refresh_selection()
    initialized = false
    last_action = "MIDI port lists refreshed; press Initialize hardware"
  end
end

local function draw_hardware_controls()
  if r.ImGui_Button(ctx, "Initialize hardware") then
    initialize_hardware()
  end

  r.ImGui_SameLine(ctx)
  if r.ImGui_Button(ctx, "Resend current page") then
    if not initialized then
      initialize_hardware()
    else
      send_page_lighting(current_page)
    end
  end

  r.ImGui_SameLine(ctx)
  if r.ImGui_Button(ctx, "Return to Live Mode") then
    send_live_mode()
  end

  r.ImGui_SameLine(ctx)
  local changed
  changed, return_to_live_on_exit = r.ImGui_Checkbox(ctx, "Return to Live Mode when script closes", return_to_live_on_exit)
end

