-- Palette values sampled from the supplied Components-style Custom SysEx.
-- Its eight Custom rows align with HOME rows 2-9 because HOME adds a separate
-- header row. Only explicit 0x48 pad blocks are listed here. Omitted pads keep
-- their original LaunchpadSystemLib colors. The Custom mockup uses palette 0x03
-- (white) as a visible stand-in for deliberately dark working buttons; convert
-- those white samples to true LED-off palette 0x00 on the scripted surface.
DAW.HOME_SYSEX_COLOR_OVERRIDES = {
  [2] = {[6] = 0x28, [7] = 0x28, [8] = 0x28},
  [3] = {[6] = 0x28, [7] = 0x28, [8] = 0x28},
  [4] = {[6] = 0x00, [7] = 0x01, [8] = 0x00},
  [5] = {[6] = 0x01, [7] = 0x00, [8] = 0x01},
  [6] = {[6] = 0x00, [7] = 0x01, [8] = 0x00},
  [7] = {[6] = 0x05, [7] = 0x21, [8] = 0x21},
  [8] = {[7] = 0x32, [8] = 0x0C},
  [9] = {[6] = 0x15, [8] = 0x01},
}

-- The hardware palette's 0x00 value is genuinely dark. The sampled palette
-- chart uses a visible gray swatch for index zero, which is useful as a chart
-- legend but misleading on the helper GRID. Draw intentionally dark HOME pads
-- with a deliberately visible dark-gray background on the helper GRID.
DAW.HOME_LED_OFF_GUI_COLOR = 0x282828FF

-- The upper-right helper-GRID status cell has no corresponding physical pad.
-- Draw it as a true black display tile with slightly larger, bold-like text in
-- the page's identity colour rather than making it resemble an LED pad.
DAW.PAGE_STATUS_GUI_BACKGROUND = 0x000000FF
DAW.GUI.page_status_draw_options = function()
  return {
    max_lines = 3,
    font = DAW.GUI.track_number_font,
    font_size = 16,
    bold = true,
  }
end

DAW.apply_home_frame_layout = function()
  for page = 1, 3 do
    for row, row_labels in pairs(DAW.HOME_FRAME_LABELS) do
      for col, label in pairs(row_labels) do
        labels[page][row][col] = label
      end
    end

    -- Match the header movement families to their right-edge timeline peers:
    -- Bank -/+40 follows Go Back/Forward 1 Section (0x25);
    -- Step -/+10 follows Go Back/Forward 1 Bar (0x21).
    hardware_colors[page][1] = " 25 "
    hardware_colors[page][2] = " 25 "
    hardware_colors[page][3] = " 21 "
    hardware_colors[page][4] = " 21 "
    gui_colors[page][1] = DAW.SAMPLED_PALETTE_GUI_COLORS[0x25] or 0x61EEFFFF
    gui_colors[page][2] = DAW.SAMPLED_PALETTE_GUI_COLORS[0x25] or 0x61EEFFFF
    gui_colors[page][3] = DAW.SAMPLED_PALETTE_GUI_COLORS[0x21] or 0x61FFE9FF
    gui_colors[page][4] = DAW.SAMPLED_PALETTE_GUI_COLORS[0x21] or 0x61FFE9FF

    -- The supplied Components-style Custom SysEx is an 8x8 layout. Its rows
    -- align with HOME rows 2-9 because HOME adds a separate header row. Apply
    -- every explicit 0x48 utility-pad block, while omitted pads retain their
    -- original colors from LaunchpadSystemLib.
    for row, row_colors in pairs(DAW.HOME_SYSEX_COLOR_OVERRIDES) do
      for col, palette in pairs(row_colors) do
        local index = ((row - 1) * 9) + col
        hardware_colors[page][index] = string.format(" %02X ", palette)
        gui_colors[page][index] =
          (palette == 0x00 and DAW.HOME_LED_OFF_GUI_COLOR)
          or DAW.SAMPLED_PALETTE_GUI_COLORS[palette]
          or DAW_MATRIX_PALETTE_TO_GUI_COLOR[palette]
          or gui_colors[page][index]
      end
    end

    -- Play deliberately matches REDO exactly: copy both the physical palette
    -- value and the helper-GRID colour rather than merely choosing a similar
    -- green from the sampled palette chart.
    local play_index = ((9 - 1) * 9) + 6
    hardware_colors[page][play_index] = hardware_colors[page][7]
    gui_colors[page][play_index] = gui_colors[page][7]
  end
end
DAW.apply_home_frame_layout()

