-- @description Launchpad Xtra - Direct MIDI Controller
-- @author Rock Kennedy + ChatGPT
-- @version 6.68 Narrows editor label field and tunes Custom upload table columns
-- @about
--   Standalone Launchpad rebuild prototype.
--
--   This test does NOT use ReaLearn. Presets 21-23 use ValueVault in Monitoring FX.
--   It loads LaunchpadSystemLib.lua from the same folder, switches a selected
--   Launchpad X or Launchpad Mini Mk3 into Programmer Mode, sends the existing
--   9x9 home-page lighting configuration directly to the hardware, draws a
--   resizable labeled helper grid, changes pages directly from incoming MIDI,
--   and runs the first set of clear REAPER actions directly. In volume Custom
--   Modes, MCP-visible track volumes and the eight Novation faders synchronize
--   in both directions without immediately echoing the same movement back.
--
--   Experimental addition: the Library also remembers a second DAW MIDI In/Out
--   pair and can configure the Launchpad firmware DAW Fader layout through the
--   DAW port. This is intentionally a parallel test path; the working Custom
--   Mode volume patch remains available unchanged.
--
--   Programmer Mode page buttons:
--     Page 1: B0 27 xx  (CC 39)
--     Page 2: B0 1D xx  (CC 29)
--     Page 3: B0 13 xx  (CC 19)
--
--   A small "x" on an on-screen cell means that the cell is intentionally not
--   wired yet. Numbered selection slots and project-specific navigation remain
--   placeholders until their intended behavior is defined.

local r = reaper

------------------------------------------------------------
-- STARTUP CHECKS
------------------------------------------------------------
if not r.ImGui_CreateContext then
  r.ShowMessageBox(
    "This script requires ReaImGui. Install or update ReaImGui through ReaPack, then run the script again.",
    "Launchpad Xtra",
    0
  )
  return
end

if not r.MIDI_GetRecentInputEvent then
  r.ShowMessageBox(
    "This version of REAPER does not provide MIDI_GetRecentInputEvent(). Please update REAPER and run the script again.",
    "Launchpad Xtra",
    0
  )
  return
end

if not r.SendMIDIMessageToHardware then
  r.ShowMessageBox(
    "This version of REAPER does not provide SendMIDIMessageToHardware(). Please update REAPER and run the script again.",
    "Launchpad Xtra",
    0
  )
  return
end

if r.set_action_options then
  -- Relaunching the action stops the already-running copy instead of opening duplicates.
  r.set_action_options(1)
end

local script_path = ({r.get_action_context()})[2]:match("^(.*[/\\])") or ""
local library_path = script_path .. "LaunchpadSystemLib.lua"
local ok, Lpxlib = pcall(dofile, library_path)

if not ok or type(Lpxlib) ~= "table" then
  r.ShowMessageBox(
    "Could not load LaunchpadSystemLib.lua.\n\nPlace this test script in the same folder as LaunchpadSystemLib.lua.\n\nAttempted path:\n" .. library_path,
    "Launchpad Xtra",
    0
  )
  return
end

------------------------------------------------------------
-- CONFIGURATION
------------------------------------------------------------
