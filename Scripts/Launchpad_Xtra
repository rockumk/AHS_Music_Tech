DAW.apply_matched_home_function_colors = function()
  for _, grid in ipairs({
    DAW.MATRIX and DAW.MATRIX.MAIN_UTILITY,
    DAW.TRACK_VIEWER and DAW.TRACK_VIEWER.STATIC_BUTTONS,
  }) do
    if grid then
      for _, row in pairs(grid) do
        for _, info in pairs(row) do
          local palette = info and DAW.MATCHED_HOME_FUNCTION_COLORS[info.label]
          if palette then info.color = palette end
        end
      end
    end
  end
end
DAW.apply_matched_home_function_colors()

local function validate_library()
  for page = 1, 3 do
    if #labels[page] ~= 9 then
      return false, "Page " .. page .. " does not contain 9 label rows."
    end
    for row = 1, 9 do
      if #labels[page][row] ~= 9 then
        return false, "Page " .. page .. ", row " .. row .. " does not contain 9 labels."
      end
    end
    if #gui_colors[page] ~= 81 then
      return false, "Page " .. page .. " does not contain 81 GUI colors."
    end
    if type(hardware_colors[page]) ~= "table" or #hardware_colors[page] ~= 81 then
      return false, "Page " .. page .. " does not contain 81 hardware palette colors."
    end
  end

  if type(Lpxlib.pad_types) ~= "table" or #Lpxlib.pad_types ~= 81 then
    return false, "pad_types does not contain 81 entries."
  end

  if type(Lpxlib.pad_addresses) ~= "table" or #Lpxlib.pad_addresses ~= 81 then
    return false, "pad_addresses does not contain 81 entries."
  end

  return true
end

local valid, err = validate_library()
if not valid then
  r.ShowMessageBox(
    "LaunchpadSystemLib.lua could not be interpreted:\n\n" .. tostring(err),
    "Launchpad Xtra",
    0
  )
  return
end

local function brighten(color, amount)
  local rr = (color >> 24) & 0xFF
  local gg = (color >> 16) & 0xFF
  local bb = (color >> 8)  & 0xFF
  local aa = color & 0xFF

  rr = math.min(255, math.floor(rr + (255 - rr) * amount + 0.5))
  gg = math.min(255, math.floor(gg + (255 - gg) * amount + 0.5))
  bb = math.min(255, math.floor(bb + (255 - bb) * amount + 0.5))

  return (rr << 24) | (gg << 16) | (bb << 8) | aa
end

local function scale_color(color, factor)
  local rr = (color >> 24) & 0xFF
  local gg = (color >> 16) & 0xFF
  local bb = (color >> 8)  & 0xFF
  local aa = color & 0xFF

  rr = math.max(0, math.min(255, math.floor(rr * factor + 0.5)))
  gg = math.max(0, math.min(255, math.floor(gg * factor + 0.5)))
  bb = math.max(0, math.min(255, math.floor(bb * factor + 0.5)))

  return (rr << 24) | (gg << 16) | (bb << 8) | aa
end

local function readable_text_color(background)
  local rr = (background >> 24) & 0xFF
  local gg = (background >> 16) & 0xFF
  local bb = (background >> 8)  & 0xFF
  local brightness = (rr * 299 + gg * 587 + bb * 114) / 1000
  return (brightness >= 150) and 0x000000FF or 0xFFFFFFFF
end

local function format_midi(status, data1, data2)
  if not status then return "None yet" end
  return string.format("%02X %02X %02X", status or 0, data1 or 0, data2 or 0)
end

local function format_midi_buffer(buf)
  if not buf or buf == "" then return "None yet" end
  local parts = {}
  for i = 1, #buf do
    parts[#parts + 1] = string.format("%02X", buf:byte(i))
  end
  return table.concat(parts, " ")
end

local function pulse_gui_color(color)
  -- Mirror the Launchpad pulse while keeping each coloured GRID cell inside
  -- its own hue family. Red must pulse from dark red to saturated red; orange
  -- from dark orange to saturated orange. Do not brighten coloured cells by
  -- drifting them toward white, pink, or yellow. Neutral white buttons still
  -- breathe from light gray to white.
  local wave = (math.sin(r.time_precise() * math.pi * 2.0 / 1.15) + 1.0) * 0.5
  local rr = (color >> 24) & 0xFF
  local gg = (color >> 16) & 0xFF
  local bb = (color >> 8)  & 0xFF
  local aa = color & 0xFF

  -- Intentionally dark working buttons remain truly black while idle. When
  -- active, mirror the hardware's off-to-dimmest-gray pulse with a restrained
  -- near-black breathing effect rather than jumping to a bright neutral white.
  if rr <= 0x20 and gg <= 0x20 and bb <= 0x20 then
    local level = math.floor(0x18 + ((0x55 - 0x18) * wave) + 0.5)
    return (level << 24) | (level << 16) | (level << 8) | aa
  end

  -- Neutral cells must stay neutral. The previous HSV branch forced gray
  -- buttons into an arbitrary red hue, which made white/gray page indicators
  -- and other neutral active controls pulse red. Keep all low-chroma colors
  -- breathing from light gray to white instead.
  local spread = math.max(rr, gg, bb) - math.min(rr, gg, bb)
  if spread <= 0x18 then
    local low = (rr >= 0xDD and gg >= 0xDD and bb >= 0xDD) and 0xB8 or 0xA0
    local level = math.floor(low + ((0xFF - low) * wave) + 0.5)
    return (level << 24) | (level << 16) | (level << 8) | aa
  end

  local rf, gf, bf = rr / 255, gg / 255, bb / 255
  local maxc = math.max(rf, gf, bf)
  local minc = math.min(rf, gf, bf)
  local delta = maxc - minc
  local hue = 0

  if delta > 0.000001 then
    if maxc == rf then
      hue = ((gf - bf) / delta) % 6
    elseif maxc == gf then
      hue = ((bf - rf) / delta) + 2
    else
      hue = ((rf - gf) / delta) + 4
    end
    hue = hue / 6
  end

  local saturation = math.max((maxc > 0 and (delta / maxc) or 0), 0.92)
  -- Keep the pulse vivid but restrained. The peak stays saturated without
  -- climbing so high that red reads as pink or orange reads as yellow.
  local value = 0.34 + (0.46 * wave)
  local chroma = value * saturation
  local segment = (hue * 6) % 6
  local x = chroma * (1 - math.abs((segment % 2) - 1))
  local m = value - chroma
  local r1, g1, b1

  if segment < 1 then
    r1, g1, b1 = chroma, x, 0
  elseif segment < 2 then
    r1, g1, b1 = x, chroma, 0
  elseif segment < 3 then
    r1, g1, b1 = 0, chroma, x
  elseif segment < 4 then
    r1, g1, b1 = 0, x, chroma
  elseif segment < 5 then
    r1, g1, b1 = x, 0, chroma
  else
    r1, g1, b1 = chroma, 0, x
  end

  rr = math.floor((r1 + m) * 255 + 0.5)
  gg = math.floor((g1 + m) * 255 + 0.5)
  bb = math.floor((b1 + m) * 255 + 0.5)
  return (rr << 24) | (gg << 16) | (bb << 8) | aa
end

local ACTIVE_STATE_CHECKS = {}

local function is_label_active(label)
  local check = ACTIVE_STATE_CHECKS[label]
  if not check then return false end
  local ok_state, state = pcall(check)
  return ok_state and state and true or false
end

