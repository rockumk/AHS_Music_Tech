DAW.MIDI_LAYOUT_BUILDER.index_for_row_col = function(row, col)
  return ((row - 1) * 9) + col
end

DAW.MIDI_LAYOUT_BUILDER.pad_index = function(pad)
  return DAW.MIDI_LAYOUT_BUILDER.index_for_row_col(pad.row, pad.col)
end

DAW.MIDI_LAYOUT_BUILDER.pad_by_index = function(index)
  for _, pad in ipairs(DAW.MIDI_LAYOUT_BUILDER.PADS) do
    if DAW.MIDI_LAYOUT_BUILDER.pad_index(pad) == index then
      return pad
    end
  end
  return nil
end

