local midi_inputs = {}
local midi_outputs = {}

local function get_saved_extstate(key, fallback)
  local value = r.GetExtState(EXTSTATE_SECTION, key)
  return (value and value ~= "") and value or fallback
end

-- Keep a remembered name separately from the current numeric index. This lets
-- the selection survive REAPER reordering MIDI ports after a reconnect.
local preferred_input_name = get_saved_extstate(EXTSTATE_MIDI_INPUT_NAME, "")
local preferred_output_name = get_saved_extstate(EXTSTATE_MIDI_OUTPUT_NAME, "")
DAW.ordinary_preferred_input_name_2 = get_saved_extstate(DAW.ORDINARY_EXTSTATE_INPUT_NAME_2, "")
DAW.ordinary_preferred_output_name_2 = get_saved_extstate(DAW.ORDINARY_EXTSTATE_OUTPUT_NAME_2, "")
DAW.preferred_input_name = get_saved_extstate(DAW.EXTSTATE_INPUT_NAME, "")
DAW.preferred_output_name = get_saved_extstate(DAW.EXTSTATE_OUTPUT_NAME, "")
DAW.preferred_input_name_2 = get_saved_extstate(DAW.EXTSTATE_INPUT_NAME_2, "")
DAW.preferred_output_name_2 = get_saved_extstate(DAW.EXTSTATE_OUTPUT_NAME_2, "")

local function save_selected_input(name)
  preferred_input_name = name or ANY_INPUT_NAME
  r.SetExtState(EXTSTATE_SECTION, EXTSTATE_MIDI_INPUT_NAME, preferred_input_name, true)
end

local function save_selected_output(name)
  preferred_output_name = name or NO_OUTPUT_NAME
  r.SetExtState(EXTSTATE_SECTION, EXTSTATE_MIDI_OUTPUT_NAME, preferred_output_name, true)
end

