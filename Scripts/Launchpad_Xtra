-- First Custom Mode experiment: Button 1 uploads an eight-fader volume layout
-- into Launchpad X Custom Mode 1, then switches the hardware into that mode.
-- The pasted data below is a captured Launchpad Custom Mode dump. When sending
-- it back to the device, build_custom_mode_upload_message() changes the dump
-- direction byte from 0x10 to the host-upload byte 0x45 and keeps slot 1 at 0x04.
local VOLUME_CUSTOM_SLOT = 1
local VOLUME_MIDI_CHANNEL = 8 -- zero-based: incoming B8 status = MIDI channel 9
local VOLUME_CC_FIRST = 0x0B -- CC 11: Track 1 volume
local VOLUME_CC_LAST  = 0x12 -- CC 18: Track 8 volume
-- When the physical Session or Notes button changes the Launchpad X layout,
-- the device reports the selected Novation layout as SysEx. Treat either report
-- as an authoritative HOME request rather than guessing from an ordinary CC.
-- Session is cleared immediately before returning to Programmer Mode so its
-- native light pattern does not remain visible during the transition.
local LAUNCHPAD_X_NOVATION_SESSION_MODE_SYSEX = string.char(
  0xF0, 0x00, 0x20, 0x29, 0x02, 0x0C, 0x00, 0x00, 0xF7
)
local LAUNCHPAD_X_NOVATION_NOTE_MODE_SYSEX = string.char(
  0xF0, 0x00, 0x20, 0x29, 0x02, 0x0C, 0x00, 0x01, 0xF7
)

local RAINBOW_FADERS_CUSTOM_MODE_DUMP_HEX = [[
