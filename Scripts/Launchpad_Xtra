  MCP_TRACK_CACHE_REFRESH_INTERVAL = 0.50,
  MCP_UI_REFRESH_INTERVAL = 0.08,
  CUSTOM_FADER_FEEDBACK_POLL_INTERVAL = 0.04,
  CUSTOM_FADER_FEEDBACK_AFTER_MODE_SWITCH_DELAY = 0.05,
  CUSTOM_FADER_FEEDBACK_ECHO_SUPPRESSION_SECONDS = 0.15,
  CUSTOM_FADER_HARDWARE_TOUCH_HOLDOFF_SECONDS = 1.50, -- start immediately on any incoming Novation fader CC; release only after the newest physical-fader event has been quiet
  CUSTOM_EXTERNAL_LAYOUT_POLL_INTERVAL = 0.20, -- safe command-00 readback query while the firmware owns a resident Custom Mode

  -- Track-color triangles shown in the upper-left corner of track pads in
  -- presets 1-20. TRIANGLE_SIZE_RATIO controls how far the diagonal reaches
  -- across the pad width and down the pad height. 0.35 means approximately
  -- one third of each dimension. The pad border supplies the top and left
  -- triangle edges; only the black diagonal separator is drawn explicitly.
  TRACK_COLOR_TRIANGLE_SIZE_RATIO = 0.48,
  TRACK_COLOR_TRIANGLE_SEPARATOR_THICKNESS = 2,
  -- Extend the diagonal slightly beyond the filled triangle so the black
  -- separator always reaches both edges cleanly.
  TRACK_COLOR_TRIANGLE_SEPARATOR_OVERHANG = 3,
  TRACK_COLOR_CENTER_CAP_RATIO = 0.18,
  TRACK_COLOR_CENTER_CAP_HEIGHT_RATIO = 0.12,
  TRACK_COLOR_TRIANGLE_DEFAULT_COLOR = 0x777777FF,
  TRACK_COLOR_TRIANGLE_SEPARATOR_COLOR = 0x000000FF,

  -- The Launchpad can emit a burst of delayed layout reports after the
  -- script requests Programmer Mode. Ignore Note, Session, and Custom-layout
  -- reports briefly so stale acknowledgments cannot bounce a scripted page
  -- back to HOME. Any ignored report extends the guard slightly to absorb the
  -- remainder of the burst without forcing a REAPER restart.
  PROGRAMMER_MODE_ACK_IGNORE_SECONDS = 2.00,
  PROGRAMMER_MODE_ACK_BURST_EXTEND_SECONDS = 0.50,

  -- Returning from a resident Custom Mode or Sleep is deliberately staged.
  -- Request Programmer Mode first, pause, clear the surface, then rebuild one
  -- row at a time before sending two final full-surface insurance passes. This
  -- avoids relying on one large LED payload while the controller is settling.
  HOME_AFTER_PROGRAMMER_SETTLE_SECONDS = 0.20,
  HOME_REPAINT_CLEAR_GAP_SECONDS = 0.04,
  HOME_REPAINT_ROW_GAP_SECONDS = 0.015,
  HOME_REPAINT_FINAL_GAP_SECONDS = 0.08,
  HOME_AFTER_PROGRAMMER_INSURANCE_SECONDS = 0.18,
  HOME_REPAINT_PAGE_CHANGE_DELAY_SECONDS = 0.03,
  CUSTOM_UPLOAD_HOME_RECOVERY_DELAY_SECONDS = 1.00, -- after Switch To = 0, let the Launchpad finish storing payloads before rebuilding HOME
}

-- Custom Mode helper display: eight native Novation fader columns plus a GUI-only
-- header row and GUI-only MCP bank selector/status column. Each physical pad
-- exposes four brightness levels. Eight pads therefore display thirty-two native
-- volume stages from bottom to top. MIDI value 0 is the first native stage
-- (bottom pad at its faintest level), not an all-lights-off state. An off cell is
-- reserved for a missing or unavailable MCP-visible track.
local CUSTOM_FADER_STAGE_COUNT = 32
