DAW.apply_home_label_renames = function()
  for page = 1, #labels do
    for row = 1, #labels[page] do
      for col = 1, #labels[page][row] do
        local original = normalize_label(labels[page][row][col])
        labels[page][row][col] = DAW.HOME_LABEL_RENAMES[original] or labels[page][row][col]
      end
    end
  end
end
DAW.apply_home_label_renames()

