  col = 5,
  role = "editor_ok",
  label = {"OK"},
  color = 88,
}

DAW.MIDI_LAYOUT_BUILDER.track_has_valid_fxi = function(track)
  if not track or not r.TrackFX_GetInstrument then return false end

  local fx_index = r.TrackFX_GetInstrument(track)
  return fx_index and fx_index >= 0
end

DAW.MIDI_LAYOUT_BUILDER.clear_warning_and_return_home = function()
  DAW.MIDI_LAYOUT_BUILDER.warning = nil
  return_to_home_page_1("Pair Launchpad and FXi: returned to HOME Page 1", false)
  return true
end

DAW.MIDI_LAYOUT_BUILDER.build_warning_lighting_message = function()
  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03
  }

  -- Clear the whole 9x9 surface first.
  for i = 1, 81 do
    DAW.append_palette_colourspec(
      bytes,
      0x00,
      hex_string_to_byte(Lpxlib.pad_addresses[i]),
      0x00,
      0x00
    )
  end

  local ok_pad = DAW.MIDI_LAYOUT_BUILDER.WARNING_OK_PAD
  local ok_index = DAW.MIDI_LAYOUT_BUILDER.pad_index(ok_pad)

  DAW.append_palette_colourspec(
    bytes,
    0x00,
    hex_string_to_byte(Lpxlib.pad_addresses[ok_index]),
    ok_pad.color,
    0x00
  )

  bytes[#bytes + 1] = 0xF7
  return bytes
end

DAW.MIDI_LAYOUT_BUILDER.show_warning = function(lines, action_text)
  DAW.MIDI_LAYOUT_BUILDER.warning = {
    title = "Pair Launchpad and FXi",
    lines = lines or {},
  }

  if not send_programmer_mode() then return false end

  surface_mode = "MIDI_LAYOUT_SETUP"
  active_custom_slot = nil
  pending_custom_slot = nil
  pending_custom_switch_time = 0

  DAW.MIDI_LAYOUT_BUILDER.send_lighting()

  last_action = action_text or "Pair Launchpad and FXi warning"
  return true
end

DAW.MIDI_LAYOUT_BUILDER.choice_label = function(group, value)
  if group == "input" then
    if value == "launchpad" then return "Set LP as Track Input" end
    if value == "all_midi" then return "All MIDI as Track Input" end
    if value == "leave_input" then return "Leave Track Input" end
  elseif group == "prep" then
    if value == "drum_arranger" then return "Add N2N Drum Arranger" end
    if value == "arp" then return "Add N2N Arp" end
    if value == "leave_fx" then return "Leave Track FX" end
  end
  return tostring(value or "")
end

DAW.MIDI_LAYOUT_BUILDER.pad_is_selected = function(pad)
  if not pad then return false end
  if pad.group == "input" then
    return DAW.MIDI_LAYOUT_BUILDER.input_mode == pad.value
  elseif pad.group == "prep" then
    return DAW.MIDI_LAYOUT_BUILDER.prep_mode == pad.value
  end
  return false
end

DAW.MIDI_LAYOUT_BUILDER.selected_track_name = function()
  local track = DAW.MIDI_LAYOUT_BUILDER.target_track
  if not track then return "No selected track" end

  local ok, name = r.GetTrackName(track)
  name = ok and trim(name or "") or ""

  local number = r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER")
  number = math.floor((tonumber(number) or 0) + 0.5)

  if name ~= "" then
    return "Track " .. tostring(number) .. ": " .. name
  end

  return "Track " .. tostring(number)
end

DAW.MIDI_LAYOUT_BUILDER.build_lighting_message = function()
  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id, 0x03
  }

  -- Clear the whole 9x9 surface first.
  for i = 1, 81 do
    DAW.append_palette_colourspec(
      bytes,
      0x00,
      hex_string_to_byte(Lpxlib.pad_addresses[i]),
      0x00,
      0x00
    )
  end

  -- Paint the setup pads. Selected choices pulse.
  for _, pad in ipairs(DAW.MIDI_LAYOUT_BUILDER.PADS) do
    local index = DAW.MIDI_LAYOUT_BUILDER.pad_index(pad)
    local selected = DAW.MIDI_LAYOUT_BUILDER.pad_is_selected(pad)

    DAW.append_palette_colourspec(
      bytes,
      selected and 0x02 or 0x00,
      hex_string_to_byte(Lpxlib.pad_addresses[index]),
      pad.color,
      0x00
    )
  end

  bytes[#bytes + 1] = 0xF7
  return bytes
end

DAW.MIDI_LAYOUT_BUILDER.send_lighting = function()
  local message

  if DAW.MIDI_LAYOUT_BUILDER.warning then
    message = DAW.MIDI_LAYOUT_BUILDER.build_warning_lighting_message()
  else
    message = DAW.MIDI_LAYOUT_BUILDER.build_lighting_message()
  end

  if not send_bytes(message) then
    last_action = "Could not send MIDI Layout Builder lighting"
    return false
  end

  return true
end

DAW.MIDI_LAYOUT_BUILDER.launch = function()
  local track = r.GetSelectedTrack(0, 0)

  if not track then
    return DAW.MIDI_LAYOUT_BUILDER.show_warning(
      {
        "Before pairing the Launchpad with a Virtual Instrument,select a track with an FXi (VSTi, AUi, JSFXi, CLAPi)",
      },
      "Pair Launchpad and FXi needs a selected track"
    )
  end

  if not DAW.MIDI_LAYOUT_BUILDER.track_has_valid_fxi(track) then
    return DAW.MIDI_LAYOUT_BUILDER.show_warning(
      {
        "Before pairing the Launchpad with a Virtual Instrument, the selected track must have a valid FXi.",
        "(VSTi, AUi, JSFXi, CLAPi)",
      },
      "Pair Launchpad and FXi needs a track with a valid FXi"
    )
  end

  DAW.MIDI_LAYOUT_BUILDER.target_track = track
  DAW.MIDI_LAYOUT_BUILDER.input_mode = "launchpad"
  DAW.MIDI_LAYOUT_BUILDER.prep_mode = "leave_fx"

  if not send_programmer_mode() then return false end

  surface_mode = "MIDI_LAYOUT_SETUP"
  active_custom_slot = nil
  pending_custom_slot = nil
  pending_custom_switch_time = 0

  DAW.MIDI_LAYOUT_BUILDER.send_lighting()

  last_action = "MIDI Layout Builder setup: "
    .. DAW.MIDI_LAYOUT_BUILDER.selected_track_name()

  return true
end

DAW.MIDI_LAYOUT_BUILDER.cancel = function()
  return_to_home_page_1("MIDI Layout Builder cancelled: returned to HOME Page 1", false)
  return true
end

DAW.MIDI_LAYOUT_BUILDER.midi_recinput_for_device = function(input_index)
  input_index = tonumber(input_index)
  if not input_index or input_index < 0 then return nil end

  -- REAPER I_RECINPUT:
  -- 4096 = MIDI input
  -- + channel 0 = all channels
  -- + physical input index * 32
  return 4096 + (input_index * 32)
end

DAW.MIDI_LAYOUT_BUILDER.midi_recinput_all_midi = function()
  -- 4096 = MIDI input
  -- 63 = all physical MIDI inputs
  -- channel 0 = all channels
  return 4096 + (63 * 32)
end

DAW.MIDI_LAYOUT_BUILDER.find_launchpad_input = function()
  -- Prefer the currently selected primary Launchpad/control input when it is specific.
  if selected_input_index and selected_input_index >= 0 then
    return selected_input_index, selected_input_name
  end

  -- If primary input is "Any enabled MIDI input", find the first Launchpad-looking port.
  for _, input in ipairs(midi_inputs or {}) do
    local name = tostring(input.name or "")
    if input.index and input.index >= 0 and name:lower():find("launchpad", 1, true) then
      return input.index, name
    end
  end

  return nil, nil
end




DAW.MIDI_LAYOUT_BUILDER.apply_track_input_choice = function(track)
  if not track then
    return false, "No selected track"
  end

  local mode = DAW.MIDI_LAYOUT_BUILDER.input_mode

  if mode == "leave_input" then
    return true, "Left Track Input untouched"
  end

  local recinput = nil
  local label = ""

  if mode == "all_midi" then
    recinput = DAW.MIDI_LAYOUT_BUILDER.midi_recinput_all_midi()
    label = "Set Track Input to All MIDI Inputs"
  elseif mode == "launchpad" then
    local input_index, input_name = DAW.MIDI_LAYOUT_BUILDER.find_launchpad_input()

    if not input_index then
      return false,
        "Could not find a Launchpad MIDI input.\n\n"
        .. "Choose a Launchpad input in Launchpad Xtra's MIDI settings first, "
        .. "or use Set Track Input to ALL MIDI."
    end

    recinput = DAW.MIDI_LAYOUT_BUILDER.midi_recinput_for_device(input_index)
    label = "Set Track Input to " .. tostring(input_name)
  else
    return false, "Unknown track input mode: " .. tostring(mode)
  end

  if not recinput then
    return false, "Could not build REAPER MIDI input value."
  end

  r.SetMediaTrackInfo_Value(track, "I_RECINPUT", recinput)

  -- Useful for actually playing the FXi immediately.

  return true, label
end

DAW.MIDI_LAYOUT_BUILDER.arm_and_monitor_track = function(track)
  if not track then
    return false, "No selected track"
  end

  r.SetMediaTrackInfo_Value(track, "I_RECARM", 1)
  r.SetMediaTrackInfo_Value(track, "I_RECMON", 1)

  return true, "Armed track and enabled input monitoring"
end

DAW.MIDI_LAYOUT_BUILDER.find_existing_fx = function(track, candidates)
  if not track then return nil, nil end

  for _, fx_name in ipairs(candidates or {}) do
    local fx_index = r.TrackFX_AddByName(track, fx_name, false, 0)
    if fx_index and fx_index >= 0 then
      return fx_index, fx_name
    end
  end

  return nil, nil
end

DAW.MIDI_LAYOUT_BUILDER.move_fx_to_top = function(track, fx_index)
  fx_index = tonumber(fx_index)

  if not track or not fx_index or fx_index <= 0 then
    return fx_index
  end

  -- Move this FX to the first normal-track FX slot.
  -- Same-track move: source track/index -> same track, destination index 0.
  if r.TrackFX_CopyToTrack then
    r.TrackFX_CopyToTrack(track, fx_index, track, 0, true)
    return 0
  end

  return fx_index
end

DAW.MIDI_LAYOUT_BUILDER.add_helper_fx = function(track, helper_key)
  if not track then
    return false, "No selected track"
  end

  local spec = DAW.MIDI_LAYOUT_BUILDER.HELPER_FX[helper_key]
  if not spec then
    return false, "Unknown helper FX: " .. tostring(helper_key)
  end

  local existing_index, existing_name =
    DAW.MIDI_LAYOUT_BUILDER.find_existing_fx(track, spec.candidates)

  if existing_index then
    local moved_index =
      DAW.MIDI_LAYOUT_BUILDER.move_fx_to_top(track, existing_index)

    if moved_index == 0 and existing_index ~= 0 then
      return true, spec.label .. " already existed and was moved to the top of the FX chain"
    end

    return true, spec.label .. " already exists at the top of the FX chain"
  end

  for _, fx_name in ipairs(spec.candidates or {}) do
    local added_index = r.TrackFX_AddByName(track, fx_name, false, 1)

    if added_index and added_index >= 0 then
      DAW.MIDI_LAYOUT_BUILDER.move_fx_to_top(track, added_index)
      return true, "Added " .. spec.label .. " at the top of the FX chain"
    end
  end

  return false,
    "Could not find/add " .. spec.label .. ".\n\nTried:\n"
    .. table.concat(spec.candidates or {}, "\n")
end

DAW.MIDI_LAYOUT_BUILDER.apply_track_prep_choice = function(track)
  local mode = DAW.MIDI_LAYOUT_BUILDER.prep_mode

  if mode == "leave_fx" then
    return true, "Left Track FX unchanged"
  end

  if mode == "drum_arranger" then
    return DAW.MIDI_LAYOUT_BUILDER.add_helper_fx(track, "drum_arranger")
  end

  if mode == "arp" then
    return DAW.MIDI_LAYOUT_BUILDER.add_helper_fx(track, "arp")
  end

  return false, "Unknown track prep mode: " .. tostring(mode)
end


DAW.MIDI_LAYOUT_BUILDER.clean_fx_name = function(name)
  name = tostring(name or "")
  name = name:gsub("^%s+", ""):gsub("%s+$", "")

  -- Strip common REAPER FX prefixes.
  name = name:gsub("^VST3i:%s*", "")
  name = name:gsub("^VSTi:%s*", "")
  name = name:gsub("^VST3:%s*", "")
  name = name:gsub("^VST:%s*", "")
  name = name:gsub("^CLAPi:%s*", "")
  name = name:gsub("^CLAP:%s*", "")
  name = name:gsub("^AU:%s*", "")
  name = name:gsub("^JS:%s*", "")

  -- Strip all trailing parenthesized chunks:
  --   MONSTER Drums v3 (AgusHardiman.TV) (32 out)
  -- becomes:
  --   MONSTER Drums v3
  while true do
    local cleaned = name:gsub("%s*%b()%s*$", "")
    cleaned = trim(cleaned)

    if cleaned == name then break end
    name = cleaned
  end

  return trim(name)
end

DAW.MIDI_LAYOUT_BUILDER.safe_filename_part = function(text)
  text = tostring(text or "")
  text = trim(text)

  -- Windows-illegal filename characters.
  text = text:gsub('[<>:"/\\|%?%*]', "_")

  -- Avoid awkward repeated spaces.
  text = text:gsub("%s+", " ")

  return text
end

DAW.MIDI_LAYOUT_BUILDER.find_track_fxi = function(track)
  if not track then
    return nil, "No selected track"
  end

  if r.TrackFX_GetInstrument then
    local fx_index = r.TrackFX_GetInstrument(track)
    if fx_index and fx_index >= 0 then
      return fx_index, nil
    end
  end

  return nil, "No valid FXi was found on the selected track."
end

DAW.MIDI_LAYOUT_BUILDER.get_fxi_info = function(track)
  local fx_index, err = DAW.MIDI_LAYOUT_BUILDER.find_track_fxi(track)
  if not fx_index then
    return nil, err
  end

  local ok_name, fx_name = r.TrackFX_GetFXName(track, fx_index)
  fx_name = ok_name and tostring(fx_name or "") or ""

  local clean_name = DAW.MIDI_LAYOUT_BUILDER.clean_fx_name(fx_name)

  local ok_preset, preset_name = r.TrackFX_GetPreset(track, fx_index)
  preset_name = ok_preset and tostring(preset_name or "") or ""
  preset_name = trim(preset_name)

  return {
    fx_index = fx_index,
    raw_fx_name = fx_name,
    fx_name = clean_name,
    preset_name = preset_name,
  }, nil
end

DAW.MIDI_LAYOUT_BUILDER.expected_map_filename = function(fxi_info)
  if not fxi_info then return nil end

  local fx_part = DAW.MIDI_LAYOUT_BUILDER.safe_filename_part(fxi_info.fx_name)
  local preset_part = DAW.MIDI_LAYOUT_BUILDER.safe_filename_part(fxi_info.preset_name)

  if fx_part == "" then return nil end

  if preset_part ~= "" then
    return fx_part .. "." .. preset_part .. ".txt"
  end

  return fx_part .. ".txt"
end

DAW.MIDI_LAYOUT_BUILDER.join_path = function(folder, filename)
  folder = tostring(folder or "")
  filename = tostring(filename or "")

  if folder:sub(-1) == "/" or folder:sub(-1) == "\\" then
    return folder .. filename
  end

  return folder .. "/" .. filename
end

DAW.MIDI_LAYOUT_BUILDER.find_map_file = function(expected_filename)
  if not expected_filename or expected_filename == "" then
    return nil
  end

  local folder = DAW.MIDI_LAYOUT_BUILDER.map_folder
  local direct_path = DAW.MIDI_LAYOUT_BUILDER.join_path(folder, expected_filename)

  if r.file_exists and r.file_exists(direct_path) then
    return direct_path
  end

  -- Case-insensitive fallback scan.
  if r.EnumerateFiles then
    local expected_lower = expected_filename:lower()
    local i = 0

    while true do
      local filename = r.EnumerateFiles(folder, i)
      if not filename then break end

      if tostring(filename):lower() == expected_lower then
        return DAW.MIDI_LAYOUT_BUILDER.join_path(folder, filename)
      end

      i = i + 1
    end
  end

  return nil
end

DAW.MIDI_LAYOUT_BUILDER.read_text_file = function(path)
  local file = io.open(path, "r")
  if not file then return nil end

  local text = file:read("*a")
  file:close()

  return text
end

DAW.MIDI_LAYOUT_BUILDER.strip_comment_prefix = function(line)
  line = tostring(line or "")
  return trim(line:gsub("^%s*//%s*", ""))
end

DAW.MIDI_LAYOUT_BUILDER.parse_map_text = function(text)
  local result = {
    notes = {},
    notes_by_number = {},
    colors = {},
    inline_colors = {},
    lp_layout = {},
    lp_layout_found = false,
    lp_device_found = false,
    lp_device_name = nil,
    lp_layout_version = nil,
    lp_layout_format = nil,
    empty_pads = 0,
    assigned_pads = 0,
  }

  local in_color_block = false
  local in_lp_device = false
  local in_lp_layout = false

  for raw_line in tostring(text or ""):gmatch("([^\r\n]*)\r?\n?") do
    local line = tostring(raw_line or "")
    local trimmed = trim(line)

    if trimmed ~= "" then
      local comment_body = DAW.MIDI_LAYOUT_BUILDER.strip_comment_prefix(trimmed)

      if trimmed:match("^%s*//%s*COLOR_BEGIN") then
        in_color_block = true

      elseif trimmed:match("^%s*//%s*COLOR_END") then
        in_color_block = false

      elseif trimmed:match("^%s*//%s*LP_DEVICE_START") then
        in_lp_device = true
        result.lp_device_found = true
        result.lp_device_name = trim(comment_body:gsub("^LP_DEVICE_START%s*", ""))

      elseif trimmed:match("^%s*//%s*LP_DEVICE_END") then
        in_lp_device = false
        in_lp_layout = false

      elseif in_lp_device and trimmed:match("^%s*//%s*LP_LAYOUT_BEGIN") then
        in_lp_layout = true
        result.lp_layout_found = true

        local version = comment_body:match("LP_LAYOUT_BEGIN%s+(v%d+)")
        local format = comment_body:match("format=([^%s]+)")

        result.lp_layout_version = version or ""
        result.lp_layout_format = format or ""

      elseif in_lp_device and trimmed:match("^%s*//%s*LP_LAYOUT_END") then
        in_lp_layout = false

      elseif in_color_block then
        local body = comment_body
        local note_text, color = body:match("^(%d+)%s*,%s*(.-)%s*$")

        local note = tonumber(note_text)
        color = trim(color or "")

        if note and color ~= "" then
          result.colors[note] = color
        end

      elseif in_lp_device and in_lp_layout then
        local body = comment_body
        local row_text, col_text, note_text =
          body:match("^(%d+)%s*,%s*(%d+)%s*,%s*([^,%s]+)%s*$")

        local row = tonumber(row_text)
        local col = tonumber(col_text)

        if row and col then
          local note = nil
          if note_text and note_text ~= "-" then
            note = tonumber(note_text)
          end

          result.lp_layout[#result.lp_layout + 1] = {
            row = row,
            col = col,
            note = note,
          }

          if note then
            result.assigned_pads = result.assigned_pads + 1
          else
            result.empty_pads = result.empty_pads + 1
          end
        end

      elseif not trimmed:match("^%s*//") then
        -- Normal REAPER-visible note-name line.
        -- Supports both:
        --   30 Bass Drum
        -- and old backward-compatible:
        --   30 Bass Drum // Yellow
        local note_text, rest = trimmed:match("^%s*(%d+)%s+(.+)%s*$")
        local note = tonumber(note_text)

        if note and rest then
          local name_part, inline_color = rest:match("^(.-)%s*//%s*(.-)%s*$")

          local name = nil
          if name_part then
            name = trim(name_part)
            inline_color = trim(inline_color or "")
          else
            name = trim(rest)
            inline_color = ""
          end

          if name ~= "" then
            local entry = {
              note = note,
              name = name,
            }

            result.notes[#result.notes + 1] = entry
            result.notes_by_number[note] = entry

            if inline_color ~= "" then
              result.inline_colors[note] = inline_color

              -- Inline color is fallback only. COLOR block wins.
              if not result.colors[note] then
                result.colors[note] = inline_color
              end
            end
          end
        end
      end
    end
  end

  return result
end

DAW.MIDI_LAYOUT_BUILDER.parse_map_file = function(path)
  if not path or path == "" then
    return nil, "No map file path"
  end

  local text = DAW.MIDI_LAYOUT_BUILDER.read_text_file(path)
  if not text then
    return nil, "Could not read map file:\n" .. tostring(path)
  end

  return DAW.MIDI_LAYOUT_BUILDER.parse_map_text(text), nil
end

DAW.MIDI_LAYOUT_BUILDER.palette_for_color_name = function(color_name)
  local key = tostring(color_name or ""):lower()
  key = trim(key:gsub("%s+", " "))

  return DAW.MIDI_LAYOUT_BUILDER.COLOR_TO_PALETTE[key] or 2
end

DAW.MIDI_LAYOUT_BUILDER.layout_pad_index = function(row, col)
  row = tonumber(row) or 0
  col = tonumber(col) or 0

  if row < 1 or row > 8 or col < 1 or col > 8 then
    return nil
  end

  -- 8x8 Launchpad Custom payload index:
  -- row 1, col 1 -> 0
  -- row 1, col 8 -> 7
  -- row 2, col 1 -> 8
  -- row 8, col 8 -> 63
  return ((row - 1) * 8) + (col - 1)
end

DAW.MIDI_LAYOUT_BUILDER.make_custom_name_bytes = function(name)
  name = tostring(name or "LP Layout")
  name = name:gsub("[\r\n\t]", " ")
  name = trim(name)

  if name == "" then name = "LP Layout" end

  -- Keep the name short. The old generator used plain 7-bit ASCII bytes.
  if #name > 16 then
    name = name:sub(1, 16)
  end

  local bytes = {}
  for i = 1, #name do
    bytes[#bytes + 1] = name:byte(i) & 0x7F
  end

  return bytes
end

DAW.MIDI_LAYOUT_BUILDER.build_custom_dump_from_map = function(parsed_map, title)
  if not parsed_map or not parsed_map.lp_layout_found then
    return nil, "Parsed map has no Launchpad layout block."
  end

  local slot = math.max(
    1,
    math.min(8, math.floor(tonumber(DAW.MIDI_LAYOUT_BUILDER.generated_custom_slot) or 8))
  )

  local pad_by_index = {}

  for _, cell in ipairs(parsed_map.lp_layout or {}) do
    local pad_index = DAW.MIDI_LAYOUT_BUILDER.layout_pad_index(cell.row, cell.col)

    if pad_index then
      pad_by_index[pad_index] = cell
    end
  end

  local bytes = {
      0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id,
      0x20, 0x00, 0x10,
      0x40, slot,
      0x20,
    }
  
    local name_bytes = DAW.MIDI_LAYOUT_BUILDER.make_custom_name_bytes(title or "LP Layout")
  
    -- Custom Mode dump format includes the name length byte after 0x20.
    bytes[#bytes + 1] = math.max(0, math.min(16, #name_bytes))
  
    for _, byte in ipairs(name_bytes) do
      bytes[#bytes + 1] = byte
    end
  
    -- Seen in captured Custom Mode dumps before the per-pad payload.
    bytes[#bytes + 1] = 0x21
    bytes[#bytes + 1] = 0x01
    bytes[#bytes + 1] = 0x00

  for pad_index = 0, 63 do
    local cell = pad_by_index[pad_index]
    local note = cell and tonumber(cell.note) or nil

    if note and note >= 0 and note <= 127 then
      local entry = parsed_map.notes_by_number and parsed_map.notes_by_number[note]
      local color_name = parsed_map.colors and parsed_map.colors[note] or nil
      local palette = DAW.MIDI_LAYOUT_BUILDER.palette_for_color_name(color_name)

      -- Button/note pad payload, matching the old working drum-map generator:
      -- 48 index 01 color 00 10 00 00 00 note
      bytes[#bytes + 1] = 0x48
      bytes[#bytes + 1] = pad_index
      bytes[#bytes + 1] = 0x01
      bytes[#bytes + 1] = palette
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = 0x10
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = note
    else
      -- Empty pad.
      bytes[#bytes + 1] = 0x40
      bytes[#bytes + 1] = pad_index
    end
  end

  -- Footer copied from working Launchpad X custom dumps.
  -- This should be harmless for ordinary note-button custom layouts.
  local footer = {
    0x00,
    0x03, 0x01,
    0x03, 0x02,
    0x00, 0x06,
    0x00, 0x07,
    0x00, 0x08,
    0x00, 0x05,
    0x00, 0x04,
    0x40,
  }

  for _, byte in ipairs(footer) do
    bytes[#bytes + 1] = byte
  end

  bytes[#bytes + 1] = 0xF7

  return bytes, nil
end

DAW.MIDI_LAYOUT_BUILDER.bytes_to_hex = function(bytes)
  local parts = {}

  for _, byte in ipairs(bytes or {}) do
    parts[#parts + 1] = string.format("%02X", tonumber(byte) or 0)
  end

  return table.concat(parts, " ")
end

DAW.MIDI_LAYOUT_BUILDER.enter_active_layout_mode = function(slot, message)
  DAW.MIDI_LAYOUT_BUILDER.warning = nil
  DAW.MIDI_LAYOUT_BUILDER.active_custom_slot = slot
  DAW.MIDI_LAYOUT_BUILDER.waiting_for_note_return = true

  surface_mode = "MIDI_LAYOUT_ACTIVE"
  active_custom_slot = nil
  pending_custom_slot = nil
  pending_custom_switch_time = 0
  initialized = true

  last_action = message or "MIDI layout active. Press NOTE to return to HOME Page 1."

  return true
end

DAW.MIDI_LAYOUT_BUILDER.labels_text_from_parsed_map = function(parsed_map)
  local rows = {}

  for row = 1, 8 do
    rows[row] = {}
    for col = 1, 8 do
      rows[row][col] = ""
    end
  end

  if not parsed_map then
    return DAW.CUSTOM_LIBRARY.button_labels_to_text(rows)
  end

  for _, cell in ipairs(parsed_map.lp_layout or {}) do
    local row = tonumber(cell.row)
    local col = tonumber(cell.col)
    local note = tonumber(cell.note)

    if row and col and row >= 1 and row <= 8 and col >= 1 and col <= 8 and note then
      local note_entry = parsed_map.notes_by_number and parsed_map.notes_by_number[note]
      local label = note_entry and tostring(note_entry.name or "") or tostring(note)
      rows[row][col] = label
    end
  end

  return DAW.CUSTOM_LIBRARY.button_labels_to_text(rows)
end

DAW.MIDI_LAYOUT_BUILDER.note_color_name_from_parsed_map = function(parsed_map, note)
  if not parsed_map or not note then return nil end

  note = tonumber(note)

  local entry = parsed_map.notes_by_number and parsed_map.notes_by_number[note]
  if entry then
    return entry.color or entry.color_name or entry.palette_name
  end

  if parsed_map.colors_by_note then
    return parsed_map.colors_by_note[note] or parsed_map.colors_by_note[tostring(note)]
  end

  if parsed_map.note_colors then
    return parsed_map.note_colors[note] or parsed_map.note_colors[tostring(note)]
  end

  return nil
end

DAW.MIDI_LAYOUT_BUILDER.note_label_from_parsed_map = function(parsed_map, note)
  if not parsed_map or not note then return tostring(note or "") end

  note = tonumber(note)

  local entry = parsed_map.notes_by_number and parsed_map.notes_by_number[note]
  if entry and entry.name and tostring(entry.name) ~= "" then
    return tostring(entry.name)
  end

  return tostring(note or "")
end

DAW.MIDI_LAYOUT_BUILDER.read_note_names_and_colors_from_map_file = function(path)
  local result = {
    names = {},
    colors = {},
  }

  local text = DAW.MIDI_LAYOUT_BUILDER.read_text_file(path)
  if not text then return result end

  local in_color = false

  for raw_line in text:gmatch("([^\r\n]*)\r?\n?") do
    local line = trim(raw_line or "")
    if line ~= "" then
      local uncommented = line:gsub("^//%s*", "")

      if uncommented:match("^COLOR_BEGIN") then
        in_color = true

      elseif uncommented:match("^COLOR_END") then
        in_color = false

      elseif in_color then
        local note, color = uncommented:match("^(%d+)%s*,%s*(.-)%s*$")
        note = tonumber(note)
        if note and color and color ~= "" then
          result.colors[note] = color
        end

      elseif not line:match("^//") then
        local note, name = line:match("^(%d+)%s+(.+)$")
        note = tonumber(note)
        if note and name and name ~= "" then
          name = name:gsub("%s*//.*$", "")
          name = trim(name)
          result.names[note] = name
        end
      end
    end
  end

  return result
end


DAW.MIDI_LAYOUT_BUILDER.apply_parsed_map_to_editor_cells = function(map_result)
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.cells then return false end

  local parsed_map = map_result and map_result.parsed_map
  if not parsed_map or not parsed_map.lp_layout then return false end

  local file_data =
    DAW.MIDI_LAYOUT_BUILDER.read_note_names_and_colors_from_map_file(
      map_result.found_path
    )

  -- First clear the 8x8 editor grid.
  for idx = 0, 63 do
    editor.cells[idx] = {
      assigned = false,
      color = 0x00,
      label = "",
      note = nil,
      block = nil,
    }
  end

  -- Then repopulate from LP_LAYOUT using note names and COLOR_BEGIN.
  for _, cell_info in ipairs(parsed_map.lp_layout) do
    local row = tonumber(cell_info.row)
    local col = tonumber(cell_info.col)
    local note = tonumber(cell_info.note)

    if row and col and row >= 1 and row <= 8 and col >= 1 and col <= 8 then
      local idx = ((row - 1) * 8) + (col - 1)

      if note then
        local color_name = file_data.colors[note]
        local palette = DAW.MIDI_LAYOUT_BUILDER.palette_for_color_name(color_name)

        if not palette or palette <= 0 then
          palette = 2 -- gray fallback only when no color exists
        end

        local label = file_data.names[note] or tostring(note)

        editor.cells[idx] = {
          assigned = true,
          color = palette,
          label = label,
          note = note,
          block = {
            0x48,
            idx,
            0x01,
            palette,
            0x00,
            0x10,
            0x00,
            0x00,
            0x00,
            note
          },
        }
      else
        editor.cells[idx] = {
          assigned = false,
          color = 0x00,
          label = "",
          note = nil,
          block = nil,
        }
      end
    end
  end

  editor.preview_signature = nil
  return true
end

DAW.MIDI_LAYOUT_BUILDER.open_layout_confirmation = function(map_result)
  if not map_result or not map_result.parsed_map then
    return false, "No parsed map available."
  end

  if not map_result.parsed_map.lp_layout_found then
    return false, "Map has no Launchpad layout block."
  end

  local parsed_map = map_result.parsed_map
  local fxi = map_result.fxi_info or {}

  local title = fxi.preset_name
  if not title or title == "" then title = fxi.fx_name end
  if not title or title == "" then title = "LP Layout" end

  local dump_bytes, dump_err =
    DAW.MIDI_LAYOUT_BUILDER.build_custom_dump_from_map(parsed_map, title)

  if not dump_bytes then
    return false, dump_err or "Could not build Custom Mode dump."
  end

  local slot = math.max(
    1,
    math.min(8, math.floor(tonumber(DAW.MIDI_LAYOUT_BUILDER.generated_custom_slot) or 1))
  )

  local dump_hex = DAW.MIDI_LAYOUT_BUILDER.bytes_to_hex(dump_bytes)
  local labels_text = DAW.MIDI_LAYOUT_BUILDER.labels_text_from_parsed_map(parsed_map)

  -- Use the existing Custom Layout Editor as a temporary confirmation editor.
  -- We place the generated layout into the current editor entry / chosen slot,
  -- open the editor, then mark it as owned by MIDI Layout Builder.
  local entry_index = math.max(1, math.floor(tonumber(DAW.CUSTOM_LIBRARY.editor_index) or 1))
  local entry = DAW.USER_DATA.ensure_custom_entry(entry_index)

  entry.customs[slot] = dump_hex
  entry.custom_labels[slot] = labels_text

  local opened = DAW.CUSTOM_LIBRARY.layout_editor_open("custom", slot)
  if not opened then
    return false, "Could not open Custom Layout Editor for generated layout."
  end

  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  
  DAW.MIDI_LAYOUT_BUILDER.apply_parsed_map_to_editor_cells(map_result)
  
  editor.midi_layout_confirm = true
  editor.midi_layout_dirty = false
  editor.midi_layout_map_result = map_result
  editor.midi_layout_slot = slot
  editor.restore_page = 1
  editor.restore_surface_mode = "MIDI_LAYOUT_PREVIEW"

  DAW.MIDI_LAYOUT_BUILDER.pending_map_result = map_result
  DAW.MIDI_LAYOUT_BUILDER.pending_layout_slot = slot

  last_action = "Review generated Launchpad layout, then press OK to send it."
  return true, "Opened generated Launchpad layout for confirmation."
end

DAW.MIDI_LAYOUT_BUILDER.editor_confirm_pad_index = function(pad)
  if not pad then return nil end
  return DAW.MIDI_LAYOUT_BUILDER.index_for_row_col(pad.row, pad.col)
end

DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.visible then return end
  if not editor.midi_layout_confirm then return end

  editor.midi_layout_dirty = true
  editor.preview_signature = nil

  -- Force immediate Launchpad redraw to the edited map.
  DAW.CUSTOM_LIBRARY.layout_editor_send_preview(true)
end

DAW.MIDI_LAYOUT_BUILDER.layout_editor_index_for_row_col = function(row, col)
  row = tonumber(row) or 0
  col = tonumber(col) or 0

  if DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor_cell_index then
    return DAW.CUSTOM_LIBRARY.layout_editor_cell_index(row, col)
  end

  return ((row - 1) * 8) + (col - 1)
end

DAW.MIDI_LAYOUT_BUILDER.editor_cell_note = function(cell)
  if not cell or not cell.assigned then return nil end

  local note = tonumber(cell.note)
  if note and note >= 0 and note <= 127 then
    return note
  end

  if type(cell.block) == "table" then
    -- Standard custom note-button block stores the MIDI note as the final byte.
    note = tonumber(cell.block[#cell.block])
    if note and note >= 0 and note <= 127 then
      return note
    end
  end

  return nil
end


DAW.MIDI_LAYOUT_BUILDER.layout_lines_from_editor = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.cells then return nil end

  local lines = {
    "// LP_LAYOUT_BEGIN v1 format=row,col,note"
  }

  for row = 1, 8 do
    for col = 1, 8 do
      local idx = ((row - 1) * 8) + (col - 1)
      local cell = editor.cells[idx]
      local note = DAW.MIDI_LAYOUT_BUILDER.editor_cell_note(cell)

      lines[#lines + 1] =
        "// " .. tostring(row) .. "," .. tostring(col) .. "," .. tostring(note or "-")
    end
  end

  lines[#lines + 1] = "// LP_LAYOUT_END"

  return lines
end

DAW.MIDI_LAYOUT_BUILDER.update_map_file_layout_from_editor = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.midi_layout_map_result then
    return false, "No MIDI layout map result is attached to the editor."
  end

  local path = editor.midi_layout_map_result.found_path
  if not path or path == "" then
    return false, "No map file path is attached to the editor."
  end

  local text = DAW.MIDI_LAYOUT_BUILDER.read_text_file(path)
  if not text then
    return false, "Could not read map file:\n" .. tostring(path)
  end

  local new_layout_lines = DAW.MIDI_LAYOUT_BUILDER.layout_lines_from_editor()
  if not new_layout_lines then
    return false, "Could not build layout lines from editor."
  end

  local new_layout_text = table.concat(new_layout_lines, "\n")

  local start_pos, start_end = text:find("//%s*LP_LAYOUT_BEGIN[^\r\n]*\r?\n")
  if not start_pos then
    return false, "Could not find LP_LAYOUT_BEGIN in map file."
  end

  local end_pos, end_end = text:find("//%s*LP_LAYOUT_END[^\r\n]*", start_end + 1)
  if not end_pos then
    return false, "Could not find LP_LAYOUT_END in map file."
  end

  local before = text:sub(1, start_pos - 1)
  local after = text:sub(end_end + 1)

  local new_text = before .. new_layout_text .. after

  local file = io.open(path, "w")
  if not file then
    return false, "Could not write map file:\n" .. tostring(path)
  end

  file:write(new_text)
  file:close()

  return true, "Updated map file layout:\n" .. tostring(path)
end

DAW.MIDI_LAYOUT_BUILDER.draw_colored_editor_button = function(label, palette)
  local bg = DAW.USER_PAGES.palette_gui(palette or 0)
  local text = readable_text_color(bg)

  if r.ImGui_PushStyleColor and r.ImGui_Col_Button and r.ImGui_Col_Text then
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Button(), bg)
    r.ImGui_PushStyleColor(ctx, r.ImGui_Col_Text(), text)
    local clicked = r.ImGui_Button(ctx, label)
    r.ImGui_PopStyleColor(ctx, 2)
    return clicked
  end

  return r.ImGui_Button(ctx, label)
end

DAW.MIDI_LAYOUT_BUILDER.library_record_name_from_editor = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  local result = editor and editor.midi_layout_map_result
  local fxi = result and result.fxi_info or {}

  local fx_name = trim(fxi.fx_name or "")
  local preset_name = trim(fxi.preset_name or "")

  if fx_name == "" then
    fx_name = "Unknown FXi"
  end

  if preset_name == "" then
    preset_name = "No Preset"
  end

  local timestamp = os.date("%Y-%m-%d %H-%M-%S")

  return fx_name .. "." .. preset_name .. "." .. timestamp
end

DAW.MIDI_LAYOUT_BUILDER.library_record_name_from_editor = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  local result = editor and editor.midi_layout_map_result
  local fxi = result and result.fxi_info or {}

  local fx_name = trim(fxi.fx_name or "")
  local preset_name = trim(fxi.preset_name or "")

  if fx_name == "" then
    fx_name = "Unknown FXi"
  end

  if preset_name == "" then
    preset_name = "No Preset"
  end

  local timestamp = os.date("%Y-%m-%d %H-%M-%S")

  return fx_name .. "." .. preset_name .. "." .. timestamp
end

DAW.MIDI_LAYOUT_BUILDER.save_editor_layout_to_custom_library = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.visible then
    return false, "Layout editor is not open."
  end

  if DAW.MIDI_LAYOUT_BUILDER.normalize_editor_cells_for_custom_upload then
    DAW.MIDI_LAYOUT_BUILDER.normalize_editor_cells_for_custom_upload()
  end

  local title =
    DAW.MIDI_LAYOUT_BUILDER.custom_title_from_editor
    and DAW.MIDI_LAYOUT_BUILDER.custom_title_from_editor()
    or "Paired MIDI Layout"

  title = trim(title or "")
  if title == "" then title = "Paired MIDI Layout" end

  local record_name =
    DAW.MIDI_LAYOUT_BUILDER.library_record_name_from_editor()

  local hex, hex_err =
    DAW.MIDI_LAYOUT_BUILDER.build_custom_dump_from_editor(
      1,
      title
    )

  if not hex or trim(hex) == "" then
    return false, hex_err or "Could not build Custom layout from editor."
  end

  local labels_text = DAW.CUSTOM_LIBRARY.layout_editor_labels_text()

  DAW.CUSTOM_LIBRARY.data.entries = DAW.CUSTOM_LIBRARY.data.entries or {}

  local new_index = #DAW.CUSTOM_LIBRARY.data.entries + 1
  local entry = DAW.USER_DATA.ensure_custom_entry(new_index)

  entry.name = record_name
  entry.label = record_name
  entry.payload_mode = "custom"
  entry.color = 0x21
  entry.switch_to_slot = 1

  entry.non_custom = ""
  entry.non_custom_labels = ""

  entry.customs = entry.customs or {}
  entry.custom_labels = entry.custom_labels or {}

  for slot = 1, 8 do
    entry.customs[slot] = entry.customs[slot] or ""
    entry.custom_labels[slot] = entry.custom_labels[slot] or ""
  end

  entry.customs[1] = hex
  entry.custom_labels[1] = labels_text

  DAW.CUSTOM_LIBRARY.payload_visual_cache = {}
  DAW.CUSTOM_LIBRARY.scroll_to_editor_index = new_index

  if DAW.CUSTOM_LIBRARY.save then
    DAW.CUSTOM_LIBRARY.save()
  end

  last_action =
    "Saved paired MIDI layout to Custom Library row "
    .. tostring(new_index)
    .. ": "
    .. record_name

  DAW.MIDI_LAYOUT_BUILDER.show_toast("Saved", 1.0)

  return true, last_action
end


DAW.MIDI_LAYOUT_BUILDER.toast = nil

DAW.MIDI_LAYOUT_BUILDER.show_toast = function(text, seconds)
  DAW.MIDI_LAYOUT_BUILDER.toast = {
    text = tostring(text or ""),
    until_time = r.time_precise() + (tonumber(seconds) or 1.0),
  }
end

DAW.MIDI_LAYOUT_BUILDER.draw_toast = function()
  local toast = DAW.MIDI_LAYOUT_BUILDER.toast
  if not toast then return end

  if r.time_precise() > (toast.until_time or 0) then
    DAW.MIDI_LAYOUT_BUILDER.toast = nil
    return
  end

  local vx, vy = r.ImGui_GetWindowPos(ctx)
  local vw, vh = r.ImGui_GetWindowSize(ctx)

  r.ImGui_SetNextWindowPos(ctx, vx + vw - 145, vy + 42, r.ImGui_Cond_Always())
  r.ImGui_SetNextWindowSize(ctx, 110, 34, r.ImGui_Cond_Always())

  local flags =
    r.ImGui_WindowFlags_NoTitleBar()
    | r.ImGui_WindowFlags_NoResize()
    | r.ImGui_WindowFlags_NoMove()
    | r.ImGui_WindowFlags_NoScrollbar()
    | r.ImGui_WindowFlags_NoSavedSettings()

  if r.ImGui_Begin(ctx, "##midi_layout_saved_toast", true, flags) then
    r.ImGui_Text(ctx, toast.text or "Saved")
  end
  r.ImGui_End(ctx)
end

DAW.MIDI_LAYOUT_BUILDER.draw_editor_confirm_buttons = function()
  if DAW.MIDI_LAYOUT_BUILDER.draw_colored_editor_button("Cancel", 5) then
    DAW.CUSTOM_LIBRARY.layout_editor_cancel()
    return
  end

  r.ImGui_SameLine(ctx)

  if r.ImGui_Button(ctx, "Save to Library") then
    local ok, msg = DAW.MIDI_LAYOUT_BUILDER.save_editor_layout_to_custom_library()
    if not ok then
      r.ShowMessageBox(
        tostring(msg or "Could not save layout to Custom Library."),
        "MIDI Layout Builder",
        0
      )
    end
  end

  r.ImGui_SameLine(ctx)

  if DAW.MIDI_LAYOUT_BUILDER.draw_colored_editor_button("OK", 88) then
    local ok, msg = DAW.MIDI_LAYOUT_BUILDER.confirm_editor_layout()
    if not ok then
      r.ShowMessageBox(
        tostring(msg or "Could not confirm layout."),
        "MIDI Layout Builder",
        0
      )
    end
  end
end

DAW.MIDI_LAYOUT_BUILDER.handle_editor_confirm_hardware_index = function(index)
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.visible or not editor.midi_layout_confirm then return false end

  -- Once the editor is dirty, hardware Cancel/OK are no longer active.
  -- The Launchpad mirrors the edited layout only. Confirmation is GUI-only.
  if editor.midi_layout_dirty then return true end

  local cancel_index =
    DAW.MIDI_LAYOUT_BUILDER.editor_confirm_pad_index(
      DAW.MIDI_LAYOUT_BUILDER.EDITOR_CONFIRM_CANCEL_PAD
    )

  local ok_index =
    DAW.MIDI_LAYOUT_BUILDER.editor_confirm_pad_index(
      DAW.MIDI_LAYOUT_BUILDER.EDITOR_CONFIRM_OK_PAD
    )

  if index == cancel_index then
    DAW.CUSTOM_LIBRARY.layout_editor_cancel()
    return true
  end

  if index == ok_index then
    local ok, msg = DAW.MIDI_LAYOUT_BUILDER.confirm_editor_layout()
    if not ok then
      r.ShowMessageBox(tostring(msg or "Could not confirm layout."), "MIDI Layout Builder", 0)
    end
    return true
  end

  return true
end

DAW.MIDI_LAYOUT_BUILDER.active_layout_from_editor = function(slot)
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.cells then return nil end

  local layout = {
    slot = slot,
    title = "Paired MIDI Layout",
    cells = {},
  }

  local result = editor.midi_layout_map_result
  if result and result.fxi_info then
    local fxi = result.fxi_info
    local preset = tostring(fxi.preset_name or "")
    local fx_name = tostring(fxi.fx_name or "")

    if preset ~= "" then
      layout.title = preset
    elseif fx_name ~= "" then
      layout.title = fx_name
    end
  end

  for row = 1, 8 do
    for col = 1, 8 do
      local idx = DAW.CUSTOM_LIBRARY.layout_editor_cell_index(row, col)
      local cell = editor.cells[idx] or {}

      layout.cells[idx] = {
        assigned = cell.assigned and true or false,
        color = math.max(0, math.min(127, tonumber(cell.color) or 0)),
        label = tostring(cell.label or ""),
        note = DAW.MIDI_LAYOUT_BUILDER.editor_cell_note(cell),
      }
    end
  end

  return layout
end

DAW.MIDI_LAYOUT_BUILDER.draw_active_layout_grid = function()
  local layout = DAW.MIDI_LAYOUT_BUILDER.active_layout

  DAW.GUI.draw_screen_title("Paired Launchpad and FXi")

  if layout and layout.title then
    r.ImGui_Text(ctx, tostring(layout.title))
  else
    r.ImGui_Text(ctx, "Active MIDI Layout")
  end

  r.ImGui_Text(ctx, "Press NOTE on the Launchpad to return to HOME Page 1.")

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for row = 1, 9 do
    for col = 1, 9 do
      local lines = {" "}
      local background = 0x181818FF
      local text_color = 0x808080FF
      local options = {max_lines = 3}

      -- Show the active 8x8 map in rows 1-8 / cols 1-8.
      -- Column 9 remains blank.
      if row <= 8 and col <= 8 and layout and layout.cells then
        local idx = ((row - 1) * 8) + (col - 1)
        local cell = layout.cells[idx]

        if cell and cell.assigned then
          lines = {tostring(cell.label or "")}
        
          if not lines[1] or lines[1] == "" then
            lines = {tostring(cell.note or "")}
          end
        
          background = DAW.USER_PAGES.palette_gui(cell.color or 0)
          text_color = readable_text_color(background)
        end
      end

      draw_compact_grid_button(
        "##midi_layout_active_" .. tostring(row) .. "_" .. tostring(col),
        lines,
        cell_w,
        cell_h,
        background,
        text_color,
        options
      )

      if col < 9 then
        r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
      end
    end
  end
end

DAW.MIDI_LAYOUT_BUILDER.normalize_editor_cells_for_custom_upload = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.cells then return false end

  for idx = 0, 63 do
    local cell = editor.cells[idx]

    if cell and cell.assigned then
      local note = DAW.MIDI_LAYOUT_BUILDER.editor_cell_note(cell)

      if note then
        local palette = math.max(0, math.min(127, tonumber(cell.color) or 0))

        cell.assigned = true
        cell.color = palette
        cell.note = note
        cell.block = {
          0x48,
          idx,
          0x01,
          palette,
          0x00,
          0x10,
          0x00,
          0x00,
          0x00,
          note
        }
      else
        cell = {
          assigned = false,
          color = 0x00,
          label = "",
          note = nil,
          block = nil,
        }
      end
    else
      cell = {
        assigned = false,
        color = 0x00,
        label = cell and tostring(cell.label or "") or "",
        note = nil,
        block = nil,
      }
    end

    editor.cells[idx] = cell
  end

  editor.preview_signature = nil
  return true
end

DAW.MIDI_LAYOUT_BUILDER.custom_title_from_editor = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  local result = editor and editor.midi_layout_map_result

  if result and result.fxi_info then
    local preset = trim(result.fxi_info.preset_name or "")
    local fx_name = trim(result.fxi_info.fx_name or "")

    if preset ~= "" then return preset end
    if fx_name ~= "" then return fx_name end
  end

  return "LP Layout"
end

DAW.MIDI_LAYOUT_BUILDER.build_custom_dump_from_editor = function(slot, title)
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.cells then
    return nil, "Layout editor cells are not available."
  end

  slot = math.max(1, math.min(8, math.floor(tonumber(slot) or 1)))

  local name_bytes =
    DAW.MIDI_LAYOUT_BUILDER.make_custom_name_bytes(title or "LP Layout")

  local bytes = {
    0xF0, 0x00, 0x20, 0x29, 0x02, selected_device.id,
    0x20, 0x00, 0x10,
    0x40, 0x03 + slot,
    0x20,
  }

  -- Custom Mode dump format includes the name length byte after 0x20.
  bytes[#bytes + 1] = math.max(0, math.min(16, #name_bytes))

  for _, byte in ipairs(name_bytes) do
    bytes[#bytes + 1] = byte
  end

  -- Section seen before the 64 pad blocks in captured Custom dumps.
  bytes[#bytes + 1] = 0x21
  bytes[#bytes + 1] = 0x01
  bytes[#bytes + 1] = 0x00

  for idx = 0, 63 do
    local cell = editor.cells[idx]
    local note =
      DAW.MIDI_LAYOUT_BUILDER.editor_cell_note
      and DAW.MIDI_LAYOUT_BUILDER.editor_cell_note(cell)

    if cell and cell.assigned and note then
      local palette = math.max(0, math.min(127, tonumber(cell.color) or 0x01))

      -- This is the important part:
      -- idx is the CURRENT editor position, not the original parsed-map order.
      bytes[#bytes + 1] = 0x48
      bytes[#bytes + 1] = idx
      bytes[#bytes + 1] = 0x01
      bytes[#bytes + 1] = palette
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = 0x10
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = 0x00
      bytes[#bytes + 1] = note
    else
      bytes[#bytes + 1] = 0x40
      bytes[#bytes + 1] = idx
    end
  end

  -- Footer from the working generated-layout payload.
  bytes[#bytes + 1] = 0x00
  bytes[#bytes + 1] = 0x03
  bytes[#bytes + 1] = 0x01
  bytes[#bytes + 1] = 0x03
  bytes[#bytes + 1] = 0x02
  bytes[#bytes + 1] = 0x00
  bytes[#bytes + 1] = 0x06
  bytes[#bytes + 1] = 0x00
  bytes[#bytes + 1] = 0x07
  bytes[#bytes + 1] = 0x00
  bytes[#bytes + 1] = 0x08
  bytes[#bytes + 1] = 0x00
  bytes[#bytes + 1] = 0x05
  bytes[#bytes + 1] = 0x01
  bytes[#bytes + 1] = 0x04
  bytes[#bytes + 1] = 0x40
  bytes[#bytes + 1] = 0xF7

  return DAW.MIDI_LAYOUT_BUILDER.bytes_to_hex(bytes)
end

DAW.MIDI_LAYOUT_BUILDER.confirm_editor_layout = function()
  local editor = DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
  if not editor or not editor.visible then
    return false, "Layout editor is not open."
  end

  local slot = math.max(
    1,
    math.min(
      8,
      math.floor(
        tonumber(editor.midi_layout_slot or DAW.MIDI_LAYOUT_BUILDER.generated_custom_slot) or 1
      )
    )
  )

  -- Make current GUI positions authoritative.
  DAW.MIDI_LAYOUT_BUILDER.normalize_editor_cells_for_custom_upload()

  -- Save the edited row,col,note assignments back into the map file.
  local ok_file, file_msg =
    DAW.MIDI_LAYOUT_BUILDER.update_map_file_layout_from_editor()

  if not ok_file then
    return false, file_msg or "Could not update MIDI Note Names file layout."
  end

  -- Build the Custom dump from the edited Custom Layout Editor cells.
  local hex, hex_err =
    DAW.MIDI_LAYOUT_BUILDER.build_custom_dump_from_editor(
      slot,
      DAW.MIDI_LAYOUT_BUILDER.custom_title_from_editor()
    )
  
  if not hex or trim(hex) == "" then
    return false, hex_err or "Could not build edited layout SysEx."
  end

  local labels_text = DAW.CUSTOM_LIBRARY.layout_editor_labels_text()

  -- Make the external Custom GRID preview use this edited layout.
  local entry = DAW.CUSTOM_LIBRARY.layout_editor_current_entry()
  if not entry then
    return false, "Could not find Custom Library entry for edited layout."
  end

  entry.customs[slot] = hex
  entry.custom_labels[slot] = labels_text

  if DAW.CUSTOM_LIBRARY.payload_visual_cache then
    DAW.CUSTOM_LIBRARY.payload_visual_cache = {}
  end

  if DAW.CUSTOM_LIBRARY.remember_resident_source then
    DAW.CUSTOM_LIBRARY.remember_resident_source(slot, editor.entry_index, slot)
  end

  if DAW.CUSTOM_LIBRARY.save then
    DAW.CUSTOM_LIBRARY.save()
  end

  local upload_bytes, upload_err =
    build_custom_mode_upload_message(hex, slot)

  if not upload_bytes then
    return false, upload_err or "Could not convert edited layout to upload message."
  end

  if not send_bytes(upload_bytes) then
    return false, "Could not upload confirmed Launchpad layout."
  end

  -- Enter normal passive firmware Custom mode, but remember that this workflow
  -- should return to Page 1.
  send_switch_to_custom_slot(
    slot,
    1,
    "NOTE mode detected: returned from paired Launchpad layout to HOME Page 1"
  )

  editor.visible = false
  editor.preview_signature = nil
  editor.midi_layout_confirm = false
  editor.midi_layout_dirty = false
  editor.midi_layout_map_result = nil
  editor.midi_layout_slot = nil

  DAW.MIDI_LAYOUT_BUILDER.pending_map_result = nil
  DAW.MIDI_LAYOUT_BUILDER.pending_layout_slot = nil

  last_action =
    "Confirmed paired Launchpad layout in Custom "
    .. tostring(slot)
    .. "; press NOTE to return to HOME Page 1"

  return true,
    "Confirmed and sent Launchpad layout to Custom "
    .. tostring(slot)
    .. "\n\n"
    .. tostring(file_msg or "")
end


DAW.MIDI_LAYOUT_BUILDER.send_generated_layout = function(map_result)
  if not map_result or not map_result.parsed_map then
    return false, "No parsed map available."
  end

  local parsed_map = map_result.parsed_map

  if not parsed_map.lp_layout_found then
    return false, "Map has no Launchpad layout block."
  end

  local fxi = map_result.fxi_info or {}
  local title = fxi.preset_name
  if not title or title == "" then title = fxi.fx_name end
  if not title or title == "" then title = "LP Layout" end

  local dump_bytes, dump_err =
    DAW.MIDI_LAYOUT_BUILDER.build_custom_dump_from_map(parsed_map, title)

  if not dump_bytes then
    return false, dump_err or "Could not build Custom Mode dump."
  end

  local dump_hex = DAW.MIDI_LAYOUT_BUILDER.bytes_to_hex(dump_bytes)
  local slot = math.max(
    1,
    math.min(8, math.floor(tonumber(DAW.MIDI_LAYOUT_BUILDER.generated_custom_slot) or 8))
  )

  local upload_bytes, upload_err =
    build_custom_mode_upload_message(dump_hex, slot)

  if not upload_bytes then
    return false, upload_err or "Could not convert Custom dump to upload message."
  end

  if not send_bytes(upload_bytes) then
    return false, "Could not upload generated Launchpad layout."
  end

  -- Small immediate switch. If this proves too fast, we can queue/delay it later.
  if DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.switch_to_slot then
    DAW.CUSTOM_LIBRARY.switch_to_slot(slot)
  else
    send_switch_to_custom_slot(slot)
  end
  
  send_switch_to_custom_slot(slot)
  
  DAW.MIDI_LAYOUT_BUILDER.enter_active_layout_mode(
    slot,
    "Paired Launchpad and FXi using generated layout in Custom " .. tostring(slot)
  )

  return true,
    "Sent generated Launchpad layout to Custom "
    .. tostring(slot)
    .. " from "
    .. tostring(map_result.expected_filename or "map file")
end

DAW.MIDI_LAYOUT_BUILDER.resolve_selected_track_map = function(track)
  local fxi_info, err = DAW.MIDI_LAYOUT_BUILDER.get_fxi_info(track)
  if not fxi_info then
    return {
      ok = false,
      error = err or "Could not identify track FXi.",
    }
  end

  local expected_filename =
    DAW.MIDI_LAYOUT_BUILDER.expected_map_filename(fxi_info)

  local found_path =
    DAW.MIDI_LAYOUT_BUILDER.find_map_file(expected_filename)

  local parsed_map = nil
  local parse_error = nil

  if found_path then
    parsed_map, parse_error =
      DAW.MIDI_LAYOUT_BUILDER.parse_map_file(found_path)
  end

  return {
    ok = found_path ~= nil and parsed_map ~= nil,
    fxi_info = fxi_info,
    expected_filename = expected_filename,
    found_path = found_path,
    parsed_map = parsed_map,
    parse_error = parse_error,
  }
end


DAW.MIDI_LAYOUT_BUILDER.count_table_keys = function(tbl)
  local count = 0
  for _ in pairs(tbl or {}) do
    count = count + 1
  end
  return count
end

DAW.MIDI_LAYOUT_BUILDER.map_report_text = function(result)
  if not result then
    return "No resolver result."
  end

  if result.error then
    return result.error
  end

  local fxi = result.fxi_info or {}

  local text =
    "FXi:\n"
    .. tostring(fxi.fx_name or "")
    .. "\n\nPreset:\n"
    .. ((fxi.preset_name and fxi.preset_name ~= "") and fxi.preset_name or "(No preset name)")
    .. "\n\nExpected MIDI Note Names file:\n"
    .. tostring(result.expected_filename or "")
    .. "\n\nFolder:\n"
    .. tostring(DAW.MIDI_LAYOUT_BUILDER.map_folder or "")

  if not result.found_path then
    return text
      .. "\n\nNot found.\n\nNext action later will be: launch MIDI Note Namer."
  end

  text = text
    .. "\n\nFound:\n"
    .. tostring(result.found_path)

  if result.parse_error then
    return text
      .. "\n\nParse error:\n"
      .. tostring(result.parse_error)
  end

  local map = result.parsed_map
  if not map then
    return text
      .. "\n\nMap was found but not parsed."
  end

  text = text
    .. "\n\nParsed Map:"
    .. "\nNotes: " .. tostring(#(map.notes or {}))
    .. "\nColors: " .. tostring(DAW.MIDI_LAYOUT_BUILDER.count_table_keys(map.colors or {}))

  if map.lp_layout_found then
    text = text
      .. "\nLaunchpad Layout: found"
      .. "\nDevice: " .. tostring(map.lp_device_name or "")
      .. "\nLayout Format: " .. tostring(map.lp_layout_format or "")
      .. "\nAssigned Pads: " .. tostring(map.assigned_pads or 0)
      .. "\nEmpty Pads: " .. tostring(map.empty_pads or 0)
  else
    text = text
      .. "\nLaunchpad Layout: not found"
      .. "\nNext action later will be: open layout builder."
  end

  return text
end

DAW.MIDI_LAYOUT_BUILDER.continue = function(arm_track)
  local track = DAW.MIDI_LAYOUT_BUILDER.target_track or r.GetSelectedTrack(0, 0)

  if not track then
    r.ShowMessageBox(
      "Before using MIDI Layout Builder, select a track with a valid FXi.",
      "MIDI Layout Builder",
      0
    )
    last_action = "MIDI Layout Builder needs a selected track"
    return false
  end

  local input_label = DAW.MIDI_LAYOUT_BUILDER.choice_label(
    "input",
    DAW.MIDI_LAYOUT_BUILDER.input_mode
  )

  local prep_label = DAW.MIDI_LAYOUT_BUILDER.choice_label(
    "prep",
    DAW.MIDI_LAYOUT_BUILDER.prep_mode
  )

  r.Undo_BeginBlock()

  local ok_input, input_result =
    DAW.MIDI_LAYOUT_BUILDER.apply_track_input_choice(track)

  if not ok_input then
    r.Undo_EndBlock("MIDI Layout Builder setup failed", -1)

    r.ShowMessageBox(
      tostring(input_result or "Could not apply track input choice."),
      "MIDI Layout Builder",
      0
    )

    last_action = "MIDI Layout Builder setup failed"
    return false
  end

  local arm_result = "Track arm state left untouched"

  if arm_track then
    local ok_arm, result =
      DAW.MIDI_LAYOUT_BUILDER.arm_and_monitor_track(track)

    if not ok_arm then
      r.Undo_EndBlock("MIDI Layout Builder setup failed", -1)

      r.ShowMessageBox(
        tostring(result or "Could not arm track."),
        "MIDI Layout Builder",
        0
      )

      last_action = "MIDI Layout Builder arm failed"
      return false
    end

    arm_result = result
  end

  local ok_prep, prep_result =
    DAW.MIDI_LAYOUT_BUILDER.apply_track_prep_choice(track)

  if not ok_prep then
    r.Undo_EndBlock("MIDI Layout Builder setup failed", -1)

    r.ShowMessageBox(
      tostring(prep_result or "Could not apply track prep choice."),
      "MIDI Layout Builder",
      0
    )

    last_action = "MIDI Layout Builder track prep failed"
    return false
  end

  local map_result =
    DAW.MIDI_LAYOUT_BUILDER.resolve_selected_track_map(track)
  
  local layout_result = "No Launchpad layout sent."
  
  if map_result
      and map_result.found_path
      and map_result.parsed_map
      and map_result.parsed_map.lp_layout_found then
  
    r.TrackList_AdjustWindows(false)
    r.UpdateArrange()
  
    r.Undo_EndBlock("MIDI Layout Builder: set track input and prep FX", -1)
  
    local ok_preview, preview_text =
      DAW.MIDI_LAYOUT_BUILDER.open_layout_confirmation(map_result)
  
    if not ok_preview then
      r.ShowMessageBox(
        tostring(preview_text or "Could not open layout confirmation editor."),
        "MIDI Layout Builder",
        0
      )
  
      last_action = "MIDI Layout Builder layout preview failed"
      return false
    end
  
    last_action = tostring(preview_text or "Opened layout confirmation editor.")
    return true
  end
  
  local layout_result = "No Launchpad layout found to preview."
  
  r.TrackList_AdjustWindows(false)
  r.UpdateArrange()
  
  r.Undo_EndBlock("MIDI Layout Builder: set track input and prep FX", -1)
  
  r.ShowMessageBox(
    DAW.MIDI_LAYOUT_BUILDER.selected_track_name() 
      .. "\n\nTrack MIDI Input:\n"
      .. input_label
      .. "\n\nApplied:\n"
      .. tostring(input_result or "")
      .. "\n\nArm / Monitor:\n"
      .. tostring(arm_result or "")
      .. "\n\nOptional Track Prep:\n"
      .. prep_label
      .. "\n\nApplied:\n"
      .. tostring(prep_result or "")
      .. "\n\nMap Resolver:\n"
      .. DAW.MIDI_LAYOUT_BUILDER.map_report_text(map_result)
      .. "\n\nLaunchpad Layout:\n"
      .. tostring(layout_result or ""),
    "MIDI Layout Builder Setup",
    0
  )

  last_action = "MIDI Layout Builder applied: "
    .. tostring(input_result or input_label)
    .. " | "
    .. tostring(arm_result or "")
    .. " | "
    .. tostring(prep_result or prep_label)

  return true
end

DAW.MIDI_LAYOUT_BUILDER.dispatch_index = function(index, source)
  if DAW.MIDI_LAYOUT_BUILDER.warning then
    local ok_index =
      DAW.MIDI_LAYOUT_BUILDER.pad_index(DAW.MIDI_LAYOUT_BUILDER.WARNING_OK_PAD)

    if index == ok_index then
      return DAW.MIDI_LAYOUT_BUILDER.clear_warning_and_return_home()
    end

    return true
  end

  local pad = DAW.MIDI_LAYOUT_BUILDER.pad_by_index(index)
  if not pad then return false end

  if pad.group == "input" then
    DAW.MIDI_LAYOUT_BUILDER.input_mode = pad.value
    DAW.MIDI_LAYOUT_BUILDER.send_lighting()
    last_action = "MIDI Layout Builder input: "
      .. DAW.MIDI_LAYOUT_BUILDER.choice_label("input", pad.value)
    return true
  end

  if pad.group == "prep" then
    DAW.MIDI_LAYOUT_BUILDER.prep_mode = pad.value
    DAW.MIDI_LAYOUT_BUILDER.send_lighting()
    last_action = "MIDI Layout Builder prep: "
      .. DAW.MIDI_LAYOUT_BUILDER.choice_label("prep", pad.value)
    return true
  end

  if pad.role == "cancel" then
    return DAW.MIDI_LAYOUT_BUILDER.cancel()
  end

  if pad.role == "continue" then
      return DAW.MIDI_LAYOUT_BUILDER.continue(false)
    end
  
    if pad.role == "arm_continue" then
      return DAW.MIDI_LAYOUT_BUILDER.continue(true)
    end

  return false
end

DAW.MIDI_LAYOUT_BUILDER.draw_grid = function()
  if DAW.MIDI_LAYOUT_BUILDER.warning then
    local warning = DAW.MIDI_LAYOUT_BUILDER.warning

    DAW.GUI.draw_screen_title(warning.title or "Pair Launchpad and FXi")

    for _, line in ipairs(warning.lines or {}) do
      if line == "" then
        r.ImGui_Spacing(ctx)
      else
        r.ImGui_TextWrapped(ctx, line)
      end
    end

    local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
    local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
    local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

    for row = 1, 9 do
      for col = 1, 9 do
        local index = DAW.MIDI_LAYOUT_BUILDER.index_for_row_col(row, col)
        local ok_index =
          DAW.MIDI_LAYOUT_BUILDER.pad_index(DAW.MIDI_LAYOUT_BUILDER.WARNING_OK_PAD)

        local pad = nil
        if index == ok_index then
          pad = DAW.MIDI_LAYOUT_BUILDER.WARNING_OK_PAD
        end

        local lines = {" "}
        local background = 0x181818FF
        local text_color = 0x808080FF
        local options = {max_lines = 3}

        if pad then
          lines = pad.label or {"OK"}
          background = DAW.USER_PAGES.palette_gui(pad.color or 0)
          text_color = readable_text_color(background)
        end

        local clicked = draw_compact_grid_button(
          "##midi_layout_warning_" .. tostring(row) .. "_" .. tostring(col),
          lines,
          cell_w,
          cell_h,
          background,
          text_color,
          options
        )

        if clicked and pad then
          DAW.MIDI_LAYOUT_BUILDER.dispatch_index(index, "GRID")
        end

        if col < 9 then
          r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
        end
      end
    end

    return
  end

  DAW.GUI.draw_screen_title("MIDI Layout Builder: Set Launchpad as Input")

  r.ImGui_Text(ctx, DAW.MIDI_LAYOUT_BUILDER.selected_track_name())
  r.ImGui_Text(ctx, "Choose track input and optional track prep. No changes are made until a later step.")

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for row = 1, 9 do
    for col = 1, 9 do
      local index = DAW.MIDI_LAYOUT_BUILDER.index_for_row_col(row, col)
      local pad = DAW.MIDI_LAYOUT_BUILDER.pad_by_index(index)

      local lines = {" "}
      local background = 0x181818FF
      local text_color = 0x808080FF
      local options = {max_lines = 3}

      if pad then
        lines = pad.label or {" "}
        background = DAW.USER_PAGES.palette_gui(pad.color or 0)
        if DAW.MIDI_LAYOUT_BUILDER.pad_is_selected(pad) then
          background = pulse_gui_color(background)
        end
        text_color = readable_text_color(background)
      end

      local clicked = draw_compact_grid_button(
        "##midi_layout_setup_" .. tostring(row) .. "_" .. tostring(col),
        lines,
        cell_w,
        cell_h,
        background,
        text_color,
        options
      )

      if clicked and pad then
        DAW.MIDI_LAYOUT_BUILDER.dispatch_index(index, "GRID")
      end

      if col < 9 then
        r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
      end
    end
  end
end

local function draw_grid()
  if surface_mode == "CUSTOM_EXTERNAL"
      and DAW.CUSTOM_LIBRARY
      and DAW.CUSTOM_LIBRARY.active_external_custom_slot
      and DAW.CUSTOM_LIBRARY.active_external_custom_slot() then
    DAW.CUSTOM_LIBRARY.draw_external_custom_grid()

  elseif surface_mode == "MIDI_LAYOUT_SETUP" and DAW.MIDI_LAYOUT_BUILDER then
    DAW.MIDI_LAYOUT_BUILDER.draw_grid()

  elseif surface_mode == "REGIONS_MARKERS" then
    DAW.REGIONS_MARKERS.draw_grid()
  elseif surface_mode == "TRACK_PICKER" then
    DAW.TRACK_PICKER.draw_grid()
  elseif surface_mode == "TRACK_VIEWER_SESSION" then
    DAW.TRACK_VIEWER.draw_grid()
  elseif surface_mode == "DAW_FX_MATRIX" then
    DAW.FX.draw_matrix_grid()
  elseif surface_mode == "DAW_FX_FADERS" then
    DAW.FX.draw_fader_grid()
  elseif surface_mode == "PROGRAMMER_TRACK_MATRIX" then
    DAW.MATRIX.draw_matrix_grid()
  elseif surface_mode == "DAW_VOLUME_FADERS" and active_custom_slot and DAW.active_target() == "pan" then
    draw_custom_pan_grid()
  elseif (surface_mode == "CUSTOM_VOLUME_BANK" or surface_mode == "DAW_VOLUME_FADERS") and active_custom_slot then
    draw_custom_volume_grid()
  else
    draw_home_grid()
  end
end


DAW.GUI.draw_palette_combo = function(label, current)
  -- Retained for the SysEx & Customs editor. The Command Library deliberately
  -- uses the chart-based picker instead.
  current=math.max(0,math.min(127,tonumber(current) or 0x25))
  r.ImGui_SetNextItemWidth(ctx,120)
  if r.ImGui_BeginCombo(ctx,label,string.format("%d",current)) then
    for palette=0,127 do
      if r.ImGui_Selectable(ctx,tostring(palette),palette==current) then current=palette end
    end
    r.ImGui_EndCombo(ctx)
  end
  return current
end

DAW.GUI.draw_palette_swatch = function(palette,id,w,h)
  local color=DAW.USER_PAGES.palette_gui(palette)
  local clicked = false
  if r.ImGui_PushStyleColor and r.ImGui_Col_Button then
    r.ImGui_PushStyleColor(ctx,r.ImGui_Col_Button(),color)
    r.ImGui_PushStyleColor(ctx,r.ImGui_Col_ButtonHovered(),brighten(color,0.15))
    r.ImGui_PushStyleColor(ctx,r.ImGui_Col_ButtonActive(),brighten(color,0.30))
    clicked = r.ImGui_Button(ctx,"##swatch_"..tostring(id),w or 20,h or 20)
    r.ImGui_PopStyleColor(ctx,3)
  else
    clicked = r.ImGui_Button(ctx,"##swatch_"..tostring(id),w or 20,h or 20)
  end
  return clicked
end

-- ImGui_IsItemHovered() may remain false while another widget owns an active
-- mouse drag. Swap targets therefore use the item's actual screen rectangle so
-- downward and upward drags behave identically for index buttons and swatches.
DAW.GUI.mouse_is_over_last_item = function()
  if r.ImGui_GetItemRectMin and r.ImGui_GetItemRectMax and r.ImGui_GetMousePos then
    local min_x,min_y = r.ImGui_GetItemRectMin(ctx)
    local max_x,max_y = r.ImGui_GetItemRectMax(ctx)
    local mouse_x,mouse_y = r.ImGui_GetMousePos(ctx)
    if min_x and min_y and max_x and max_y and mouse_x and mouse_y then
      return mouse_x >= min_x and mouse_x <= max_x
        and mouse_y >= min_y and mouse_y <= max_y
    end
  end
  return r.ImGui_IsItemHovered(ctx)
end

-- ReaImGui's current BeginChild binding expects numeric child flags as its
-- fifth argument. Keep this wrapper in one place so every new library pane
-- uses the same signature.
DAW.GUI.force_next_window_opaque = function()
  if r.ImGui_SetNextWindowBgAlpha then
    r.ImGui_SetNextWindowBgAlpha(ctx,1.0)
  end
end

DAW.GUI.begin_child = function(id, width, height, window_flags)
  return r.ImGui_BeginChild(
    ctx,
    id,
    width or 0,
    height or 0,
    0,
    window_flags or 0
  )
end

DAW.GUI.palette_chart = {
  path = script_path .. CFG.PALETTE_CHART_FILENAME,
  image = nil,
  attached_context = nil,
  width = 325,
  height = 615,
  left = 21,
  top = 21,
  cell = 32,
  gap = 4,
}

DAW.GUI.palette_chart_index_from_xy = function(x,y)
  local chart=DAW.GUI.palette_chart
  local rel_x=(tonumber(x) or -1)-chart.left
  local rel_y=(tonumber(y) or -1)-chart.top
  if rel_x < 0 or rel_y < 0 then return nil end
  local step=chart.cell+chart.gap
  local col=math.floor(rel_x/step)
  local row=math.floor(rel_y/step)
  if col < 0 or col > 7 or row < 0 or row > 15 then return nil end
  if (rel_x%step) >= chart.cell or (rel_y%step) >= chart.cell then return nil end
  return (row*8)+col
end

DAW.GUI.ensure_palette_chart_image = function()
  local chart=DAW.GUI.palette_chart
  if chart.image then
    if chart.attached_context ~= ctx and r.ImGui_Attach then
      pcall(r.ImGui_Attach,ctx,chart.image)
      chart.attached_context=ctx
    end
    return chart.image
  end
  if not r.ImGui_CreateImage then return nil end
  local ok,image=pcall(r.ImGui_CreateImage,chart.path)
  if not ok or not image then return nil end
  chart.image=image
  if r.ImGui_Attach then pcall(r.ImGui_Attach,ctx,image) end
  chart.attached_context=ctx
  return image
end

DAW.GUI.draw_palette_chart_fallback = function(pending)
  local chart=DAW.GUI.palette_chart
  local cell,gap=chart.cell,chart.gap
  for row=0,15 do
    for col=0,7 do
      local palette=(row*8)+col
      local x,y=r.ImGui_GetCursorScreenPos(ctx)
      local clicked=r.ImGui_InvisibleButton(ctx,"##palette_cell_"..tostring(palette),cell,cell)
      local draw_list=r.ImGui_GetWindowDrawList(ctx)
      local color=DAW.USER_PAGES.palette_gui(palette)
      r.ImGui_DrawList_AddRectFilled(draw_list,x,y,x+cell,y+cell,color)
      r.ImGui_DrawList_AddText(draw_list,x+4,y+7,readable_text_color(color),tostring(palette))
      if palette==pending then r.ImGui_DrawList_AddRect(draw_list,x,y,x+cell,y+cell,0xFFFFFFFF,0,0,3) end
      if clicked then pending=palette end
      if col<7 then r.ImGui_SameLine(ctx,nil,gap) end
    end
  end
  return pending
end

DAW.GUI.draw_palette_chart = function(pending)
  local chart=DAW.GUI.palette_chart
  local image=DAW.GUI.ensure_palette_chart_image()
  if image and r.ImGui_Image then
    local x,y=r.ImGui_GetCursorScreenPos(ctx)
    local ok=pcall(r.ImGui_Image,ctx,image,chart.width,chart.height)
    if ok then
      if r.ImGui_IsItemHovered(ctx) and r.ImGui_IsMouseClicked(ctx,0) then
        local mx,my=r.ImGui_GetMousePos(ctx)
        local palette=DAW.GUI.palette_chart_index_from_xy(mx-x,my-y)
        if palette ~= nil then pending=palette end
      end
      local selected_col=pending%8
      local selected_row=math.floor(pending/8)
      local sx=x+chart.left+(selected_col*(chart.cell+chart.gap))
      local sy=y+chart.top+(selected_row*(chart.cell+chart.gap))
      r.ImGui_DrawList_AddRect(
        r.ImGui_GetWindowDrawList(ctx),
        sx,sy,sx+chart.cell,sy+chart.cell,
        0xFFFFFFFF,0,0,3
      )
      return pending
    end
  end

  r.ImGui_Text(ctx,"Palette image could not be loaded; using generated fallback chart.")
  return DAW.GUI.draw_palette_chart_fallback(pending)
end

DAW.GUI.draw_page_swatches = function(entries,start_index,on_click,register_swap_item,is_drag_active,display_color)
  r.ImGui_Text(ctx,"40 Visible Slot Colors:")
  for offset=0,39 do
    local index=start_index+offset
    local entry=entries[index]
    local palette=display_color and display_color(entry) or (entry and entry.color or 0x01)
    local clicked=DAW.GUI.draw_palette_swatch(palette,"bank_"..tostring(offset),18,18)
    if register_swap_item then register_swap_item(index) end
    if clicked and on_click and entry and not (is_drag_active and is_drag_active()) then
      on_click(palette)
    end
    if (offset%5)~=4 then r.ImGui_SameLine(ctx) end
  end
end

DAW.GUI.table_flags = function()
  local flags=0
  if r.ImGui_TableFlags_Borders then flags=flags|r.ImGui_TableFlags_Borders() end
  if r.ImGui_TableFlags_RowBg then flags=flags|r.ImGui_TableFlags_RowBg() end
  if r.ImGui_TableFlags_Resizable then flags=flags|r.ImGui_TableFlags_Resizable() end
  -- Manual separator dragging remains available for visual tuning during the
  -- current run, but ImGui's saved .ini widths must not override CFG defaults
  -- on later launches. Restarting the script now resets librarian widths.
  if r.ImGui_TableFlags_NoSavedSettings then flags=flags|r.ImGui_TableFlags_NoSavedSettings() end
  if r.ImGui_TableFlags_ScrollY then flags=flags|r.ImGui_TableFlags_ScrollY() end
  return flags
end

-- BeginDisabled is present in current ReaImGui builds. Keep a visual-only
-- fallback for older builds so the script remains usable while all click and
-- edit handlers still guard against inactive payload modes.
DAW.GUI.begin_disabled = function(disabled)
  disabled = disabled and true or false
  if disabled then DAW.GUI.disabled_depth=(tonumber(DAW.GUI.disabled_depth) or 0)+1 end
  if r.ImGui_BeginDisabled then
    r.ImGui_BeginDisabled(ctx,disabled)
    return disabled and "native_disabled" or "native_enabled"
  end
  if disabled and r.ImGui_PushStyleVar and r.ImGui_StyleVar_Alpha then
    r.ImGui_PushStyleVar(ctx,r.ImGui_StyleVar_Alpha(),0.45)
    return "alpha"
  end
  return disabled and "disabled" or nil
end

DAW.GUI.end_disabled = function(token)
  if (token == "native_disabled" or token == "native_enabled") and r.ImGui_EndDisabled then
    r.ImGui_EndDisabled(ctx)
  elseif token == "alpha" and r.ImGui_PopStyleVar then
    r.ImGui_PopStyleVar(ctx)
  end
  if token == "native_disabled" or token == "alpha" or token == "disabled" then
    DAW.GUI.disabled_depth=math.max(0,(tonumber(DAW.GUI.disabled_depth) or 1)-1)
  end
end

-- ImGui_InputTextMultiline does not natively soft-wrap editable text. SysEx
-- payloads are whitespace-insensitive hexadecimal byte lists, so present them
-- with harmless hard line breaks between complete byte tokens. This keeps long
-- Entries readable without changing the data sent to or saved from the device.
DAW.GUI.resizable_multiline_active = DAW.GUI.resizable_multiline_active or {}

DAW.GUI.sysex_bytes_per_editor_line = function(field_width)
  local token_width = 0
  if r.ImGui_CalcTextSize then
    token_width = select(1,r.ImGui_CalcTextSize(ctx,"00 ")) or 0
  end
  if token_width <= 0 then token_width = 21 end
  return math.max(4,math.floor(((tonumber(field_width) or 430)-18)/token_width))
end

DAW.GUI.wrap_sysex_hex_for_editor = function(text,field_width)
  text=tostring(text or "")
  if trim(text)=="" then return "" end

  -- Reformat only a clean hexadecimal-byte list. Preserve unfamiliar or
  -- partially edited content verbatim rather than discarding user input.
  local compact=text:gsub("0[xX]",""):gsub("[%s,;]+","")
  if compact=="" or not compact:match("^[%x]+$") or (#compact%2)~=0 then
    return text
  end

  local bytes={}
  for index=1,#compact,2 do bytes[#bytes+1]=compact:sub(index,index+1):upper() end
  local per_line=DAW.GUI.sysex_bytes_per_editor_line(field_width)
  local lines={}
  for first=1,#bytes,per_line do
    local line={}
    for index=first,math.min(#bytes,first+per_line-1) do line[#line+1]=bytes[index] end
    lines[#lines+1]=table.concat(line," ")
  end
  return table.concat(lines,"\n")
end

DAW.GUI.resizable_multiline = function(id,label,value,width,state,key,default_height)
  state = state or {}
  key = tostring(key or id)
  local minimum_height = 24
  local field_width = tonumber(width) or 430
  local height = math.max(minimum_height, tonumber(state[key]) or tonumber(default_height) or minimum_height)
  local editor_value=tostring(value or "")
  if not DAW.GUI.resizable_multiline_active[key] then
    editor_value=DAW.GUI.wrap_sysex_hex_for_editor(editor_value,field_width)
  end

  local changed, new_value = r.ImGui_InputTextMultiline(
    ctx,
    tostring(label) .. "##" .. tostring(id),
    editor_value,
    field_width,
    height
  )
  local item_active = r.ImGui_IsItemActive and r.ImGui_IsItemActive(ctx) or false
  DAW.GUI.resizable_multiline_active[key]=item_active and true or false
  if not item_active then
    local wrapped=DAW.GUI.wrap_sysex_hex_for_editor(new_value,field_width)
    if wrapped~=new_value then new_value=wrapped; changed=true end
  end

  if r.ImGui_GetItemRectMin and r.ImGui_GetCursorScreenPos
      and r.ImGui_SetCursorScreenPos and r.ImGui_InvisibleButton then
    -- Derive the lower-right corner from the text-box width itself. For a
    -- visible label, GetItemRectMax() can include the label and place the
    -- dog-ear well to the right of the actual field.
    local min_x, min_y = r.ImGui_GetItemRectMin(ctx)
    local max_x, max_y = min_x + field_width, min_y + height
    local restore_x, restore_y = r.ImGui_GetCursorScreenPos(ctx)
    local handle = 14

    r.ImGui_SetCursorScreenPos(ctx,max_x-handle,max_y-handle)
    r.ImGui_InvisibleButton(ctx,"##dogear_"..tostring(id),handle,handle)

    -- Use direct rectangle hit-testing rather than relying on the overlapping
    -- InvisibleButton to become ImGui's active item inside a table cell.
    local mouse_x, mouse_y = 0, 0
    if r.ImGui_GetMousePos then mouse_x, mouse_y = r.ImGui_GetMousePos(ctx) end
    local over_handle = mouse_x >= max_x-handle and mouse_x <= max_x
      and mouse_y >= max_y-handle and mouse_y <= max_y

    local interaction_disabled = (tonumber(DAW.GUI.disabled_depth) or 0) > 0
    if not interaction_disabled and over_handle and r.ImGui_IsMouseClicked and r.ImGui_IsMouseClicked(ctx,0) then
      DAW.CUSTOM_LIBRARY.field_resize_active_key = key
      DAW.CUSTOM_LIBRARY.field_resize_start_mouse_y = mouse_y
      DAW.CUSTOM_LIBRARY.field_resize_start_height = height
      DAW.CUSTOM_LIBRARY.field_resize_start[key] = height
    end

    if DAW.CUSTOM_LIBRARY.field_resize_active_key == key then
      if r.ImGui_IsMouseDown and r.ImGui_IsMouseDown(ctx,0) then
        state[key] = math.max(
          minimum_height,
          (tonumber(DAW.CUSTOM_LIBRARY.field_resize_start_height) or height)
            + mouse_y - (tonumber(DAW.CUSTOM_LIBRARY.field_resize_start_mouse_y) or mouse_y)
        )
      else
        DAW.CUSTOM_LIBRARY.field_resize_active_key = nil
        DAW.CUSTOM_LIBRARY.field_resize_start[key] = nil
      end
    end

    if r.ImGui_SetMouseCursor and r.ImGui_MouseCursor_ResizeNS
        and (over_handle or DAW.CUSTOM_LIBRARY.field_resize_active_key == key) then
      r.ImGui_SetMouseCursor(ctx,r.ImGui_MouseCursor_ResizeNS())
    end

    if r.ImGui_GetWindowDrawList and r.ImGui_DrawList_AddLine then
      local draw_list = r.ImGui_GetWindowDrawList(ctx)
      r.ImGui_DrawList_AddLine(draw_list,max_x-11,max_y-3,max_x-3,max_y-11,0xBBBBBBFF,1)
      r.ImGui_DrawList_AddLine(draw_list,max_x-7,max_y-3,max_x-3,max_y-7,0xBBBBBBFF,1)
    end

    r.ImGui_SetCursorScreenPos(ctx,restore_x,restore_y)
    r.ImGui_Dummy(ctx,0,0)
  end

  return changed,new_value
end

DAW.GUI.first_line = function(text)
  return trim((tostring(text or ""):match("([^\r\n]+)") or ""))
end

DAW.GUI.single_line_text = function(text)
  text = tostring(text or "")
  text = text:gsub("[\r\n]+"," ")
  text = text:gsub("%s+"," ")
  return trim(text)
end

DAW.GUI.clip_text = function(text,max_chars)
  text=tostring(text or "")
  max_chars=math.max(4,tonumber(max_chars) or 48)
  if #text<=max_chars then return text end
  return text:sub(1,max_chars-3).."..."
end

DAW.COMMAND_LIBRARY.open_palette_picker = function()
  local entry=DAW.USER_DATA.ensure_command_entry(DAW.COMMAND_LIBRARY.editor_index)
  DAW.COMMAND_LIBRARY.pending_palette_color=math.max(0,math.min(127,tonumber(entry.color) or 0x25))
  DAW.COMMAND_LIBRARY.palette_picker_visible=true
end

DAW.COMMAND_LIBRARY.set_editor_color = function(palette)
  local entry=DAW.USER_DATA.ensure_command_entry(DAW.COMMAND_LIBRARY.editor_index)
  entry.color=math.max(0,math.min(127,tonumber(palette) or 0x25))
  DAW.COMMAND_LIBRARY.save()
  last_hardware_state_signature=nil
end

DAW.COMMAND_LIBRARY.delete_entry = function(index)
  index=math.max(1,math.floor(tonumber(index) or 1))
  local entries=DAW.COMMAND_LIBRARY.data.entries
  if not entries[index] then return false end
  table.remove(entries,index)
  DAW.COMMAND_LIBRARY.editor_index=math.max(1,math.min(DAW.COMMAND_LIBRARY.editor_index,#entries>0 and #entries or 1))
  DAW.COMMAND_LIBRARY.scroll_to_editor_index=DAW.COMMAND_LIBRARY.editor_index
  DAW.COMMAND_LIBRARY.save()
  last_hardware_state_signature=nil
  return true
end

DAW.COMMAND_LIBRARY.swap_entries = function(a,b)
  a,b=tonumber(a),tonumber(b)
  local entries=DAW.COMMAND_LIBRARY.data.entries
  if not a or not b or a==b or not entries[a] or not entries[b] then return false end
  entries[a],entries[b]=entries[b],entries[a]
  if DAW.COMMAND_LIBRARY.editor_index==a then
    DAW.COMMAND_LIBRARY.editor_index=b
  elseif DAW.COMMAND_LIBRARY.editor_index==b then
    DAW.COMMAND_LIBRARY.editor_index=a
  end
  DAW.COMMAND_LIBRARY.scroll_to_editor_index=DAW.COMMAND_LIBRARY.editor_index
  DAW.COMMAND_LIBRARY.save()
  last_hardware_state_signature=nil
  return true
end

DAW.COMMAND_LIBRARY.draw_palette_picker_window = function()
  if not DAW.COMMAND_LIBRARY.palette_picker_visible then return false end
  r.ImGui_SetNextWindowSize(ctx,380,710,r.ImGui_Cond_FirstUseEver())
  DAW.GUI.force_next_window_opaque()
  local visible,open_window=r.ImGui_Begin(ctx,"Launchpad Xtra Palette 0 - 127",true,r.ImGui_WindowFlags_NoCollapse())
    if visible == nil then return true end
    if visible then
    r.ImGui_Text(ctx,"Click a chart color, then choose SET or CANCEL.")
    DAW.COMMAND_LIBRARY.pending_palette_color=
      DAW.GUI.draw_palette_chart(DAW.COMMAND_LIBRARY.pending_palette_color)
    r.ImGui_Text(ctx,"Selected palette index: "..tostring(DAW.COMMAND_LIBRARY.pending_palette_color))
    DAW.GUI.draw_palette_swatch(DAW.COMMAND_LIBRARY.pending_palette_color,"palette_pending",44,26)
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"SET") then
      DAW.COMMAND_LIBRARY.set_editor_color(DAW.COMMAND_LIBRARY.pending_palette_color)
      DAW.COMMAND_LIBRARY.palette_picker_visible=false
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"CANCEL") then
      DAW.COMMAND_LIBRARY.palette_picker_visible=false
    end
  end
  r.ImGui_End(ctx)
  if not open_window then DAW.COMMAND_LIBRARY.palette_picker_visible=false end
  return true
end

DAW.COMMAND_LIBRARY.register_swap_item = function(index)
  index = tonumber(index)
  if not index then return end

  local hovered = DAW.GUI.mouse_is_over_last_item()
  if hovered then
    DAW.COMMAND_LIBRARY.hovered_swap_index = index
    if DAW.COMMAND_LIBRARY.drag_index and index ~= DAW.COMMAND_LIBRARY.drag_index then
      DAW.COMMAND_LIBRARY.drag_target = index
      DAW.COMMAND_LIBRARY.last_valid_drop_index = index
    end
  end

  if r.ImGui_IsItemActive(ctx) and r.ImGui_IsMouseDragging(ctx,0,4) then
    if not DAW.COMMAND_LIBRARY.drag_index then
      DAW.COMMAND_LIBRARY.drag_index = index
      DAW.COMMAND_LIBRARY.drag_target = nil
      DAW.COMMAND_LIBRARY.last_valid_drop_index = nil
    end
  end
end

DAW.COMMAND_LIBRARY.apply_selected_row_background = function(index)
  if tonumber(index) ~= tonumber(DAW.COMMAND_LIBRARY.editor_index) then return end
  if not (r.ImGui_TableSetBgColor and r.ImGui_TableBgTarget_RowBg0) then return end
  pcall(
    r.ImGui_TableSetBgColor,
    ctx,
    r.ImGui_TableBgTarget_RowBg0(),
    0x205F5FFF
  )
end

DAW.GUI.table_fixed_column_flag = function()
  return r.ImGui_TableColumnFlags_WidthFixed
    and r.ImGui_TableColumnFlags_WidthFixed()
    or 0
end

DAW.COMMAND_LIBRARY.begin_width_capture_frame = function()
  DAW.COMMAND_LIBRARY.width_capture_x = {}
end

DAW.COMMAND_LIBRARY.capture_table_column_width = function(column)
  column = math.max(0, math.floor(tonumber(column) or 0))
  DAW.COMMAND_LIBRARY.table_column_widths = DAW.COMMAND_LIBRARY.table_column_widths or {}
  DAW.COMMAND_LIBRARY.width_capture_x = DAW.COMMAND_LIBRARY.width_capture_x or {}

  if r.ImGui_GetCursorScreenPos then
    local x = select(1,r.ImGui_GetCursorScreenPos(ctx))
    if tonumber(x) then
      DAW.COMMAND_LIBRARY.width_capture_x[column + 1] = x
      if column > 0 then
        local prior_x = DAW.COMMAND_LIBRARY.width_capture_x[column]
        if tonumber(prior_x) and x > prior_x then
          DAW.COMMAND_LIBRARY.table_column_widths[column] = x - prior_x
        end
      end
    end
  end

  if r.ImGui_TableGetColumnWidth then
    local ok_width, width = pcall(r.ImGui_TableGetColumnWidth,ctx,column)
    if ok_width and tonumber(width) and width > 0 then
      DAW.COMMAND_LIBRARY.table_column_widths[column + 1] = width
    end
  elseif column == 6 and r.ImGui_GetContentRegionAvail then
    local available_w = select(1,r.ImGui_GetContentRegionAvail(ctx))
    if tonumber(available_w) and available_w > 0 then
      DAW.COMMAND_LIBRARY.table_column_widths[7] = available_w
    end
  end
end

DAW.COMMAND_LIBRARY.set_table_column = function(column)
  r.ImGui_TableSetColumnIndex(ctx,column)
  DAW.COMMAND_LIBRARY.capture_table_column_width(column)
end

DAW.COMMAND_LIBRARY.capture_table_column_widths = function()
  if not r.ImGui_TableGetColumnWidth then return end
  DAW.COMMAND_LIBRARY.table_column_widths = DAW.COMMAND_LIBRARY.table_column_widths or {}
  for column = 0,6 do
    local ok_width,width = pcall(r.ImGui_TableGetColumnWidth,ctx,column)
    if ok_width and tonumber(width) and width > 0 then
      DAW.COMMAND_LIBRARY.table_column_widths[column + 1] = width
    end
  end
end

DAW.COMMAND_LIBRARY.table_widths_status_text = function()
  local names = CFG.COMMAND_TABLE_COLUMN_NAMES
  local measured = DAW.COMMAND_LIBRARY.table_column_widths or {}
  local defaults = CFG.COMMAND_TABLE_COLUMN_DEFAULT_WIDTHS
  local parts = {}

  for index, name in ipairs(names) do
    local width = tonumber(measured[index]) or tonumber(defaults[index]) or 0
    parts[#parts + 1] = tostring(name) .. "=" .. tostring(math.floor(width + 0.5))
  end

  return table.concat(parts, " | ")
end

DAW.COMMAND_LIBRARY.draw_table = function()
  local entries=DAW.COMMAND_LIBRARY.data.entries
  local delete_index=nil

  if not (r.ImGui_BeginTable and r.ImGui_TableSetupColumn and r.ImGui_TableHeadersRow
      and r.ImGui_TableNextRow and r.ImGui_TableSetColumnIndex) then
    r.ImGui_Text(ctx,"This ReaImGui build does not provide table widgets.")
    return
  end

  if r.ImGui_BeginTable(ctx,"##command_library_table",7,DAW.GUI.table_flags(),0,0) then
    local column_flags = DAW.GUI.table_fixed_column_flag()
    for index, name in ipairs(CFG.COMMAND_TABLE_COLUMN_NAMES) do
      r.ImGui_TableSetupColumn(
        ctx,
        name,
        column_flags,
        CFG.COMMAND_TABLE_COLUMN_DEFAULT_WIDTHS[index] or 0
      )
    end
    r.ImGui_TableHeadersRow(ctx)

    DAW.COMMAND_LIBRARY.hovered_swap_index = nil
    DAW.COMMAND_LIBRARY.begin_width_capture_frame()

    for index,row_entry in ipairs(entries) do
      DAW.USER_DATA.ensure_command_entry(index)
      if ((index-1)%40)==0 then
        r.ImGui_TableNextRow(ctx)
        DAW.COMMAND_LIBRARY.set_table_column(2)
        r.ImGui_Text(ctx,"Bank "..tostring(math.floor((index-1)/40)+1)
          .." — Slots "..tostring(index).."-"..tostring(index+39))
      end

      r.ImGui_TableNextRow(ctx)
      DAW.COMMAND_LIBRARY.apply_selected_row_background(index)
      DAW.COMMAND_LIBRARY.set_table_column(0)
      local is_target=DAW.COMMAND_LIBRARY.drag_target==index
      if is_target and r.ImGui_PushStyleColor and r.ImGui_Col_Button then
        r.ImGui_PushStyleColor(ctx,r.ImGui_Col_Button(),0x20BFAFFF)
      end
      local selected=r.ImGui_Button(ctx,string.format("%03d",index).."##command_index_"..tostring(index))
      if is_target and r.ImGui_PopStyleColor then r.ImGui_PopStyleColor(ctx,1) end
      if selected then DAW.COMMAND_LIBRARY.select_editor_index(index, false) end
      DAW.COMMAND_LIBRARY.register_swap_item(index)

      DAW.COMMAND_LIBRARY.set_table_column(1)
      if r.ImGui_Button(ctx,"Run##command_run_"..tostring(index)) then
        DAW.COMMAND_LIBRARY.run_entry(index)
      end

      if tonumber(DAW.COMMAND_LIBRARY.scroll_to_editor_index) == tonumber(index)
          and r.ImGui_SetScrollHereY then
        r.ImGui_SetScrollHereY(ctx,0.45)
        DAW.COMMAND_LIBRARY.scroll_to_editor_index=nil
      end

      DAW.COMMAND_LIBRARY.set_table_column(2)
      r.ImGui_Text(ctx,DAW.GUI.clip_text(row_entry.name,52))
      DAW.COMMAND_LIBRARY.set_table_column(3)
      r.ImGui_Text(ctx,DAW.GUI.clip_text(row_entry.command,34))
      DAW.COMMAND_LIBRARY.set_table_column(4)
      r.ImGui_Text(ctx,DAW.GUI.clip_text(DAW.GUI.single_line_text(row_entry.label),42))
      DAW.COMMAND_LIBRARY.set_table_column(5)
      DAW.GUI.draw_palette_swatch(DAW.COMMAND_LIBRARY.display_color(row_entry),"command_row_"..tostring(index),20,20)
      DAW.COMMAND_LIBRARY.register_swap_item(index)
      DAW.COMMAND_LIBRARY.set_table_column(6)
      if r.ImGui_Button(ctx,"-##command_delete_"..tostring(index)) then delete_index=index end
    end

    DAW.COMMAND_LIBRARY.capture_table_column_widths()

    if DAW.COMMAND_LIBRARY.drag_index
        and DAW.COMMAND_LIBRARY.hovered_swap_index then
      DAW.COMMAND_LIBRARY.drag_target=DAW.COMMAND_LIBRARY.hovered_swap_index
    end

    r.ImGui_EndTable(ctx)
  end

  if DAW.COMMAND_LIBRARY.drag_index and not r.ImGui_IsMouseDown(ctx,0) then
    DAW.COMMAND_LIBRARY.swap_entries(
      DAW.COMMAND_LIBRARY.drag_index,
      DAW.COMMAND_LIBRARY.drag_target or DAW.COMMAND_LIBRARY.last_valid_drop_index
    )
    DAW.COMMAND_LIBRARY.drag_index=nil
    DAW.COMMAND_LIBRARY.drag_target=nil
    DAW.COMMAND_LIBRARY.last_valid_drop_index=nil
  end
  if delete_index then DAW.COMMAND_LIBRARY.delete_entry(delete_index) end
end

DAW.COMMAND_LIBRARY.draw_window = function()
  if not DAW.COMMAND_LIBRARY.visible then return false end
  r.ImGui_SetNextWindowSize(
    ctx,
    CFG.COMMAND_LIBRARY_DEFAULT_WIDTH,
    CFG.COMMAND_LIBRARY_DEFAULT_HEIGHT,
    r.ImGui_Cond_FirstUseEver()
  )
  DAW.GUI.force_next_window_opaque()
  local visible,open_window=r.ImGui_Begin(ctx,CFG.COMMAND_LIBRARY_WINDOW_TITLE,true,r.ImGui_WindowFlags_NoCollapse())
    if visible == nil then return true end
    if visible then
    local command_window_w, command_window_h = r.ImGui_GetWindowSize(ctx)
    DAW.COMMAND_LIBRARY.window_width = command_window_w
    DAW.COMMAND_LIBRARY.window_height = command_window_h

    local changed
    r.ImGui_SetNextItemWidth(ctx,500)
    changed,DAW.COMMAND_LIBRARY.search_text=r.ImGui_InputText(ctx,"Action-list search",DAW.COMMAND_LIBRARY.search_text)
    if changed then DAW.COMMAND_LIBRARY.refresh_search() end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"Search") then DAW.COMMAND_LIBRARY.refresh_search() end
    r.ImGui_Text(ctx,"Search results (click to load the selected editor row):")
    local search_child_open=DAW.GUI.begin_child("##action_search_results",0,110)
    if search_child_open then
      for _,result in ipairs(DAW.COMMAND_LIBRARY.search_results) do
        if r.ImGui_Selectable(ctx,result.name.."##action_result_"..tostring(result.id),false) then
          local entry=DAW.USER_DATA.ensure_command_entry(DAW.COMMAND_LIBRARY.editor_index)
          entry.name=result.name
          entry.command=result.command
          entry.source_action_name=result.name
          entry.source_named_command=DAW.COMMAND_LIBRARY.normalized_named_command(result.named or result.command)
          entry.import_unresolved=false
          if entry.label=="" then entry.label=result.name:gsub("^Script:%s*","") end
          DAW.COMMAND_LIBRARY.save()
          last_hardware_state_signature=nil
        end
      end
    end
    
    r.ImGui_EndChild(ctx)

    local entry=DAW.USER_DATA.ensure_command_entry(DAW.COMMAND_LIBRARY.editor_index)
    r.ImGui_Separator(ctx)

    if r.ImGui_BeginGroup then r.ImGui_BeginGroup(ctx) end
    r.ImGui_Text(ctx,"Selected Action Slot: "..tostring(DAW.COMMAND_LIBRARY.editor_index))
    r.ImGui_SetNextItemWidth(ctx,420); changed,entry.name=r.ImGui_InputText(ctx,"Name",entry.name)
    r.ImGui_SetNextItemWidth(ctx,420); local c2; c2,entry.command=r.ImGui_InputText(ctx,"Command ID or named command",entry.command); changed=changed or c2
    r.ImGui_SetNextItemWidth(ctx,420); local c3; c3,entry.label=r.ImGui_InputTextMultiline(ctx,"Button label text",entry.label,80,58); changed=changed or c3
    r.ImGui_Text(ctx,"Current button color:")
    r.ImGui_SameLine(ctx)
    if DAW.GUI.draw_palette_swatch(entry.color,"command_editor_current",34,24) then
      DAW.COMMAND_LIBRARY.open_palette_picker()
    end
    r.ImGui_SameLine(ctx)
    r.ImGui_Text(ctx,"Palette "..tostring(entry.color).." — click square to choose from chart")
    if r.ImGui_EndGroup then r.ImGui_EndGroup(ctx) end

    r.ImGui_SameLine(ctx,nil,30)
    if r.ImGui_BeginGroup then r.ImGui_BeginGroup(ctx) end
    DAW.GUI.draw_page_swatches(
      DAW.COMMAND_LIBRARY.data.entries,
      DAW.USER_PAGES.starts[2],
      function(palette) DAW.COMMAND_LIBRARY.set_editor_color(palette) end,
      DAW.COMMAND_LIBRARY.register_swap_item,
      function() return DAW.COMMAND_LIBRARY.drag_index ~= nil end,
      DAW.COMMAND_LIBRARY.display_color
    )
    if r.ImGui_EndGroup then r.ImGui_EndGroup(ctx) end

    if changed then DAW.COMMAND_LIBRARY.save(); last_hardware_state_signature=nil end

    if r.ImGui_Button(ctx,"+ Add action row") then
      DAW.USER_DATA.ensure_command_entry(#DAW.COMMAND_LIBRARY.data.entries+1)
      DAW.COMMAND_LIBRARY.save()
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"Import") then DAW.COMMAND_LIBRARY.import_library() end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"Export") then DAW.COMMAND_LIBRARY.export_library() end
    r.ImGui_SameLine(ctx)
    r.ImGui_Text(ctx,"Drag indexes or color squares to rearrange.")

    r.ImGui_Separator(ctx)
    local command_rows_child_open=DAW.GUI.begin_child("##command_rows",0,0,r.ImGui_WindowFlags_HorizontalScrollbar())
    if command_rows_child_open then
      DAW.COMMAND_LIBRARY.draw_table()
    end
    r.ImGui_EndChild(ctx)
  end
  r.ImGui_End(ctx)
  if not open_window then
    DAW.COMMAND_LIBRARY.visible=false
    last_hardware_state_signature=nil
    refresh_hardware_state(true)
  end
  return true
end

DAW.CUSTOM_LIBRARY.open_palette_picker = function(target)
  if target ~= "scroll" and target ~= "layout_editor" then target = "entry" end
  DAW.CUSTOM_LIBRARY.palette_picker_target = target
  if target == "scroll" then
    DAW.CUSTOM_LIBRARY.pending_palette_color = DAW.CUSTOM_LIBRARY.scroll_palette
  elseif target == "layout_editor" then
    local editor = DAW.CUSTOM_LIBRARY.layout_editor or {}
    local idx = tonumber(editor.selected)
    local cell = idx and editor.cells and editor.cells[idx] or nil
    DAW.CUSTOM_LIBRARY.pending_palette_color = cell and math.max(0,math.min(127,tonumber(cell.color) or 0x01)) or 0x01
  else
    local entry = DAW.USER_DATA.ensure_custom_entry(DAW.CUSTOM_LIBRARY.editor_index)
    DAW.CUSTOM_LIBRARY.pending_palette_color = entry.color
  end
  DAW.CUSTOM_LIBRARY.palette_picker_visible = true
end

DAW.CUSTOM_LIBRARY.apply_palette_picker = function()
  local palette = math.max(0,math.min(127,tonumber(DAW.CUSTOM_LIBRARY.pending_palette_color) or 0x25))
  if DAW.CUSTOM_LIBRARY.palette_picker_target == "scroll" then
    DAW.CUSTOM_LIBRARY.scroll_palette = palette
    DAW.CUSTOM_LIBRARY.save()
    last_hardware_state_signature=nil
    refresh_hardware_state(true)
  elseif DAW.CUSTOM_LIBRARY.palette_picker_target == "layout_editor" then
    DAW.CUSTOM_LIBRARY.layout_editor_apply_color(palette)
    DAW.CUSTOM_LIBRARY.layout_editor_send_preview(true)
  else
    local entry = DAW.USER_DATA.ensure_custom_entry(DAW.CUSTOM_LIBRARY.editor_index)
    entry.color = palette
    DAW.CUSTOM_LIBRARY.save()
    last_hardware_state_signature=nil
    refresh_hardware_state(true)
  end
end


------------------------------------------------------------
-- SysEx / Custom Layout Editor
------------------------------------------------------------
DAW.CUSTOM_LIBRARY.layout_editor = {
  visible = false,
  kind = nil, -- "custom" or "non_custom"
  entry_index = nil,
  payload_slot = nil,
  source_hex = "",
  source_labels = "",
  rows = 8,
  cols = 8,
  cells = {},
  prefix = {},
  suffix = {},
  unsupported_reason = nil,
  selected = nil,
  drag_source = nil,
  drag_target = nil,
  copy_mode = false,
  pending_palette = 0x01,
  preview_signature = nil,
  restore_page = nil,
  restore_surface_mode = nil,
  window_ext_prefix = "LayoutEditor",
}

DAW.CUSTOM_LIBRARY.hex_clean_bytes = function(hex)
  return hex_text_to_bytes(hex or "")
end

DAW.CUSTOM_LIBRARY.button_labels_to_text = function(rows)
  local lines = {}
  for row = 1, 8 do
    local cells = {}
    for col = 1, 8 do
      local value = tostring(rows and rows[row] and rows[row][col] or "")
      value = value:gsub("\n", "|"):gsub(",", " ")
      cells[#cells + 1] = value
    end
    lines[#lines + 1] = table.concat(cells, ",")
  end
  return table.concat(lines, "\n")
end

DAW.CUSTOM_LIBRARY.empty_label_rows = function()
  local rows = {}
  for row = 1, 8 do
    rows[row] = {}
    for col = 1, 8 do rows[row][col] = "" end
  end
  return rows
end

DAW.CUSTOM_LIBRARY.copy_cell = function(cell)
  if type(cell) ~= "table" then return {assigned=false,color=0x01,label="",block=nil} end
  local out = {assigned=cell.assigned and true or false,color=math.max(0,math.min(127,tonumber(cell.color) or 0x01)),label=tostring(cell.label or "")}
  if type(cell.block) == "table" then
    out.block = {}
    for i = 1, #cell.block do out.block[i] = cell.block[i] end
  end
  return out
end

DAW.CUSTOM_LIBRARY.custom_payload_model_from_hex = function(hex, labels_text)
  local bytes = DAW.CUSTOM_LIBRARY.hex_clean_bytes(hex)
  if #bytes <= 0 then return nil, "This Custom row has no SysEx payload to edit." end

  local first_block, after_blocks = nil, nil
  local i = 1
  while i <= #bytes do
    local block_type = bytes[i]
    local pad_index = bytes[i + 1]
    if block_type == 0x48 and pad_index and pad_index >= 0 and pad_index <= 63
        and i + 9 <= #bytes then
      first_block = i
      i = i + 10
      break
    elseif block_type == 0x40 and pad_index and pad_index >= 0 and pad_index <= 63 then
      first_block = i
      i = i + 2
      break
    end
    i = i + 1
  end
  if not first_block then return nil, "Could not find editable 8x8 pad blocks in this Custom payload." end

  local cells = {}
  for idx = 0, 63 do cells[idx] = {assigned=false,color=0x01,label="",block=nil} end

  i = first_block
  while i <= #bytes do
    local block_type = bytes[i]
    local pad_index = bytes[i + 1]
    if block_type == 0x48 and pad_index and pad_index >= 0 and pad_index <= 63
        and i + 9 <= #bytes then
      local block = {}
      for b = 0, 9 do block[#block + 1] = bytes[i + b] end
      cells[pad_index] = {
        assigned = true,
        color = math.max(0, math.min(127, tonumber(bytes[i + 3]) or 0x01)),
        label = "",
        block = block,
      }
      i = i + 10
    elseif block_type == 0x40 and pad_index and pad_index >= 0 and pad_index <= 63 then
      cells[pad_index] = {assigned=false,color=0x01,label="",block=nil}
      i = i + 2
    else
      after_blocks = i
      break
    end
  end
  after_blocks = after_blocks or i

  local labels_rows = nil
  if trim(labels_text or "") ~= "" then
    labels_rows = DAW.CUSTOM_LIBRARY.parse_button_labels_text(labels_text)
  end
  if not labels_rows then labels_rows = DAW.CUSTOM_LIBRARY.empty_label_rows() end
  for row = 1, 8 do
    for col = 1, 8 do
      local idx = ((row - 1) * 8) + (col - 1)
      cells[idx].label = tostring(labels_rows[row][col] or "")
    end
  end

  local prefix, suffix = {}, {}
  for n = 1, first_block - 1 do prefix[#prefix + 1] = bytes[n] end
  for n = after_blocks, #bytes do suffix[#suffix + 1] = bytes[n] end
  return {kind="custom",rows=8,cols=8,cells=cells,prefix=prefix,suffix=suffix}
end

DAW.CUSTOM_LIBRARY.custom_payload_hex_from_model = function(model)
  local bytes = {}
  for _,b in ipairs(model.prefix or {}) do bytes[#bytes + 1] = b end
  for idx = 0, 63 do
    local cell = model.cells and model.cells[idx]
    if cell and cell.assigned and type(cell.block) == "table" then
      local block = {}
      for i = 1, #cell.block do block[i] = cell.block[i] end
      block[1] = 0x48
      block[2] = idx
      block[4] = math.max(0, math.min(127, tonumber(cell.color) or 0x01))
      for _,b in ipairs(block) do bytes[#bytes + 1] = b end
    else
      bytes[#bytes + 1] = 0x40
      bytes[#bytes + 1] = idx
    end
  end
  for _,b in ipairs(model.suffix or {}) do bytes[#bytes + 1] = b end
  return DAW.CUSTOM_LIBRARY.bytes_to_hex(bytes)
end

DAW.CUSTOM_LIBRARY.non_custom_lighting_model_from_hex = function(hex, labels_text)
  local bytes = DAW.CUSTOM_LIBRARY.hex_clean_bytes(hex)
  if #bytes < 8 then return nil, "This Non-Custom row has no SysEx payload to edit." end
  if not (bytes[1] == 0xF0 and bytes[2] == 0x00 and bytes[3] == 0x20 and bytes[4] == 0x29 and bytes[5] == 0x02) then
    return nil, "This Non-Custom payload is not a recognized Novation SysEx message."
  end

  local cmd_index = nil
  for i = 6, math.min(#bytes, 10) do
    if bytes[i] == 0x03 then cmd_index = i; break end
  end
  if not cmd_index then
    return nil, "Only Programmer/Session lighting SysEx payloads can be edited in this first editor version."
  end

  local address_to_cell = {}
  for index = 1, 81 do
    address_to_cell[hex_string_to_byte(Lpxlib.pad_addresses[index])] = index - 1
  end
  local cells = {}
  for idx = 0, 80 do cells[idx] = {assigned=false,color=0x00,label="",lighting_type=0x00} end
  local prefix = {}
  for i = 1, cmd_index do prefix[#prefix + 1] = bytes[i] end
  local cursor = cmd_index + 1
  local suffix_start = nil
  while cursor <= #bytes do
    if bytes[cursor] == 0xF7 then suffix_start = cursor; break end
    local lt, addr = bytes[cursor], bytes[cursor + 1]
    local cell_idx = address_to_cell[addr]
    if not cell_idx then suffix_start = cursor; break end
    if lt == 0x01 and cursor + 3 <= #bytes then
      cells[cell_idx] = {assigned=true,color=math.max(0,math.min(127,bytes[cursor + 3] or 0)),label="",lighting_type=0x01,flash_base=bytes[cursor + 2] or 0x00}
      cursor = cursor + 4
    elseif (lt == 0x00 or lt == 0x02) and cursor + 2 <= #bytes then
      cells[cell_idx] = {assigned=true,color=math.max(0,math.min(127,bytes[cursor + 2] or 0)),label="",lighting_type=lt}
      cursor = cursor + 3
    else
      suffix_start = cursor
      break
    end
  end
  suffix_start = suffix_start or cursor
  local suffix = {}
  for i = suffix_start, #bytes do suffix[#suffix + 1] = bytes[i] end

  -- Non-Custom labels may be absent or may contain only an 8x8 CSV.  If present,
  -- place it in the inner 8x8 area below the top header row.
  local label_rows = nil
  if trim(labels_text or "") ~= "" then label_rows = DAW.CUSTOM_LIBRARY.parse_button_labels_text(labels_text) end
  if label_rows then
    for row = 2, 9 do
      for col = 1, 8 do
        local idx = ((row - 1) * 9) + (col - 1)
        cells[idx].label = tostring(label_rows[row - 1][col] or "")
      end
    end
  end
  return {kind="non_custom",rows=9,cols=9,cells=cells,prefix=prefix,suffix=suffix}
end

DAW.CUSTOM_LIBRARY.non_custom_hex_from_model = function(model)
  local bytes = {}
  for _,b in ipairs(model.prefix or {}) do bytes[#bytes + 1] = b end
  for idx = 0, 80 do
    local cell = model.cells and model.cells[idx]
    if cell and cell.assigned then
      local address = hex_string_to_byte(Lpxlib.pad_addresses[idx + 1])
      local color = math.max(0,math.min(127,tonumber(cell.color) or 0))
      local lighting_type = math.max(0,math.min(2,tonumber(cell.lighting_type) or 0))
      if lighting_type == 0x01 then
        bytes[#bytes + 1] = 0x01
        bytes[#bytes + 1] = address
        bytes[#bytes + 1] = math.max(0,math.min(127,tonumber(cell.flash_base) or 0))
        bytes[#bytes + 1] = color
      else
        bytes[#bytes + 1] = lighting_type
        bytes[#bytes + 1] = address
        bytes[#bytes + 1] = color
      end
    end
  end
  for _,b in ipairs(model.suffix or {0xF7}) do bytes[#bytes + 1] = b end
  return DAW.CUSTOM_LIBRARY.bytes_to_hex(bytes)
end

DAW.CUSTOM_LIBRARY.layout_editor_cell_index = function(row,col)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  return ((row - 1) * editor.cols) + (col - 1)
end

DAW.CUSTOM_LIBRARY.layout_editor_current_entry = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  if not editor.entry_index then return nil end
  return DAW.USER_DATA.ensure_custom_entry(editor.entry_index)
end

DAW.CUSTOM_LIBRARY.layout_editor_ext_key = function(name)
  return "CustomLayoutEditor" .. tostring(name or "")
end

DAW.CUSTOM_LIBRARY.layout_editor_load_number = function(name, fallback)
  local value = tonumber(get_saved_extstate(DAW.CUSTOM_LIBRARY.layout_editor_ext_key(name), ""))
  return value or fallback
end

DAW.CUSTOM_LIBRARY.layout_editor_save_window_rect = function()
  if not r.ImGui_GetWindowPos or not r.ImGui_GetWindowSize then return end
  local x, y = r.ImGui_GetWindowPos(ctx)
  local w, h = r.ImGui_GetWindowSize(ctx)
  if not x or not y or not w or not h then return end
  r.SetExtState(EXTSTATE_SECTION, DAW.CUSTOM_LIBRARY.layout_editor_ext_key("X"), tostring(math.floor(x + 0.5)), true)
  r.SetExtState(EXTSTATE_SECTION, DAW.CUSTOM_LIBRARY.layout_editor_ext_key("Y"), tostring(math.floor(y + 0.5)), true)
  r.SetExtState(EXTSTATE_SECTION, DAW.CUSTOM_LIBRARY.layout_editor_ext_key("W"), tostring(math.floor(w + 0.5)), true)
  r.SetExtState(EXTSTATE_SECTION, DAW.CUSTOM_LIBRARY.layout_editor_ext_key("H"), tostring(math.floor(h + 0.5)), true)
end

DAW.CUSTOM_LIBRARY.layout_editor_first_editable_cell = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local count = (tonumber(editor.rows) or 0) * (tonumber(editor.cols) or 0)
  for idx = 0, count - 1 do
    if editor.cells and editor.cells[idx] then return idx end
  end
  return nil
end

DAW.CUSTOM_LIBRARY.layout_editor_open = function(kind, payload_slot)
  local entry_index = math.max(1, math.floor(tonumber(DAW.CUSTOM_LIBRARY.editor_index) or 1))
  local entry = DAW.USER_DATA.ensure_custom_entry(entry_index)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  editor.visible = true
  editor.kind = kind
  editor.entry_index = entry_index
  editor.payload_slot = payload_slot
  editor.restore_page = current_page
  editor.restore_surface_mode = surface_mode
  editor.drag_source = nil
  editor.drag_target = nil
  editor.selected = nil
  editor.copy_mode = false
  editor.unsupported_reason = nil
  editor.preview_signature = nil

  local model, err
  if kind == "custom" then
    payload_slot = math.max(1, math.min(8, math.floor(tonumber(payload_slot) or 1)))
    editor.payload_slot = payload_slot
    editor.source_hex = tostring(entry.customs[payload_slot] or "")
    editor.source_labels = tostring(entry.custom_labels[payload_slot] or "")
    model, err = DAW.CUSTOM_LIBRARY.custom_payload_model_from_hex(editor.source_hex, editor.source_labels)
  else
    editor.source_hex = tostring(entry.non_custom or "")
    editor.source_labels = tostring(entry.non_custom_labels or "")
    model, err = DAW.CUSTOM_LIBRARY.non_custom_lighting_model_from_hex(editor.source_hex, editor.source_labels)
  end

  if not model then
    editor.unsupported_reason = err or "This payload cannot be edited."
    editor.rows = (kind == "custom") and 8 or 9
    editor.cols = editor.rows
    editor.cells = {}
    return false
  end

  editor.rows = model.rows
  editor.cols = model.cols
  editor.cells = model.cells or {}
  editor.prefix = model.prefix or {}
  editor.suffix = model.suffix or {}
  editor.selected = DAW.CUSTOM_LIBRARY.layout_editor_first_editable_cell()
  if editor.selected and editor.cells[editor.selected] then
    editor.pending_palette = math.max(0, math.min(127, tonumber(editor.cells[editor.selected].color) or 0x01))
  else
    editor.pending_palette = 0x01
  end
  last_action = "Editing " .. (kind == "custom" and ("Custom " .. tostring(payload_slot)) or "Non-Custom layout")
  send_programmer_mode()
  surface_mode = "SYSEX_LAYOUT_EDITOR"
  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_make_model = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  return {
    kind = editor.kind,
    rows = editor.rows,
    cols = editor.cols,
    cells = editor.cells,
    prefix = editor.prefix,
    suffix = editor.suffix,
  }
end

DAW.CUSTOM_LIBRARY.layout_editor_hex = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local model = DAW.CUSTOM_LIBRARY.layout_editor_make_model()
  if editor.kind == "custom" then return DAW.CUSTOM_LIBRARY.custom_payload_hex_from_model(model) end
  return DAW.CUSTOM_LIBRARY.non_custom_hex_from_model(model)
end

DAW.CUSTOM_LIBRARY.layout_editor_labels_text = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  if editor.kind ~= "custom" then return editor.source_labels or "" end
  local rows = {}
  for row = 1, 8 do
    rows[row] = {}
    for col = 1, 8 do
      local idx = ((row - 1) * 8) + (col - 1)
      rows[row][col] = tostring(editor.cells[idx] and editor.cells[idx].label or "")
    end
  end
  return DAW.CUSTOM_LIBRARY.button_labels_to_text(rows)
end

DAW.CUSTOM_LIBRARY.layout_editor_restore = function(reason)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  editor.visible = false
  editor.preview_signature = nil
  surface_mode = (editor.restore_surface_mode and editor.restore_surface_mode ~= "SYSEX_LAYOUT_EDITOR")
    and editor.restore_surface_mode
    or ((editor.restore_page == 2) and "USER_ACTIONS" or ((editor.restore_page == 3) and "USER_CUSTOMS" or "PROGRAMMER"))
  current_page = math.max(1, math.min(3, tonumber(editor.restore_page) or current_page or 3))
  last_hardware_state_signature = nil
  refresh_hardware_state(true)
  last_action = reason or "Closed Custom Layout Editor"
end

DAW.CUSTOM_LIBRARY.layout_editor_save = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local entry = DAW.CUSTOM_LIBRARY.layout_editor_current_entry()
  if not entry then return false end
  local hex = DAW.CUSTOM_LIBRARY.layout_editor_hex()
  if editor.kind == "custom" then
    entry.customs[editor.payload_slot] = hex
    entry.custom_labels[editor.payload_slot] = DAW.CUSTOM_LIBRARY.layout_editor_labels_text()
  else
    entry.non_custom = hex
  end
  DAW.CUSTOM_LIBRARY.payload_visual_cache = {}
  DAW.CUSTOM_LIBRARY.save()
  DAW.CUSTOM_LIBRARY.layout_editor_restore("Saved edited layout")
  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_save_as = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local entry = DAW.CUSTOM_LIBRARY.layout_editor_current_entry()
  if not entry then return false end
  if editor.kind ~= "custom" then
    last_action = "Save As is currently available for Custom rows only"
    return false
  end
  local target_slot = nil
  for slot = 1, 8 do
    if slot ~= tonumber(editor.payload_slot) and trim(entry.customs and entry.customs[slot] or "") == "" then
      target_slot = slot
      break
    end
  end
  if not target_slot then
    last_action = "No empty Custom slot is available for Save As"
    return false
  end
  entry.customs[target_slot] = DAW.CUSTOM_LIBRARY.layout_editor_hex()
  entry.custom_labels[target_slot] = DAW.CUSTOM_LIBRARY.layout_editor_labels_text()
  DAW.CUSTOM_LIBRARY.payload_visual_cache = {}
  DAW.CUSTOM_LIBRARY.save()
  DAW.CUSTOM_LIBRARY.layout_editor_restore("Saved edited layout as Custom " .. tostring(target_slot))
  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_cancel = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor

  if editor and editor.midi_layout_confirm then
    editor.visible = false
    editor.preview_signature = nil
    editor.midi_layout_confirm = false
    editor.midi_layout_dirty = false
    editor.midi_layout_map_result = nil
    editor.midi_layout_slot = nil

    DAW.MIDI_LAYOUT_BUILDER.pending_map_result = nil
    DAW.MIDI_LAYOUT_BUILDER.pending_layout_slot = nil

    return_to_home_page_1(
      "Canceled MIDI layout confirmation: returned to HOME Page 1",
      false
    )

    return true
  end

  DAW.CUSTOM_LIBRARY.layout_editor_restore("Canceled layout edit")
  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_clear_selected = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local idx = tonumber(editor.selected)
  if not idx or not editor.cells[idx] then return false end

  editor.cells[idx] = {
    assigned = false,
    color = 0x00,
    label = "",
    note = nil,
    block = nil,
  }

  editor.preview_signature = nil

  if DAW.MIDI_LAYOUT_BUILDER and DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty then
    DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty()
  end

  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_apply_color = function(palette)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local idx = tonumber(editor.selected)
  if not idx or not editor.cells[idx] then return false end

  editor.cells[idx].color = math.max(0, math.min(127, tonumber(palette) or 0))

  if editor.kind == "non_custom" then
    editor.cells[idx].assigned = true
  end

  editor.preview_signature = nil

  if DAW.MIDI_LAYOUT_BUILDER and DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty then
    DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty()
  end

  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_swap_or_copy = function(source, target, copy_mode)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  source, target = tonumber(source), tonumber(target)

  if not source or not target or source == target then return false end
  if not editor.cells[source] or not editor.cells[target] then return false end

  if copy_mode then
    editor.cells[target] = DAW.CUSTOM_LIBRARY.copy_cell(editor.cells[source])
  else
    editor.cells[source], editor.cells[target] = editor.cells[target], editor.cells[source]
  end

  editor.selected = target
  editor.preview_signature = nil

  if DAW.MIDI_LAYOUT_BUILDER and DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty then
    DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty()
  else
    DAW.CUSTOM_LIBRARY.layout_editor_send_preview(true)
  end

  return true
end

DAW.CUSTOM_LIBRARY.layout_editor_shift_down = function()
  if r.ImGui_GetKeyMods and r.ImGui_Mod_Shift then
    local ok, mods = pcall(r.ImGui_GetKeyMods, ctx)
    local ok2, shift = pcall(r.ImGui_Mod_Shift)
    if ok and ok2 and mods and shift then return (mods & shift) ~= 0 end
  end
  return false
end

DAW.CUSTOM_LIBRARY.layout_editor_send_preview = function(force)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  -- MIDI Layout confirmation mode:
  -- Before any GUI edit, the Launchpad should show only Cancel/OK.
  -- After a GUI edit, it should mirror the edited layout.
  if editor.midi_layout_confirm and not editor.midi_layout_dirty then
    local bytes = {0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x03}
  
    -- Clear the visible 9x9 surface.
    for index, address_hex in pairs(Lpxlib.pad_addresses or {}) do
      DAW.append_palette_colourspec(
        bytes,
        0x00,
        hex_string_to_byte(address_hex),
        0,
        0x00
      )
    end
  
    local cancel_pad = DAW.MIDI_LAYOUT_BUILDER.EDITOR_CONFIRM_CANCEL_PAD
    local ok_pad = DAW.MIDI_LAYOUT_BUILDER.EDITOR_CONFIRM_OK_PAD
  
    local cancel_index =
      DAW.MIDI_LAYOUT_BUILDER.index_for_row_col(cancel_pad.row, cancel_pad.col)
  
    local ok_index =
      DAW.MIDI_LAYOUT_BUILDER.index_for_row_col(ok_pad.row, ok_pad.col)
  
    DAW.append_palette_colourspec(
      bytes,
      0x00,
      hex_string_to_byte(Lpxlib.pad_addresses[cancel_index]),
      cancel_pad.color,
      0x00
    )
  
    DAW.append_palette_colourspec(
      bytes,
      0x00,
      hex_string_to_byte(Lpxlib.pad_addresses[ok_index]),
      ok_pad.color,
      0x00
    )
  
    bytes[#bytes + 1] = 0xF7
    editor.preview_signature = "midi_layout_confirm_clean"
    return send_bytes(bytes)
  end
  if not editor.visible or editor.unsupported_reason then return false end
  local parts = {editor.kind or "", tostring(editor.rows), tostring(editor.cols)}
  for idx = 0, (editor.rows * editor.cols) - 1 do
    local c = editor.cells[idx] or {}
    parts[#parts + 1] = tostring(idx)..":"..tostring(c.assigned and 1 or 0)..":"..tostring(c.color or 0)
  end
  local signature = table.concat(parts,"|")
  if not force and signature == editor.preview_signature then return false end
  editor.preview_signature = signature

  local bytes = {0xF0,0x00,0x20,0x29,0x02,selected_device.id,0x03}
  for row = 1, editor.rows do
    for col = 1, editor.cols do
      local idx = ((row - 1) * editor.cols) + (col - 1)
      local address_index
      if editor.kind == "custom" then
        address_index = ((row) * 9) + col -- Custom 8x8 previews inside HOME inner surface rows 2-9, cols 1-8.
      else
        address_index = ((row - 1) * 9) + col
      end
      local cell = editor.cells[idx] or {}
      local color = (cell.assigned ~= false) and math.max(0,math.min(127,tonumber(cell.color) or 0)) or 0x00
      DAW.append_palette_colourspec(
        bytes,
        0x00,
        hex_string_to_byte(Lpxlib.pad_addresses[address_index]),
        color,
        0x00
      )
    end
  end

  bytes[#bytes + 1] = 0xF7
  return send_bytes(bytes)
end

DAW.CUSTOM_LIBRARY.layout_editor_draw_cell = function(row,col,cell_size)
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  local idx = DAW.CUSTOM_LIBRARY.layout_editor_cell_index(row,col)
  local cell = editor.cells[idx] or {assigned=false,color=0,label=""}
  local bg = cell.assigned == false and 0x151515FF or DAW.USER_PAGES.palette_gui(cell.color or 0)
  local selected = tonumber(editor.selected) == idx
  local drag_source = tonumber(editor.drag_source) == idx
  local draw_list = r.ImGui_GetWindowDrawList(ctx)
  local x,y = r.ImGui_GetCursorScreenPos(ctx)
  local clicked = false
  if r.ImGui_InvisibleButton then
    clicked = r.ImGui_InvisibleButton(ctx,"##layout_edit_cell_"..tostring(idx),cell_size,cell_size)
  else
    clicked = r.ImGui_Button(ctx,"##layout_edit_cell_"..tostring(idx),cell_size,cell_size)
  end
  r.ImGui_DrawList_AddRectFilled(draw_list,x,y,x+cell_size,y+cell_size,bg,6)
  local border = selected and 0xFFFFFFFF or (drag_source and 0x20BFAFFF or 0x000000FF)
  r.ImGui_DrawList_AddRect(draw_list,x,y,x+cell_size,y+cell_size,border,6,0,selected and 3 or 1)
  local label = tostring(cell.label or "")
  if label == "" and cell.assigned == false then label = "—" end
  local text_col = readable_text_color(bg)
  if cell.assigned == false then text_col = 0xA0A0A0FF end
  local tx = x + 5
  local ty = y + 7
  for line in (label.."\n"):gmatch("(.-)\n") do
    if line ~= "" then
      r.ImGui_DrawList_AddText(draw_list,tx,ty,text_col,line:sub(1,14))
      ty = ty + 14
    end
  end

  if clicked then
    editor.selected = idx
    editor.pending_palette = math.max(0,math.min(127,tonumber(cell.color) or 0x01))
  end
  if r.ImGui_IsItemActive(ctx) and r.ImGui_IsMouseDragging(ctx,0,4) and not editor.drag_source then
    editor.drag_source = idx
  end
  if DAW.GUI.mouse_is_over_last_item() then editor.drag_target = idx end
  return clicked
end

DAW.CUSTOM_LIBRARY.draw_layout_editor_window = function()
  local editor = DAW.CUSTOM_LIBRARY.layout_editor
  if not editor.visible then return false end
  local remembered_x = DAW.CUSTOM_LIBRARY.layout_editor_load_number("X", nil)
  local remembered_y = DAW.CUSTOM_LIBRARY.layout_editor_load_number("Y", nil)
  local remembered_w = DAW.CUSTOM_LIBRARY.layout_editor_load_number("W", 670)
  local remembered_h = DAW.CUSTOM_LIBRARY.layout_editor_load_number("H", 80)
  if remembered_x and remembered_y and r.ImGui_SetNextWindowPos then
    r.ImGui_SetNextWindowPos(ctx, remembered_x, remembered_y, r.ImGui_Cond_FirstUseEver())
  end
 r.ImGui_SetNextWindowSize(ctx, 625, 807, r.ImGui_Cond_Always())
  DAW.GUI.force_next_window_opaque()
  local title = editor.kind == "custom"
    and ("Custom Layout Editor — Entry " .. tostring(editor.entry_index) .. ", Custom " .. tostring(editor.payload_slot))
    or ("Non-Custom Layout Editor — Entry " .. tostring(editor.entry_index))
  local visible, open_window = r.ImGui_Begin(ctx,title,true,r.ImGui_WindowFlags_NoCollapse())
    if visible == nil then return true end
    if visible then
    DAW.CUSTOM_LIBRARY.layout_editor_save_window_rect()
    if editor.unsupported_reason then
      r.ImGui_Text(ctx,"This payload is not editable yet.")
      r.ImGui_TextWrapped(ctx,tostring(editor.unsupported_reason))
      if r.ImGui_Button(ctx,"Close") then DAW.CUSTOM_LIBRARY.layout_editor_cancel() end
    else
      r.ImGui_Text(ctx,"Editor owns the Launchpad preview until Save or Cancel. Drag swaps pads; Shift-drag or Copy Mode duplicates.")
      if editor.kind == "custom" then
        r.ImGui_Text(ctx,"Custom global settings and transposition bytes are preserved exactly; only the 8x8 pad blocks and labels are edited.")
      end
      local selected = tonumber(editor.selected)
      if selected and editor.cells[selected] then
        local cell = editor.cells[selected]
        r.ImGui_Separator(ctx)
        local available_w = 760
        if r.ImGui_GetContentRegionAvail then
          available_w = select(1, r.ImGui_GetContentRegionAvail(ctx)) or available_w
        end
        local label_w = (editor.kind == "custom") and 146 or 0
        local left_w = math.max(420, available_w - label_w - 16)
        local top_h = 66

        if DAW.GUI.begin_child("##layout_editor_top_left", left_w, top_h, 0) then
          r.ImGui_Text(ctx,"Selected pad: row "..tostring(math.floor(selected/editor.cols)+1)..", column "..tostring((selected%editor.cols)+1))
          if DAW.GUI.draw_palette_swatch(cell.color or 0,"layout_editor_selected",28,24) then
            DAW.CUSTOM_LIBRARY.open_palette_picker("layout_editor")
          end
          r.ImGui_SameLine(ctx)
          r.ImGui_Text(ctx,"Palette")
          r.ImGui_SameLine(ctx)
          r.ImGui_SetNextItemWidth(ctx,76)
          local changed_color, new_color = r.ImGui_InputInt(ctx,"##layout_editor_palette",math.max(0,math.min(127,tonumber(cell.color) or 0)),1,10)
          if changed_color then DAW.CUSTOM_LIBRARY.layout_editor_apply_color(new_color) end
          r.ImGui_SameLine(ctx)
          r.ImGui_Text(ctx,"click square to choose")
        end
        r.ImGui_EndChild(ctx)

        if editor.kind == "custom" then
          r.ImGui_SameLine(ctx,nil,10)
          if DAW.GUI.begin_child("##layout_editor_label_area", label_w, top_h, 0) then
            r.ImGui_Text(ctx,"Label")
            r.ImGui_SameLine(ctx)
            r.ImGui_SetNextItemWidth(ctx,label_w - 54)
            local changed_label, new_label = r.ImGui_InputTextMultiline(ctx,"##layout_editor_pad_label",tostring(cell.label or ""),label_w - 54,58)
            if changed_label then
              cell.label = new_label
              editor.preview_signature = nil
              if DAW.MIDI_LAYOUT_BUILDER and DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty then
                DAW.MIDI_LAYOUT_BUILDER.mark_editor_dirty()
              end
            end
          end
          r.ImGui_EndChild(ctx)
        end

        if DAW.GUI.begin_child("##layout_editor_action_row", available_w, 36, 0) then
          local changed_copy, copy_val = r.ImGui_Checkbox(ctx,"Copy Mode##layout_editor_copy",editor.copy_mode)
          if changed_copy then editor.copy_mode = copy_val and true or false end
        
          r.ImGui_SameLine(ctx)
        
          if r.ImGui_Button(ctx,"Clear Selected") then
            DAW.CUSTOM_LIBRARY.layout_editor_clear_selected()
          end
        
          r.ImGui_SameLine(ctx)
        
          if editor.midi_layout_confirm then
            DAW.MIDI_LAYOUT_BUILDER.draw_editor_confirm_buttons()
          else
            if r.ImGui_Button(ctx,"Save") then DAW.CUSTOM_LIBRARY.layout_editor_save() end
            r.ImGui_SameLine(ctx)
            if r.ImGui_Button(ctx,"Save As") then DAW.CUSTOM_LIBRARY.layout_editor_save_as() end
            r.ImGui_SameLine(ctx)
            if r.ImGui_Button(ctx,"Cancel") then DAW.CUSTOM_LIBRARY.layout_editor_cancel() end
          end
        end
        
        r.ImGui_EndChild(ctx)
        else
          r.ImGui_Separator(ctx)
          r.ImGui_Text(ctx,"Select a pad to edit its label, color, copy mode, or clear it.")
          r.ImGui_SameLine(ctx,nil,18)
        
          if editor.midi_layout_confirm then
            DAW.MIDI_LAYOUT_BUILDER.draw_editor_confirm_buttons()
          else
            if r.ImGui_Button(ctx,"Save") then DAW.CUSTOM_LIBRARY.layout_editor_save() end
            r.ImGui_SameLine(ctx)
            if r.ImGui_Button(ctx,"Save As") then DAW.CUSTOM_LIBRARY.layout_editor_save_as() end
            r.ImGui_SameLine(ctx)
            if r.ImGui_Button(ctx,"Cancel") then DAW.CUSTOM_LIBRARY.layout_editor_cancel() end
          end
        end

      r.ImGui_Separator(ctx)
      local cell_size = editor.kind == "custom" and 72 or 62
      for row = 1, editor.rows do
        for col = 1, editor.cols do
          DAW.CUSTOM_LIBRARY.layout_editor_draw_cell(row,col,cell_size)
          if col < editor.cols then r.ImGui_SameLine(ctx,nil,4) end
        end
      end
      if editor.drag_source and not r.ImGui_IsMouseDown(ctx,0) then
        local target = editor.drag_target
        local copy_mode = editor.copy_mode or DAW.CUSTOM_LIBRARY.layout_editor_shift_down()
        DAW.CUSTOM_LIBRARY.layout_editor_swap_or_copy(editor.drag_source,target,copy_mode)
        editor.drag_source = nil
        editor.drag_target = nil
      end
      DAW.CUSTOM_LIBRARY.layout_editor_send_preview(false)
    end
  end
  if DAW.MIDI_LAYOUT_BUILDER and DAW.MIDI_LAYOUT_BUILDER.draw_toast then
    DAW.MIDI_LAYOUT_BUILDER.draw_toast()
  end
  r.ImGui_End(ctx)
  if not open_window and editor.visible then DAW.CUSTOM_LIBRARY.layout_editor_cancel() end
  return true
end

DAW.CUSTOM_LIBRARY.draw_palette_picker_window = function()
  if not DAW.CUSTOM_LIBRARY.palette_picker_visible then return false end
  r.ImGui_SetNextWindowSize(ctx,343,740,r.ImGui_Cond_Always())
  DAW.GUI.force_next_window_opaque()
  local visible,open_window=r.ImGui_Begin(ctx,"Launchpad Xtra SysEx Palette",true,r.ImGui_WindowFlags_NoCollapse())
    if visible == nil then return true end
    if visible then
    r.ImGui_Text(
      ctx,
      DAW.CUSTOM_LIBRARY.palette_picker_target=="scroll"
        and "Choose scrolling-text palette color"
        or (DAW.CUSTOM_LIBRARY.palette_picker_target=="layout_editor"
          and "Choose selected pad palette color"
          or "Choose selected Customs-slot palette color")
    )
    r.ImGui_Text(ctx,"Click a chart color, then choose SET or CANCEL.")
    DAW.CUSTOM_LIBRARY.pending_palette_color=
      DAW.GUI.draw_palette_chart(DAW.CUSTOM_LIBRARY.pending_palette_color)
    r.ImGui_Text(ctx,"Selected palette index: "..tostring(DAW.CUSTOM_LIBRARY.pending_palette_color))
    DAW.GUI.draw_palette_swatch(DAW.CUSTOM_LIBRARY.pending_palette_color,"custom_palette_pending",120,21)
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"SET##custom_palette") then
      DAW.CUSTOM_LIBRARY.apply_palette_picker()
      DAW.CUSTOM_LIBRARY.palette_picker_visible=false
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"CANCEL##custom_palette") then
      DAW.CUSTOM_LIBRARY.palette_picker_visible=false
    end
  end
  r.ImGui_End(ctx)
  if not open_window then DAW.CUSTOM_LIBRARY.palette_picker_visible=false end
  return true
end

DAW.CUSTOM_LIBRARY.set_editor_color = function(palette)
  local entry=DAW.USER_DATA.ensure_custom_entry(DAW.CUSTOM_LIBRARY.editor_index)
  entry.color=math.max(0,math.min(127,tonumber(palette) or 0x25))
  DAW.CUSTOM_LIBRARY.save()
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
end

DAW.CUSTOM_LIBRARY.register_swap_item = function(index)
  index=tonumber(index)
  if not index then return end

  local hovered=DAW.GUI.mouse_is_over_last_item()
  if hovered then
    DAW.CUSTOM_LIBRARY.hovered_swap_index=index
    if DAW.CUSTOM_LIBRARY.drag_index and index~=DAW.CUSTOM_LIBRARY.drag_index then
      DAW.CUSTOM_LIBRARY.drag_target=index
      DAW.CUSTOM_LIBRARY.last_valid_drop_index=index
    end
  end

  if r.ImGui_IsItemActive(ctx) and r.ImGui_IsMouseDragging(ctx,0,4) then
    if not DAW.CUSTOM_LIBRARY.drag_index then
      DAW.CUSTOM_LIBRARY.drag_index=index
      DAW.CUSTOM_LIBRARY.drag_target=nil
      DAW.CUSTOM_LIBRARY.last_valid_drop_index=nil
    end
  end
end

DAW.CUSTOM_LIBRARY.swap_entries = function(a,b)
  a,b=tonumber(a),tonumber(b)
  if not a or not b or a==b then return false end
  local entries=DAW.CUSTOM_LIBRARY.data.entries
  DAW.USER_DATA.ensure_custom_entry(math.max(a,b))
  if not entries[a] or not entries[b] then return false end
  entries[a],entries[b]=entries[b],entries[a]
  DAW.CUSTOM_LIBRARY.remap_resident_source_entries_after_swap(a,b)
  if DAW.CUSTOM_LIBRARY.editor_index==a then
    DAW.CUSTOM_LIBRARY.editor_index=b
  elseif DAW.CUSTOM_LIBRARY.editor_index==b then
    DAW.CUSTOM_LIBRARY.editor_index=a
  end
  DAW.CUSTOM_LIBRARY.scroll_to_editor_index=DAW.CUSTOM_LIBRARY.editor_index
  DAW.CUSTOM_LIBRARY.save()
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return true
end

DAW.CUSTOM_LIBRARY.delete_entry = function(index)
  index=math.max(1,math.floor(tonumber(index) or 1))
  local entries=DAW.CUSTOM_LIBRARY.data.entries
  if not entries[index] then return false end
  table.remove(entries,index)
  DAW.CUSTOM_LIBRARY.remap_resident_source_entries_after_delete(index)
  DAW.CUSTOM_LIBRARY.editor_index=math.max(
    1,
    math.min(DAW.CUSTOM_LIBRARY.editor_index,#entries>0 and #entries or 1)
  )
  DAW.CUSTOM_LIBRARY.scroll_to_editor_index=DAW.CUSTOM_LIBRARY.editor_index
  DAW.CUSTOM_LIBRARY.save()
  last_hardware_state_signature=nil
  refresh_hardware_state(true)
  return true
end

DAW.CUSTOM_LIBRARY.finish_drag_swap = function()
  if DAW.CUSTOM_LIBRARY.drag_index and not r.ImGui_IsMouseDown(ctx,0) then
    DAW.CUSTOM_LIBRARY.swap_entries(
      DAW.CUSTOM_LIBRARY.drag_index,
      DAW.CUSTOM_LIBRARY.drag_target
        or DAW.CUSTOM_LIBRARY.last_valid_drop_index
        or DAW.CUSTOM_LIBRARY.hovered_swap_index
    )
    DAW.CUSTOM_LIBRARY.drag_index=nil
    DAW.CUSTOM_LIBRARY.drag_target=nil
    DAW.CUSTOM_LIBRARY.hovered_swap_index=nil
    DAW.CUSTOM_LIBRARY.last_valid_drop_index=nil
  end
end

DAW.CUSTOM_LIBRARY.apply_selected_row_background = function(index)
  if not DAW.CUSTOM_LIBRARY.selection_active then return end
  if tonumber(index) ~= tonumber(DAW.CUSTOM_LIBRARY.editor_index) then return end
  if not (r.ImGui_TableSetBgColor and r.ImGui_TableBgTarget_RowBg0) then return end
  pcall(r.ImGui_TableSetBgColor,ctx,r.ImGui_TableBgTarget_RowBg0(),0x205F5FFF)
end

DAW.CUSTOM_LIBRARY.draw_page_swatches = function()
  r.ImGui_Text(ctx,"40 Visible Slot Colors:")
  for offset=0,39 do
    local index=DAW.USER_PAGES.starts[3]+offset
    local entry=DAW.CUSTOM_LIBRARY.data.entries[index]
    local palette=DAW.CUSTOM_LIBRARY.display_color(entry)
    local clicked=DAW.GUI.draw_palette_swatch(palette,"custom_bank_"..tostring(index),18,18)
    DAW.CUSTOM_LIBRARY.register_swap_item(index)
    if clicked and not DAW.CUSTOM_LIBRARY.drag_index and entry then
      DAW.CUSTOM_LIBRARY.set_editor_color(palette)
    end
    if (offset%5)~=4 then r.ImGui_SameLine(ctx) end
  end
end

DAW.CUSTOM_LIBRARY.register_destination_swap_item = function(index)
  index = tonumber(index)
  if not index then return end
  local hovered = DAW.GUI.mouse_is_over_last_item()
  if hovered then
    DAW.CUSTOM_LIBRARY.destination_hovered_index = index
    if DAW.CUSTOM_LIBRARY.destination_drag_index
        and index ~= DAW.CUSTOM_LIBRARY.destination_drag_index then
      DAW.CUSTOM_LIBRARY.destination_drag_target = index
      DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index = index
    end
  end
  if r.ImGui_IsItemActive(ctx) and r.ImGui_IsMouseDragging(ctx,0,4) then
    if not DAW.CUSTOM_LIBRARY.destination_drag_index then
      DAW.CUSTOM_LIBRARY.destination_drag_index = index
      DAW.CUSTOM_LIBRARY.destination_drag_target = nil
      DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index = nil
    end
  end
end

DAW.CUSTOM_LIBRARY.swap_destination_slots = function(a,b)
  a,b = tonumber(a),tonumber(b)
  if not a or not b or a == b or a < 1 or a > 8 or b < 1 or b > 8 then return false end
  local entry_index = math.max(1, math.floor(tonumber(DAW.CUSTOM_LIBRARY.editor_index) or 1))
  local entry = DAW.USER_DATA.ensure_custom_entry(entry_index)
  entry.customs[a],entry.customs[b] = entry.customs[b],entry.customs[a]
  entry.custom_labels[a],entry.custom_labels[b] = entry.custom_labels[b],entry.custom_labels[a]
  DAW.CUSTOM_LIBRARY.remap_resident_source_payloads_after_swap(entry_index,a,b)
  local key_a = "custom_"..tostring(entry_index).."_"..tostring(a)
  local key_b = "custom_"..tostring(entry_index).."_"..tostring(b)
  DAW.CUSTOM_LIBRARY.field_heights[key_a],DAW.CUSTOM_LIBRARY.field_heights[key_b] =
    DAW.CUSTOM_LIBRARY.field_heights[key_b],DAW.CUSTOM_LIBRARY.field_heights[key_a]
  DAW.CUSTOM_LIBRARY.field_resize_active_key = nil
  DAW.CUSTOM_LIBRARY.save()
  return true
end

DAW.CUSTOM_LIBRARY.finish_destination_drag_swap = function()
  if DAW.CUSTOM_LIBRARY.destination_drag_index and not r.ImGui_IsMouseDown(ctx,0) then
    DAW.CUSTOM_LIBRARY.swap_destination_slots(
      DAW.CUSTOM_LIBRARY.destination_drag_index,
      DAW.CUSTOM_LIBRARY.destination_drag_target
        or DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index
        or DAW.CUSTOM_LIBRARY.destination_hovered_index
    )
    DAW.CUSTOM_LIBRARY.destination_drag_index = nil
    DAW.CUSTOM_LIBRARY.destination_drag_target = nil
    DAW.CUSTOM_LIBRARY.destination_hovered_index = nil
    DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index = nil
  end
end

DAW.CUSTOM_LIBRARY.draw_destination_drag_status = function()
  local source = tonumber(DAW.CUSTOM_LIBRARY.destination_drag_index)
  if not source then return false end
  local target = tonumber(DAW.CUSTOM_LIBRARY.destination_drag_target)
    or tonumber(DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index)
    or tonumber(DAW.CUSTOM_LIBRARY.destination_hovered_index)
  local message = "DRAGGING CUSTOM " .. tostring(source)
    .. (target and ("  ->  " .. tostring(target)) or "  ->  drop on another number")
  -- Keep the table snug beneath its heading.  During a drag the source and
  -- target buttons still change colour, while this tooltip supplies the live
  -- text cue without reserving a blank line in the normal layout.
  if r.ImGui_SetTooltip then
    r.ImGui_SetTooltip(ctx,message)
  end
  return true
end

DAW.CUSTOM_LIBRARY.schedule_home_lighting_after_programmer = function(page, reason, delay_seconds)
  page = math.max(1, math.min(3, math.floor(tonumber(page) or current_page or 1)))
  DAW.CUSTOM_LIBRARY.pending_home_resend_page = page
  DAW.CUSTOM_LIBRARY.pending_home_resend_count = 0
  DAW.CUSTOM_LIBRARY.pending_home_resend_stage = "clear"
  DAW.CUSTOM_LIBRARY.pending_home_resend_row = 1
  DAW.CUSTOM_LIBRARY.pending_home_resend_time = r.time_precise()
    + (tonumber(delay_seconds) or CFG.HOME_AFTER_PROGRAMMER_SETTLE_SECONDS or 0.20)
  DAW.CUSTOM_LIBRARY.pending_home_resend_reason = reason
  last_hardware_state_signature = nil
  return true
end

DAW.CUSTOM_LIBRARY.cancel_pending_home_repaint = function()
  DAW.CUSTOM_LIBRARY.pending_home_resend_time = nil
  DAW.CUSTOM_LIBRARY.pending_home_resend_count = 0
  DAW.CUSTOM_LIBRARY.pending_home_resend_page = nil
  DAW.CUSTOM_LIBRARY.pending_home_resend_reason = nil
  DAW.CUSTOM_LIBRARY.pending_home_resend_stage = nil
  DAW.CUSTOM_LIBRARY.pending_home_resend_row = nil
  return true
end

DAW.CUSTOM_LIBRARY.cancel_pending_post_upload_home_recovery = function()
  DAW.CUSTOM_LIBRARY.pending_post_upload_home_time = nil
  DAW.CUSTOM_LIBRARY.pending_post_upload_home_page = nil
  DAW.CUSTOM_LIBRARY.pending_post_upload_home_reason = nil
  return true
end

DAW.CUSTOM_LIBRARY.schedule_home_recovery_after_custom_upload = function(page, reason, delay_seconds)
  page = math.max(1, math.min(3, math.floor(tonumber(page) or current_page or 1)))
  DAW.CUSTOM_LIBRARY.pending_post_upload_home_page = page
  DAW.CUSTOM_LIBRARY.pending_post_upload_home_reason = reason
  DAW.CUSTOM_LIBRARY.pending_post_upload_home_time = r.time_precise()
    + (tonumber(delay_seconds) or CFG.CUSTOM_UPLOAD_HOME_RECOVERY_DELAY_SECONDS or 1.00)
  last_action = "Uploaded Custom payloads; restoring HOME Page "
    .. tostring(page) .. " after the Launchpad finishes storing them"
  return true
end

DAW.CUSTOM_LIBRARY.process_pending_post_upload_home_recovery = function(now)
  local due = DAW.CUSTOM_LIBRARY.pending_post_upload_home_time
  if not due or now < due then return false end

  -- Respect an intentional on-screen page change made during the one-second
  -- storage pause.  Whichever HOME page is current when recovery begins is the
  -- one the user should see after the staged redraw completes.
  local page = math.max(1, math.min(3, math.floor(tonumber(current_page)
    or tonumber(DAW.CUSTOM_LIBRARY.pending_post_upload_home_page) or 1)))
  local reason = DAW.CUSTOM_LIBRARY.pending_post_upload_home_reason
    or ("SysEx & Customs Library: restored HOME Page " .. tostring(page)
      .. " after Custom upload")
  DAW.CUSTOM_LIBRARY.cancel_pending_post_upload_home_recovery()

  return_to_home_page_1(reason, false, page, true)
  return true
end

DAW.CUSTOM_LIBRARY.go_home = function()
  DAW.CUSTOM_LIBRARY.cancel_pending_post_upload_home_recovery()
  -- Direct Session / Note / Custom testing can leave the Launchpad outside the
  -- scripted HOME surface. Request Programmer Mode now, then use the same
  -- staged recovery path as Notes-mode and Sleep wakeups.
  if not send_programmer_mode() then return false end
  surface_mode = (current_page == 2) and "USER_ACTIONS"
    or ((current_page == 3) and "USER_CUSTOMS" or "PROGRAMMER")
  DAW.CUSTOM_LIBRARY.schedule_home_lighting_after_programmer(
    current_page,
    "SysEx & Customs Library: restored HOME Page " .. tostring(current_page)
  )
  last_action = "SysEx & Customs Library: requested Programmer Mode; rebuilding HOME in staged passes"
  return true
end

DAW.CUSTOM_LIBRARY.process_pending_home_resend = function(now)
  if not DAW.CUSTOM_LIBRARY.pending_home_resend_time
      or now < DAW.CUSTOM_LIBRARY.pending_home_resend_time then
    return false
  end

  local page = tonumber(DAW.CUSTOM_LIBRARY.pending_home_resend_page) or current_page

  -- Do not let a stale recovery repaint overwrite a different surface. Page
  -- changes made during recovery reschedule the staged pass in set_page().
  if current_page ~= page or not DAW.programmer_surface_is_active() then
    DAW.CUSTOM_LIBRARY.cancel_pending_home_repaint()
    return false
  end

  local stage = DAW.CUSTOM_LIBRARY.pending_home_resend_stage or "clear"
  if stage == "clear" then
    send_clear_lighting(true)
    DAW.CUSTOM_LIBRARY.pending_home_resend_stage = "rows"
    DAW.CUSTOM_LIBRARY.pending_home_resend_row = 1
    DAW.CUSTOM_LIBRARY.pending_home_resend_time = now
      + (CFG.HOME_REPAINT_CLEAR_GAP_SECONDS or 0.04)
  elseif stage == "rows" then
    local row = math.max(1, math.min(9, tonumber(DAW.CUSTOM_LIBRARY.pending_home_resend_row) or 1))
    send_page_lighting_range(page, ((row - 1) * 9) + 1, row * 9)
    if row < 9 then
      DAW.CUSTOM_LIBRARY.pending_home_resend_row = row + 1
      DAW.CUSTOM_LIBRARY.pending_home_resend_time = now
        + (CFG.HOME_REPAINT_ROW_GAP_SECONDS or 0.015)
    else
      DAW.CUSTOM_LIBRARY.pending_home_resend_stage = "full"
      DAW.CUSTOM_LIBRARY.pending_home_resend_time = now
        + (CFG.HOME_REPAINT_FINAL_GAP_SECONDS or 0.08)
    end
  elseif stage == "full" then
    send_page_lighting(page,true)
    DAW.CUSTOM_LIBRARY.pending_home_resend_stage = "insurance"
    DAW.CUSTOM_LIBRARY.pending_home_resend_time = now
      + (CFG.HOME_AFTER_PROGRAMMER_INSURANCE_SECONDS or 0.18)
  else
    send_page_lighting(page,true)
    local reason = DAW.CUSTOM_LIBRARY.pending_home_resend_reason
      or ("Restored HOME Page " .. tostring(page))
    DAW.CUSTOM_LIBRARY.cancel_pending_home_repaint()
    last_action = reason
  end
  return true
end

DAW.CUSTOM_LIBRARY.draw_table = function()
  local entries=DAW.CUSTOM_LIBRARY.data.entries
  if not (r.ImGui_BeginTable and r.ImGui_TableSetupColumn and r.ImGui_TableHeadersRow
      and r.ImGui_TableNextRow and r.ImGui_TableSetColumnIndex) then
    r.ImGui_Text(ctx,"This ReaImGui build does not provide table widgets.")
    return
  end

  local delete_index=nil
  if r.ImGui_BeginTable(ctx,"##custom_library_table",16,DAW.GUI.table_flags(),0,0) then
    local fixed=DAW.GUI.table_fixed_column_flag()
    local names={"#","Send","Name","Button Label","Switch To","Non-Custom","C1","C2","C3","C4","C5","C6","C7","C8","Color","-"}
    local widths={27,35,240,110,52,50,50,50,50,50,50,50,50,50,21,14}
    for index,name in ipairs(names) do
      r.ImGui_TableSetupColumn(ctx,name,fixed,widths[index])
    end
    r.ImGui_TableHeadersRow(ctx)
    DAW.CUSTOM_LIBRARY.hovered_swap_index=nil

    for index,row_entry in ipairs(entries) do
      DAW.USER_DATA.ensure_custom_entry(index)
      if ((index-1)%40)==0 then
        r.ImGui_TableNextRow(ctx)
        r.ImGui_TableSetColumnIndex(ctx,2)
        r.ImGui_Text(ctx,"Bank "..tostring(math.floor((index-1)/40)+1)
          .." — Slots "..tostring(index).."-"..tostring(index+39))
      end

      r.ImGui_TableNextRow(ctx)
      DAW.CUSTOM_LIBRARY.apply_selected_row_background(index)

      r.ImGui_TableSetColumnIndex(ctx,0)
      local selected=r.ImGui_Button(ctx,string.format("%03d",index).."##custom_index_"..tostring(index))
      if selected then DAW.CUSTOM_LIBRARY.select_editor_index(index,false) end
      DAW.CUSTOM_LIBRARY.register_swap_item(index)
      if tonumber(DAW.CUSTOM_LIBRARY.scroll_to_editor_index)==tonumber(index)
          and r.ImGui_SetScrollHereY then
        r.ImGui_SetScrollHereY(ctx,0.45)
        DAW.CUSTOM_LIBRARY.scroll_to_editor_index=nil
      end

      r.ImGui_TableSetColumnIndex(ctx,1)
      if r.ImGui_Button(ctx,"Send##custom_send_"..tostring(index)) then
        DAW.CUSTOM_LIBRARY.execute_entry(index)
      end

      r.ImGui_TableSetColumnIndex(ctx,2)
      r.ImGui_Text(ctx,DAW.GUI.clip_text(row_entry.name,42))
      r.ImGui_TableSetColumnIndex(ctx,3)
      r.ImGui_Text(ctx,DAW.GUI.clip_text(DAW.GUI.single_line_text(row_entry.label),36))
      r.ImGui_TableSetColumnIndex(ctx,4)
      r.ImGui_Text(ctx,tostring(math.max(0,math.min(8,tonumber(row_entry.switch_to_slot) or 0))))
      r.ImGui_TableSetColumnIndex(ctx,5)
      r.ImGui_Text(ctx,DAW.GUI.clip_text(row_entry.non_custom,10))
      for slot=1,8 do
        r.ImGui_TableSetColumnIndex(ctx,5+slot)
        r.ImGui_Text(ctx,DAW.GUI.clip_text(row_entry.customs[slot],10))
      end
      r.ImGui_TableSetColumnIndex(ctx,14)
      DAW.GUI.draw_palette_swatch(DAW.CUSTOM_LIBRARY.display_color(row_entry),"custom_row_"..tostring(index),20,20)
      DAW.CUSTOM_LIBRARY.register_swap_item(index)
      r.ImGui_TableSetColumnIndex(ctx,15)
      if r.ImGui_Button(ctx,"-##custom_delete_"..tostring(index)) then
        delete_index=index
      end
    end

    if DAW.CUSTOM_LIBRARY.drag_index and DAW.CUSTOM_LIBRARY.hovered_swap_index then
      DAW.CUSTOM_LIBRARY.drag_target=DAW.CUSTOM_LIBRARY.hovered_swap_index
    end
    r.ImGui_EndTable(ctx)
  end
  if delete_index then DAW.CUSTOM_LIBRARY.delete_entry(delete_index) end
end

DAW.CUSTOM_LIBRARY.draw_window = function()
  if not DAW.CUSTOM_LIBRARY.visible then return false end

  r.ImGui_SetNextWindowSize(ctx,1121,750,r.ImGui_Cond_FirstUseEver())
  r.ImGui_SetNextWindowSizeConstraints(ctx,1121,770,1121,2000)
  DAW.GUI.force_next_window_opaque()

  local visible,open_window=r.ImGui_Begin(ctx,CFG.CUSTOM_LIBRARY_WINDOW_TITLE,true,r.ImGui_WindowFlags_NoCollapse())
    if visible == nil then return true end
    if visible then
    if r.ImGui_Button(ctx,"Return to HOME") then DAW.CUSTOM_LIBRARY.go_home() end
    r.ImGui_SameLine(ctx); r.ImGui_Text(ctx,"Direct hardware modes:")
    r.ImGui_SameLine(ctx); if r.ImGui_Button(ctx,"Programmer Mode") then send_programmer_mode() end
    r.ImGui_SameLine(ctx); if r.ImGui_Button(ctx,"Session Mode") then DAW.CUSTOM_LIBRARY.send_layout(0x00) end
    r.ImGui_SameLine(ctx); if r.ImGui_Button(ctx,"Note Mode") then DAW.CUSTOM_LIBRARY.send_layout(0x01) end
    r.ImGui_SameLine(ctx); r.ImGui_Text(ctx,"Customs:")

    for slot=1,8 do
      r.ImGui_SameLine(ctx)
      if r.ImGui_Button(ctx,tostring(slot).."##direct_custom_"..tostring(slot)) then
        DAW.CUSTOM_LIBRARY.switch_to_slot(slot)
      end
    end

    r.ImGui_Separator(ctx)
    r.ImGui_Text(ctx,"Text Scrolling:")
    r.ImGui_SameLine(ctx)

    local scroll_changed
    r.ImGui_SetNextItemWidth(ctx,560)
    scroll_changed,DAW.CUSTOM_LIBRARY.scroll_text=r.ImGui_InputText(
      ctx,"Text to scroll",DAW.CUSTOM_LIBRARY.scroll_text
    )

    r.ImGui_SameLine(ctx)
    r.ImGui_Dummy(ctx,33,5)
    r.ImGui_SameLine(ctx); if r.ImGui_Button(ctx,"Begin Text Scroll") then DAW.CUSTOM_LIBRARY.send_scroll() end
    r.ImGui_SameLine(ctx); if r.ImGui_Button(ctx,"Stop Text Scroll") then DAW.CUSTOM_LIBRARY.stop_scroll() end

    local loop_changed
    loop_changed,DAW.CUSTOM_LIBRARY.scroll_loop=r.ImGui_Checkbox(
      ctx,"Loop message",DAW.CUSTOM_LIBRARY.scroll_loop
    )

    r.ImGui_SameLine(ctx)
    r.ImGui_SetNextItemWidth(ctx,110)

    local interval_changed
    interval_changed,DAW.CUSTOM_LIBRARY.scroll_interval=r.ImGui_InputDouble(
      ctx,"Seconds before looping",DAW.CUSTOM_LIBRARY.scroll_interval,0.25,1.0,"%.2f"
    )

    r.ImGui_SameLine(ctx)
    r.ImGui_Text(ctx,"Scroll palette color:")
    r.ImGui_SameLine(ctx)

    if DAW.GUI.draw_palette_swatch(DAW.CUSTOM_LIBRARY.scroll_palette,"custom_scroll_palette",34,24) then
      DAW.CUSTOM_LIBRARY.open_palette_picker("scroll")
    end

    r.ImGui_SameLine(ctx)
    r.ImGui_Text(ctx,"Palette "..tostring(DAW.CUSTOM_LIBRARY.scroll_palette).." — click square to choose from chart")

    if scroll_changed or loop_changed or interval_changed then DAW.CUSTOM_LIBRARY.save() end

    local entry=DAW.USER_DATA.ensure_custom_entry(DAW.CUSTOM_LIBRARY.editor_index)
    r.ImGui_Separator(ctx)

    DAW.CUSTOM_LIBRARY.hovered_swap_index=nil

    if r.ImGui_BeginGroup then r.ImGui_BeginGroup(ctx) end

    local changed_mode = false
    local uses_custom = DAW.CUSTOM_LIBRARY.entry_uses_custom(entry)

    if r.ImGui_RadioButton(ctx,"Non-Custom SysEx (Session, etc.)",not uses_custom) then
      entry.payload_mode="non_custom"
      uses_custom=false
      changed_mode=true
      DAW.CUSTOM_LIBRARY.destination_drag_index=nil
      DAW.CUSTOM_LIBRARY.destination_drag_target=nil
      DAW.CUSTOM_LIBRARY.destination_hovered_index=nil
      DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index=nil
    end

    r.ImGui_SameLine(ctx)

    if r.ImGui_RadioButton(ctx,"Custom SysEx",uses_custom) then
      entry.payload_mode="custom"
      uses_custom=true
      changed_mode=true
    end

    r.ImGui_Text(ctx,"Selected SysEx Slot: "..tostring(DAW.CUSTOM_LIBRARY.editor_index))

    r.ImGui_SetNextItemWidth(ctx,430)
    local changed_name
    changed_name,entry.name=r.ImGui_InputText(ctx,"Name",entry.name)

    local changed_label
    changed_label,entry.label=r.ImGui_InputTextMultiline(
      ctx,"Button label text",entry.label,80,58
    )

    r.ImGui_Text(ctx,"Non-Custom SysEx:")

    local non_custom_disabled = uses_custom
    local non_custom_disabled_token = DAW.GUI.begin_disabled(non_custom_disabled)
    local changed_non_custom = false

    if r.ImGui_Button(ctx,"Load##custom_non_load",40,24) and not non_custom_disabled then
      local loaded_hex,loaded_labels,loaded = DAW.CUSTOM_LIBRARY.load_payload_asset(
        entry.non_custom,entry.non_custom_labels,"Non-Custom"
      )
      if loaded then
        entry.non_custom,entry.non_custom_labels=loaded_hex,loaded_labels
        changed_non_custom=true
      end
    end

    r.ImGui_SameLine(ctx)

    if r.ImGui_Button(ctx,"Edit##custom_non_edit",40,24) and not non_custom_disabled then
      DAW.CUSTOM_LIBRARY.layout_editor_open("non_custom")
    end

    r.ImGui_SameLine(ctx)

    if r.ImGui_Button(ctx,"Save##custom_non_save",40,24) and not non_custom_disabled then
      DAW.CUSTOM_LIBRARY.save_payload_files(
        entry.non_custom,
        entry.non_custom_labels,
        "Entry_"..string.format("%03d",DAW.CUSTOM_LIBRARY.editor_index).."_Non_Custom.syx",
        "Non-Custom"
      )
    end

    r.ImGui_SameLine(ctx)

    if r.ImGui_Button(ctx,"Send##custom_non_send",40,24) and not non_custom_disabled then
      if trim(entry.non_custom or "") ~= "" then
        DAW.CUSTOM_LIBRARY.send_hex(entry.non_custom)
        last_action="Sent Non-Custom SysEx from library entry "..tostring(DAW.CUSTOM_LIBRARY.editor_index)
      else
        last_action="This entry has no Non-Custom SysEx payload"
      end
    end

    r.ImGui_SameLine(ctx)

    local prior_non_custom = entry.non_custom
    local changed_non_custom_text
    changed_non_custom_text,entry.non_custom=DAW.GUI.resizable_multiline(
      "custom_non_"..tostring(DAW.CUSTOM_LIBRARY.editor_index),
      "##non_custom_entry",
      entry.non_custom,
      430,
      DAW.CUSTOM_LIBRARY.field_heights,
      "non_"..tostring(DAW.CUSTOM_LIBRARY.editor_index),
      24
    )

    if non_custom_disabled then
      entry.non_custom=prior_non_custom
      changed_non_custom_text=false
    end

    changed_non_custom=changed_non_custom or changed_non_custom_text
    DAW.GUI.end_disabled(non_custom_disabled_token)

    local switch_disabled = not uses_custom
    local switch_disabled_token = DAW.GUI.begin_disabled(switch_disabled)

    r.ImGui_SetNextItemWidth(ctx,120)
    local prior_switch_to_slot = entry.switch_to_slot
    local changed_switch
    changed_switch,entry.switch_to_slot=r.ImGui_InputInt(
      ctx,"Custom # to switch to on send (0 = Send, but don't switch)",entry.switch_to_slot
    )

    if switch_disabled then
      entry.switch_to_slot=prior_switch_to_slot
      changed_switch=false
    end

    entry.switch_to_slot=math.max(0,math.min(8,entry.switch_to_slot or 0))
    DAW.GUI.end_disabled(switch_disabled_token)

    if r.ImGui_EndGroup then r.ImGui_EndGroup(ctx) end

    r.ImGui_SameLine(ctx,nil,30)

    if r.ImGui_BeginGroup then r.ImGui_BeginGroup(ctx) end
    r.ImGui_Text(ctx,"Button palette color:")
    if DAW.GUI.draw_palette_swatch(entry.color,"custom_editor_current",34,24) then
      DAW.CUSTOM_LIBRARY.open_palette_picker("entry")
    end
    r.ImGui_Text(ctx,"Palette # "..tostring(entry.color))
    if r.ImGui_EndGroup then r.ImGui_EndGroup(ctx) end

    r.ImGui_SameLine(ctx,nil,30)

    if r.ImGui_BeginGroup then r.ImGui_BeginGroup(ctx) end
    DAW.CUSTOM_LIBRARY.draw_page_swatches()
    if r.ImGui_EndGroup then r.ImGui_EndGroup(ctx) end

    r.ImGui_Text(ctx,"Custom Slots — Drag the index numbers 1-8 to rearrange.                                                                                                                                                                                  Get from Launchpad Hardware:")
    DAW.CUSTOM_LIBRARY.draw_destination_drag_status()

    local edited=changed_mode or changed_name or changed_label or changed_non_custom or changed_switch

    DAW.CUSTOM_LIBRARY.destination_hovered_index = nil

    local upload_table_flags = r.ImGui_TableFlags_SizingFixedFit
      and r.ImGui_TableFlags_SizingFixedFit()
      or 0

    local compact_upload_padding = false
    if r.ImGui_PushStyleVar and r.ImGui_StyleVar_CellPadding then
      r.ImGui_PushStyleVar(ctx,r.ImGui_StyleVar_CellPadding(),2,1)
      compact_upload_padding = true
    end

    local custom_rows_disabled = not uses_custom
    local custom_rows_disabled_token = DAW.GUI.begin_disabled(custom_rows_disabled)

    local row_h=24
    local action_w=40
    local field_w=640
    local hardware_w=28

    if r.ImGui_BeginTable(ctx,"##custom_upload_rows",14,upload_table_flags,1265,0) then
      local fixed=DAW.GUI.table_fixed_column_flag()

      r.ImGui_TableSetupColumn(ctx,"#",fixed,28)
      r.ImGui_TableSetupColumn(ctx,"Load",fixed,44)
      r.ImGui_TableSetupColumn(ctx,"Edit",fixed,44)
      r.ImGui_TableSetupColumn(ctx,"Save",fixed,44)
      r.ImGui_TableSetupColumn(ctx,"Send",fixed,44)
      r.ImGui_TableSetupColumn(ctx,"SysEx",fixed,590)

      for hardware_slot=1,8 do
        r.ImGui_TableSetupColumn(ctx,tostring(hardware_slot),fixed,32)
      end

      for destination=1,8 do
        r.ImGui_TableNextRow(ctx)

        r.ImGui_TableSetColumnIndex(ctx,0)

        local drag_source = tonumber(DAW.CUSTOM_LIBRARY.destination_drag_index) == destination
        local drag_target = tonumber(DAW.CUSTOM_LIBRARY.destination_drag_target
          or DAW.CUSTOM_LIBRARY.destination_last_valid_drop_index) == destination
        local switch_target = uses_custom and tonumber(entry.switch_to_slot) == destination

        local pushed_drag_color = false
        local pushed_switch_border = false
        local pushed_switch_border_size = false

        if (drag_source or drag_target) and r.ImGui_PushStyleColor and r.ImGui_Col_Button then
          r.ImGui_PushStyleColor(
            ctx,
            r.ImGui_Col_Button(),
            drag_target and 0x20BFAFFF or 0x3168BFFF
          )
          pushed_drag_color = true
        end

        if switch_target and r.ImGui_PushStyleColor and r.ImGui_Col_Border then
          r.ImGui_PushStyleColor(ctx,r.ImGui_Col_Border(),0xFFB347FF)
          pushed_switch_border = true
        end

        if switch_target and r.ImGui_PushStyleVar and r.ImGui_StyleVar_FrameBorderSize then
          r.ImGui_PushStyleVar(ctx,r.ImGui_StyleVar_FrameBorderSize(),2)
          pushed_switch_border_size = true
        end

        r.ImGui_Button(ctx,tostring(destination).."##custom_destination_index_"..tostring(destination),24,row_h)

        if pushed_switch_border_size and r.ImGui_PopStyleVar then r.ImGui_PopStyleVar(ctx) end
        if pushed_switch_border and r.ImGui_PopStyleColor then r.ImGui_PopStyleColor(ctx,1) end
        if pushed_drag_color and r.ImGui_PopStyleColor then r.ImGui_PopStyleColor(ctx,1) end

        if not custom_rows_disabled then DAW.CUSTOM_LIBRARY.register_destination_swap_item(destination) end

        r.ImGui_TableSetColumnIndex(ctx,1)
        if r.ImGui_Button(ctx,"Load##custom_destination_load_"..tostring(destination),action_w,row_h)
            and not custom_rows_disabled then
          local loaded_hex,loaded_labels,loaded=DAW.CUSTOM_LIBRARY.load_payload_asset(
            entry.customs[destination],entry.custom_labels[destination],"Custom "..tostring(destination)
          )
          if loaded then
            entry.customs[destination],entry.custom_labels[destination]=loaded_hex,loaded_labels
            edited=true
          end
        end

        r.ImGui_TableSetColumnIndex(ctx,2)
        if r.ImGui_Button(ctx,"Edit##custom_destination_edit_"..tostring(destination),action_w,row_h)
            and not custom_rows_disabled then
          DAW.CUSTOM_LIBRARY.layout_editor_open("custom", destination)
        end

        r.ImGui_TableSetColumnIndex(ctx,3)
        if r.ImGui_Button(ctx,"Save##custom_destination_save_"..tostring(destination),action_w,row_h)
            and not custom_rows_disabled then
          DAW.CUSTOM_LIBRARY.save_payload_files(
            entry.customs[destination],
            entry.custom_labels[destination],
            "Entry_"..string.format("%03d",DAW.CUSTOM_LIBRARY.editor_index).."_Custom_"..tostring(destination)..".syx",
            "Custom "..tostring(destination)
          )
        end

        r.ImGui_TableSetColumnIndex(ctx,4)
        if r.ImGui_Button(ctx,"Send##custom_destination_send_"..tostring(destination),action_w,row_h)
            and not custom_rows_disabled then
          DAW.CUSTOM_LIBRARY.send_custom_slot(entry,destination,DAW.CUSTOM_LIBRARY.editor_index,false)
        end

        r.ImGui_TableSetColumnIndex(ctx,5)
        local prior_custom_payload = entry.customs[destination]
        local changed_custom
        changed_custom,entry.customs[destination]=DAW.GUI.resizable_multiline(
          "custom_destination_"..tostring(DAW.CUSTOM_LIBRARY.editor_index).."_"..tostring(destination),
          "##Custom "..tostring(destination),
          entry.customs[destination],
          field_w,
          DAW.CUSTOM_LIBRARY.field_heights,
          "custom_"..tostring(DAW.CUSTOM_LIBRARY.editor_index).."_"..tostring(destination),
          row_h
        )

        if custom_rows_disabled then
          entry.customs[destination]=prior_custom_payload
          changed_custom=false
        end

        edited=edited or changed_custom

        for hardware_slot=1,8 do
          r.ImGui_TableSetColumnIndex(ctx,5+hardware_slot)
          if r.ImGui_Button(ctx,tostring(hardware_slot).."##get_custom_"..tostring(destination).."_"..tostring(hardware_slot),hardware_w,row_h)
              and not custom_rows_disabled then
            DAW.CUSTOM_LIBRARY.request_custom(
              DAW.CUSTOM_LIBRARY.editor_index,
              destination,
              hardware_slot
            )
          end
        end
      end

      r.ImGui_EndTable(ctx)
    end

    DAW.GUI.end_disabled(custom_rows_disabled_token)

    if compact_upload_padding and r.ImGui_PopStyleVar then
      r.ImGui_PopStyleVar(ctx)
    end

    DAW.CUSTOM_LIBRARY.finish_destination_drag_swap()

    if edited then
      DAW.CUSTOM_LIBRARY.save()
      last_hardware_state_signature=nil
      refresh_hardware_state(true)
    end

    if r.ImGui_Button(ctx,"+ Add SysEx / Customs row") then
      DAW.USER_DATA.ensure_custom_entry(#DAW.CUSTOM_LIBRARY.data.entries+1)
      DAW.CUSTOM_LIBRARY.save()
    end

    r.ImGui_SameLine(ctx)

    local custom_import_export_w=132
    if r.ImGui_GetWindowWidth and r.ImGui_SetCursorPosX and r.ImGui_GetCursorPosX then
      r.ImGui_SetCursorPosX(ctx,math.max(r.ImGui_GetCursorPosX(ctx),r.ImGui_GetWindowWidth(ctx)-custom_import_export_w-18))
    end

    if r.ImGui_Button(ctx,"Import") then DAW.CUSTOM_LIBRARY.import_library() end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx,"Export") then DAW.CUSTOM_LIBRARY.export_library() end

    r.ImGui_Separator(ctx)

    local custom_rows_child_open=DAW.GUI.begin_child(
      "##custom_rows",
      0,
      0,
      r.ImGui_WindowFlags_HorizontalScrollbar()
    )

    if custom_rows_child_open then
      DAW.CUSTOM_LIBRARY.draw_table()
    end

    r.ImGui_EndChild(ctx)

    DAW.CUSTOM_LIBRARY.finish_drag_swap()
  end

  r.ImGui_End(ctx)

  if not open_window then
    DAW.CUSTOM_LIBRARY.visible=false
    last_hardware_state_signature=nil
    refresh_hardware_state(true)
  end

  return true
end

local function draw_library_window(now)
  if not library_visible then return false end

  r.ImGui_SetNextWindowSize(ctx, CFG.SETTINGS_DEFAULT_WIDTH, CFG.SETTINGS_DEFAULT_HEIGHT, r.ImGui_Cond_FirstUseEver())
  DAW.GUI.force_next_window_opaque()
  local visible, still_open = r.ImGui_Begin(ctx, CFG.LIBRARY_WINDOW_TITLE, true, r.ImGui_WindowFlags_NoCollapse())
    if visible == nil then return true end
    if visible then

    r.ImGui_Text(ctx, "Device Setup")
    local quit_label = "Quit App"
    local quit_w = (select(1, r.ImGui_CalcTextSize(ctx, quit_label)) or 55) + 22
    if r.ImGui_SetCursorPosX and r.ImGui_GetWindowWidth then
      r.ImGui_SameLine(ctx)
      r.ImGui_SetCursorPosX(ctx, math.max(12, r.ImGui_GetWindowWidth(ctx) - quit_w - 14))
    else
      r.ImGui_SameLine(ctx)
    end
    if r.ImGui_Button(ctx, quit_label) then open = false end

    r.ImGui_Separator(ctx)
    draw_device_setup()

    r.ImGui_Separator(ctx)
    draw_hardware_controls()

    r.ImGui_Separator(ctx)
    if r.ImGui_Button(ctx, "Open Command Library") then
      DAW.COMMAND_LIBRARY.open_for_index(DAW.COMMAND_LIBRARY.editor_index,true)
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx, "Open SysEx & Customs Library") then
      DAW.CUSTOM_LIBRARY.open_for_index(DAW.CUSTOM_LIBRARY.editor_index,true)
    end
    r.ImGui_SameLine(ctx)
    if r.ImGui_Button(ctx, grid_visible and "Hide Launchpad Xtra Display Grid" or "Show Launchpad Xtra Display Grid") then
      grid_visible = not grid_visible
      grid_preview_until = 0
      grid_preview_held = false
      last_action = grid_visible and "Launchpad Xtra Display Grid shown" or "Launchpad Xtra Display Grid hidden"
      refresh_hardware_state(true)
      DAW.TRACK_PICKER.refresh_hardware_state(true)
      if surface_mode == "PROGRAMMER_TRACK_MATRIX" then DAW.refresh_matrix_surface(true) end
      if surface_mode == "REGIONS_MARKERS" then DAW.REGIONS_MARKERS.refresh_hardware_state(true) end
      if surface_mode == "TRACK_VIEWER_SESSION" then DAW.TRACK_VIEWER.refresh_button_surface(true) end
    end

    r.ImGui_Separator(ctx)
    r.ImGui_Text(ctx, "Current HOME page: " .. tostring(current_page))
    r.ImGui_Text(ctx, "Primary device: " .. tostring(selected_device.name))
    r.ImGui_Text(ctx, "Primary MIDI: " .. tostring(selected_input_name) .. "  ->  " .. tostring(selected_output_name))
    r.ImGui_Text(ctx, "Primary DAW: " .. tostring(DAW.input_name) .. "  ->  " .. tostring(DAW.output_name))
    r.ImGui_Text(ctx, "Secondary device: " .. tostring((DAW.secondary_device or selected_device).name))
    r.ImGui_Text(ctx, "Secondary MIDI: " .. tostring(DAW.ordinary_input_name_2) .. "  ->  " .. tostring(DAW.ordinary_output_name_2))
    r.ImGui_Text(ctx, "Secondary DAW: " .. tostring(DAW.input_name_2) .. "  ->  " .. tostring(DAW.output_name_2))
    r.ImGui_Text(ctx, string.format("Settings window size: %d x %d", math.floor((window_w or 0) + 0.5), math.floor((window_h or 0) + 0.5)))
    r.ImGui_Text(
      ctx,
      string.format(
        "Command Library window size: %d x %d",
        math.floor((DAW.COMMAND_LIBRARY.window_width or 0) + 0.5),
        math.floor((DAW.COMMAND_LIBRARY.window_height or 0) + 0.5)
      )
    )
    r.ImGui_Text(ctx, "Command table column widths: " .. DAW.COMMAND_LIBRARY.table_widths_status_text())
    r.ImGui_Text(ctx, "Surface mode: " .. tostring(surface_mode))
    r.ImGui_Text(ctx, "Track-panel tab status: " .. tostring(mcp_tab_state.status))
    r.ImGui_Text(ctx, "Hardware initialized: " .. (initialized and "Yes" or "No"))
    r.ImGui_Text(ctx, "Last accepted MIDI: " .. last_midi .. "    Source: " .. last_midi_source)
    r.ImGui_Text(ctx, "Status: " .. last_action)
  end

  r.ImGui_End(ctx)
  if not still_open then library_visible = false end
  return true
end

local function draw_grid_window(now)
  if not helper_window_should_be_visible() then return false end

  r.ImGui_SetNextWindowSize(ctx, 900, 900, r.ImGui_Cond_FirstUseEver())

  local window_flags = r.ImGui_WindowFlags_NoCollapse()

  local viewer_drag_active = DAW.TRACK_VIEWER
    and DAW.TRACK_VIEWER.grid_drag
    and DAW.TRACK_VIEWER.grid_drag.active_fader

  if (custom_grid_drag.active_fader or viewer_drag_active) and r.ImGui_WindowFlags_NoMove then
    window_flags = window_flags | r.ImGui_WindowFlags_NoMove()
  end

  DAW.GUI.force_next_window_opaque()

  local visible, still_open = r.ImGui_Begin(ctx, CFG.WINDOW_TITLE, true, window_flags)

  -- ReaImGui dock/undock can return false/nil during transient frames.
  -- In this script, calling End() unless visible is exactly true can cause:
  -- "ImGui_End: Calling End() too many times!"
  if visible == true then
    if DAW.CUSTOM_LIBRARY and DAW.CUSTOM_LIBRARY.layout_editor
        and DAW.CUSTOM_LIBRARY.layout_editor.visible then
      r.ImGui_Text(ctx, "Custom Layout Editor is active.")
      r.ImGui_Text(ctx, "Use Save or Cancel in the editor window to restore this GRID.")
    else
      local ok_grid, grid_err = pcall(draw_grid)
      if not ok_grid then
        r.ImGui_Text(ctx, "GRID draw skipped during dock/undock transition.")
        -- Optional debug:
        -- r.ShowConsoleMsg(tostring(grid_err) .. "\n")
      end
    end

    r.ImGui_End(ctx)
  end

  if still_open == false then
    grid_visible = false
    grid_preview_until = 0
    grid_preview_held = false
  end

  return true
end

local shutdown_complete = false
local function shutdown()
  if shutdown_complete then return end
  shutdown_complete = true
  if clear_custom_fader_mcp_layout_tabs then
    clear_custom_fader_mcp_layout_tabs()
  end
  active_custom_slot = nil
  pending_custom_slot = nil
  pending_custom_switch_time = 0
  if DAW and DAW.TRACK_VIEWER then
    DAW.TRACK_VIEWER.layout_identity = nil
    DAW.TRACK_VIEWER.surface_identity = nil
    DAW.TRACK_VIEWER.fade_states = {}
    DAW.TRACK_VIEWER.pending_fx_click = nil
    DAW.TRACK_VIEWER.pending_fx_center = nil
    DAW.TRACK_VIEWER.last_selection_signature = nil
    DAW.TRACK_VIEWER.last_touched_selected_track = nil
    DAW.TRACK_VIEWER.locked_to_track = false
    DAW.TRACK_VIEWER.select_hold = {
      active = false,
      source = nil,
      start_time = 0,
      lock_triggered = false,
    }
  end
  reset_custom_fader_feedback_state()
  for _, hold_action in pairs(HOLD_ACTIONS) do
    if hold_action.release then hold_action.release() end
  end
  if return_to_live_on_exit and (selected_output_index ~= nil or DAW.ordinary_output_index_2 ~= nil) then
    send_live_mode()
  end
  if DAW.output_index ~= nil or DAW.output_index_2 ~= nil then
    DAW.send_mode(false)
  end
  if r.ImGui_DestroyContext and context_is_valid() then
    r.ImGui_DestroyContext(ctx)
  end
  ctx = nil
end

if r.atexit then
  r.atexit(shutdown)
end

local last_state_refresh_time = 0

local function loop()
  poll_recent_midi()

  local now = r.time_precise()
  process_pending_custom_mode_switch(now)
  if DAW.CUSTOM_LIBRARY then
    DAW.CUSTOM_LIBRARY.process_scroll_loop(now)
    DAW.CUSTOM_LIBRARY.process_readback_timeout(now)
    DAW.CUSTOM_LIBRARY.process_external_layout_poll(now)
    DAW.CUSTOM_LIBRARY.process_pending_post_upload_home_recovery(now)
    DAW.CUSTOM_LIBRARY.process_pending_home_resend(now)
  end
  if DAW.TRACK_VIEWER and DAW.TRACK_VIEWER.process_feedback then
    DAW.TRACK_VIEWER.process_feedback(now)
  end
  if DAW.TRACK_VIEWER and DAW.TRACK_VIEWER.process_pending_fx_center then
    DAW.TRACK_VIEWER.process_pending_fx_center(now)
  end
  refresh_mcp_track_cache(false)
  DAW.reconcile_mcp_structure()
  process_active_custom_fader_feedback(now)
  if DAW.FX and DAW.FX.process_fader_feedback then DAW.FX.process_fader_feedback(now) end
  if surface_mode == "PROGRAMMER_TRACK_MATRIX" then DAW.refresh_matrix_surface(false) end
  if surface_mode == "REGIONS_MARKERS" then DAW.REGIONS_MARKERS.refresh_hardware_state(false) end
  if surface_mode == "DAW_FX_MATRIX" then
    DAW.FX.refresh_labels(false)
    DAW.FX.refresh_active_assignment_surface_if_needed()
    DAW.FX.refresh_matrix_surface(false)
  end
  repeat_scan_if_held(now)
  refresh_mcp_ui_if_needed(now)
  if now - last_state_refresh_time >= CFG.STATE_REFRESH_INTERVAL then
    refresh_hardware_state(false)
    DAW.TRACK_PICKER.refresh_hardware_state(false)
    last_state_refresh_time = now
  end

  -- The grid and Library are independent windows. Toggle Show This Grid hides
  -- only the 9x9 helper. Toggle Show Library hides only the settings/status window.
  -- If both are hidden, keep a tiny off-screen frame alive so the shared context
  -- remains valid while hardware MIDI continues to be processed.
  ensure_context()
  local drew_grid = draw_grid_window(now)
  local drew_library = draw_library_window(now)
  local drew_command_library = DAW.COMMAND_LIBRARY.draw_window()
  local drew_command_palette = DAW.COMMAND_LIBRARY.draw_palette_picker_window()
  local drew_custom_library = DAW.CUSTOM_LIBRARY.draw_window()
  local drew_custom_palette = DAW.CUSTOM_LIBRARY.draw_palette_picker_window()
  local drew_layout_editor = DAW.CUSTOM_LIBRARY.draw_layout_editor_window()
  if not drew_grid and not drew_library and not drew_command_library
      and not drew_command_palette and not drew_custom_library
      and not drew_custom_palette and not drew_layout_editor then
    keep_context_alive_while_hidden()
  end

  if open then
    r.defer(loop)
  else
    shutdown()
  end
end

-- Initialize the ordinary Launchpad hardware automatically on startup when
-- the remembered MIDI output is available. This restores Programmer Mode and
-- sends HOME Page 1 immediately, while keeping the Library button
-- available as a manual retry if the device was disconnected during launch.
if selected_output_index ~= nil or DAW.ordinary_output_index_2 ~= nil then
  initialize_hardware()
else
  last_action = "Waiting to initialize hardware: choose or reconnect the ordinary MIDI output"
end

r.defer(loop)
