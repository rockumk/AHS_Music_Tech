DAW.save_secondary_device_model = function(device)
  DAW.secondary_device = device or selected_device
  r.SetExtState(EXTSTATE_SECTION, DAW.EXTSTATE_SECONDARY_DEVICE_MODEL, DAW.secondary_device.key, true)
end

local function refresh_midi_inputs()
  midi_inputs = {{index = -1, name = ANY_INPUT_NAME}}
  local launchpad_choice, remembered_choice, remembered_choice_2 = nil, nil, nil

  for i = 0, r.GetNumMIDIInputs() - 1 do
    local retval, name = r.GetMIDIInputName(i, "")
    if retval then
      name = (name ~= "") and name or ("MIDI Input " .. tostring(i))
      local item = {index = i, name = name}
      midi_inputs[#midi_inputs + 1] = item
      if name == preferred_input_name then remembered_choice = item end
      if name == DAW.ordinary_preferred_input_name_2 then remembered_choice_2 = item end
      if not launchpad_choice and name:lower():find("launchpad", 1, true) then launchpad_choice = item end
    end
  end

  if preferred_input_name == ANY_INPUT_NAME then
    selected_input_index, selected_input_name = -1, ANY_INPUT_NAME
  elseif remembered_choice then
    selected_input_index, selected_input_name = remembered_choice.index, remembered_choice.name
  elseif preferred_input_name == "" and launchpad_choice then
    selected_input_index, selected_input_name = launchpad_choice.index, launchpad_choice.name
    save_selected_input(selected_input_name)
  elseif preferred_input_name == "" then
    selected_input_index, selected_input_name = -1, ANY_INPUT_NAME
    save_selected_input(selected_input_name)
  else
    selected_input_index, selected_input_name = -1, ANY_INPUT_NAME .. " (saved port unavailable)"
  end

  if DAW.ordinary_preferred_input_name_2 == "" or DAW.ordinary_preferred_input_name_2 == DAW.NO_SECONDARY_ORDINARY_INPUT_NAME then
    DAW.ordinary_input_index_2, DAW.ordinary_input_name_2 = nil, DAW.NO_SECONDARY_ORDINARY_INPUT_NAME
  elseif remembered_choice_2 then
    DAW.ordinary_input_index_2, DAW.ordinary_input_name_2 = remembered_choice_2.index, remembered_choice_2.name
  else
    DAW.ordinary_input_index_2, DAW.ordinary_input_name_2 = nil, DAW.NO_SECONDARY_ORDINARY_INPUT_NAME .. " (saved port unavailable)"
  end
end

local function refresh_midi_outputs()
  midi_outputs = {}
  local launchpad_choice, remembered_choice, remembered_choice_2 = nil, nil, nil

  for i = 0, r.GetNumMIDIOutputs() - 1 do
    local retval, name = r.GetMIDIOutputName(i, "")
    if retval then
      name = (name ~= "") and name or ("MIDI Output " .. tostring(i))
      local item = {index = i, name = name}
      midi_outputs[#midi_outputs + 1] = item
      if name == preferred_output_name then remembered_choice = item end
      if name == DAW.ordinary_preferred_output_name_2 then remembered_choice_2 = item end
      if not launchpad_choice and name:lower():find("launchpad", 1, true) then launchpad_choice = item end
    end
  end

  if remembered_choice then
    selected_output_index, selected_output_name = remembered_choice.index, remembered_choice.name
  elseif preferred_output_name == "" and launchpad_choice then
    selected_output_index, selected_output_name = launchpad_choice.index, launchpad_choice.name
    save_selected_output(selected_output_name)
  elseif preferred_output_name == "" then
    selected_output_index, selected_output_name = nil, NO_OUTPUT_NAME
  else
    selected_output_index, selected_output_name = nil, NO_OUTPUT_NAME .. " (saved port unavailable)"
  end

  if DAW.ordinary_preferred_output_name_2 == "" or DAW.ordinary_preferred_output_name_2 == DAW.NO_SECONDARY_ORDINARY_OUTPUT_NAME then
    DAW.ordinary_output_index_2, DAW.ordinary_output_name_2 = nil, DAW.NO_SECONDARY_ORDINARY_OUTPUT_NAME
  elseif remembered_choice_2 then
    DAW.ordinary_output_index_2, DAW.ordinary_output_name_2 = remembered_choice_2.index, remembered_choice_2.name
  else
    DAW.ordinary_output_index_2, DAW.ordinary_output_name_2 = nil, DAW.NO_SECONDARY_ORDINARY_OUTPUT_NAME .. " (saved port unavailable)"
  end
end

DAW.refresh_selection = function()
  local remembered_input = nil
  local remembered_output = nil
  local remembered_input_2 = nil
  local remembered_output_2 = nil
  local daw_input_choice = nil
  local daw_output_choice = nil

  for _, input in ipairs(midi_inputs) do
    if input.index ~= -1 then
      local lower_name = input.name:lower()
      if input.name == DAW.preferred_input_name then remembered_input = input end
      if input.name == DAW.preferred_input_name_2 then remembered_input_2 = input end
      if not daw_input_choice and lower_name:find("daw", 1, true) then
        daw_input_choice = input
      end
    end
  end

  for _, output in ipairs(midi_outputs) do
    local lower_name = output.name:lower()
    if output.name == DAW.preferred_output_name then remembered_output = output end
    if output.name == DAW.preferred_output_name_2 then remembered_output_2 = output end
    if not daw_output_choice and lower_name:find("daw", 1, true) then
      daw_output_choice = output
    end
  end

  if remembered_input then
    DAW.input_index = remembered_input.index
    DAW.input_name = remembered_input.name
  elseif DAW.preferred_input_name == "" and daw_input_choice then
    DAW.input_index = daw_input_choice.index
    DAW.input_name = daw_input_choice.name
    DAW.save_input(DAW.input_name)
  else
    DAW.input_index = nil
    DAW.input_name = DAW.NO_INPUT_NAME
  end

  if remembered_output then
    DAW.output_index = remembered_output.index
    DAW.output_name = remembered_output.name
  elseif DAW.preferred_output_name == "" and daw_output_choice then
    DAW.output_index = daw_output_choice.index
    DAW.output_name = daw_output_choice.name
    DAW.save_output(DAW.output_name)
  else
    DAW.output_index = nil
    DAW.output_name = DAW.NO_OUTPUT_NAME
  end

  if DAW.preferred_input_name_2 == "" or DAW.preferred_input_name_2 == DAW.NO_INPUT_NAME_2 then
    DAW.input_index_2, DAW.input_name_2 = nil, DAW.NO_INPUT_NAME_2
  elseif remembered_input_2 then
    DAW.input_index_2, DAW.input_name_2 = remembered_input_2.index, remembered_input_2.name
  else
    DAW.input_index_2, DAW.input_name_2 = nil, DAW.NO_INPUT_NAME_2 .. " (saved port unavailable)"
  end

  if DAW.preferred_output_name_2 == "" or DAW.preferred_output_name_2 == DAW.NO_OUTPUT_NAME_2 then
    DAW.output_index_2, DAW.output_name_2 = nil, DAW.NO_OUTPUT_NAME_2
  elseif remembered_output_2 then
    DAW.output_index_2, DAW.output_name_2 = remembered_output_2.index, remembered_output_2.name
  else
    DAW.output_index_2, DAW.output_name_2 = nil, DAW.NO_OUTPUT_NAME_2 .. " (saved port unavailable)"
  end
end

refresh_midi_inputs()
refresh_midi_outputs()
DAW.refresh_selection()

