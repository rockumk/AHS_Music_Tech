local function move_to_adjacent_barline(direction)
  local cursor = r.GetCursorPosition()
  local beat_in_measure, measure_index = r.TimeMap2_timeToBeats(0, cursor)
  local current_measure = measure_index or 0
  local beat = beat_in_measure or 0
  local eps = 0.000001
  local target_measure

  if direction > 0 then
    -- Always go to the next measure start, even when the cursor is currently
    -- somewhere in the middle of a bar.
    target_measure = current_measure + 1
  elseif beat > eps then
    -- From the middle of a bar, go back to the start of the current bar.
    target_measure = current_measure
  else
    -- From an existing barline, go back to the previous barline.
    target_measure = math.max(0, current_measure - 1)
  end

  local target_time = r.TimeMap2_beatsToTime(0, 0, target_measure)
  r.SetEditCurPos(target_time, true, true)
  last_action = (direction > 0) and "Moved to next barline" or "Moved to previous barline"
end

bind("Fast Forward", function() move_to_adjacent_barline(1) end)

