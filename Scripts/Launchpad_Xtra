DAW.GUI.draw_screen_title = function(title)
  title = tostring(title or "")
  local x, y = r.ImGui_GetCursorScreenPos(ctx)
  if DAW.GUI.screen_title_font and r.ImGui_PushFont then
    r.ImGui_PushFont(ctx, DAW.GUI.screen_title_font, 19)
  end
  local _, text_h = r.ImGui_CalcTextSize(ctx, title)
  local draw_list = r.ImGui_GetWindowDrawList(ctx)
  -- A one-pixel second pass gives the persistent screen title a stronger,
  -- bold-like weight without depending on a platform-specific bold font face.
  r.ImGui_DrawList_AddText(draw_list, x, y, 0xFFFFFFFF, title)
  r.ImGui_DrawList_AddText(draw_list, x + 1, y, 0xFFFFFFFF, title)
  if DAW.GUI.screen_title_font and r.ImGui_PopFont then
    r.ImGui_PopFont(ctx)
  end
  r.ImGui_Dummy(ctx, 1, (text_h or 19) + 5)
end

DAW.GUI.track_color_triangle_color = function(track)
  if not track then return CFG.TRACK_COLOR_TRIANGLE_DEFAULT_COLOR end
  local native_color = tonumber(r.GetTrackColor(track)) or 0
  if native_color == 0 then return CFG.TRACK_COLOR_TRIANGLE_DEFAULT_COLOR end

  -- REAPER native colors may include the custom-color flag. ColorFromNative
  -- expects the RGB payload and returns ordinary red, green, and blue bytes.
  local rr, gg, bb = r.ColorFromNative(native_color & 0xFFFFFF)
  rr = tonumber(rr) or 0
  gg = tonumber(gg) or 0
  bb = tonumber(bb) or 0
  return (rr << 24) | (gg << 16) | (bb << 8) | 0xFF
end

DAW.GUI.draw_track_color_triangle = function(draw_list, cell_x, cell_y, cell_w, cell_h, track)
  if not (
    draw_list
    and track
    and r.ImGui_DrawList_AddTriangleFilled
    and r.ImGui_DrawList_AddRectFilled
    and r.ImGui_DrawList_AddLine
  ) then
    return
  end

  local ratio = math.max(0.05, math.min(0.90, tonumber(CFG.TRACK_COLOR_TRIANGLE_SIZE_RATIO) or 0.48))
  local side_w = cell_w * ratio
  local lower_y = cell_y + (cell_h * ratio)
  local color = DAW.GUI.track_color_triangle_color(track)

  -- Mirrored dog-ears: show the original track colour on both upper corners
  -- instead of only the left corner. This makes the track colour readable even
  -- when the label/number is centered over a dark pad.
  r.ImGui_DrawList_AddTriangleFilled(
    draw_list,
    cell_x,
    cell_y,
    cell_x + side_w,
    cell_y,
    cell_x,
    lower_y,
    color
  )

  r.ImGui_DrawList_AddTriangleFilled(
    draw_list,
    cell_x + cell_w,
    cell_y,
    cell_x + cell_w - side_w,
    cell_y,
    cell_x + cell_w,
    lower_y,
    color
  )

  -- A small center cap gives a third quick read of the track colour while
  -- preserving a visible gap between the mirrored dog-ears.
  local cap_ratio = math.max(0.04, math.min(0.40, tonumber(CFG.TRACK_COLOR_CENTER_CAP_RATIO) or 0.18))
  local cap_h_ratio = math.max(0.04, math.min(0.30, tonumber(CFG.TRACK_COLOR_CENTER_CAP_HEIGHT_RATIO) or 0.12))
  local cap_w = cell_w * cap_ratio
  local cap_h = cell_h * cap_h_ratio
  local cap_x1 = cell_x + ((cell_w - cap_w) * 0.5)
  r.ImGui_DrawList_AddRectFilled(
    draw_list,
    cap_x1,
    cell_y,
    cap_x1 + cap_w,
    cell_y + cap_h,
    color
  )

  -- Draw diagonal separators on both mirrored dog-ears. Overshoot endpoints
  -- slightly so the separator reaches the pad edges cleanly.
  local overhang = math.max(0, tonumber(CFG.TRACK_COLOR_TRIANGLE_SEPARATOR_OVERHANG) or 0)
  local thickness = CFG.TRACK_COLOR_TRIANGLE_SEPARATOR_THICKNESS
  local separator = CFG.TRACK_COLOR_TRIANGLE_SEPARATOR_COLOR
  local function separator_line(x1, y1, x2, y2)
    local dx = x2 - x1
    local dy = y2 - y1
    local length = math.max(0.0001, math.sqrt((dx * dx) + (dy * dy)))
    local ux = dx / length
    local uy = dy / length
    r.ImGui_DrawList_AddLine(
      draw_list,
      x1 - (ux * overhang),
      y1 - (uy * overhang),
      x2 + (ux * overhang),
      y2 + (uy * overhang),
      separator,
      thickness
    )
  end

  separator_line(cell_x, lower_y, cell_x + side_w, cell_y)
  separator_line(cell_x + cell_w - side_w, cell_y, cell_x + cell_w, lower_y)
end
DAW.GUI.draw_track_identity_overlay = function(
  cell_x, cell_y, cell_w, cell_h, track, fallback, text_color, align_bottom,
  triangle_x, triangle_y, triangle_w, triangle_h
)
  if not track then return end

  local number_text = tostring(DAW.project_track_number(track, fallback))
  local name_text = DAW.short_track_name(track, 12)
  local draw_list = r.ImGui_GetWindowDrawList(ctx)

  if DAW.GUI.track_number_font and r.ImGui_PushFont then
    r.ImGui_PushFont(ctx, DAW.GUI.track_number_font, 16)
  end
  local number_w, number_h = r.ImGui_CalcTextSize(ctx, number_text)
  if DAW.GUI.track_number_font and r.ImGui_PopFont then
    r.ImGui_PopFont(ctx)
  end

  local name_w, name_h = 0, 0
  if name_text ~= "" then
    name_w, name_h = r.ImGui_CalcTextSize(ctx, name_text)
  end

  local gap = name_text ~= "" and 1 or 0
  local total_h = (number_h or 15) + gap + (name_h or 0)
  local text_y
  if align_bottom then
    text_y = cell_y + cell_h - total_h - 3
  else
    text_y = cell_y + math.max(2, (cell_h - total_h) * 0.5)
  end

  if DAW.GUI.track_number_font and r.ImGui_PushFont then
    r.ImGui_PushFont(ctx, DAW.GUI.track_number_font, 16)
  end
  local number_x = cell_x + math.max(2, (cell_w - (number_w or 0)) * 0.5)
  DAW.GUI.draw_track_color_triangle(
    draw_list,
    triangle_x or cell_x,
    triangle_y or cell_y,
    triangle_w or cell_w,
    triangle_h or cell_h,
    track
  )
  r.ImGui_DrawList_AddText(
    draw_list,
    number_x,
    text_y,
    text_color,
    number_text
  )
  -- A subtle second pass makes the track number read as bold while keeping the
  -- same portable sans-serif font on Windows and macOS.
  r.ImGui_DrawList_AddText(
    draw_list,
    number_x + 1,
    text_y,
    text_color,
    number_text
  )
  if DAW.GUI.track_number_font and r.ImGui_PopFont then
    r.ImGui_PopFont(ctx)
  end

  if name_text ~= "" then
    r.ImGui_DrawList_AddText(
      draw_list,
      cell_x + math.max(2, (cell_w - (name_w or 0)) * 0.5),
      text_y + (number_h or 15) + gap,
      text_color,
      name_text
    )
  end
end

DAW.GUI.current_screen_title = function()
  if surface_mode == "PROGRAMMER_TRACK_MATRIX" then
    local preset_number = DAW.active_preset or DAW.MATRIX.matrix_preset_for_mode(DAW.MATRIX.active_mode) or 3
    return string.format("Preset %d: %s", preset_number, DAW.preset_name(preset_number) or "Track Matrix")
  elseif surface_mode == "DAW_VOLUME_FADERS" or surface_mode == "CUSTOM_VOLUME_BANK" then
    local preset_number = DAW.active_preset or 1
    return string.format("Preset %d: %s", preset_number, DAW.preset_name(preset_number) or "Unnamed")
  elseif surface_mode == "TRACK_PICKER" then
    return DAW.TRACK_PICKER.screen_title()
  elseif surface_mode == "TRACK_VIEWER_SESSION" then
    return DAW.TRACK_VIEWER.screen_title and DAW.TRACK_VIEWER.screen_title() or "Preset 29: Track Viewer"
  elseif surface_mode == "REGIONS_MARKERS" then
    return "Preset 31: Regions & Markers"
  end
  return "HOME: Page " .. tostring(current_page)
end

local function compact_label_lines(raw_label, normalized, wired, is_page_status)
  local lines = {}

  if is_page_status then
    if current_page == 1 then return {"Basics"} end
    return {"Home", "Page", tostring(current_page)}
  end

  if DISPLAY_LINE_OVERRIDES[normalized] then
    for _, line in ipairs(DISPLAY_LINE_OVERRIDES[normalized]) do
      lines[#lines + 1] = line
    end
  elseif normalized == "Metronome" then
    lines = {"Metro-", "nome"}
  else
    for word in normalized:gmatch("%S+") do
      lines[#lines + 1] = word
    end
  end

  if #lines == 0 then
    lines[1] = " "
  end

  if not wired then
    lines[#lines + 1] = "x"
  end

  return lines
end

local function draw_compact_grid_button(id, lines, cell_w, cell_h, background, text_color, options)
  options = options or {}
  local x, y = r.ImGui_GetCursorScreenPos(ctx)
  local clicked = r.ImGui_InvisibleButton(ctx, id, cell_w, cell_h)
  local hovered = r.ImGui_IsItemHovered(ctx)
  local active = r.ImGui_IsItemActive(ctx)

  local fill = background
  if active then
    fill = brighten(background, 0.30)
  elseif hovered then
    fill = brighten(background, 0.18)
  end

  local draw_list = r.ImGui_GetWindowDrawList(ctx)
  local rounding = tonumber(options.rounding) or tonumber(CFG.GUI_GRID_BUTTON_ROUNDING) or 6
  r.ImGui_DrawList_AddRectFilled(draw_list, x, y, x + cell_w, y + cell_h, fill, rounding)

  local pushed_font = false
  if options.font and r.ImGui_PushFont then
    r.ImGui_PushFont(ctx, options.font, tonumber(options.font_size) or 0)
    pushed_font = true
  end

  local visible_lines = {}
  local max_lines = tonumber(options.max_lines) or #lines
  for index = 1, math.min(#lines, max_lines) do
    visible_lines[#visible_lines + 1] = lines[index]
  end
  if #visible_lines == 0 then visible_lines = {" "} end

  local _, measured_line_h = r.ImGui_CalcTextSize(ctx, "Ag")
  local line_h = measured_line_h or 14
  local total_h = (#visible_lines * line_h) + ((#visible_lines - 1) * CFG.TEXT_LINE_SPACING)
  local text_y = options.align_top
    and (y + 3)
    or (y + math.max(2, (cell_h - total_h) * 0.5))

  for _, line in ipairs(visible_lines) do
    local text_w = select(1, r.ImGui_CalcTextSize(ctx, line)) or 0
    local text_x = x + math.max(2, (cell_w - text_w) * 0.5)
    r.ImGui_DrawList_AddText(draw_list, text_x, text_y, text_color, line)
    if options.bold then
      r.ImGui_DrawList_AddText(draw_list, text_x + 1, text_y, text_color, line)
    end
    text_y = text_y + line_h + CFG.TEXT_LINE_SPACING
  end

  if pushed_font and r.ImGui_PopFont then r.ImGui_PopFont(ctx) end
  return clicked
end

DAW.GUI.capture_fader_gap_items = function(prefix, bounds_by_fader, orientation, cell_w, cell_h)
  if not (
    r.ImGui_SetCursorScreenPos
    and r.ImGui_GetCursorScreenPos
    and r.ImGui_InvisibleButton
    and r.ImGui_IsItemActive
  ) then
    return nil
  end

  local gap = math.max(0, tonumber(CFG.CELL_GAP) or 0)
  if gap <= 0 then return nil end

  local restore_x, restore_y = r.ImGui_GetCursorScreenPos(ctx)
  local captured_fader = nil

  for fader_number, bounds in pairs(bounds_by_fader or {}) do
    for gap_index = 1, 7 do
      local x, y, w, h
      if orientation == "horizontal" then
        x = bounds.x1 + (gap_index * cell_w) + ((gap_index - 1) * gap)
        y = bounds.y1
        w = gap
        h = cell_h
      else
        x = bounds.x1
        y = bounds.y1 + (gap_index * cell_h) + ((gap_index - 1) * gap)
        w = cell_w
        h = gap
      end

      r.ImGui_SetCursorScreenPos(ctx, x, y)
      r.ImGui_InvisibleButton(
        ctx,
        tostring(prefix) .. tostring(fader_number) .. "_" .. tostring(gap_index),
        math.max(1, w),
        math.max(1, h)
      )
      if r.ImGui_IsItemActive(ctx) then
        captured_fader = tonumber(fader_number)
      end
    end
  end

  r.ImGui_SetCursorScreenPos(ctx, restore_x, restore_y)

  -- ReaImGui requires an item to be submitted after SetCursorPos() or
  -- SetCursorScreenPos(). Without this final zero-size item, ImGui_End() can
  -- report that cursor positioning was used to extend the parent boundaries.
  r.ImGui_Dummy(ctx, 0, 0)

  return captured_fader
end

DAW.GUI.begin_grid_fader_drag = function(drag_state, fader_number, mouse_x, mouse_y, started_in_gap)
  if not drag_state or not fader_number then return end

  -- Once a gap press has established its anchor, do not reset that anchor on
  -- every defer cycle while the invisible gap strip remains active.
  if drag_state.active_fader == fader_number then return end

  drag_state.active_fader = fader_number
  drag_state.last_value = nil
  drag_state.started_in_gap = started_in_gap and true or false
  drag_state.start_x = tonumber(mouse_x) or 0
  drag_state.start_y = tonumber(mouse_y) or 0
end

DAW.GUI.grid_fader_drag_ready = function(drag_state, mouse_x, mouse_y)
  if not drag_state then return false end
  if not drag_state.started_in_gap then return true end

  local dx = math.abs((tonumber(mouse_x) or 0) - (tonumber(drag_state.start_x) or 0))
  local dy = math.abs((tonumber(mouse_y) or 0) - (tonumber(drag_state.start_y) or 0))
  if dx >= 2 or dy >= 2 then
    drag_state.started_in_gap = false
    return true
  end
  return false
end

DAW.REGIONS_MARKERS.location_display_lines = function(label)
  label = trim(tostring(label or ""))
  local base_label, bar_offset = DAW.REGIONS_MARKERS.parse_location_label(label)
  if bar_offset > 0 then
    return {base_label, "Bar " .. tostring(bar_offset)}
  end
  return {label}
end

DAW.REGIONS_MARKERS.display_lines = function(info)
  if not info then return {" "} end
  if info.kind == "status" then return {"Home", "Page", "1"} end

  local normalized = normalize_label(info.label or "")
  if info.kind == "location" then
    return DAW.REGIONS_MARKERS.location_display_lines(info.label)
  end

  local wired = DAW.REGIONS_MARKERS.cell_available(info)
  local lines = compact_label_lines(info.label or "", normalized, wired, false)

  if normalized == "Playback on Click" then return {"Playback", "on Click"} end
  if normalized == "Previous Section" then return {"Previous", "Section"} end
  if normalized == "Next Section" then return {"Next", "Section"} end
  if normalized == "Loop Section" then return {"Loop", "Section"} end
  if normalized == "Start - 2 Bars" then return {"Start", "- 2 Bars"} end
  if normalized == "Start - 1 Bars" then return {"Start", "- 1 Bar"} end
  if normalized == "Start Immediate" then return {"Start", "Immediate"} end
  if normalized == "MCP Volumes" then return {"MCP", "Volumes"} end
  if normalized == "MCP Select" then return {"MCP", "Select"} end
  if normalized == "Track Viewer" then return {"Track", "Viewer"} end
  if normalized == "GO HOME" then return {"GO", "HOME"} end

  return lines
end

DAW.REGIONS_MARKERS.draw_grid = function()
  DAW.GUI.draw_screen_title("Preset 31: Regions & Markers")
  DAW.REGIONS_MARKERS.refresh_targets(false)

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for row = 1, 9 do
    for col = 1, 9 do
      local info = DAW.REGIONS_MARKERS.cell_info(row, col)
      local background = DAW.REGIONS_MARKERS.cell_gui_color(info)
      if DAW.REGIONS_MARKERS.cell_pulses(info) then
        background = DAW.record_flash_gui_color(info and (info.home_label or info.label))
          or pulse_gui_color(background)
      end

      local text_color = readable_text_color(background)
      local draw_options = nil
      if info and info.kind == "status" then
        text_color = background
        background = DAW.PAGE_STATUS_GUI_BACKGROUND
        draw_options = DAW.GUI.page_status_draw_options()
      end
      local clicked = draw_compact_grid_button(
        "##regions_markers_" .. tostring(row) .. "_" .. tostring(col),
        DAW.REGIONS_MARKERS.display_lines(info),
        cell_w,
        cell_h,
        background,
        text_color,
        draw_options
      )

      if clicked then
        DAW.REGIONS_MARKERS.dispatch_cell(row, col, true, "GRID")
        DAW.REGIONS_MARKERS.dispatch_cell(row, col, false, "GRID")
      end

      if col < 9 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
    end
  end
end

DAW.USER_PAGES.first_three_lines = function(text)
  local result = {}
  for line in tostring(text or ""):gmatch("[^\r\n]+") do
    local clean_line = trim(line)
    if clean_line ~= "" then
      result[#result + 1] = clean_line
      if #result >= 3 then break end
    end
  end
  return result
end

DAW.USER_PAGES.display_lines = function(info)
  if not info then return {" "} end

  if info.kind == "slot" then
    local result = DAW.USER_PAGES.first_three_lines(info.label)
    if #result == 0 then result = {tostring(info.slot)} end
    return result
  end

  local label = normalize_label(info.label or "")
  if label == "Bank -40" then return {"BANK", "- 40"} end
  if label == "Bank +40" then return {"BANK", "+ 40"} end
  if label == "Step -10" then return {"STEP", "- 10"} end
  if label == "Step +10" then return {"STEP", "+ 10"} end
  if label == "GO HOME" then return {"GO", "HOME"} end

  if DISPLAY_LINE_OVERRIDES[label] then
    return DISPLAY_LINE_OVERRIDES[label]
  end

  local multiline = DAW.USER_PAGES.first_three_lines(info.label)
  if #multiline > 1 then return multiline end

  local result = {}
  for word in label:gmatch("%S+") do
    result[#result + 1] = word
    if #result >= 3 then break end
  end
  return #result > 0 and result or {" "}
end

DAW.USER_PAGES.grid_flash_on = function()
  return (math.floor(r.time_precise() * 4) % 2) == 0
end

DAW.USER_PAGES.draw_grid = function(page)
  DAW.GUI.draw_screen_title(page == 2 and "HOME Page 2: Actions" or "HOME Page 3: Customs")
  local avail_w,avail_h=r.ImGui_GetContentRegionAvail(ctx)
  local cell_w=math.max(CFG.MIN_CELL_W,(avail_w-(CFG.CELL_GAP*8))/9)
  local cell_h=math.max(CFG.MIN_CELL_H,(avail_h-(CFG.CELL_GAP*8))/9)
  local library = DAW.USER_PAGES.library(page)
  local editing_slot = DAW.USER_PAGES.editing_slot_for_page(page)
  local flashed_editor_slot=false

  for row=1,9 do
    for col=1,9 do
      local info=DAW.USER_PAGES.cell_info(page,row,col)
      local background=(info and info.gui)
        or DAW.USER_PAGES.palette_gui(info and info.color or 0)
      if (info and info.kind=="page" and info.value==page)
          or DAW.USER_PAGES.info_is_active(page,info) then
        background = DAW.record_flash_gui_color(info and (info.home_label or info.label))
          or pulse_gui_color(background)
      end

      local editing_flash = not flashed_editor_slot
        and info and info.kind=="slot"
        and tonumber(editing_slot)==tonumber(info.slot)
      if editing_flash then flashed_editor_slot=true end
      if editing_flash and not DAW.USER_PAGES.grid_flash_on() then
        background = 0x181818FF
      end

      local text_color = readable_text_color(background)
      local draw_options = {align_top = info and info.kind == "slot", max_lines = 3}
      if info and info.kind == "status" then
        text_color = background
        background = DAW.PAGE_STATUS_GUI_BACKGROUND
        draw_options = DAW.GUI.page_status_draw_options()
      end

      local clicked=draw_compact_grid_button(
        "##user_page_"..tostring(page).."_"..tostring(row).."_"..tostring(col),
        DAW.USER_PAGES.display_lines(info),
        cell_w,
        cell_h,
        background,
        text_color,
        draw_options
      )
      if clicked then
        DAW.USER_PAGES.run_cell(page,row,col,true,"GRID")
        DAW.USER_PAGES.run_cell(page,row,col,false,"GRID")
      end
      if col<9 then r.ImGui_SameLine(ctx,nil,CFG.CELL_GAP) end
    end
  end
end

local function draw_home_grid()
  if (current_page == 2 or current_page == 3) and DAW.USER_PAGES then
    return DAW.USER_PAGES.draw_grid(current_page)
  end
  DAW.GUI.draw_screen_title(DAW.GUI.current_screen_title())
  local page_labels = labels[current_page]
  local page_colors = gui_colors[current_page]

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for row = 1, 9 do
    for col = 1, 9 do
      local index = (row - 1) * 9 + col
      local raw_label = page_labels[row][col]
      local normalized = normalize_label(raw_label)
      local background = page_colors[index]
      local action = ACTIONS[normalized]
      local hold_action = HOLD_ACTIONS[normalized]
      local is_page_status = (normalized == "Page Status")
      local wired = action ~= nil or hold_action ~= nil or is_page_status
      local display_lines = compact_label_lines(raw_label, normalized, wired, is_page_status)
      local preset_lines = DAW.home_preset_lines(tonumber(normalized))
      if preset_lines then display_lines = preset_lines end

      local page_button_active = DAW.page_number_from_label(normalized) == current_page
      local state_active = page_button_active or is_label_active(normalized)
      if state_active then
        background = DAW.record_flash_gui_color(normalized) or pulse_gui_color(background)
      end

      local text_color = readable_text_color(background)
      local draw_options = nil
      if is_page_status then
        text_color = background
        background = DAW.PAGE_STATUS_GUI_BACKGROUND
        draw_options = DAW.GUI.page_status_draw_options()
      end
      local clicked = draw_compact_grid_button(
        "##cell_" .. row .. "_" .. col,
        display_lines,
        cell_w,
        cell_h,
        background,
        text_color,
        draw_options
      )

      if clicked then
        dispatch_index(index, "On-screen grid")
      end

      if col < 9 then
        r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
      end
    end
  end
end

-- Resident Custom Mode belongs to the Launchpad firmware.  Keep the helper
-- GRID useful without pretending that its dimmed scripted buttons describe the
-- hardware's active 8x8 Custom layout.  The bright outer-shell overrides below
-- provide an obvious HOME escape and direct resident Custom 1..8 switching.
DAW.CUSTOM_LIBRARY.active_external_custom_slot = function()
  local layout = tonumber(DAW.CUSTOM_LIBRARY.external_layout)
  if layout and layout >= 0x04 and layout <= 0x0B then
    return layout - 0x03
  end
  return nil
end

DAW.CUSTOM_LIBRARY.custom_payload_palettes = function(hex)
  local bytes = hex_text_to_bytes(hex)
  local palettes = {}
  for index = 1, 64 do palettes[index] = 0x01 end
  local cursor = 1
  while cursor <= #bytes - 3 do
    local block_type = bytes[cursor]
    local pad_index = bytes[cursor + 1]
    if block_type == 0x48 and pad_index and pad_index >= 0 and pad_index <= 63
        and bytes[cursor + 2] == 0x01 then
      palettes[pad_index + 1] = math.max(0,math.min(127,tonumber(bytes[cursor + 3]) or 0x01))
      cursor = cursor + 10
    elseif block_type == 0x40 and pad_index and pad_index >= 0 and pad_index <= 63 then
      palettes[pad_index + 1] = 0x01
      cursor = cursor + 2
    else
      cursor = cursor + 1
    end
  end
  return palettes
end

DAW.CUSTOM_LIBRARY.custom_grid_payload_index = function(label_row,col)
  -- Components-style Custom payload rows align with the visible top-to-bottom
  -- Button Labels grid used by the resident-Custom preview.  Do not reverse
  -- rows here: doing so vertically flips the GUI colors while the hardware
  -- remains correct.
  return ((label_row - 1) * 8) + (col - 1)
end

DAW.CUSTOM_LIBRARY.custom_payload_visuals = function(entry,payload_slot)
  if not entry or not payload_slot then return nil end
  local labels_text = tostring(entry.custom_labels and entry.custom_labels[payload_slot] or "")
  if trim(labels_text) == "" then return nil end
  local payload = tostring(entry.customs and entry.customs[payload_slot] or "")
  local signature = payload .. "\0" .. labels_text
  local cached = DAW.CUSTOM_LIBRARY.payload_visual_cache[signature]
  if cached then return cached end
  local rows, err = DAW.CUSTOM_LIBRARY.parse_button_labels_text(labels_text)
  if not rows then return nil,err end
  local palettes = DAW.CUSTOM_LIBRARY.custom_payload_palettes(payload)
  local visuals = {labels=rows,palettes=palettes}
  DAW.CUSTOM_LIBRARY.payload_visual_cache[signature] = visuals
  return visuals
end

DAW.CUSTOM_LIBRARY.active_external_visuals = function(active_slot)
  local entry,payload_slot,entry_index = DAW.CUSTOM_LIBRARY.resident_source(active_slot)
  if not entry then return nil end
  local visuals = DAW.CUSTOM_LIBRARY.custom_payload_visuals(entry,payload_slot)
  if not visuals then return nil end
  return visuals,entry,payload_slot,entry_index
end

DAW.CUSTOM_LIBRARY.external_grid_base_cell = function(page,row,col)
  local index = ((row - 1) * 9) + col
  if (page == 2 or page == 3) and DAW.USER_PAGES then
    local info = DAW.USER_PAGES.cell_info(page,row,col)
    local background = (info and info.gui)
      or DAW.USER_PAGES.palette_gui(info and info.color or 0)
    local editing_slot = DAW.USER_PAGES.editing_slot_for_page(page)
    return {
      lines = DAW.USER_PAGES.display_lines(info),
      background = background,
      -- Preserve the ordinary HOME Page 2/3 visual feedback inside the dimmed
      -- resident-Custom shell.  The shell dims the calculated result later; it
      -- must not replace the underlying button-state animation.
      pulse = (info and info.kind == "page" and info.value == page)
        or DAW.USER_PAGES.info_is_active(page,info),
      flash = info and info.kind == "slot"
        and tonumber(editing_slot) == tonumber(info.slot),
      status = info and info.kind == "status",
      status_text_color = background,
      run = function()
        DAW.USER_PAGES.run_cell(page,row,col,true,"Custom-mode GRID")
        DAW.USER_PAGES.run_cell(page,row,col,false,"Custom-mode GRID")
      end,
    }
  end

  local raw_label = labels[page][row][col]
  local normalized = normalize_label(raw_label)
  local background = gui_colors[page][index]
  local action = ACTIONS[normalized]
  local hold_action = HOLD_ACTIONS[normalized]
  local is_page_status = normalized == "Page Status"
  local wired = action ~= nil or hold_action ~= nil or is_page_status
  local display_lines = compact_label_lines(raw_label, normalized, wired, is_page_status)
  local preset_lines = DAW.home_preset_lines(tonumber(normalized))
  if preset_lines then display_lines = preset_lines end
  return {
    label = normalized,
    lines = display_lines,
    background = background,
    status = is_page_status,
    status_text_color = background,
    -- HOME Page 1 uses these flags for its fade-in/fade-out status cues.  Keep
    -- them alive while Custom Mode is active, then apply the shell dimming.
    pulse = (DAW.page_number_from_label(normalized) == page)
      or is_label_active(normalized),
    run = function() dispatch_index(index,"Custom-mode GRID") end,
  }
end

DAW.CUSTOM_LIBRARY.external_grid_cell = function(page,row,col,active_slot,custom_visuals)
  -- In the labeled resident-Custom preview the inner 8x8 already mirrors the
  -- hardware. The normal Page 2/3 bank-navigation controls have no useful
  -- meaning here, so leave header columns 1-4 intentionally blank.
  if custom_visuals and row == 1 and col >= 1 and col <= 4 then
    return {lines={" "}, background=0x181818FF, emphasis=true}
  end

  -- Header column 6 is the on-screen equivalent of pressing Notes to leave the
  -- Launchpad's resident Custom Mode.  UNDO moves into REDO's old position;
  -- REDO is intentionally removed while this alternate shell is displayed.
  -- Patch 35 paired-layout Custom shell:
  -- Only GO HOME should be active in the header. SAVE / UNDO / PANIC / etc.
  -- are intentionally disabled while the Launchpad firmware owns the Custom.
  if custom_visuals
      and tonumber(DAW.custom_external_return_page or 3) == 1
      and row == 1
      and col ~= 6
      and col ~= 9 then
    return {
      lines = {"NA"},
      background = 0x181818FF,
      emphasis = true,
    }
  end
  
  if row == 1 and col == 6 then
    return {
      lines = {"GO","HOME"},
      background = 0xFFFFFFFF,
      emphasis = true,
      run = function()
        local return_page =
          math.max(1, math.min(3, math.floor(tonumber(DAW.custom_external_return_page) or 3)))
        
        local msg =
          DAW.custom_external_return_message
          or ("GO HOME: returned to HOME Page " .. tostring(return_page))
        
        if return_page == 3 then
          return_to_home_page_1(msg, false, 3, true)
        else
          return_to_home_page_1(msg, false, return_page, false)
        end
      end,
    }
  elseif row == 1 and col == 7 then
    return {
      lines = {"UNDO"},
      background = 0x61A1DDFF,
      emphasis = true,
      run = function() ACTIONS["UNDO"]() end,
    }
  elseif row == 1 and col == 9 then
    return {
      lines = {"Custom",tostring(active_slot),"Active"},
      background = DAW.PAGE_STATUS_GUI_BACKGROUND,
      status = true,
      status_text_color = 0x8456C7FF,
      emphasis = true,
    }
  elseif col == 9 and row >= 2 and row <= 9 then
    local slot = row - 1
    return {
      lines = {"Custom",tostring(slot)},
      background = (slot == active_slot) and 0x8456C7FF or 0x454545FF,
      emphasis = true,
      active = slot == active_slot,
      run = function() DAW.CUSTOM_LIBRARY.switch_to_slot(slot) end,
    }
  elseif custom_visuals and row >= 2 and row <= 9 and col >= 1 and col <= 8 then
    local label_row = row - 1
    local payload_index = DAW.CUSTOM_LIBRARY.custom_grid_payload_index(label_row,col)
    local palette = custom_visuals.palettes[payload_index + 1] or 0x01
    return {
      lines = compact_label_lines(custom_visuals.labels[label_row][col],custom_visuals.labels[label_row][col],true,false),
      background = DAW.USER_PAGES.palette_gui(palette),
      custom_label = true,
    }
  end

  return DAW.CUSTOM_LIBRARY.external_grid_base_cell(page,row,col)
end

DAW.CUSTOM_LIBRARY.draw_external_custom_grid = function()
  local active_slot = DAW.CUSTOM_LIBRARY.active_external_custom_slot()
  if not active_slot then return draw_home_grid() end

  local custom_visuals,source_entry = DAW.CUSTOM_LIBRARY.active_external_visuals(active_slot)
  local title = "Launchpad Custom " .. tostring(active_slot) .. " Active"
  if source_entry and trim(source_entry.name or "") ~= "" then
    title = title .. " — " .. trim(source_entry.name)
  end
  DAW.GUI.draw_screen_title(title)
  if custom_visuals then
    r.ImGui_TextWrapped(
      ctx,
      'The labeled 8x8 grid below mirrors the Launchpad\'s custom mode. Press its "Note" pad or click GO HOME below to return to HOME.'
    )
  else
    r.ImGui_TextWrapped(
      ctx,
      'The dimmed grid below and Launchpad hardware are working separately until you leave the Launchpad\'s custom mode by pressing its "Note" pad or clicking GO HOME below.'
    )
  end
  r.ImGui_Spacing(ctx)

  local avail_w,avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W,(avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H,(avail_h - (CFG.CELL_GAP * 8)) / 9)

  for row = 1,9 do
    for col = 1,9 do
      local info = DAW.CUSTOM_LIBRARY.external_grid_cell(current_page,row,col,active_slot,custom_visuals)
      local background = info and info.background or CUSTOM_FADER_OFF_COLOR
      -- Calculate the underlying scripted GRID animation first, then dim the
      -- result.  This keeps useful fade-in/fade-out status feedback visible
      -- without implying that the dimmed GRID mirrors the Custom hardware.
      if info and info.pulse then
        background = DAW.record_flash_gui_color(info.label) or pulse_gui_color(background)
      end
      if info and info.flash and not DAW.USER_PAGES.grid_flash_on() then
        background = 0x181818FF
      end
      -- A named Custom payload preview mirrors the Launchpad's inner 8x8
      -- surface, so show those cells at full brightness.  The dimmed fallback
      -- applies only when the script lacks Button Labels and is deliberately
      -- showing its separate scripted GRID underneath the resident Custom mode.
      if not (info and (info.emphasis or info.custom_label)) then
        background = scale_color(background,0.48)
      elseif info.active then
        background = pulse_gui_color(background)
      end
      local text_color = readable_text_color(background)
      local draw_options = {max_lines = 3}
      if info and info.status then
        text_color = info.status_text_color or background
        background = DAW.PAGE_STATUS_GUI_BACKGROUND
        draw_options = DAW.GUI.page_status_draw_options()
      end
      local clicked = draw_compact_grid_button(
        "##external_custom_" .. tostring(row) .. "_" .. tostring(col),
        (info and info.lines) or {" "},
        cell_w,
        cell_h,
        background,
        text_color,
        draw_options
      )
      if clicked and info and info.run then info.run() end
      if col < 9 then r.ImGui_SameLine(ctx,nil,CFG.CELL_GAP) end
    end
  end
end

DAW.TRACK_PICKER.draw_grid = function()
  DAW.GUI.draw_screen_title(DAW.TRACK_PICKER.screen_title())
  local page = DAW.TRACK_PICKER.page
  local page_labels = labels[page]
  local page_colors = gui_colors[page]
  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for row = 1, 9 do
    for col = 1, 9 do
      local index = (row - 1) * 9 + col
      local normalized = normalize_label(page_labels[row][col])
      local background = page_colors[index]
      local display_lines
      local wired = false
      local is_page_status = false

      if row >= 2 and col <= 5 then
        local track_number = DAW.TRACK_PICKER.track_number_at_cell(row, col)
        local track = track_number and r.GetTrack(0, track_number - 1) or nil
        background = DAW.TRACK_PICKER.track_color_for_inner_row(row - 1, true)
        if track then
          display_lines = {tostring(track_number)}
          wired = true
        else
          display_lines = {" "}
          background = CUSTOM_FADER_OFF_COLOR
        end
      else
        is_page_status = normalized == "Page Status"
        local action = ACTIONS[normalized]
        local hold_action = HOLD_ACTIONS[normalized]
        wired = action ~= nil or hold_action ~= nil or is_page_status
        if DAW.page_number_from_label(normalized) then wired = true end

        if is_page_status then
          display_lines = {"Track", "Picker", "Page " .. tostring(page)}
        elseif normalized == "Save Project" then
          display_lines = {"GO", "HOME"}
          wired = true
        else
          display_lines = compact_label_lines(page_labels[row][col], normalized, wired, false)
        end

        local page_button_active = DAW.page_number_from_label(normalized) == page
        if page_button_active or is_label_active(normalized) then
          background = DAW.record_flash_gui_color(normalized) or pulse_gui_color(background)
        end
      end

      local text_color = readable_text_color(background)
      local draw_options = nil
      if is_page_status then
        text_color = background
        background = DAW.PAGE_STATUS_GUI_BACKGROUND
        draw_options = DAW.GUI.page_status_draw_options()
      end
      local cell_x, cell_y = r.ImGui_GetCursorScreenPos(ctx)
      local clicked = draw_compact_grid_button(
        "##track_picker_" .. tostring(row) .. "_" .. tostring(col),
        display_lines,
        cell_w,
        cell_h,
        background,
        text_color,
        draw_options
      )
      if row >= 2 and col <= 5 then
        local track_number = DAW.TRACK_PICKER.track_number_at_cell(row, col)
        local track = track_number and r.GetTrack(0, track_number - 1) or nil
        if track then
          DAW.GUI.draw_track_color_triangle(
            r.ImGui_GetWindowDrawList(ctx),
            cell_x, cell_y, cell_w, cell_h,
            track
          )
        end
      end
      if clicked and wired then
        DAW.TRACK_PICKER.dispatch_index(index, "GRID")
      end
      if col < 9 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
    end
  end
end

DAW.TRACK_VIEWER.draw_grid = function()
  if DAW.TRACK_VIEWER.draw_grid_impl then
    return DAW.TRACK_VIEWER.draw_grid_impl()
  end
end

local function custom_fader_stage_color(column_color, stage_count, segment_from_bottom)
  local segment_stage_start = ((segment_from_bottom - 1) * 4) + 1
  local level = stage_count - segment_stage_start + 1

  if level >= 4 then
    return column_color
  elseif level == 3 then
    return scale_color(column_color, 0.76)
  elseif level == 2 then
    return scale_color(column_color, 0.56)
  elseif level == 1 then
    return scale_color(column_color, 0.34)
  end

  return CUSTOM_FADER_OFF_COLOR
end

local function custom_fader_stage_count_for_track(track)
  if not DAW.target_is_available(track) then return 0 end
  local midi_value = track_target_to_midi_cc(track)

  -- Native Novation fader value 0 still lights the bottom pad faintly. Map the
  -- available CC range onto stages 1..32: four brightness levels for each of
  -- the eight physical pads. Stage 0 is GUI-only and represents an unavailable
  -- track rather than a valid fader value.
  return 1 + math.floor((midi_value / 127) * (CUSTOM_FADER_STAGE_COUNT - 1) + 0.5)
end


local function set_custom_fader_volume_from_gui(custom_slot, fader_number, midi_value)
  refresh_mcp_track_cache(false)

  custom_slot = custom_slot or 1
  fader_number = math.max(1, math.min(8, fader_number or 1))
  midi_value = math.max(0, math.min(127, math.floor((tonumber(midi_value) or 0) + 0.5)))

  local start_index = (surface_mode == "DAW_VOLUME_FADERS")
    and DAW.current_start_track()
    or (((custom_slot - 1) * 8) + 1)
  local visible_track_index = start_index + fader_number - 1
  local track = DAW.active_fader_track_list()[visible_track_index]
  if not DAW.target_is_available(track) then
    last_action = DAW.active_scope_label() .. "-visible track " .. tostring(visible_track_index) .. " or its target is unavailable"
    return false
  end

  apply_midi_cc_to_track_target(track, midi_value)

  -- A GUI click originates on the computer, so allow the normal outbound poll
  -- to update the Novation immediately. Clearing the remembered value guarantees
  -- a feedback CC even if the selected stage happens to match an older state.
  custom_fader_hardware_holdoff_until[fader_number] = 0
  last_sent_custom_fader_values[fader_number] = nil
  last_custom_fader_feedback_poll_time = -1000000
  mcp_ui_dirty = true
  last_action = string.format(
    "GUI %s -> fader %d -> %s-visible track %d: value %d",
    DAW.active_parameter_label(),
    fader_number,
    DAW.active_scope_label(),
    visible_track_index,
    midi_value
  )
  return true
end

local function draw_custom_go_back_footer(cell_x, cell_y, cell_w, cell_h)
  local footer_h = math.max(11, math.min(16, cell_h * 0.20))
  local pad = 3
  local x1 = cell_x + pad
  local y1 = cell_y + pad
  local x2 = cell_x + cell_w - pad
  local y2 = cell_y + footer_h + pad
  local draw_list = r.ImGui_GetWindowDrawList(ctx)

  r.ImGui_DrawList_AddRectFilled(draw_list, x1, y1, x2, y2, CUSTOM_FADER_GO_BACK_FOOTER_COLOR)

  if custom_footer_font and r.ImGui_PushFont then
    r.ImGui_PushFont(ctx, custom_footer_font, 9)
  end
  local caption = "(GO HOME)"
  local text_w, text_h = r.ImGui_CalcTextSize(ctx, caption)
  local text_x = x1 + math.max(1, ((x2 - x1) - (text_w or 0)) * 0.5)
  local text_y = y1 + math.max(0, ((y2 - y1) - (text_h or 0)) * 0.5)
  r.ImGui_DrawList_AddText(draw_list, text_x, text_y, CUSTOM_FADER_GO_BACK_TEXT_COLOR, caption)
  if custom_footer_font and r.ImGui_PopFont then
    r.ImGui_PopFont(ctx)
  end
end

local function custom_fader_midi_value_from_grid_y(y1, y2)
  local _, mouse_y = r.ImGui_GetMousePos(ctx)
  local height = math.max(1, y2 - y1)
  local normalized = 1 - ((mouse_y - y1) / height)
  normalized = math.max(0, math.min(1, normalized))
  return math.floor((normalized * 127) + 0.5)
end


------------------------------------------------------------------
-- TRACK VIEWER: DAW SESSION / FADER SURFACE (PRESET 29)
------------------------------------------------------------------
-- Track Viewer deliberately uses the Launchpad X DAW In/Out interface rather
-- than a resident Custom Mode. Four firmware DAW faders occupy the first four
-- columns. DAW Session note states provide the central buttons in columns 5-8.
-- DAW Session CC states provide the top row and right-side group selectors.

DAW.TRACK_VIEWER.surface_is_active = function()
  return surface_mode == "TRACK_VIEWER_SESSION"
end

DAW.TRACK_VIEWER.project_track_number = function(track)
  if not track then return nil end
  if track == r.GetMasterTrack(0) then return 0 end
  return math.floor((r.GetMediaTrackInfo_Value(track, "IP_TRACKNUMBER") or 0) + 0.5)
end

DAW.TRACK_VIEWER.track_name = function(track)
  if not track then return "No Track" end
  if track == r.GetMasterTrack(0) then return "MASTER" end
  local ok, name = r.GetTrackName(track)
  name = ok and trim(name or "") or ""
  if name == "" then
    local number = DAW.TRACK_VIEWER.project_track_number(track)
    return "Track " .. tostring(number or "?")
  end
  return name
end

DAW.TRACK_VIEWER.count_selected_tracks = function()
  if r.CountSelectedTracks2 then return r.CountSelectedTracks2(0, true) end
  return r.CountSelectedTracks(0)
end

DAW.TRACK_VIEWER.selected_track_at = function(index)
  if r.GetSelectedTrack2 then return r.GetSelectedTrack2(0, index, true) end
  return r.GetSelectedTrack(0, index)
end

DAW.TRACK_VIEWER.is_track_selected = function(track)
  return track and r.IsTrackSelected and r.IsTrackSelected(track) or false
end

DAW.TRACK_VIEWER.adopt_viewed_track = function(track)
  if not track then return false end
  DAW.TRACK_VIEWER.selected_track = track
  DAW.TRACK_VIEWER.selected_track_number = DAW.TRACK_VIEWER.project_track_number(track)
  DAW.active_preset = (track == r.GetMasterTrack(0)) and 30 or 29
  return true
end

DAW.TRACK_VIEWER.toggle_view_lock = function()
  DAW.TRACK_VIEWER.locked_to_track = not DAW.TRACK_VIEWER.locked_to_track
  DAW.TRACK_VIEWER.surface_identity = nil
  DAW.TRACK_VIEWER.refresh_button_surface(true)
  last_action = DAW.TRACK_VIEWER.locked_to_track
    and ("Track Viewer locked to " .. DAW.TRACK_VIEWER.track_name(DAW.TRACK_VIEWER.selected_track))
    or "Track Viewer focus unlocked"
  return true
end

DAW.TRACK_VIEWER.toggle_viewed_track_selection = function()
  local track = DAW.TRACK_VIEWER.selected_track
  if not track then return false end
  local selected = DAW.TRACK_VIEWER.is_track_selected(track)
  r.SetTrackSelected(track, not selected)
  if r.TrackList_AdjustWindows then r.TrackList_AdjustWindows(false) end
  if r.UpdateArrange then r.UpdateArrange() end
  DAW.TRACK_VIEWER.remember_selection_signature()
  DAW.TRACK_VIEWER.surface_identity = nil
  DAW.TRACK_VIEWER.refresh_button_surface(true)
  last_action = selected
    and "Track Viewer: deselected viewed track"
    or "Track Viewer: selected viewed track"
  return true
end

DAW.TRACK_VIEWER.begin_select_hold = function(source)
  local hold = DAW.TRACK_VIEWER.select_hold
  if hold.active then return true end
  hold.active = true
  hold.source = source or "unknown"
  hold.start_time = r.time_precise()
  hold.lock_triggered = false
  return true
end

DAW.TRACK_VIEWER.process_select_hold = function(now)
  local hold = DAW.TRACK_VIEWER.select_hold
  if not hold.active or hold.lock_triggered then return false end
  if (tonumber(now) or r.time_precise()) - hold.start_time < DAW.TRACK_VIEWER.LOCK_HOLD_SECONDS then
    return false
  end
  hold.lock_triggered = true
  return DAW.TRACK_VIEWER.toggle_view_lock()
end

DAW.TRACK_VIEWER.end_select_hold = function(source)
  local hold = DAW.TRACK_VIEWER.select_hold
  if not hold.active then return false end
  if source and hold.source and source ~= hold.source then return false end
  local triggered = hold.lock_triggered
  hold.active = false
  hold.source = nil
  hold.start_time = 0
  hold.lock_triggered = false
  if not triggered then
    return DAW.TRACK_VIEWER.toggle_viewed_track_selection()
  end
  return true
end

DAW.TRACK_VIEWER.draw_lock_indicator = function(cell_x, cell_y, cell_w, cell_h)
  if not DAW.TRACK_VIEWER.locked_to_track then return end
  local draw_list = r.ImGui_GetWindowDrawList(ctx)
  if not draw_list then return end

  local right = cell_x + cell_w - 7
  local top = cell_y + 7
  local left = right - 12
  local body_top = top + 6
  local body_bottom = body_top + 9
  local color = 0xFFFFFFFF
  local brim = 0x000000FF

  r.ImGui_DrawList_AddRectFilled(draw_list, left - 1, body_top - 1, right + 1, body_bottom + 1, brim)
  r.ImGui_DrawList_AddRectFilled(draw_list, left, body_top, right, body_bottom, color)
  if r.ImGui_DrawList_AddLine then
    r.ImGui_DrawList_AddLine(draw_list, left + 2, body_top, left + 2, top + 3, color, 2)
    r.ImGui_DrawList_AddLine(draw_list, left + 2, top + 3, right - 2, top + 3, color, 2)
    r.ImGui_DrawList_AddLine(draw_list, right - 2, top + 3, right - 2, body_top, color, 2)
  end
end

DAW.TRACK_VIEWER.resolve_track = function(track_number)
  track_number = tonumber(track_number)
  if track_number ~= nil then
    if track_number <= 0 then return r.GetMasterTrack(0) end
    return r.GetTrack(0, track_number - 1)
  end

  local selected = DAW.TRACK_VIEWER.selected_track_at(0)
  if selected then return selected end

  local first = r.GetTrack(0, 0)
  if first then return first end

  return r.GetMasterTrack(0)
end

DAW.TRACK_VIEWER.select_track = function(track, preserve_selection)
  if not track then return false end
  DAW.TRACK_VIEWER.adopt_viewed_track(track)

  if not preserve_selection then
    local master = r.GetMasterTrack(0)
    if track == master then
      for i = 0, r.CountTracks(0) - 1 do
        local candidate = r.GetTrack(0, i)
        if candidate then r.SetTrackSelected(candidate, false) end
      end
      r.SetTrackSelected(master, true)
    else
      if master then r.SetTrackSelected(master, false) end
      if r.SetOnlyTrackSelected then
        r.SetOnlyTrackSelected(track)
      else
        for i = 0, r.CountTracks(0) - 1 do
          local candidate = r.GetTrack(0, i)
          if candidate then r.SetTrackSelected(candidate, candidate == track) end
        end
      end
      if r.SetMixerScroll then r.SetMixerScroll(track) end
    end
  end

  if r.UpdateArrange then r.UpdateArrange() end
  return true
end

DAW.TRACK_VIEWER.selection_signature = function()
  local parts = {}
  for i = 0, DAW.TRACK_VIEWER.count_selected_tracks() - 1 do
    parts[#parts + 1] = tostring(DAW.TRACK_VIEWER.selected_track_at(i))
  end
  return table.concat(parts, "|")
end

DAW.TRACK_VIEWER.remember_selection_signature = function()
  DAW.TRACK_VIEWER.last_selection_signature = DAW.TRACK_VIEWER.selection_signature()
  local touched = r.GetLastTouchedTrack and r.GetLastTouchedTrack() or nil
  DAW.TRACK_VIEWER.last_touched_selected_track =
    (touched and DAW.TRACK_VIEWER.is_track_selected(touched))
      and touched
      or nil
end

DAW.TRACK_VIEWER.follow_reaper_selection = function()
  if not DAW.TRACK_VIEWER.surface_is_active() then return false end
  if DAW.TRACK_VIEWER.locked_to_track then return false end

  local signature = DAW.TRACK_VIEWER.selection_signature()
  local touched = r.GetLastTouchedTrack and r.GetLastTouchedTrack() or nil
  local touched_selected =
    (touched and DAW.TRACK_VIEWER.is_track_selected(touched))
      and touched
      or nil

  if signature == (DAW.TRACK_VIEWER.last_selection_signature or "")
      and touched_selected == DAW.TRACK_VIEWER.last_touched_selected_track then
    return false
  end
  DAW.TRACK_VIEWER.last_selection_signature = signature
  DAW.TRACK_VIEWER.last_touched_selected_track = touched_selected

  local count = DAW.TRACK_VIEWER.count_selected_tracks()
  if count <= 0 then return false end

  -- GetLastTouchedTrack is the best available indication of the track the user
  -- most recently acted upon with the mouse. Fall back to the newest enumerated
  -- selected track if REAPER does not expose a selected last-touched track.
  local track = touched_selected or DAW.TRACK_VIEWER.selected_track_at(count - 1)
  if not track or track == DAW.TRACK_VIEWER.selected_track then return false end

  DAW.TRACK_VIEWER.cancel_all_fades()
  DAW.TRACK_VIEWER.adopt_viewed_track(track)
  DAW.TRACK_VIEWER.layout_identity = nil
  DAW.TRACK_VIEWER.surface_identity = nil
  DAW.TRACK_VIEWER.rebuild_surface(true)
  last_action = "Track Viewer followed REAPER selection: "
    .. DAW.TRACK_VIEWER.track_name(track)
  return true
end

DAW.TRACK_VIEWER.track_rgb = function(track)
  local native = track and (tonumber(r.GetTrackColor(track)) or 0) or 0
  if native == 0 then return 0xB1B1B1 end
  local rr, gg, bb = r.ColorFromNative(native & 0xFFFFFF)
  rr, gg, bb = tonumber(rr) or 177, tonumber(gg) or 177, tonumber(bb) or 177
  return (rr << 16) | (gg << 8) | bb
end

DAW.TRACK_VIEWER.gui_rgba_from_rgb = function(rgb)
  rgb = tonumber(rgb) or 0xB1B1B1
  return ((rgb & 0xFFFFFF) << 8) | 0xFF
end

DAW.TRACK_VIEWER.nearest_palette = function(rgb)
  rgb = tonumber(rgb) or 0xB1B1B1
  local rr, gg, bb = (rgb >> 16) & 0xFF, (rgb >> 8) & 0xFF, rgb & 0xFF
  local best_index, best_distance = 0x03, math.huge

  for _, choice in ipairs(DAW.TRACK_VIEWER.MATCH_PALETTE) do
    local candidate = choice.rgb or 0
    local cr, cg, cb = (candidate >> 16) & 0xFF, (candidate >> 8) & 0xFF, candidate & 0xFF
    local dr, dg, db = rr - cr, gg - cg, bb - cb
    local distance = (dr * dr * 0.30) + (dg * dg * 0.59) + (db * db * 0.11)
    if distance < best_distance then
      best_distance = distance
      best_index = choice.index
    end
  end

  return best_index
end

DAW.TRACK_VIEWER.palette_gui_color = function(palette, row)
  palette = tonumber(palette) or 0x00
  if palette == 0x00 then return CUSTOM_FADER_OFF_COLOR end

  -- Prefer the curated RGB approximations sampled from the photographed
  -- Launchpad hardware palette. This keeps the helper GRID close to what the
  -- physical controller actually displays, including the Color Track banks.
  for _, choice in ipairs(DAW.TRACK_VIEWER.COLOR_CHOICES) do
    if choice.palette == palette then
      return DAW.TRACK_VIEWER.gui_rgba_from_rgb(choice.rgb)
    end
  end
  for _, choice in ipairs(DAW.TRACK_VIEWER.MATCH_PALETTE) do
    if choice.index == palette then
      return DAW.TRACK_VIEWER.gui_rgba_from_rgb(choice.rgb)
    end
  end

  return DAW_MATRIX_PALETTE_TO_GUI_COLOR[palette]
    or CUSTOM_FADER_GUI_COLORS[((tonumber(row) or 1) - 1) % 8 + 1]
    or CUSTOM_FADER_OFF_COLOR
end

DAW.TRACK_VIEWER.send_indices = function()
  local bank = math.max(1, math.min(8, tonumber(DAW.TRACK_VIEWER.bank) or 1))
  return ((bank - 1) * 2), ((bank - 1) * 2) + 1
end

DAW.TRACK_VIEWER.fx_or_color_base = function()
  local bank = math.max(1, math.min(8, tonumber(DAW.TRACK_VIEWER.bank) or 1))
  if bank <= 4 then return "fx", ((bank - 1) * 8) end
  return "color", ((bank - 5) * 8)
end

DAW.TRACK_VIEWER.fader_available = function(fader_number)
  local track = DAW.TRACK_VIEWER.selected_track
  if not track then return false end
  if fader_number == 1 or fader_number == 2 then return true end
  local send_a, send_b = DAW.TRACK_VIEWER.send_indices()
  local send_index = (fader_number == 3) and send_a or send_b
  return send_index < (r.GetTrackNumSends(track, 0) or 0)
end

DAW.TRACK_VIEWER.fader_palette = function(fader_number)
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return 0x00 end
  if fader_number == 1 or fader_number == 2 then
    return DAW.TRACK_VIEWER.nearest_palette(
      DAW.TRACK_VIEWER.track_rgb(DAW.TRACK_VIEWER.selected_track)
    )
  end
  return (fader_number == 3) and 0x0C or 0x15
end

DAW.TRACK_VIEWER.fader_gui_color = function(fader_number)
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return CUSTOM_FADER_OFF_COLOR end
  if fader_number == 1 or fader_number == 2 then
    return DAW.TRACK_VIEWER.gui_rgba_from_rgb(
      DAW.TRACK_VIEWER.track_rgb(DAW.TRACK_VIEWER.selected_track)
    )
  end
  return (fader_number == 3) and CUSTOM_FADER_GUI_COLORS[3] or CUSTOM_FADER_GUI_COLORS[4]
end

DAW.TRACK_VIEWER.fader_label = function(fader_number)
  if fader_number == 1 then return "Volume" end
  if fader_number == 2 then return "Pan" end
  local send_a, send_b = DAW.TRACK_VIEWER.send_indices()
  local index = (fader_number == 3) and send_a or send_b
  return "Send " .. tostring(index + 1)
end

DAW.TRACK_VIEWER.fader_value = function(fader_number)
  local track = DAW.TRACK_VIEWER.selected_track
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return 0 end

  if fader_number == 1 then
    return track_volume_to_midi_cc(r.GetMediaTrackInfo_Value(track, "D_VOL"))
  elseif fader_number == 2 then
    return track_pan_to_midi_cc(r.GetMediaTrackInfo_Value(track, "D_PAN"))
  end

  local send_a, send_b = DAW.TRACK_VIEWER.send_indices()
  local index = (fader_number == 3) and send_a or send_b
  return track_volume_to_midi_cc(r.GetTrackSendInfo_Value(track, 0, index, "D_VOL"))
end

DAW.TRACK_VIEWER.set_fader_value = function(fader_number, value, source)
  local track = DAW.TRACK_VIEWER.selected_track
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return false end

  value = math.max(0, math.min(127, math.floor((tonumber(value) or 0) + 0.5)))
  if fader_number == 1 then
    r.SetMediaTrackInfo_Value(track, "D_VOL", midi_cc_to_track_volume(value))
  elseif fader_number == 2 then
    r.SetMediaTrackInfo_Value(track, "D_PAN", midi_cc_to_track_pan(value))
  else
    local send_a, send_b = DAW.TRACK_VIEWER.send_indices()
    local index = (fader_number == 3) and send_a or send_b
    r.SetTrackSendInfo_Value(track, 0, index, "D_VOL", midi_cc_to_track_volume(value))
  end

  mcp_ui_dirty = true
  if source ~= "emulated fade" then
    last_action = string.format(
      "Track Viewer %s: %s = %d",
      source or "fader",
      DAW.TRACK_VIEWER.fader_label(fader_number),
      value
    )
  end
  return true
end


DAW.TRACK_VIEWER.ensure_fade_state = function(fader_number)
  local state = DAW.TRACK_VIEWER.fade_states[fader_number]
  if not state then
    state = {
      active = false,
      start_value = 0,
      target_value = 0,
      expected_value = 0,
      last_written_value = nil,
      start_time = 0,
      duration = 0,
      last_update_time = -1000000,
      last_input_time = -1000000,
      feedback_guard_until = 0,
    }
    DAW.TRACK_VIEWER.fade_states[fader_number] = state
  end
  return state
end

DAW.TRACK_VIEWER.cancel_fade = function(fader_number, reason)
  local state = DAW.TRACK_VIEWER.ensure_fade_state(fader_number)
  local was_active = state.active
  state.active = false
  state.feedback_guard_until = 0
  state.last_written_value = nil
  if was_active and reason then
    last_action = "Track Viewer " .. DAW.TRACK_VIEWER.fader_label(fader_number)
      .. ": " .. tostring(reason)
  end
  return was_active
end

DAW.TRACK_VIEWER.cancel_all_fades = function()
  for fader = 1, 4 do
    DAW.TRACK_VIEWER.cancel_fade(fader)
  end
end

DAW.TRACK_VIEWER.velocity_to_duration = function(velocity)
  velocity = math.max(1, math.min(127, tonumber(velocity) or 127))
  local normalized = 1 - ((velocity - 1) / 126)
  return DAW.TRACK_VIEWER.FADE_MAX_SECONDS * normalized * normalized
end

DAW.TRACK_VIEWER.target_value_from_row = function(row)
  row = math.max(1, math.min(8, tonumber(row) or 8))
  local segment_from_bottom = 9 - row
  return math.floor((((segment_from_bottom - 1) / 7) * 127) + 0.5)
end

DAW.TRACK_VIEWER.current_interpolated_value = function(fader_number, now)
  local state = DAW.TRACK_VIEWER.ensure_fade_state(fader_number)
  if not state.active or state.duration <= 0 then
    return DAW.TRACK_VIEWER.fader_value(fader_number)
  end

  now = tonumber(now) or r.time_precise()
  local progress = math.max(0, math.min(1, (now - state.start_time) / state.duration))
  return state.start_value + ((state.target_value - state.start_value) * progress)
end

DAW.TRACK_VIEWER.start_emulated_fade = function(fader_number, row, velocity, source)
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return false end

  local now = r.time_precise()
  local state = DAW.TRACK_VIEWER.ensure_fade_state(fader_number)
  local current = DAW.TRACK_VIEWER.current_interpolated_value(fader_number, now)
  local target = DAW.TRACK_VIEWER.target_value_from_row(row)
  local duration = DAW.TRACK_VIEWER.velocity_to_duration(velocity)
  local rapid_followup =
    (now - (state.last_input_time or -1000000))
      <= DAW.TRACK_VIEWER.DRAG_OVERRIDE_WINDOW_SECONDS

  -- A new signal supersedes an active long movement. This is the important
  -- difference between a deliberate single tap and a finger drag across pads.
  if state.active or rapid_followup then
    duration = math.min(duration, DAW.TRACK_VIEWER.DRAG_SMOOTH_SECONDS)
  end

  state.last_input_time = now
  state.start_value = current
  state.target_value = target
  state.expected_value = current
  state.last_written_value = math.floor(current + 0.5)
  state.start_time = now
  state.duration = duration
  state.last_update_time = -1000000
  state.feedback_guard_until = now + duration + DAW.TRACK_VIEWER.FADE_SETTLE_SECONDS

  if duration <= DAW.TRACK_VIEWER.FADE_IMMEDIATE_THRESHOLD then
    state.active = false
    DAW.TRACK_VIEWER.set_fader_value(fader_number, target, source or "hard hit")
    state.last_written_value = target
    DAW.TRACK_VIEWER.refresh_button_surface(false)
  else
    state.active = true
    last_action = string.format(
      "Track Viewer %s: %s fading to %d over %.2f seconds",
      source or "pad",
      DAW.TRACK_VIEWER.fader_label(fader_number),
      target,
      duration
    )
  end

  return true
end

DAW.TRACK_VIEWER.fader_stage_index = function(fader_number)
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return nil end
  return math.floor((DAW.TRACK_VIEWER.fader_value(fader_number) / 127) * 31 + 0.5)
end

DAW.TRACK_VIEWER.closest_fader_family = function(rgb)
  rgb = tonumber(rgb) or 0xB1B1B1
  local rr, gg, bb = (rgb >> 16) & 0xFF, (rgb >> 8) & 0xFF, rgb & 0xFF
  local best, best_distance = DAW.TRACK_VIEWER.FADER_COLOR_FAMILIES[#DAW.TRACK_VIEWER.FADER_COLOR_FAMILIES], math.huge

  for _, family in ipairs(DAW.TRACK_VIEWER.FADER_COLOR_FAMILIES) do
    local candidate = family.rgb or 0
    local cr, cg, cb = (candidate >> 16) & 0xFF, (candidate >> 8) & 0xFF, candidate & 0xFF
    local dr, dg, db = rr - cr, gg - cg, bb - cb
    local distance = (dr * dr * 0.30) + (dg * dg * 0.59) + (db * db * 0.11)
    if distance < best_distance then
      best_distance = distance
      best = family
    end
  end

  return best
end

DAW.TRACK_VIEWER.fader_family = function(fader_number)
  if fader_number == 1 or fader_number == 2 then
    return DAW.TRACK_VIEWER.closest_fader_family(
      DAW.TRACK_VIEWER.track_rgb(DAW.TRACK_VIEWER.selected_track)
    )
  elseif fader_number == 3 then
    return DAW.TRACK_VIEWER.closest_fader_family(0xFFE84A)
  end
  return DAW.TRACK_VIEWER.closest_fader_family(0x43F05A)
end

DAW.TRACK_VIEWER.fader_pad_palette = function(fader_number, row)
  local stage = DAW.TRACK_VIEWER.fader_stage_index(fader_number)
  if stage == nil then return 0x00 end

  local family = DAW.TRACK_VIEWER.fader_family(fader_number)
  local levels = family and family.levels or {0x01, 0x02, 0x75, 0x03}
  local active_segment = math.floor(stage / 4) + 1
  local active_level = (stage % 4) + 1
  local segment_from_bottom = 9 - row

  if segment_from_bottom < active_segment then
    return levels[4]
  elseif segment_from_bottom == active_segment then
    return levels[active_level]
  end
  return 0x00
end

DAW.TRACK_VIEWER.process_emulated_fades = function(now)
  local surface_changed = false
  now = tonumber(now) or r.time_precise()

  for fader = 1, 4 do
    local state = DAW.TRACK_VIEWER.ensure_fade_state(fader)
    if state.active and DAW.TRACK_VIEWER.fader_available(fader) then
      local actual = DAW.TRACK_VIEWER.fader_value(fader)
      if state.last_written_value ~= nil
          and now <= state.feedback_guard_until
          and math.abs(actual - state.last_written_value) > DAW.TRACK_VIEWER.EXTERNAL_TAKEOVER_TOLERANCE then
        DAW.TRACK_VIEWER.cancel_fade(fader, "external REAPER change took over")
        surface_changed = true
      elseif (now - state.last_update_time) >= DAW.TRACK_VIEWER.FADE_UPDATE_INTERVAL then
        local progress = math.max(0, math.min(1, (now - state.start_time) / math.max(state.duration, 0.0001)))
        local expected = state.start_value + ((state.target_value - state.start_value) * progress)
        local rounded = math.floor(expected + 0.5)

        state.expected_value = expected
        state.last_update_time = now
        if state.last_written_value == nil or rounded ~= state.last_written_value or progress >= 1 then
          DAW.TRACK_VIEWER.set_fader_value(fader, rounded, "emulated fade")
          state.last_written_value = rounded
          surface_changed = true
        end

        if progress >= 1 then
          state.active = false
          state.feedback_guard_until = now + DAW.TRACK_VIEWER.FADE_SETTLE_SECONDS
          last_action = "Track Viewer " .. DAW.TRACK_VIEWER.fader_label(fader) .. ": fade complete"
        end
      end
    end
  end

  if surface_changed then
    DAW.TRACK_VIEWER.refresh_button_surface(false)
  end
  return surface_changed
end

DAW.TRACK_VIEWER.static_button = function(row, col)
  return DAW.TRACK_VIEWER.STATIC_BUTTONS[row]
    and DAW.TRACK_VIEWER.STATIC_BUTTONS[row][col]
    or nil
end

DAW.TRACK_VIEWER.button_info = function(row, col)
  if col == 5 then
    local kind, base = DAW.TRACK_VIEWER.fx_or_color_base()
    if kind == "fx" then
      local fx_index = base + row - 1
      local track = DAW.TRACK_VIEWER.selected_track
      local count = track and (r.TrackFX_GetCount(track) or 0) or 0
      if fx_index >= count then return {label = " ", color = 0x00, kind = "none"} end
      local ok, name = r.TrackFX_GetFXName(track, fx_index, "")
      name = ok and trim(name or "") or ("FX " .. tostring(fx_index + 1))
      if #name > 18 then name = name:sub(1, 18) end
      return {
        label = "FX " .. tostring(fx_index + 1),
        detail = name,
        color = DAW.FX.ROW_COLORS[row] or 0x03,
        kind = "fx",
        value = fx_index,
      }
    end

    local choice_index = base + row
    local choice = DAW.TRACK_VIEWER.COLOR_CHOICES[choice_index]
    if not choice then return {label = " ", color = 0x00, kind = "none"} end
    return {
      label = "Color Track",
      detail = tostring(choice_index),
      color = choice.palette,
      kind = "color",
      value = choice_index,
    }
  end

  return DAW.TRACK_VIEWER.static_button(row, col)
end

DAW.TRACK_VIEWER.button_available = function(info)
  if not info or info.kind == "none" then return false end
  local track = DAW.TRACK_VIEWER.selected_track
  if info.kind == "duplicate" or info.kind == "clear" or info.kind == "delete" then
    return track ~= nil and track ~= r.GetMasterTrack(0)
  end
  return track ~= nil or info.kind == "grid" or info.kind == "library"
end

DAW.TRACK_VIEWER.button_active = function(info)
  if not DAW.TRACK_VIEWER.button_available(info) then return false end
  local track = DAW.TRACK_VIEWER.selected_track
  local kind = info.kind

  if kind == "fx" then
    return r.TrackFX_GetOpen and r.TrackFX_GetOpen(track, info.value) or false
  elseif kind == "color" then
    return DAW.TRACK_VIEWER.track_rgb(track) == (DAW.TRACK_VIEWER.COLOR_CHOICES[info.value].rgb or -1)
  elseif kind == "automode" then
    return math.floor((r.GetMediaTrackInfo_Value(track, "I_AUTOMODE") or 0) + 0.5) == info.value
  elseif kind == "phase" then
    return (r.GetMediaTrackInfo_Value(track, "B_PHASE") or 0) > 0.5
  elseif kind == "select" then
    return DAW.TRACK_VIEWER.locked_to_track
      or DAW.TRACK_VIEWER.is_track_selected(track)
  elseif kind == "mute" then
    return (r.GetMediaTrackInfo_Value(track, "B_MUTE") or 0) > 0.5
  elseif kind == "solo" then
    return (r.GetMediaTrackInfo_Value(track, "I_SOLO") or 0) > 0
  elseif kind == "arm" then
    return (r.GetMediaTrackInfo_Value(track, "I_RECARM") or 0) > 0.5
  elseif kind == "track_fx" then
    return r.TrackFX_GetChainVisible(track) ~= -1
  elseif kind == "library" then
    return library_visible
  elseif kind == "grid" then
    return grid_visible
  elseif kind == "play" then
    return ((r.GetPlayState() or 0) & 1) == 1
  elseif kind == "pause" then
    return ((r.GetPlayState() or 0) & 2) == 2
  end
  return false
end

DAW.TRACK_VIEWER.button_palette = function(row, col)
  local info = DAW.TRACK_VIEWER.button_info(row, col)
  if not DAW.TRACK_VIEWER.button_available(info) then return 0x00 end
  return info.color or 0x03
end

DAW.TRACK_VIEWER.session_note = function(row, col)
  return ((9 - row) * 10) + col
end

DAW.TRACK_VIEWER.reset_led_cache = function()
  DAW.TRACK_VIEWER.led_cache = {notes = {}, ccs = {}}
end

DAW.TRACK_VIEWER.led_key = function(color, pulse, flash)
  return string.format(
    "%02X:%s",
    tonumber(color) or 0,
    flash and "F" or (pulse and "P" or "S")
  )
end

DAW.TRACK_VIEWER.send_note_if_changed = function(note, color, pulse, force, flash)
  local desired = DAW.TRACK_VIEWER.led_key(color, pulse, flash)
  if not force and DAW.TRACK_VIEWER.led_cache.notes[note] == desired then return false end
  DAW.send_bytes({flash and 0x91 or (pulse and 0x92 or 0x90), note, color or 0x00})
  DAW.TRACK_VIEWER.led_cache.notes[note] = desired
  return true
end

DAW.TRACK_VIEWER.send_cc_if_changed = function(cc, color, pulse, force, flash)
  local desired = DAW.TRACK_VIEWER.led_key(color, pulse, flash)
  if not force and DAW.TRACK_VIEWER.led_cache.ccs[cc] == desired then return false end
  DAW.send_bytes({flash and 0xB1 or (pulse and 0xB2 or 0xB0), cc, color or 0x00})
  DAW.TRACK_VIEWER.led_cache.ccs[cc] = desired
  return true
end

DAW.TRACK_VIEWER.top_palette = function(slot)
  if slot == 1 or slot == 2 then return 0x25 end -- selected-track navigation
  if slot == 3 or slot == 4 then return 0x15 end -- project-track navigation
  if slot == 5 then return 0x03 end              -- GO HOME / Session
  return 0x00
end

DAW.TRACK_VIEWER.send_session_surface = function(force)
  if not DAW.TRACK_VIEWER.surface_is_active() then return false end

  for row = 1, 8 do
    for col = 1, 8 do
      if col <= 4 then
        DAW.TRACK_VIEWER.send_note_if_changed(
          DAW.TRACK_VIEWER.session_note(row, col),
          DAW.TRACK_VIEWER.fader_pad_palette(col, row),
          false,
          force
        )
      else
        local info = DAW.TRACK_VIEWER.button_info(row, col)
        DAW.TRACK_VIEWER.send_note_if_changed(
          DAW.TRACK_VIEWER.session_note(row, col),
          DAW.TRACK_VIEWER.button_palette(row, col),
          DAW.TRACK_VIEWER.button_active(info),
          force,
          info and info.kind == "grid" and not grid_visible
        )
      end
    end
  end

  for slot = 1, 8 do
    DAW.TRACK_VIEWER.send_cc_if_changed(
      DAW.TOP_ROW_CC_BY_SLOT[slot],
      DAW.TRACK_VIEWER.top_palette(slot),
      false,
      force
    )
  end
  DAW.send_session_button_colors(0x03, 0x03)

  for bank = 1, 8 do
    DAW.TRACK_VIEWER.send_cc_if_changed(
      DAW.BANK_CC_BY_SLOT[bank],
      DAW.FX.ROW_COLORS[bank] or 0x03,
      bank == DAW.TRACK_VIEWER.bank,
      force
    )
  end

  return true
end

DAW.TRACK_VIEWER.layout_signature = function()
  local track = DAW.TRACK_VIEWER.selected_track
  local count = track and (r.TrackFX_GetCount(track) or 0) or 0
  local sends = track and (r.GetTrackNumSends(track, 0) or 0) or 0
  return table.concat({
    tostring(track),
    tostring(DAW.TRACK_VIEWER.bank),
    tostring(DAW.TRACK_VIEWER.nearest_palette(DAW.TRACK_VIEWER.track_rgb(track))),
    tostring(count),
    tostring(sends),
  }, "|")
end

DAW.TRACK_VIEWER.surface_signature = function()
  local parts = {
    DAW.TRACK_VIEWER.layout_signature(),
    grid_visible and "grid:1" or "grid:0",
  }
  for fader = 1, 4 do
    parts[#parts + 1] = "fader:" .. tostring(fader) .. ":"
      .. tostring(DAW.TRACK_VIEWER.fader_stage_index(fader) or -1)
  end
  for row = 1, 8 do
    for col = 5, 8 do
      local info = DAW.TRACK_VIEWER.button_info(row, col)
      parts[#parts + 1] = tostring(row) .. ":" .. tostring(col) .. ":"
        .. tostring(DAW.TRACK_VIEWER.button_palette(row, col)) .. ":"
        .. (DAW.TRACK_VIEWER.button_active(info) and "1" or "0")
    end
  end
  return table.concat(parts, "|")
end

DAW.TRACK_VIEWER.sync_fader_feedback = function(force)
  -- Compatibility name retained for existing call sites. In the Session-mode
  -- implementation, feedback means repainting the emulated fader pad stages.
  return DAW.TRACK_VIEWER.refresh_button_surface(force)
end

DAW.TRACK_VIEWER.rebuild_surface = function(force)
  if not DAW.TRACK_VIEWER.surface_is_active() then return false end
  DAW.TRACK_VIEWER.layout_identity = DAW.TRACK_VIEWER.layout_signature()
  DAW.TRACK_VIEWER.surface_identity = nil
  DAW.TRACK_VIEWER.reset_led_cache()
  return DAW.TRACK_VIEWER.refresh_button_surface(true)
end

DAW.TRACK_VIEWER.refresh_button_surface = function(force)
  if not DAW.TRACK_VIEWER.surface_is_active() then return false end
  local signature = DAW.TRACK_VIEWER.surface_signature()
  if not force and signature == DAW.TRACK_VIEWER.surface_identity then return false end
  DAW.TRACK_VIEWER.surface_identity = signature
  return DAW.TRACK_VIEWER.send_session_surface(force)
end

DAW.TRACK_VIEWER.process_feedback = function(now)
  if not DAW.TRACK_VIEWER.surface_is_active() then return end

  DAW.TRACK_VIEWER.process_select_hold(now)
  DAW.TRACK_VIEWER.follow_reaper_selection()
  DAW.TRACK_VIEWER.process_pending_fx_click(now)
  DAW.TRACK_VIEWER.process_emulated_fades(now)

  if (now - (DAW.TRACK_VIEWER.last_feedback_time or -1000000)) < CFG.CUSTOM_FADER_FEEDBACK_POLL_INTERVAL then
    return
  end

  DAW.TRACK_VIEWER.last_feedback_time = now
  local identity = DAW.TRACK_VIEWER.layout_signature()
  if identity ~= DAW.TRACK_VIEWER.layout_identity then
    DAW.TRACK_VIEWER.layout_identity = identity
    DAW.TRACK_VIEWER.surface_identity = nil
  end
  DAW.TRACK_VIEWER.refresh_button_surface(false)
end

DAW.TRACK_VIEWER.screen_title = function()
  local track = DAW.TRACK_VIEWER.selected_track
  local number = DAW.TRACK_VIEWER.project_track_number(track)
  local number_text = (number == 0) and "MASTER" or ("Track " .. tostring(number or "?"))
  local preset_text = (number == 0) and "Preset 30: Master Track View" or "Preset 29: Track Viewer"
  local lock_text = DAW.TRACK_VIEWER.locked_to_track and " | LOCKED" or ""
  return preset_text .. " | " .. number_text .. ": "
    .. DAW.TRACK_VIEWER.track_name(track) .. " | "
    .. (DAW.TRACK_VIEWER.BANK_NAMES[DAW.TRACK_VIEWER.bank] or "Bank ?")
    .. lock_text
end

DAW.TRACK_VIEWER.enter = function(track_number, options)
  options = options or {}
  local track = DAW.TRACK_VIEWER.resolve_track(track_number or DAW.TRACK_PICKER.selected_track_number)
  if not track then
    last_action = "Track Viewer: no track is available"
    return false
  end

  if not DAW.send_mode(true) then return false end
  DAW.send_session_button_colors()
  DAW.TRACK_VIEWER.select_track(track, true)
  DAW.TRACK_VIEWER.bank = math.max(1, math.min(8, tonumber(DAW.TRACK_VIEWER.bank) or 1))
  DAW.active_preset = (track == r.GetMasterTrack(0)) and 30 or 29
  active_custom_slot = nil
  surface_mode = "TRACK_VIEWER_SESSION"
  initialized = true
  DAW.TRACK_VIEWER.layout_identity = nil
  DAW.TRACK_VIEWER.surface_identity = nil
  DAW.TRACK_VIEWER.last_feedback_time = -1000000
  DAW.TRACK_VIEWER.fade_states = {}
  DAW.TRACK_VIEWER.locked_to_track = options.lock_to_track and true or false
  DAW.TRACK_VIEWER.select_hold = {
    active = false,
    source = nil,
    start_time = 0,
    lock_triggered = false,
  }
  DAW.TRACK_VIEWER.reset_led_cache()
  DAW.TRACK_VIEWER.remember_selection_signature()
  DAW.TRACK_VIEWER.session_entry_ack_ignore_until =
    r.time_precise() + DAW.TRACK_VIEWER.SESSION_ENTRY_ACK_IGNORE_SECONDS

  if not DAW.send_layout(0x00) then return false end
  DAW.TRACK_VIEWER.rebuild_surface(true)
  last_action = DAW.TRACK_VIEWER.screen_title()
  return true
end

DAW.TRACK_VIEWER.set_bank = function(bank, source)
  bank = math.max(1, math.min(8, tonumber(bank) or 1))
  if bank == DAW.TRACK_VIEWER.bank then
    DAW.TRACK_VIEWER.send_session_surface(true)
    return true
  end
  DAW.TRACK_VIEWER.bank = bank
  DAW.TRACK_VIEWER.layout_identity = nil
  DAW.TRACK_VIEWER.rebuild_surface(true)
  last_action = (source or "Track Viewer") .. ": "
    .. (DAW.TRACK_VIEWER.BANK_NAMES[bank] or ("Bank " .. tostring(bank)))
  return true
end

DAW.TRACK_VIEWER.open_picker_for_track = function()
  local number = DAW.TRACK_VIEWER.selected_track_number or 1
  local page = (number <= 0) and 1 or ((number <= 40) and 1 or ((number <= 80) and 2 or 3))
  return DAW.TRACK_PICKER.enter(page)
end

DAW.TRACK_VIEWER.navigate_project_track = function(direction)
  direction = (tonumber(direction) or 1) >= 0 and 1 or -1
  local current = tonumber(DAW.TRACK_VIEWER.selected_track_number) or 0
  local count = r.CountTracks(0)
  if count <= 0 then
    DAW.TRACK_VIEWER.select_track(r.GetMasterTrack(0), false)
    DAW.TRACK_VIEWER.remember_selection_signature()
    DAW.TRACK_VIEWER.layout_identity = nil
    DAW.TRACK_VIEWER.rebuild_surface(true)
    return true
  end

  -- Position zero is the Master. Project tracks are 1..count.
  local next_number = (current + direction) % (count + 1)
  local next_track = (next_number == 0)
    and r.GetMasterTrack(0)
    or r.GetTrack(0, next_number - 1)

  DAW.TRACK_VIEWER.select_track(next_track, false)
  DAW.TRACK_VIEWER.remember_selection_signature()
  DAW.TRACK_VIEWER.layout_identity = nil
  DAW.TRACK_VIEWER.rebuild_surface(true)
  return true
end

DAW.TRACK_VIEWER.navigate_selected_track = function(direction)
  local selected = {}
  for i = 0, DAW.TRACK_VIEWER.count_selected_tracks() - 1 do
    selected[#selected + 1] = DAW.TRACK_VIEWER.selected_track_at(i)
  end
  if #selected == 0 then return DAW.TRACK_VIEWER.navigate_project_track(direction) end

  local current = DAW.TRACK_VIEWER.selected_track
  local position = nil
  for i, track in ipairs(selected) do
    if track == current then position = i break end
  end
  if not position then position = (direction > 0) and 0 or 1 end
  local next_pos = ((position - 1 + direction) % #selected) + 1
  DAW.TRACK_VIEWER.select_track(selected[next_pos], true)
  DAW.TRACK_VIEWER.layout_identity = nil
  DAW.TRACK_VIEWER.rebuild_surface(true)
  return true
end

DAW.TRACK_VIEWER.center_floating_fx_window = function(track, fx_index)
  if not (
    track
    and r.TrackFX_GetFloatingWindow
    and r.GetMainHwnd
    and r.JS_Window_GetRect
    and r.JS_Window_SetPosition
  ) then
    return false
  end

  local hwnd = r.TrackFX_GetFloatingWindow(track, fx_index)
  local main_hwnd = r.GetMainHwnd()
  if not hwnd or not main_hwnd then return false end

  local fx_ok, fx_left, fx_top, fx_right, fx_bottom = r.JS_Window_GetRect(hwnd)
  local main_ok, main_left, main_top, main_right, main_bottom = r.JS_Window_GetRect(main_hwnd)
  if not fx_ok or not main_ok then return false end

  local width = math.max(1, fx_right - fx_left)
  local height = math.max(1, fx_bottom - fx_top)
  local x = math.floor(main_left + ((main_right - main_left - width) * 0.5) + 0.5)
  local y = math.floor(main_top + ((main_bottom - main_top - height) * 0.5) + 0.5)
  r.JS_Window_SetPosition(hwnd, x, y, width, height)
  return true
end

DAW.TRACK_VIEWER.schedule_fx_center = function(track, fx_index)
  DAW.TRACK_VIEWER.pending_fx_center = {
    track = track,
    fx_index = fx_index,
    next_time = r.time_precise() + DAW.TRACK_VIEWER.FX_CENTER_RETRY_SECONDS,
    attempts_left = DAW.TRACK_VIEWER.FX_CENTER_RETRY_COUNT,
  }
end

DAW.TRACK_VIEWER.process_pending_fx_center = function(now)
  local pending = DAW.TRACK_VIEWER.pending_fx_center
  if not pending or now < pending.next_time then return false end

  if DAW.TRACK_VIEWER.center_floating_fx_window(pending.track, pending.fx_index) then
    DAW.TRACK_VIEWER.pending_fx_center = nil
    return true
  end

  pending.attempts_left = pending.attempts_left - 1
  if pending.attempts_left <= 0 then
    DAW.TRACK_VIEWER.pending_fx_center = nil
  else
    pending.next_time = now + DAW.TRACK_VIEWER.FX_CENTER_RETRY_SECONDS
  end
  return false
end

DAW.TRACK_VIEWER.open_fx_centered_if_needed = function(track, fx_index)
  if not track or fx_index < 0 or fx_index >= (r.TrackFX_GetCount(track) or 0) then
    return false
  end

  local is_open = r.TrackFX_GetOpen and r.TrackFX_GetOpen(track, fx_index)
  if not is_open then
    r.TrackFX_Show(track, fx_index, 3)
    DAW.TRACK_VIEWER.schedule_fx_center(track, fx_index)
  else
    -- Bring an already-open floated FX forward without repositioning it.
    r.TrackFX_Show(track, fx_index, 3)
  end
  return true
end

DAW.TRACK_VIEWER.toggle_fx_float = function(track, fx_index)
  if not track or fx_index < 0 or fx_index >= (r.TrackFX_GetCount(track) or 0) then
    return false
  end

  local is_open = r.TrackFX_GetOpen and r.TrackFX_GetOpen(track, fx_index)
  if is_open then
    r.TrackFX_Show(track, fx_index, 2)
    last_action = "Closed Track Viewer FX " .. tostring(fx_index + 1)
  else
    DAW.TRACK_VIEWER.open_fx_centered_if_needed(track, fx_index)
    last_action = "Opened and centered Track Viewer FX " .. tostring(fx_index + 1)
  end
  return true
end

DAW.TRACK_VIEWER.activate_fx_pots_for_fx = function(track, fx_index)
  if not DAW.TRACK_VIEWER.open_fx_centered_if_needed(track, fx_index) then
    return false
  end

  DAW.TRACK_VIEWER.pending_fx_click = nil
  last_action = "Opened Track Viewer FX " .. tostring(fx_index + 1)
    .. " and switched to FX Pots/Sliders"
  return DAW.activate_preset(21)
end

DAW.TRACK_VIEWER.execute_pending_fx_click = function()
  local pending = DAW.TRACK_VIEWER.pending_fx_click
  if not pending then return false end
  DAW.TRACK_VIEWER.pending_fx_click = nil
  return DAW.TRACK_VIEWER.toggle_fx_float(pending.track, pending.fx_index)
end

DAW.TRACK_VIEWER.queue_fx_click = function(track, fx_index, source)
  if not track then return false end
  local now = r.time_precise()
  local pending = DAW.TRACK_VIEWER.pending_fx_click

  if pending
      and pending.track == track
      and pending.fx_index == fx_index
      and now <= pending.due_time then
    DAW.TRACK_VIEWER.pending_fx_click = nil
    return DAW.TRACK_VIEWER.activate_fx_pots_for_fx(track, fx_index)
  end

  -- Do not lose a prior single click on a different FX if the user immediately
  -- moves elsewhere.
  if pending then
    DAW.TRACK_VIEWER.execute_pending_fx_click()
  end

  DAW.TRACK_VIEWER.pending_fx_click = {
    track = track,
    fx_index = fx_index,
    source = source,
    due_time = now + DAW.TRACK_VIEWER.FX_DOUBLE_CLICK_SECONDS,
  }
  last_action = "Track Viewer FX " .. tostring(fx_index + 1) .. ": awaiting possible double-click"
  return true
end

DAW.TRACK_VIEWER.process_pending_fx_click = function(now)
  local pending = DAW.TRACK_VIEWER.pending_fx_click
  if not pending or now < pending.due_time then return false end
  return DAW.TRACK_VIEWER.execute_pending_fx_click()
end

DAW.TRACK_VIEWER.set_track_color = function(choice_index)
  local track = DAW.TRACK_VIEWER.selected_track
  local choice = DAW.TRACK_VIEWER.COLOR_CHOICES[choice_index]
  if not track or not choice then return false end
  local rgb = choice.rgb or 0xB1B1B1
  local rr, gg, bb = (rgb >> 16) & 0xFF, (rgb >> 8) & 0xFF, rgb & 0xFF
  r.SetTrackColor(track, (r.ColorToNative(rr, gg, bb) or 0) | 0x1000000)
  DAW.TRACK_VIEWER.layout_identity = nil
  if r.UpdateArrange then r.UpdateArrange() end
  DAW.TRACK_VIEWER.rebuild_surface(true)
  last_action = "Track Viewer: set track color choice " .. tostring(choice_index)
  return true
end

DAW.TRACK_VIEWER.duplicate_track = function()
  local track = DAW.TRACK_VIEWER.selected_track
  if not track or track == r.GetMasterTrack(0) then return false end
  DAW.TRACK_VIEWER.select_track(track, false)
  r.Main_OnCommand(40062, 0) -- Track: Duplicate tracks
  local duplicate = r.GetSelectedTrack(0, 0)
  if duplicate then
    DAW.TRACK_VIEWER.select_track(duplicate, false)
    DAW.TRACK_VIEWER.layout_identity = nil
    DAW.TRACK_VIEWER.rebuild_surface(true)
  end
  last_action = "Track Viewer: duplicated track"
  return true
end

DAW.TRACK_VIEWER.clear_track_items = function()
  local track = DAW.TRACK_VIEWER.selected_track
  if not track or track == r.GetMasterTrack(0) then return false end
  if r.ShowMessageBox("Remove all media items from the viewed track?", "Track Viewer: Clear", 4) ~= 6 then
    last_action = "Track Viewer: clear cancelled"
    return false
  end

  r.Undo_BeginBlock2(0)
  for i = (r.CountTrackMediaItems(track) or 0) - 1, 0, -1 do
    local item = r.GetTrackMediaItem(track, i)
    if item then r.DeleteTrackMediaItem(track, item) end
  end
  r.Undo_EndBlock2(0, "Track Viewer: clear track items", -1)
  if r.UpdateArrange then r.UpdateArrange() end
  last_action = "Track Viewer: cleared all media items from viewed track"
  return true
end

DAW.TRACK_VIEWER.delete_track = function()
  local track = DAW.TRACK_VIEWER.selected_track
  if not track or track == r.GetMasterTrack(0) then return false end
  if r.ShowMessageBox("Delete the viewed track?", "Track Viewer: Delete", 4) ~= 6 then
    last_action = "Track Viewer: delete cancelled"
    return false
  end

  local old_number = DAW.TRACK_VIEWER.project_track_number(track) or 1
  r.Undo_BeginBlock2(0)
  r.DeleteTrack(track)
  r.Undo_EndBlock2(0, "Track Viewer: delete track", -1)
  local next_track = r.GetTrack(0, math.max(0, math.min((r.CountTracks(0) or 1) - 1, old_number - 1)))
    or r.GetTrack(0, 0)
    or r.GetMasterTrack(0)
  DAW.TRACK_VIEWER.select_track(next_track, false)
  DAW.TRACK_VIEWER.layout_identity = nil
  DAW.TRACK_VIEWER.rebuild_surface(true)
  last_action = "Track Viewer: deleted track"
  return true
end

DAW.TRACK_VIEWER.dispatch_button = function(row, col, source)
  local info = DAW.TRACK_VIEWER.button_info(row, col)
  if not DAW.TRACK_VIEWER.button_available(info) then return false end
  local track = DAW.TRACK_VIEWER.selected_track
  local kind = info.kind

  if kind == "fx" then
    DAW.TRACK_VIEWER.queue_fx_click(track, info.value, source)
  elseif kind == "color" then
    DAW.TRACK_VIEWER.set_track_color(info.value)
  elseif kind == "automode" then
    if r.SetTrackAutomationMode then
      r.SetTrackAutomationMode(track, info.value)
    else
      r.SetMediaTrackInfo_Value(track, "I_AUTOMODE", info.value)
    end
    last_action = "Track Viewer: " .. info.label
  elseif kind == "phase" then
    r.SetMediaTrackInfo_Value(track, "B_PHASE", DAW.TRACK_VIEWER.button_active(info) and 0 or 1)
  elseif kind == "select" then
    return DAW.TRACK_VIEWER.toggle_viewed_track_selection()
  elseif kind == "mute" then
    r.SetMediaTrackInfo_Value(track, "B_MUTE", DAW.TRACK_VIEWER.button_active(info) and 0 or 1)
  elseif kind == "solo" then
    r.SetMediaTrackInfo_Value(track, "I_SOLO", DAW.TRACK_VIEWER.button_active(info) and 0 or 2)
  elseif kind == "arm" then
    r.SetMediaTrackInfo_Value(track, "I_RECARM", DAW.TRACK_VIEWER.button_active(info) and 0 or 1)
  elseif kind == "track_picker" then
    return DAW.TRACK_VIEWER.open_picker_for_track()
  elseif kind == "track_fx" then
    toggle_track_fx_chain(track, "Track Viewer FX chain")
  elseif kind == "duplicate" then
    return DAW.TRACK_VIEWER.duplicate_track()
  elseif kind == "clear" then
    return DAW.TRACK_VIEWER.clear_track_items()
  elseif kind == "delete" then
    return DAW.TRACK_VIEWER.delete_track()
  elseif kind == "library" then
    ACTIONS["Show/Hide Library & Settings"]()
  elseif kind == "grid" then
    ACTIONS["Show/Hide This Grid"]()
  elseif kind == "record" then
    ACTIONS["Record"]()
  elseif kind == "save_take" then
    ACTIONS["Save Take"]()
  elseif kind == "restart_take" then
    ACTIONS["Restart Take"]()
  elseif kind == "cancel_take" then
    ACTIONS["Cancel Take"]()
  elseif kind == "play" then
    ACTIONS["Play"]()
  elseif kind == "stop" then
    ACTIONS["Stop"]()
  elseif kind == "pause" then
    ACTIONS["Pause"]()
  end

  if r.UpdateArrange then r.UpdateArrange() end
  DAW.TRACK_VIEWER.refresh_button_surface(true)
  DAW.TRACK_VIEWER.sync_fader_feedback(true)
  return true
end

DAW.TRACK_VIEWER.handle_top_slot = function(slot)
  if slot == 1 then return DAW.TRACK_VIEWER.navigate_selected_track(-1) end
  if slot == 2 then return DAW.TRACK_VIEWER.navigate_selected_track(1) end
  if slot == 3 then return DAW.TRACK_VIEWER.navigate_project_track(-1) end
  if slot == 4 then return DAW.TRACK_VIEWER.navigate_project_track(1) end
  if slot == 5 then
    return_to_home_page_1("Track Viewer: returned to HOME Page 1", false)
    return true
  end
  return false
end

DAW.TRACK_VIEWER.process_daw_midi_event = function(buf, dev_idx)
  if not buf or (DAW.input_index == nil and DAW.input_index_2 == nil) or not DAW.TRACK_VIEWER.surface_is_active() then return false end
  local device_index = (dev_idx or 0) & 0xFFFF
  if not DAW.input_matches(device_index) then return false end
  if #buf < 3 then return false end

  local status, data1, data2 = buf:byte(1, 3)
  if not status or not data1 or not data2 then return false end
  local message_type = status & 0xF0
  local channel = status & 0x0F

  if channel == 0 and message_type == 0xB0 and data2 > 0 then
    local top_slot = DAW.TOP_ROW_SLOT_BY_CC[data1]
    if top_slot then
      last_midi = format_midi(status, data1, data2)
      return DAW.TRACK_VIEWER.handle_top_slot(top_slot)
    end

    local bank = DAW.FX.GROUP_SLOT_BY_CC[data1]
    if bank then
      last_midi = format_midi(status, data1, data2)
      return DAW.TRACK_VIEWER.set_bank(bank, "Track Viewer hardware")
    end
  end

  if channel == 0 and (message_type == 0x90 or message_type == 0x80) then
    local row, col = DAW.MATRIX.matrix_note_to_cell(data1)
    if row and col then
      last_midi = format_midi(status, data1, data2)
      local pressed = message_type == 0x90 and data2 > 0
      if row == 2 and col == 7 then
        if pressed then
          DAW.TRACK_VIEWER.begin_select_hold("hardware")
        else
          DAW.TRACK_VIEWER.end_select_hold("hardware")
        end
      elseif pressed then
        if col <= 4 then
          DAW.TRACK_VIEWER.start_emulated_fade(col, row, data2, "hardware pad")
        elseif col <= 8 then
          DAW.TRACK_VIEWER.dispatch_button(row, col, "hardware")
        end
      end
      return true
    end
  end

  return false
end

DAW.TRACK_VIEWER.fader_stage_count = function(fader_number)
  if not DAW.TRACK_VIEWER.fader_available(fader_number) then return 0 end
  return 1 + math.floor(
    (DAW.TRACK_VIEWER.fader_value(fader_number) / 127) * (CUSTOM_FADER_STAGE_COUNT - 1) + 0.5
  )
end

DAW.TRACK_VIEWER.top_lines = function(slot)
  if slot == 1 then return {"PREVIOUS", "SELECTED", "TRACK"} end
  if slot == 2 then return {"NEXT", "SELECTED", "TRACK"} end
  if slot == 3 then return {"PREVIOUS", "TRACK"} end
  if slot == 4 then return {"NEXT", "TRACK"} end
  if slot == 5 then return {"GO", "HOME"} end
  return {"N.A."}
end

DAW.TRACK_VIEWER.top_gui_color = function(slot)
  if slot == 1 or slot == 2 then return 0x61A1DDFF end
  if slot == 3 or slot == 4 then return 0x61B36BFF end
  if slot == 5 then return 0xFFFFFFFF end
  return CUSTOM_FADER_OFF_COLOR
end

DAW.TRACK_VIEWER.bank_lines = function(bank)
  local text = DAW.TRACK_VIEWER.BANK_NAMES[bank] or ("Bank " .. tostring(bank))
  local lines = {}
  for part in text:gmatch("[^/]+") do lines[#lines + 1] = trim(part) end
  return lines
end

DAW.TRACK_VIEWER.gui_button_lines = function(row, col)
  local info = DAW.TRACK_VIEWER.button_info(row, col)

  -- Keep a small orientation label at the bottom of the FX column whenever
  -- this bank contains fewer than eight visible FX. The physical pad remains
  -- off; this is a helper-GRID label.
  if col == 5 and row == 8 then
    local kind, base = DAW.TRACK_VIEWER.fx_or_color_base()
    if kind == "fx" then
      local track = DAW.TRACK_VIEWER.selected_track
      local count = track and (r.TrackFX_GetCount(track) or 0) or 0
      local visible_in_bank = math.max(0, math.min(8, count - base))
      if visible_in_bank < 8 then return {"FX"} end
    end
  end

  if not info or not DAW.TRACK_VIEWER.button_available(info) then return {" "} end
  if info.kind == "fx" then return {info.label, info.detail or ""} end
  if info.kind == "color" then return {"Color", "Track", info.detail or ""} end

  local lines = {}
  if DISPLAY_LINE_OVERRIDES[info.label] then
    for _, line in ipairs(DISPLAY_LINE_OVERRIDES[info.label]) do lines[#lines + 1] = line end
  else
    for word in tostring(info.label or ""):gmatch("%S+") do lines[#lines + 1] = word end
  end
  return (#lines > 0) and lines or {" "}
end

DAW.TRACK_VIEWER.draw_grid_impl = function()
  DAW.GUI.draw_screen_title(DAW.TRACK_VIEWER.screen_title())
  DAW.TRACK_VIEWER.grid_drag.bounds = {}

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for slot = 1, 8 do
    local background = DAW.TRACK_VIEWER.top_gui_color(slot)
    local clicked = draw_compact_grid_button(
      "##track_viewer_top_" .. tostring(slot),
      DAW.TRACK_VIEWER.top_lines(slot),
      cell_w, cell_h, background, readable_text_color(background)
    )
    if clicked then DAW.TRACK_VIEWER.handle_top_slot(slot) end
    r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
  end
  local header = 0x303030FF
  draw_compact_grid_button(
    "##track_viewer_header",
    {"TRACK", "VIEWER"},
    cell_w, cell_h, header, readable_text_color(header)
  )

  for row = 1, 8 do
    local segment_from_bottom = 9 - row
    for col = 1, 9 do
      local lines = {" "}
      local background = CUSTOM_FADER_OFF_COLOR
      local clicked

      if col <= 4 then
        background = custom_fader_stage_color(
          DAW.TRACK_VIEWER.fader_gui_color(col),
          DAW.TRACK_VIEWER.fader_stage_count(col),
          segment_from_bottom
        )
        if col == 2 and row == 1 then
          lines = {"L"}
        elseif col == 2 and row == 7 then
          lines = {"R"}
        elseif row == 8 then
          lines = {DAW.TRACK_VIEWER.fader_label(col)}
        end
      elseif col <= 8 then
        local info = DAW.TRACK_VIEWER.button_info(row, col)
        background = DAW.TRACK_VIEWER.palette_gui_color(
          DAW.TRACK_VIEWER.button_palette(row, col),
          row
        )
        if DAW.TRACK_VIEWER.button_active(info) then background = pulse_gui_color(background) end
        lines = DAW.TRACK_VIEWER.gui_button_lines(row, col)
      else
        background = CUSTOM_FADER_GUI_COLORS[row] or CUSTOM_FADER_BANK_COLOR
        if row == DAW.TRACK_VIEWER.bank then background = pulse_gui_color(background) end
        lines = DAW.TRACK_VIEWER.bank_lines(row)
      end

      local cell_x, cell_y = r.ImGui_GetCursorScreenPos(ctx)
      clicked = draw_compact_grid_button(
        "##track_viewer_cell_" .. tostring(row) .. "_" .. tostring(col),
        lines, cell_w, cell_h, background, readable_text_color(background)
      )
      local item_active = r.ImGui_IsItemActive(ctx)

      if row == 2 and col == 7 then
        if item_active then DAW.TRACK_VIEWER.begin_select_hold("GRID") end
        if DAW.TRACK_VIEWER.locked_to_track then
          DAW.TRACK_VIEWER.draw_lock_indicator(cell_x, cell_y, cell_w, cell_h)
        end
      end

      if col <= 4 then
        local bounds = DAW.TRACK_VIEWER.grid_drag.bounds[col]
        if not bounds then
          bounds = {x1 = cell_x, x2 = cell_x + cell_w, y1 = cell_y, y2 = cell_y + cell_h}
          DAW.TRACK_VIEWER.grid_drag.bounds[col] = bounds
        else
          bounds.x1 = math.min(bounds.x1, cell_x)
          bounds.x2 = math.max(bounds.x2, cell_x + cell_w)
          bounds.y1 = math.min(bounds.y1, cell_y)
          bounds.y2 = math.max(bounds.y2, cell_y + cell_h)
        end
        if clicked then
          DAW.TRACK_VIEWER.cancel_fade(col)
          DAW.TRACK_VIEWER.set_fader_value(
            col,
            custom_fader_midi_value_from_grid_y(bounds.y1, bounds.y2),
            "GRID"
          )
          DAW.TRACK_VIEWER.refresh_button_surface(true)
        end
      elseif col <= 8 then
        if row == 2 and col == 7 then
          if clicked then DAW.TRACK_VIEWER.end_select_hold("GRID") end
        elseif clicked then
          DAW.TRACK_VIEWER.dispatch_button(row, col, "GRID")
        end
      elseif clicked then
        DAW.TRACK_VIEWER.set_bank(row, "Track Viewer GRID")
      end

      if col < 9 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
    end
  end

  local gap_fader = DAW.GUI.capture_fader_gap_items(
    "##track_viewer_gap_",
    DAW.TRACK_VIEWER.grid_drag.bounds,
    "vertical",
    cell_w,
    cell_h
  )
  local mouse_down = r.ImGui_IsMouseDown(ctx, 0)
  local mouse_x, mouse_y = r.ImGui_GetMousePos(ctx)

  if DAW.TRACK_VIEWER.select_hold.active
      and DAW.TRACK_VIEWER.select_hold.source == "GRID"
      and not mouse_down then
    DAW.TRACK_VIEWER.end_select_hold("GRID")
  end

  if not mouse_down then
    DAW.TRACK_VIEWER.grid_drag.active_fader = nil
    DAW.TRACK_VIEWER.grid_drag.last_value = nil
    DAW.TRACK_VIEWER.grid_drag.started_in_gap = false
  elseif gap_fader then
    DAW.GUI.begin_grid_fader_drag(
      DAW.TRACK_VIEWER.grid_drag,
      gap_fader,
      mouse_x,
      mouse_y,
      true
    )
  elseif not DAW.TRACK_VIEWER.grid_drag.active_fader then
    for fader = 1, 4 do
      local bounds = DAW.TRACK_VIEWER.grid_drag.bounds[fader]
      if bounds and mouse_x >= bounds.x1 and mouse_x <= bounds.x2
          and mouse_y >= bounds.y1 and mouse_y <= bounds.y2 then
        DAW.GUI.begin_grid_fader_drag(
          DAW.TRACK_VIEWER.grid_drag,
          fader,
          mouse_x,
          mouse_y,
          false
        )
        break
      end
    end
  end

  local fader = DAW.TRACK_VIEWER.grid_drag.active_fader
  local bounds = fader and DAW.TRACK_VIEWER.grid_drag.bounds[fader]
  if mouse_down and fader and bounds
      and DAW.GUI.grid_fader_drag_ready(DAW.TRACK_VIEWER.grid_drag, mouse_x, mouse_y) then
    local value = custom_fader_midi_value_from_grid_y(bounds.y1, bounds.y2)
    if DAW.TRACK_VIEWER.grid_drag.last_value ~= value then
      DAW.TRACK_VIEWER.grid_drag.last_value = value
      DAW.TRACK_VIEWER.cancel_fade(fader)
      DAW.TRACK_VIEWER.set_fader_value(fader, value, "GRID drag")
      DAW.TRACK_VIEWER.refresh_button_surface(true)
    end
  end
end

local function draw_custom_volume_grid()
  refresh_mcp_track_cache(false)
  custom_grid_drag.bounds = {}

  local slot = active_custom_slot or 1
  local bank_start = active_fader_start_index()
  local visible_tracks = DAW.active_fader_track_list()
  local preset_number = DAW.active_preset or 1
  DAW.GUI.draw_screen_title(string.format("Preset %d: %s", preset_number, DAW.preset_name(preset_number) or "Unnamed"))

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  -- Mirror the physical DAW-fader top row. The first two buttons name the
  -- adjacent presets, the next two navigate MCP banks, Session is requested
  -- white, Note and Custom stay dark, and the final button returns HOME.
  for top_slot = 1, 8 do
    local lines = DAW.top_row_slot_lines(top_slot)
    local background = DAW.top_row_slot_color(top_slot)
    local clicked = draw_compact_grid_button(
      "##daw_top_row_" .. tostring(top_slot),
      lines,
      cell_w,
      cell_h,
      background,
      readable_text_color(background)
    )
    if clicked then DAW.handle_top_row_press(top_slot) end
    if top_slot < 8 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
  end
  -- GUI-only top-right header for the physical right-column bank selectors.
  -- The aligned bank buttons themselves remain ordered from high tracks at the
  -- top to Tracks 1-8 at the bottom.
  r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
  local spacer = CUSTOM_FADER_HEADER_COLOR
  draw_compact_grid_button(
    "##daw_top_row_spacer",
    {DAW.active_scope_label(), "Fader", "Banks"},
    cell_w,
    cell_h,
    spacer,
    readable_text_color(spacer)
  )

  -- Eight physical rows. Each colored Launchpad pad represents four brightness
  -- stages. This mirrors the native fader appearance while keeping the computer
  -- display easy to read.
  for gui_row = 1, 8 do
    local segment_from_bottom = 9 - gui_row
    local row_slot = gui_row

    for col = 1, 9 do
      local lines = {" "}
      local background

      if col <= 8 then
        local mcp_index = bank_start + col - 1
        local track = visible_tracks[mcp_index]
        local stage_count = custom_fader_stage_count_for_track(track)
        background = custom_fader_stage_color(
          CUSTOM_FADER_GUI_COLORS[col],
          stage_count,
          segment_from_bottom
        )
      else
        local logical_bank = 9 - row_slot
        local row_start = ((logical_bank - 1) * 8) + 1
        local row_finish = logical_bank * 8
        lines = {DAW.active_scope_label(), "Tracks", tostring(row_start) .. " - " .. tostring(row_finish)}
        background = CUSTOM_FADER_BANK_COLOR
        if bank_start == row_start then
          background = pulse_gui_color(background)
        end
      end

      local cell_x, cell_y = r.ImGui_GetCursorScreenPos(ctx)
      local clicked = draw_compact_grid_button(
        "##custom_cell_" .. tostring(gui_row) .. "_" .. tostring(col),
        lines,
        cell_w,
        cell_h,
        background,
        readable_text_color(background)
      )

      if col <= 8 and gui_row == 8 then
        local mcp_index = bank_start + col - 1
        local track = visible_tracks[mcp_index]
        DAW.GUI.draw_track_identity_overlay(
          cell_x, cell_y, cell_w, cell_h, track, mcp_index,
          readable_text_color(background), true
        )
      end

      if col <= 8 then
        -- Build a single continuous vertical hit region for each GUI fader.
        -- The actual drag logic runs after the entire grid is drawn, allowing
        -- the pointer to cross the boundaries between the eight visual pads.
        local bounds = custom_grid_drag.bounds[col]
        if not bounds then
          bounds = {x1 = cell_x, x2 = cell_x + cell_w, y1 = cell_y, y2 = cell_y + cell_h}
          custom_grid_drag.bounds[col] = bounds
        else
          bounds.x1 = math.min(bounds.x1, cell_x)
          bounds.x2 = math.max(bounds.x2, cell_x + cell_w)
          bounds.y1 = math.min(bounds.y1, cell_y)
          bounds.y2 = math.max(bounds.y2, cell_y + cell_h)
        end

        if clicked then
          -- Preserve the known-good discrete GRID click behavior exactly.
          -- Each physical pad exposes four native brightness levels.
          local _, mouse_y = r.ImGui_GetMousePos(ctx)
          local rel_y = math.max(0, math.min(cell_h - 0.0001, mouse_y - cell_y))
          local quarter_from_top = math.floor((rel_y / cell_h) * 4)
          local level_within_segment = 4 - quarter_from_top
          local stage = ((segment_from_bottom - 1) * 4) + level_within_segment
          local midi_value = math.floor(((stage - 1) / (CUSTOM_FADER_STAGE_COUNT - 1)) * 127 + 0.5)
          set_custom_fader_volume_from_gui(slot, col, midi_value)
        end
      elseif clicked then
        -- The GUI-only right column is a bank selector. Ask the Launchpad X
        -- to enter the matching resident Custom Mode; its report will confirm
        -- the selection and refresh the correct MCP fader block.
        if surface_mode == "DAW_VOLUME_FADERS" then
          DAW.select_volume_bank(9 - row_slot)
          sync_active_custom_fader_feedback(true)
        elseif selected_device.key == "X" then
          send_switch_to_custom_slot(row_slot)
        else
          last_action = "GUI Custom bank switching is currently enabled for Launchpad X only"
        end
      end

      if col < 9 then
        r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
      end
    end
  end

  -- Optional continuous GRID dragging. The initial mouse-down chooses a GUI
  -- fader column. That same column remains active until release, even while the
  -- pointer crosses the boundaries between visual pad cells. This does not add
  -- any DAW/Novation ownership or feedback logic; it only calls the existing
  -- GRID click setter when the calculated MIDI value changes.
  local gap_fader = DAW.GUI.capture_fader_gap_items(
    "##custom_volume_gap_",
    custom_grid_drag.bounds,
    "vertical",
    cell_w,
    cell_h
  )
  local mouse_down = r.ImGui_IsMouseDown(ctx, 0)
  local mouse_x, mouse_y = r.ImGui_GetMousePos(ctx)

  if not mouse_down then
    custom_grid_drag.active_fader = nil
    custom_grid_drag.last_value = nil
    custom_grid_drag.started_in_gap = false
  elseif gap_fader then
    DAW.GUI.begin_grid_fader_drag(custom_grid_drag, gap_fader, mouse_x, mouse_y, true)
  elseif not custom_grid_drag.active_fader then
    for fader_number = 1, 8 do
      local bounds = custom_grid_drag.bounds[fader_number]
      if bounds and mouse_x >= bounds.x1 and mouse_x <= bounds.x2
          and mouse_y >= bounds.y1 and mouse_y <= bounds.y2 then
        DAW.GUI.begin_grid_fader_drag(custom_grid_drag, fader_number, mouse_x, mouse_y, false)
        break
      end
    end
  end

  local active_fader = custom_grid_drag.active_fader
  local bounds = active_fader and custom_grid_drag.bounds[active_fader]
  if mouse_down and active_fader and bounds
      and DAW.GUI.grid_fader_drag_ready(custom_grid_drag, mouse_x, mouse_y) then
    local midi_value = custom_fader_midi_value_from_grid_y(bounds.y1, bounds.y2)
    if custom_grid_drag.last_value ~= midi_value then
      custom_grid_drag.last_value = midi_value
      set_custom_fader_volume_from_gui(slot, active_fader, midi_value)
    end
  end
end

local function custom_pan_segment_color(row_color, midi_value, segment_from_left)
  midi_value = math.max(0, math.min(127, tonumber(midi_value) or 64))
  -- Bipolar firmware faders use MIDI value 64 as the exact centre. At centre,
  -- show both middle pads fully lit. Just off-centre, the existing staged
  -- behaviour resumes: the nearer middle pad dims and the opposite side turns off.
  if midi_value == 64 then
    if segment_from_left == 4 or segment_from_left == 5 then return row_color end
    return CUSTOM_FADER_OFF_COLOR
  end
  local position = (midi_value / 127) * 31
  local micro_start = (segment_from_left - 1) * 4
  local micro_finish = micro_start + 3
  local count = 0

  if position < 15.5 then
    local from_micro = math.floor(position + 0.5)
    count = math.max(0, math.min(micro_finish, 15) - math.max(micro_start, from_micro) + 1)
  elseif position > 15.5 then
    local to_micro = math.floor(position + 0.5)
    count = math.max(0, math.min(micro_finish, to_micro) - math.max(micro_start, 16) + 1)
  elseif segment_from_left == 4 or segment_from_left == 5 then
    count = 1
  end

  if count >= 4 then return row_color end
  if count == 3 then return scale_color(row_color, 0.76) end
  if count == 2 then return scale_color(row_color, 0.56) end
  if count == 1 then return scale_color(row_color, 0.34) end
  return CUSTOM_FADER_OFF_COLOR
end

DAW.GUI.custom_pan_snap_center = function(normalized)
  normalized = math.max(0, math.min(1, normalized or 0.5))
  -- Give the exact centre a slightly wider sweet spot than a single MIDI value
  -- so it is easy to land on a centered pan with the GUI.
  if math.abs(normalized - 0.5) <= 0.035 then return 64 end
  return math.floor((normalized * 127) + 0.5)
end

local function custom_pan_midi_value_from_grid_x(x1, x2)
  local mouse_x = select(1, r.ImGui_GetMousePos(ctx))
  local width = math.max(1, x2 - x1)
  return DAW.GUI.custom_pan_snap_center((mouse_x - x1) / width)
end

local function draw_custom_pan_grid()
  refresh_mcp_track_cache(false)
  custom_grid_drag.bounds = {}

  local slot = active_custom_slot or 1
  local bank_start = active_fader_start_index()
  local visible_tracks = DAW.active_fader_track_list()
  local preset_number = DAW.active_preset or 2
  DAW.GUI.draw_screen_title(string.format("Preset %d: %s", preset_number, DAW.preset_name(preset_number) or "Unnamed"))

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  -- Patch 2 mirrors the physical 8x8 horizontal-fader surface plus the
  -- GUI-only right-hand bank selector column. There is deliberately no
  -- extra left label column: the leftmost pad remains an active pan cell.
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)
  local spacer = CUSTOM_FADER_HEADER_COLOR

  -- Eight physical DAW-fader top-row controls aligned directly above the
  -- eight active horizontal pan segments.
  for top_slot = 1, 8 do
    local lines = DAW.top_row_slot_lines(top_slot)
    local background = DAW.top_row_slot_color(top_slot)
    local clicked = draw_compact_grid_button(
      "##pan_top_" .. tostring(top_slot),
      lines,
      cell_w,
      cell_h,
      background,
      readable_text_color(background)
    )
    if clicked then DAW.handle_top_row_press(top_slot) end
    r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
  end

  -- GUI-only header for the physical right-column bank selectors.
  draw_compact_grid_button(
    "##pan_top_right",
    {DAW.active_scope_label(), "Fader", "Banks"},
    cell_w,
    cell_h,
    spacer,
    readable_text_color(spacer)
  )

  for gui_row = 1, 8 do
    local mcp_index = bank_start + gui_row - 1
    local track = visible_tracks[mcp_index]
    local row_color = CUSTOM_FADER_GUI_COLORS[gui_row]
    local midi_value = track and track_target_to_midi_cc(track) or 64

    for segment = 1, 8 do
      local background = track and custom_pan_segment_color(row_color, midi_value, segment) or CUSTOM_FADER_OFF_COLOR
      -- Keep every pan cell active. Segment 1 also carries the ordinary
      -- track-number/name overlay used by the other track-oriented patches.
      local lines = {" "}

      local cell_x, cell_y = r.ImGui_GetCursorScreenPos(ctx)
      local clicked = draw_compact_grid_button(
        "##pan_cell_" .. tostring(gui_row) .. "_" .. tostring(segment),
        lines,
        cell_w,
        cell_h,
        background,
        readable_text_color(background)
      )

      if track and segment == 1 then
        DAW.GUI.draw_track_identity_overlay(
          cell_x, cell_y, cell_w, cell_h,
          track, mcp_index, readable_text_color(background), false
        )
      end

      local bounds = custom_grid_drag.bounds[gui_row]
      if not bounds then
        bounds = {x1 = cell_x, x2 = cell_x + cell_w, y1 = cell_y, y2 = cell_y + cell_h}
        custom_grid_drag.bounds[gui_row] = bounds
      else
        bounds.x1 = math.min(bounds.x1, cell_x)
        bounds.x2 = math.max(bounds.x2, cell_x + cell_w)
        bounds.y1 = math.min(bounds.y1, cell_y)
        bounds.y2 = math.max(bounds.y2, cell_y + cell_h)
      end

      if clicked then
        local mouse_x = select(1, r.ImGui_GetMousePos(ctx))
        local rel_x = math.max(0, math.min(cell_w - 0.0001, mouse_x - cell_x))
        local quarter_from_left = math.floor((rel_x / cell_w) * 4)
        local stage = ((segment - 1) * 4) + quarter_from_left + 1
        local normalized = (stage - 1) / (CUSTOM_FADER_STAGE_COUNT - 1)
        set_custom_fader_volume_from_gui(slot, gui_row, DAW.GUI.custom_pan_snap_center(normalized))
      end

      r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
    end

    local logical_bank = 9 - gui_row
    local row_start = ((logical_bank - 1) * 8) + 1
    local row_finish = logical_bank * 8
    local background = CUSTOM_FADER_BANK_COLOR
    if bank_start == row_start then background = pulse_gui_color(background) end
    local clicked_bank = draw_compact_grid_button(
      "##pan_bank_" .. tostring(gui_row),
      {DAW.active_scope_label(), "Tracks", tostring(row_start) .. " - " .. tostring(row_finish)},
      cell_w,
      cell_h,
      background,
      readable_text_color(background)
    )
    if clicked_bank then
      DAW.select_volume_bank(logical_bank)
      sync_active_custom_fader_feedback(true)
    end
  end

  local gap_fader = DAW.GUI.capture_fader_gap_items(
    "##custom_pan_gap_",
    custom_grid_drag.bounds,
    "horizontal",
    cell_w,
    cell_h
  )
  local mouse_down = r.ImGui_IsMouseDown(ctx, 0)
  local mouse_x, mouse_y = r.ImGui_GetMousePos(ctx)
  if not mouse_down then
    custom_grid_drag.active_fader = nil
    custom_grid_drag.last_value = nil
    custom_grid_drag.started_in_gap = false
  elseif gap_fader then
    DAW.GUI.begin_grid_fader_drag(custom_grid_drag, gap_fader, mouse_x, mouse_y, true)
  elseif not custom_grid_drag.active_fader then
    for fader_number = 1, 8 do
      local bounds = custom_grid_drag.bounds[fader_number]
      if bounds and mouse_x >= bounds.x1 and mouse_x <= bounds.x2 and mouse_y >= bounds.y1 and mouse_y <= bounds.y2 then
        DAW.GUI.begin_grid_fader_drag(custom_grid_drag, fader_number, mouse_x, mouse_y, false)
        break
      end
    end
  end

  local active_fader = custom_grid_drag.active_fader
  local bounds = active_fader and custom_grid_drag.bounds[active_fader]
  if mouse_down and active_fader and bounds
      and DAW.GUI.grid_fader_drag_ready(custom_grid_drag, mouse_x, mouse_y) then
    local value = custom_pan_midi_value_from_grid_x(bounds.x1, bounds.x2)
    if custom_grid_drag.last_value ~= value then
      custom_grid_drag.last_value = value
      set_custom_fader_volume_from_gui(slot, active_fader, value)
    end
  end
end

DAW.MATRIX.matrix_palette_gui_color = function(palette)
  palette = tonumber(palette) or 0x00
  if palette == 0x00 then return DAW.HOME_LED_OFF_GUI_COLOR or 0x282828FF end
  return DAW.SAMPLED_PALETTE_GUI_COLORS[palette]
    or DAW_MATRIX_PALETTE_TO_GUI_COLOR[palette]
    or 0x444444FF
end

DAW.MATRIX.matrix_gui_utility_color = function(label, color)
  if label == "Tracks 1-40" and DAW.MATRIX.matrix_page_for_start_track() == 1 then
    return pulse_gui_color(color or 0x00)
  elseif label == "Tracks 41-80" and DAW.MATRIX.matrix_page_for_start_track() == 2 then
    return pulse_gui_color(color or 0x00)
  elseif label == "Tracks 81-120" and DAW.MATRIX.matrix_page_for_start_track() == 3 then
    return pulse_gui_color(color or 0x00)
  elseif ACTIVE_STATE_CHECKS[label] and is_label_active(label) then
    return DAW.record_flash_gui_color(label) or pulse_gui_color(color or 0x00)
  end
  return color or 0x00
end

DAW.MATRIX.draw_matrix_grid = function()
  refresh_mcp_track_cache(false)
  local preset_number = DAW.active_preset or DAW.MATRIX.matrix_preset_for_mode(DAW.MATRIX.active_mode) or 3
  local preset_name = DAW.preset_name(preset_number) or "Track Matrix"
  DAW.GUI.draw_screen_title(string.format("Preset %d: %s", preset_number, preset_name))

  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  -- GUI top row mirrors the Session hardware navigation strip.
  for slot = 1, 8 do
    local palette = DAW.MATRIX.matrix_top_row_color(slot)
    local background = DAW.MATRIX.matrix_palette_gui_color(palette)
    local clicked = draw_compact_grid_button(
      "##matrix_top_" .. tostring(slot),
      DAW.MATRIX.matrix_top_row_lines(slot),
      cell_w, cell_h, background, readable_text_color(background)
    )
    if clicked then DAW.MATRIX.matrix_handle_top_row_press(slot, "GRID") end
    if slot < 8 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
  end
  r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
  do
    local status_palette = DAW.MATRIX.matrix_page_status_color()
    local status_text = DAW.SAMPLED_PALETTE_GUI_COLORS[status_palette] or DAW_MATRIX_PALETTE_TO_GUI_COLOR[status_palette] or 0xFFFFFFFF
    draw_compact_grid_button(
      "##matrix_top_spacer",
      DAW.MATRIX.matrix_page_status_lines(),
      cell_w,
      cell_h,
      DAW.PAGE_STATUS_GUI_BACKGROUND,
      status_text,
      DAW.GUI.page_status_draw_options()
    )
  end

  for row = 1, 8 do
    for col = 1, 9 do
      local lines = {" "}
      local background = 0x181818FF
      local clicked_action = nil

      if col <= 5 then
        local track, mcp_index = DAW.MATRIX.matrix_track_at_cell(row, col)
        if track then
          local track_active = DAW.MATRIX.matrix_track_is_active(track, DAW.MATRIX.active_mode)
          local palette = DAW.MATRIX.matrix_track_style(mcp_index, track_active)
          background = DAW.MATRIX.matrix_palette_gui_color(palette)
          if track_active then background = pulse_gui_color(background) end
          clicked_action = function() DAW.MATRIX.matrix_apply_track_press(track, mcp_index); DAW.refresh_matrix_surface(false) end
        end
      elseif col == 7 and row <= 5 then
        local mode = DAW.MATRIX.MODE_ORDER[row]
        lines = {DAW.MATRIX.MODE_LABELS[mode]}
        background = DAW.MATRIX.matrix_palette_gui_color(DAW.MATRIX.MODE_COLORS[mode])
        if mode == DAW.MATRIX.active_mode then background = pulse_gui_color(background) end
        clicked_action = function() DAW.MATRIX.matrix_set_mode(mode); DAW.refresh_matrix_surface(false) end
      elseif col <= 8 then
        local utility = DAW.MATRIX.MAIN_UTILITY[row] and DAW.MATRIX.MAIN_UTILITY[row][col]
        if utility then
          lines = compact_label_lines(utility.label, utility.label, DAW.MATRIX.matrix_utility_is_wired(utility.label), false)
          background = DAW.MATRIX.matrix_palette_gui_color(utility.color)
          background = DAW.MATRIX.matrix_gui_utility_color(utility.label, background)
          clicked_action = function() DAW.MATRIX.matrix_dispatch_named_action(utility.label, true, "GRID"); DAW.MATRIX.matrix_dispatch_named_action(utility.label, false, "GRID"); DAW.refresh_matrix_surface(false) end
        end
      else
        local utility = DAW.MATRIX.RIGHT_UTILITY[row]
        if utility then
          lines = compact_label_lines(utility.label, utility.label, DAW.MATRIX.matrix_utility_is_wired(utility.label), false)
          background = DAW.MATRIX.matrix_palette_gui_color(utility.color)
          background = DAW.MATRIX.matrix_gui_utility_color(utility.label, background)
          clicked_action = function() DAW.MATRIX.matrix_dispatch_named_action(utility.label, true, "GRID right column"); DAW.MATRIX.matrix_dispatch_named_action(utility.label, false, "GRID right column"); DAW.refresh_matrix_surface(false) end
        end
      end

      local cell_x, cell_y = r.ImGui_GetCursorScreenPos(ctx)
      local draw_options = nil
      if col == 9 then
        draw_options = {max_lines = 3}
      end
      local clicked = draw_compact_grid_button("##matrix_" .. tostring(row) .. "_" .. tostring(col), lines, cell_w, cell_h, background, readable_text_color(background), draw_options)
      if col <= 5 then
        local track, mcp_index = DAW.MATRIX.matrix_track_at_cell(row, col)
        if track then
          DAW.GUI.draw_track_identity_overlay(
            cell_x, cell_y, cell_w, cell_h, track, mcp_index,
            readable_text_color(background), false
          )
        end
      end
      if clicked and clicked_action then clicked_action() end
      if col < 9 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
    end
  end
end


DAW.FX.fader_stage_color = function(row_color, midi_value, segment_from_bottom)
  midi_value = math.max(0, math.min(127, tonumber(midi_value) or 0))
  local stage = math.floor((midi_value / 127) * 31 + 0.5) + 1
  local segment_start = ((segment_from_bottom - 1) * 4) + 1
  local lit = stage - segment_start + 1
  if lit >= 4 then return row_color end
  if lit == 3 then return scale_color(row_color, 0.76) end
  if lit == 2 then return scale_color(row_color, 0.56) end
  if lit == 1 then return scale_color(row_color, 0.34) end
  return CUSTOM_FADER_OFF_COLOR
end

DAW.FX.horizontal_stage_color = function(row_color, midi_value, segment_from_left)
  midi_value = math.max(0, math.min(127, tonumber(midi_value) or 0))
  local stage = math.floor((midi_value / 127) * 31 + 0.5) + 1
  local segment_start = ((segment_from_left - 1) * 4) + 1
  local lit = stage - segment_start + 1
  if lit >= 4 then return row_color end
  if lit == 3 then return scale_color(row_color, 0.76) end
  if lit == 2 then return scale_color(row_color, 0.56) end
  if lit == 1 then return scale_color(row_color, 0.34) end
  return CUSTOM_FADER_OFF_COLOR
end

DAW.FX.fader_midi_from_grid_y = function(y1, y2)
  local _, mouse_y = r.ImGui_GetMousePos(ctx)
  local height = math.max(1, y2 - y1)
  local normalized = 1.0 - ((mouse_y - y1) / height)
  return math.floor(math.max(0, math.min(1, normalized)) * 127 + 0.5)
end

DAW.FX.fader_midi_from_grid_x = function(x1, x2)
  local mouse_x = select(1, r.ImGui_GetMousePos(ctx))
  local width = math.max(1, x2 - x1)
  local normalized = (mouse_x - x1) / width
  return math.floor(math.max(0, math.min(1, normalized)) * 127 + 0.5)
end

DAW.FX.set_fader_from_gui = function(fader_number, midi_value)
  local param_index = DAW.FX.param_for_fader(fader_number)
  if DAW.FX.set_normalized(param_index, DAW.FX.midi_to_normalized(midi_value)) then
    DAW.FX.last_sent_fader_values[fader_number] = midi_value
    DAW.FX.send_fader_feedback(fader_number, midi_value)
    last_action = string.format("GRID set ValueVault parameter %d to %d", DAW.FX.param_human_number(param_index), midi_value)
  end
end

DAW.FX.draw_fader_grid = function()
  custom_grid_drag.bounds = {}
  local preset_number = DAW.active_preset or 21
  local horizontal = (DAW.FX.active_preset() or {}).orientation == 0x01
  DAW.GUI.draw_screen_title(string.format("Preset %d: %s", preset_number, DAW.preset_name(preset_number) or "FX Faders"))
  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for top_slot = 1, 8 do
    local lines = DAW.top_row_slot_lines(top_slot)
    local background = DAW.top_row_slot_color(top_slot)
    local clicked = draw_compact_grid_button("##fx_top_" .. tostring(top_slot), lines, cell_w, cell_h, background, readable_text_color(background))
    if clicked then DAW.FX.handle_top_row_press(top_slot, "GRID") end
    r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
  end
  local corner_lines
  if DAW.FX.surface_is_combo() then
    corner_lines = {"Buttons", DAW.FX.combo_button_range_text()}
  else
    corner_lines = horizontal and {"Pot/Slider", "Groups"} or {"Fader", "Groups"}
  end
  draw_compact_grid_button("##fx_top_right", corner_lines, cell_w, cell_h, CUSTOM_FADER_HEADER_COLOR, readable_text_color(CUSTOM_FADER_HEADER_COLOR))

  for gui_row = 1, 8 do
    local segment_from_bottom = 9 - gui_row
    for col = 1, 9 do
      local lines = {" "}
      local background = CUSTOM_FADER_OFF_COLOR
      local clicked = false
      local assigned = false
      if col <= 8 then
        -- Vertical surfaces use one fader per column. Horizontal surfaces use
        -- one fader per row, with the row's value spreading left-to-right.
        local fader_number = horizontal and gui_row or col
        local param_index = DAW.FX.param_for_fader(fader_number)
        assigned = DAW.FX.has_assignment(param_index)
        if assigned then
          local midi_value = DAW.FX.normalized_to_midi(DAW.FX.get_normalized(param_index) or 0)
          background = horizontal
            and DAW.FX.horizontal_stage_color(CUSTOM_FADER_GUI_COLORS[gui_row], midi_value, col)
            or DAW.FX.fader_stage_color(CUSTOM_FADER_GUI_COLORS[col], midi_value, segment_from_bottom)
        end
      else
        if DAW.FX.surface_is_combo() then
          -- Top-to-bottom ValueVault button column, independently paged from
          -- the fader bank. The row color remains the standard rainbow.
          local param_index = DAW.FX.combo_button_param(gui_row)
          local active = (DAW.FX.get_normalized(param_index) or 0) > 0.5
          lines = {
            tostring(DAW.FX.param_human_number(param_index)),
            DAW.FX.short_label(param_index),
          }
          background = CUSTOM_FADER_GUI_COLORS[gui_row] or CUSTOM_FADER_BANK_COLOR
          if active then background = pulse_gui_color(background) end
        else
          -- Top-to-bottom right-column orientation and direct group selector.
          local logical_group = gui_row
          lines = DAW.FX.group_selector_lines(logical_group)
          background = CUSTOM_FADER_GUI_COLORS[logical_group] or CUSTOM_FADER_BANK_COLOR
          if logical_group == (DAW.FX.active_page or 1) then background = pulse_gui_color(background) end
        end
      end

      local cell_x, cell_y = r.ImGui_GetCursorScreenPos(ctx)
      clicked = draw_compact_grid_button("##fx_fader_cell_" .. tostring(gui_row) .. "_" .. tostring(col), lines, cell_w, cell_h, background, readable_text_color(background))

      if col <= 8 and assigned then
        if (horizontal and col == 1) or ((not horizontal) and gui_row == 8) then
          local param_index = DAW.FX.param_for_fader(horizontal and gui_row or col)
          DAW.GUI.draw_track_identity_overlay(cell_x, cell_y, cell_w, cell_h, nil, DAW.FX.param_human_number(param_index), readable_text_color(background), true)
          local draw_list = r.ImGui_GetWindowDrawList(ctx)
          r.ImGui_DrawList_AddText(draw_list, cell_x + 4, cell_y + 4, readable_text_color(background), DAW.FX.short_label(param_index))
        end

        local fader_number = horizontal and gui_row or col
        local bounds = custom_grid_drag.bounds[fader_number]
        if not bounds then
          bounds = {x1 = cell_x, x2 = cell_x + cell_w, y1 = cell_y, y2 = cell_y + cell_h}
          custom_grid_drag.bounds[fader_number] = bounds
        else
          bounds.x1 = math.min(bounds.x1, cell_x)
          bounds.x2 = math.max(bounds.x2, cell_x + cell_w)
          bounds.y1 = math.min(bounds.y1, cell_y)
          bounds.y2 = math.max(bounds.y2, cell_y + cell_h)
        end

        if clicked then
          local midi_value = horizontal
            and DAW.FX.fader_midi_from_grid_x(bounds.x1, bounds.x2)
            or DAW.FX.fader_midi_from_grid_y(bounds.y1, bounds.y2)
          DAW.FX.set_fader_from_gui(fader_number, midi_value)
        end
      elseif col == 9 and clicked then
        if DAW.FX.surface_is_combo() then
          DAW.FX.toggle_combo_button(gui_row)
        else
          DAW.FX.select_page(gui_row, "GRID selected ValueVault FX group " .. tostring(gui_row))
          DAW.FX.sync_fader_feedback(true)
        end
      end

      if col < 9 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
    end
  end

  local gap_fader = DAW.GUI.capture_fader_gap_items(
    "##fx_fader_gap_",
    custom_grid_drag.bounds,
    horizontal and "horizontal" or "vertical",
    cell_w,
    cell_h
  )
  local mouse_down = r.ImGui_IsMouseDown(ctx, 0)
  local mouse_x, mouse_y = r.ImGui_GetMousePos(ctx)
  if not mouse_down then
    custom_grid_drag.active_fader = nil
    custom_grid_drag.last_value = nil
    custom_grid_drag.started_in_gap = false
  elseif gap_fader then
    DAW.GUI.begin_grid_fader_drag(custom_grid_drag, gap_fader, mouse_x, mouse_y, true)
  elseif not custom_grid_drag.active_fader then
    for fader_number = 1, 8 do
      local bounds = custom_grid_drag.bounds[fader_number]
      if bounds and mouse_x >= bounds.x1 and mouse_x <= bounds.x2 and mouse_y >= bounds.y1 and mouse_y <= bounds.y2 then
        DAW.GUI.begin_grid_fader_drag(custom_grid_drag, fader_number, mouse_x, mouse_y, false)
        break
      end
    end
  end

  local active_fader = custom_grid_drag.active_fader
  local bounds = active_fader and custom_grid_drag.bounds[active_fader]
  if mouse_down and active_fader and bounds
      and DAW.GUI.grid_fader_drag_ready(custom_grid_drag, mouse_x, mouse_y) then
    local midi_value = horizontal and DAW.FX.fader_midi_from_grid_x(bounds.x1, bounds.x2) or DAW.FX.fader_midi_from_grid_y(bounds.y1, bounds.y2)
    if custom_grid_drag.last_value ~= midi_value then
      custom_grid_drag.last_value = midi_value
      DAW.FX.set_fader_from_gui(active_fader, midi_value)
    end
  end
end

DAW.FX.draw_matrix_grid = function()
  DAW.GUI.draw_screen_title("Preset 22: FX Buttons")
  local avail_w, avail_h = r.ImGui_GetContentRegionAvail(ctx)
  local cell_w = math.max(CFG.MIN_CELL_W, (avail_w - (CFG.CELL_GAP * 8)) / 9)
  local cell_h = math.max(CFG.MIN_CELL_H, (avail_h - (CFG.CELL_GAP * 8)) / 9)

  for top_slot = 1, 8 do
    local lines = DAW.top_row_slot_lines(top_slot)
    local background = DAW.top_row_slot_color(top_slot)
    local clicked = draw_compact_grid_button("##fx_matrix_top_" .. tostring(top_slot), lines, cell_w, cell_h, background, readable_text_color(background))
    if clicked then DAW.FX.handle_top_row_press(top_slot, "GRID") end
    r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP)
  end
  -- The title already identifies this surface; keep the corner cell visually quiet.
  draw_compact_grid_button("##fx_matrix_top_right", {" "}, cell_w, cell_h, CUSTOM_FADER_HEADER_COLOR, readable_text_color(CUSTOM_FADER_HEADER_COLOR))

  for row = 1, 8 do
    for col = 1, 9 do
      local lines = {" "}
      local background = CUSTOM_FADER_OFF_COLOR
      local clicked = false
      if col <= 8 then
        local param_index = DAW.FX.param_for_matrix_cell(row, col)
        local active = (DAW.FX.get_normalized(param_index) or 0) > 0.5
        -- Odd rows are rainbow; even rows are a slightly lighter neutral gray.
        if (row % 2) == 0 then
          background = DAW_MATRIX_PALETTE_TO_GUI_COLOR[DAW.FX.GRAY_NORMAL] or 0x555555FF
        else
          background = CUSTOM_FADER_GUI_COLORS[col] or 0x333333FF
        end
        if active then background = pulse_gui_color(background) end
        lines = {tostring(DAW.FX.param_human_number(param_index)), DAW.FX.short_label(param_index)}
      else
        -- Blank right-column group key, top-to-bottom red through neutral.
        lines = {" "}
        background = CUSTOM_FADER_GUI_COLORS[row] or CUSTOM_FADER_HEADER_COLOR
      end
      clicked = draw_compact_grid_button("##fx_matrix_cell_" .. tostring(row) .. "_" .. tostring(col), lines, cell_w, cell_h, background, readable_text_color(background))
      if clicked and col <= 8 then
        DAW.FX.handle_matrix_pad(row, col, true)
      end
      if col < 9 then r.ImGui_SameLine(ctx, nil, CFG.CELL_GAP) end
    end
  end
end

