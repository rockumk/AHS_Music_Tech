DAW.GUI = DAW.GUI or {}

-- Shared Programmer-mode 40-button MCP/TCP matrix used by Matrix presets.
-- The surface shows forty visible tracks at a time and moves through three
-- direct forty-track ranges. BANK moves by forty tracks; TRACK moves by ten.
-- Columns 1-5 are track buttons. Column 7 rows 1-5 selects Multiselect,
-- Select One, Mute, Solo, or Arm. Row 1 also exposes Clear Selections and
-- Select All. The bottom-right 3x3 retains basic transport controls, and the
-- far-right Session CC column preserves useful controller navigation.
DAW.MATRIX = {
  start_track = 1,
  visible_track_count = 40,
  maximum_track_count = 120,
  bank_step = 40,
  track_step = 10,
  active_mode = "select",
  last_surface_signature = nil,
  -- Cached hardware LED state. Ordinary matrix changes update only the pads or
  -- buttons whose desired state actually changed, avoiding a visible full-board blink.
  led_cache = {notes = {}, ccs = {}},
  MODE_ORDER = {"multiselect", "select", "mute", "solo", "arm"},
  MODE_LABELS = {
    multiselect = "Multiselect",
    select = "Select One",
    mute = "Mute",
    solo = "Solo",
    arm = "Arm",
  },
  MODE_PRESET_BY_SCOPE = {
    mcp = {multiselect = 3, select = 3, mute = 4, solo = 5, arm = 11},
    tcp = {multiselect = 8, select = 8, mute = 9, solo = 10, arm = 16},
  },
  MODE_COLORS = {
    multiselect = 0x25, -- blue, matching Select One
    select = 0x25,      -- blue, matching metronome family
    mute = 0x05,        -- red
    solo = 0x15,        -- green
    arm = 0x0D,         -- orange
  },
  -- Absolute MCP-visible track rows, five tracks per row. Every coloured
  -- five-track band is followed by a neutral gray band. The colour then repeats
  -- once before advancing to the next hue. This gives the mixer a finer visual
  -- locator: groups of five rather than groups of ten.
  ROW_STYLES = {
    {normal = 0x07, active = 0x05}, --  1- 5 dim red -> bright red
    {normal = 0x02, active = 0x03}, --  6-10 gray -> white
    {normal = 0x07, active = 0x05}, -- 11-15 dim red -> bright red
    {normal = 0x02, active = 0x03}, -- 16-20 gray -> white
    {normal = 0x0B, active = 0x09}, -- 21-25 dim orange -> bright orange
    {normal = 0x02, active = 0x03}, -- 26-30 gray -> white
    {normal = 0x0B, active = 0x09}, -- 31-35 dim orange -> bright orange
    {normal = 0x02, active = 0x03}, -- 36-40 gray -> white
    {normal = 0x0F, active = 0x0D}, -- 41-45 dim yellow -> bright yellow
    {normal = 0x02, active = 0x03}, -- 46-50 gray -> white
    {normal = 0x0F, active = 0x0D}, -- 51-55 dim yellow -> bright yellow
    {normal = 0x02, active = 0x03}, -- 56-60 gray -> white
    {normal = 0x1B, active = 0x15}, -- 61-65 dim green -> bright green
    {normal = 0x02, active = 0x03}, -- 66-70 gray -> white
    {normal = 0x1B, active = 0x15}, -- 71-75 dim green -> bright green
    {normal = 0x02, active = 0x03}, -- 76-80 gray -> white
  },
  -- Theme MCP layouts applied while a matrix patch is active. The theme's
  -- neutral A_Fader_White layout is used for the gray bands because no separate
  -- gray fader-tab layout has been defined yet.
  TAB_LAYOUTS = {
    "A_Fader_Red",    "A_Fader_White", "A_Fader_Red",    "A_Fader_White",
    "A_Fader_Orange", "A_Fader_White", "A_Fader_Orange", "A_Fader_White",
    "A_Fader_Yellow", "A_Fader_White", "A_Fader_Yellow", "A_Fader_White",
    "A_Fader_Green",  "A_Fader_White", "A_Fader_Green",  "A_Fader_White",
  },
  -- Main 8x8 utility cells not occupied by the forty-track matrix or mode
  -- selectors. Rows are top-to-bottom within the Session 8x8 surface.
  MAIN_UTILITY = {
    [1] = {
      [6] = {label = "Clear Selections", color = 0x02},
      [8] = {label = "Select All", color = 0x02},
    },
    [3] = {
      [6] = {label = "Track View of Selected", color = 0x25},
      [8] = {label = "Track Picker", color = 0x21},
    },
    [6] = {
      [6] = {label = "Record", color = 0x6A},
      [7] = {label = "Fast Reverse", color = 0x21},
      [8] = {label = "Fast Forward", color = 0x21},
    },
    [7] = {
      [6] = {label = "Save Take", color = 0x2A},
      [7] = {label = "Restart Take", color = 0x32},
      [8] = {label = "Cancel Take", color = 0x75},
    },
    [8] = {
      [6] = {label = "Play", color = 0x21},
      [7] = {label = "Stop", color = 0x05},
      [8] = {label = "Pause", color = 0x09},
    },
  },
  -- Far-right Programmer-mode column, top-to-bottom. Preserve the useful
  -- controller navigation behavior. The final three pads jump directly among
  -- the three forty-track ranges.
  RIGHT_UTILITY = {
    [1] = {label = "Go Marker Right", color = 0x25},
