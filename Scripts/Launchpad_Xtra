------------------------------------------------------------
-- HELPERS
------------------------------------------------------------
local function trim(s)
  return (s or ""):match("^%s*(.-)%s*$") or ""
end

local function normalize_label(label)
  return trim((label or ""):gsub("\n", " "):gsub("%s+", " "))
end

local function parse_label_grid(text)
  local rows = {}
  for line in (text or ""):gmatch("[^\r\n]+") do
    if line:match("%S") then
      local row = {}
      for cell in (line .. ","):gmatch("(.-),") do
        row[#row + 1] = trim(cell):gsub("_", "\n")
      end
      rows[#rows + 1] = row
    end
  end
  return rows
end

local function parse_color_grid(text)
  local colors = {}
  for token in (text or ""):gmatch("0x[%x]+") do
    colors[#colors + 1] = tonumber(token:sub(3), 16) or 0x444444FF
  end
  return colors
end

local function hex_string_to_byte(s)
  return tonumber((s or ""):gsub("%s+", ""), 16) or 0
end

local function bytes_to_string(bytes)
  local chars = {}
  for i = 1, #bytes do
    chars[i] = string.char(bytes[i])
  end
  return table.concat(chars)
end

-- An active LED cannot visibly pulse if its palette value remains true off
-- (0x00). Keep intentionally dark HOME buttons completely unlit while idle,
-- but let them breathe through the dimmest visible gray while their state is on.
-- Gray checkerboard buttons remain dim gray while idle, but pulse through the
-- next brighter gray so they remain visibly distinct from active dark buttons.
-- This is applied centrally so HOME, Actions, Customs, Track Picker, Regions &
-- Markers, and matrix surfaces all follow the same rule.
DAW.LED_OFF_ACTIVE_PULSE_PALETTE = 0x01
DAW.LED_DIM_GRAY_ACTIVE_PULSE_PALETTE = 0x02

-- Append one LED-lighting SysEx colourspec. Launchpad flash type 0x01 is the
-- only palette lighting type that carries two data bytes: Colour B followed by
-- Colour A. Omitting Colour A shifts every following colourspec out of alignment.
DAW.append_palette_colourspec = function(bytes, lighting_type, address, color, flash_base_color)
  lighting_type = math.max(0, math.min(3, math.floor(tonumber(lighting_type) or 0)))
  address = math.max(0, math.min(127, math.floor(tonumber(address) or 0)))
  color = math.max(0, math.min(127, math.floor(tonumber(color) or 0)))
  if lighting_type == 0x02 then
    if color == 0x00 then
      color = DAW.LED_OFF_ACTIVE_PULSE_PALETTE
    elseif color == 0x01 then
      color = DAW.LED_DIM_GRAY_ACTIVE_PULSE_PALETTE
    end
  end
  bytes[#bytes + 1] = lighting_type
  bytes[#bytes + 1] = address
  bytes[#bytes + 1] = color
  if lighting_type == 0x01 then
    bytes[#bytes + 1] = math.max(0, math.min(127, math.floor(tonumber(flash_base_color) or 0)))
  end
  return bytes
end

local function hex_text_to_bytes(hex_text)
  local bytes = {}
  for token in (hex_text or ""):gmatch("[%x][%x]") do
    bytes[#bytes + 1] = tonumber(token, 16)
  end
  return bytes
end

