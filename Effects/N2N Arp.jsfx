local(n1, n2, n3, n4, n5, dn1)
(
    clear_lane_set(base_ptr);

    n1 = next_scale_up(root);
    n2 = next_scale_up(n1);
    n3 = next_scale_up(n2);
    n4 = next_scale_up(n3);
    n5 = next_scale_up(n4);
    dn1 = next_scale_dn(root);

    mem[base_ptr+7] = root; // red lane
    mem[base_ptr+6] = n1;
    mem[base_ptr+5] = n1;
    mem[base_ptr+4] = n2;
    mem[base_ptr+3] = n3;
    mem[base_ptr+2] = n3;
    mem[base_ptr+1] = n4;
    mem[base_ptr+0] = n5;
    mem[base_ptr+8] = dn1;
);

