// Maps out patterns to flag if they qualify for Fallback behavior at all
function needs_fallback(t) (
    ((t >= 1 && t <= 20) || (t >= 32 && t <= 47) || (t >= 59 && t <= 74)) ? 1 : 0;
);

function get_active_fallback(req_tab) local(ptr, i, found_tab, cand, current_t, last_cand, iter) (
    // 1. If it's Tab 0 (Off) or doesn't qualify for a fallback based on mapping list, return itself.
    (req_tab == 0 || !needs_fallback(req_tab)) ? req_tab :
    
    // 2. Loop to resolve cascades
    (
        found_tab = -1;
        current_t = req_tab;
        iter = 0;
        
        while(iter < 20 && found_tab == -1) ( // 20 iterations max to prevent infinite loops
            mem[LOC_TAB_POPULATED + current_t] ? (
                found_tab = current_t;
            ) : (
                // Search its custom fallback list
                ptr = fallback_base + (current_t * 10);
                i = 0; 
                last_cand = -1;
                
                while(i < 10 && found_tab == -1) (
                    cand = mem[ptr + i];
                    cand != -1 ? (
                        mem[LOC_TAB_POPULATED + cand] ? (
                            found_tab = cand;
                        ) : (
                            last_cand = cand; // Remember the last valid fallback in this chain
                        );
                    ) : (
                        i = 10; // Break the inner loop early if we hit -1
                    );
                    i += 1;
                );
                
                // If we didn't find anything in the list, cascade to the last candidate
                found_tab == -1 ? (
                    last_cand != -1 ? (
                        current_t = last_cand; // Cascade!
                    ) : (
                        // No fallbacks defined and target is empty -> Force Default
                        found_tab = 26; 
                    );
                );
            );
            iter += 1;
        );
        
        // Failsafe: Return populated tab, or 26 if the entire chain is empty
        found_tab != -1 ? found_tab : 26;
    );
);

function update_active_row_list(t_idx) 
local(r, s, has_data, p_grid)
(
    active_row_count = 0;
    p_grid = grid_base + (t_idx * vel_stride_tab);
    r = 0;
    loop(MAX_ROWS,
        has_data = 0;
        s = 0;
        // Check if this row has ANY notes in this specific pattern
        while(s < vel_stride_row && !has_data) (
            mem[p_grid + (r * vel_stride_row) + s] > 0 ? has_data = 1;
            s += 1;
        );
        
        has_data ? (
            mem[active_row_list + active_row_count] = r;
            active_row_count += 1;
        );
        r += 1;
    );
);



function send_tab_trigger(t_idx) local(out_n) (
    out_n = -1;

    // --- SYSTEM & USER TABS ---
    t_idx == 0  ? out_n = 24 : // Off
    t_idx == 26 ? out_n = 25 : // Def
    t_idx == 53 ? out_n = 19 : // Min
    (t_idx >= 27 && t_idx <= 31) ? out_n = 1 + (t_idx - 27) : // User 1-5
    (t_idx >= 54 && t_idx <= 58) ? out_n = 6 + (t_idx - 54) : // User 6-10

    // --- HOOKS & FILLS ---
    t_idx == 21 ? out_n = 20 : // H1
    t_idx == 22 ? out_n = 21 : // H2
    t_idx == 48 ? out_n = 22 : // H3
    t_idx == 49 ? out_n = 23 : // H4
    (t_idx >= 23 && t_idx <= 25) ? out_n = 26 + (t_idx - 23) : // Fills 1 < = >
    (t_idx >= 50 && t_idx <= 52) ? out_n = 29 + (t_idx - 50) : // Fills 2 < = >

    // --- SONG SECTIONS ---
    (t_idx >= 1  && t_idx <= 4)  ? out_n = 32 + (t_idx - 1)  : // Intro A-D
    (t_idx >= 5  && t_idx <= 8)  ? out_n = 36 + (t_idx - 5)  : // Verse 1 A-D
    (t_idx >= 32 && t_idx <= 35) ? out_n = 40 + (t_idx - 32) : // Verse 2 A-D
    (t_idx >= 59 && t_idx <= 62) ? out_n = 44 + (t_idx - 59) : // Verse 3 A-D
    (t_idx >= 9  && t_idx <= 12) ? out_n = 48 + (t_idx - 9)  : // Pre 1 A-D
    (t_idx >= 36 && t_idx <= 39) ? out_n = 52 + (t_idx - 36) : // Pre 2 A-D
    (t_idx >= 63 && t_idx <= 66) ? out_n = 56 + (t_idx - 63) : // Pre 3 A-D
    (t_idx >= 13 && t_idx <= 16) ? out_n = 60 + (t_idx - 13) : // Chorus 1 A-D
    (t_idx >= 40 && t_idx <= 43) ? out_n = 64 + (t_idx - 40) : // Chorus 2 A-D
    (t_idx >= 67 && t_idx <= 70) ? out_n = 68 + (t_idx - 67) : // Chorus 3 A-D
    (t_idx >= 17 && t_idx <= 20) ? out_n = 72 + (t_idx - 17) : // Bridge A-D
    (t_idx >= 44 && t_idx <= 47) ? out_n = 76 + (t_idx - 44) : // Solo A-D
    (t_idx >= 71 && t_idx <= 74) ? out_n = 80 + (t_idx - 71) : // Outro A-D
    (t_idx >= 75 && t_idx <= 79) ? out_n = 84 + (t_idx - 75) : // RSV 1-5

    0;

    (out_n != -1) ? (
        midi_trigger_queued = out_n; 
        cue_armed = 1;
        cue_target_tab = t_idx;
        
        // REFINED: Only update grid if REC is OFF.
        // This ensures clicking a tab while recording doesn't make it appear on the grid.
        rec_cues_active == 0 ? (
            mem[ui_edit_tab] = t_idx;
        );
        
        needs_tab_update = 1;
    );
);

function get_tab_from_pc(pc_val) (
    pc_val == 0 ? 0 : // Off
    (pc_val >= 1 && pc_val <= 5) ? 27 + (pc_val - 1) : // 1-5 -> Tabs 27-31
    (pc_val >= 6 && pc_val <= 10) ? 54 + (pc_val - 6) : // 6-10 -> Tabs 54-58
    pc_val == 19 ? 53 : // Min
    pc_val == 20 ? 21 : // H1
    pc_val == 21 ? 22 : // H2
    pc_val == 22 ? 48 : // H3
    pc_val == 23 ? 49 : // H4
    pc_val == 24 ? 0 : // Off
    pc_val == 25 ? 26 : // Def
    pc_val == 26 ? 23 : // F1<
    pc_val == 27 ? 24 : // F1=
    pc_val == 28 ? 25 : // F1>
    pc_val == 29 ? 50 : // F2<
    pc_val == 30 ? 51 : // F2=
    pc_val == 31 ? 52 : // F2>
    (pc_val >= 32 && pc_val <= 35) ? 1 + (pc_val - 32) : // Intro A-D -> 1-4
    (pc_val >= 36 && pc_val <= 39) ? 5 + (pc_val - 36) : // Verse 1 A-D -> 5-8
    (pc_val >= 40 && pc_val <= 43) ? 32 + (pc_val - 40) : // Verse 2 A-D -> 32-35
    (pc_val >= 44 && pc_val <= 47) ? 59 + (pc_val - 44) : // Verse 3 A-D -> 59-62
    (pc_val >= 48 && pc_val <= 51) ? 9 + (pc_val - 48) : // Pre 1 A-D -> 9-12
    (pc_val >= 52 && pc_val <= 55) ? 36 + (pc_val - 52) : // Pre 2 A-D -> 36-39
    (pc_val >= 56 && pc_val <= 59) ? 63 + (pc_val - 56) : // Pre 3 A-D -> 63-66
    (pc_val >= 60 && pc_val <= 63) ? 13 + (pc_val - 60) : // Chorus 1 A-D -> 13-16
    (pc_val >= 64 && pc_val <= 67) ? 40 + (pc_val - 64) : // Chorus 2 A-D -> 40-43
    (pc_val >= 68 && pc_val <= 71) ? 67 + (pc_val - 68) : // Chorus 3 A-D -> 67-70
    (pc_val >= 72 && pc_val <= 75) ? 17 + (pc_val - 72) : // Bridge A-D -> 17-20
    (pc_val >= 76 && pc_val <= 79) ? 44 + (pc_val - 76) : // Solo A-D -> 44-47
    (pc_val >= 80 && pc_val <= 83) ? 71 + (pc_val - 80) : // Outro A-D -> 71-74
    (pc_val >= 84 && pc_val <= 88) ? 75 + (pc_val - 84) : // Rsv -> 75-79
    -2; // Unmapped
);




active_row_list = mem_pos; mem_pos += 128; // Ensure this has its own space
