        file_mem(0, 0, state_len);
        i=0; loop(MAX_ROWS, file_string(0, row_name_str_base + i); i+=1;);
        t=0; loop(TOTAL_TABS,
            file_var(0, v1); mem[bars_ov_base + t] = v1;
            file_var(0, v2); mem[subdiv_ov_base + t] = v2;
            file_var(0, v3); mem[hum_ov_base + t] = v3;
            file_var(0, v4); mem[swing_ov_base + t] = v4;
            file_var(0, v5); mem[half_speed_ov_base + t] = v5;
            t+=1;
        );
        file_mem(0, vel_base, TOTAL_TABS * vel_stride_tab);
        file_mem(0, grid_base, TOTAL_TABS * vel_stride_tab);
        file_mem(0, step_len_base, TOTAL_TABS * vel_stride_tab);

    ) : (loaded_ver >= 27050) ? (
        // --- PATH C: MODERN SPARSE FORMAT ---
        memset(vel_base, 0, TOTAL_TABS * vel_stride_tab);
        memset(grid_base, 0, TOTAL_TABS * vel_stride_tab);
        memset(step_len_base, 0, TOTAL_TABS * vel_stride_tab);
        t_rst = 0; loop(TOTAL_TABS,
            mem[bars_ov_base + t_rst] = 0; mem[subdiv_ov_base + t_rst] = -1; 
            mem[hum_ov_base + t_rst] = -1; mem[swing_ov_base + t_rst] = -1;
            mem[half_speed_ov_base + t_rst] = 0; mem[tab_mute_base + t_rst] = 0;
            t_rst += 1;
        );

        file_mem(0, ui_base, ui_header_size);
        file_mem(0, row_mute_base, row_settings_size);
        // FIXED: Load into Safe Zone 512
        i=0; loop(MAX_ROWS, file_string(0, row_name_str_base + i); i+=1;);
        
        cont_load = 1;
        while(cont_load) (
            file_var(0, t_idx);
            (t_idx == -1) ? ( cont_load = 0; ) : (
                file_var(0, v1); mem[bars_ov_base+t_idx]=v1; 
                file_var(0, v2); mem[subdiv_ov_base+t_idx]=v2;
                file_var(0, v3); mem[hum_ov_base+t_idx]=v3; 
                file_var(0, v4); mem[swing_ov_base+t_idx]=v4;
                file_var(0, v5); mem[half_speed_ov_base+t_idx]=v5;
                
                // Mute logic: Handled for both 27050 (Morning) and 27060 (Newest)
                file_var(0, v_mt); mem[tab_mute_base+t_idx]=v_mt;

                file_mem(0, vel_base + t_idx*vel_stride_tab, vel_stride_tab);
                file_mem(0, grid_base + t_idx*vel_stride_tab, vel_stride_tab);
                file_mem(0, step_len_base + t_idx*vel_stride_tab, vel_stride_tab);
            );
        );
        file_var(0, requested_start_bar);
        file_var(0, rec_cues_active);
    );
    
    scan_all_tabs();
    slider5 = preserved_id;
    last_kit_idx = slider10;
    last_reported_id = slider5;
    needs_tab_update = 1;
    last_raw_target = -99; 
    
) : (
    // =========================================================
