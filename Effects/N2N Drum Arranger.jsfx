gfx_setfont(1, "Arial", fontsize, 'b'); 
(mb && p_mb == 0 && !rec_hit && mx>=FOLLOW_BOX_X && mx<FOLLOW_BOX_X+FOLLOW_BOX_W+20 && my>=row2_y+25 && my<row2_y+45+FOLLOW_BOX_H+4) ? (
