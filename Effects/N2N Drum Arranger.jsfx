        // When REC turns ON: Force Follow Mode
        mem[ui_locked_tab] = -1; 
        gmem[GM_BASE+1] = -1;
        gmem[GMEM_REC_FLAG_ADDR] = 1;
    ) : (
        // When REC turns OFF: Stop REC flag, and Force FOLLOW mode
        gmem[GMEM_REC_FLAG_ADDR] = 0;
        mem[ui_locked_tab] = -1; 
        gmem[GM_BASE+1] = -1;
    );
    needs_tab_update = 1;
);

