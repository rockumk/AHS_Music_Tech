    // =========================================================
    file_var(0, NEW_MAGIC_VER); // 27060
    
    file_mem(0, ui_base, ui_header_size);
    file_mem(0, row_mute_base, row_settings_size);
    // FIXED: Save from Safe Zone 512+
    i=0; loop(MAX_ROWS, file_string(0, row_name_str_base + i); i+=1;);
    
    t=0; loop(TOTAL_TABS,
        mem[LOC_TAB_POPULATED + t] ? (
            file_var(0, t); 
            file_var(0, mem[bars_ov_base+t]); 
            file_var(0, mem[subdiv_ov_base+t]);
            file_var(0, mem[hum_ov_base+t]); 
            file_var(0, mem[swing_ov_base+t]);
            file_var(0, mem[half_speed_ov_base+t]);
            file_var(0, mem[tab_mute_base+t]); 
            file_mem(0, vel_base + t*vel_stride_tab, vel_stride_tab);
            file_mem(0, grid_base + t*vel_stride_tab, vel_stride_tab);
            file_mem(0, step_len_base + t*vel_stride_tab, vel_stride_tab);
        );
