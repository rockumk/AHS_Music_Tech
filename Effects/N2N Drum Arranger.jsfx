lx=tx+tw-25; ly=ty+9; lw=17; lh=14;   
rect(lx,ly,lw,lh, 0.1,0.1,0.1,1); 

(mb && p_mb == 0 && mx>=lx-3 && mx<lx+lw+3 && my>=ly-2 && my<ly+lh+2) ? ( 
